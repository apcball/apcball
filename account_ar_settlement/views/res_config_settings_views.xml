<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_ar_settlement" model="ir.ui.view">
        <field name="name">res.config.settings.ar.settlement</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="AR Settlement" name="ar_settlement_settings">
                    <setting id="payment_difference_account_setting"
                             title="Default account used for payment differences in AR Settlement"
                             string="Payment Difference Account"
                             help="Account for posting over/under-payment differences (e.g. 214100 Accrued Expenses).">
                        <field name="payment_difference_account_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
