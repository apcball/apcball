<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_wht_installment_wizard_form" model="ir.ui.view">
    <field name="name">wht.installment.payment.wizard.form</field>
    <field name="model">wht.installment.payment.wizard</field>
    <field name="arch" type="xml">
      <form string="Installment Payment (WHT)">
        <group>
          <group>
            <field name="move_id" readonly="1"/>
            <field name="partner_id" readonly="1"/>
            <field name="date"/>
            <field name="journal_id" options="{'no_create': False}"/>
            <field name="memo"/>
          </group>
          <group>
            <field name="currency_id" invisible="1"/>
            <field name="company_id" invisible="1"/>
          </group>
        </group>
        <group string="Amounts">
          <field name="amount_to_clear"/>
          <field name="wht_percent"/>
          <field name="wht_amount" readonly="1"/>
          <field name="bank_charge"/>
          <field name="net_pay_amount" readonly="1"/>
        </group>
        <group string="VAT Options">
          <field name="include_vat" string="Include VAT calculation for this payment"/>
        </group>
        <group string="VAT Calculation" invisible="not include_vat">
          <group>
            <field name="vat_rate" string="VAT Rate (%)"/>
            <field name="manual_vat_account_id" string="VAT Account" 
                   required="include_vat" 
                   options="{'no_create': True}"/>
          </group>
          <group>
            <field name="proportional_vat_amount" readonly="1" string="VAT Amount"/>
            <field name="vat_account_id" readonly="1" string="Selected VAT Account"/>
          </group>
        </group>
        <group string="Tax Invoice Information" invisible="not include_vat">
          <group>
            <field name="tax_invoice_number" string="Tax Invoice No." 
                   placeholder="e.g. INV-2024-001"/>
            <field name="tax_invoice_date" string="Tax Invoice Date"/>
          </group>
          <group>
            <div class="o_form_label" style="font-style: italic; color: #6c757d;">
              หมายเหตุ: กรอกข้อมูลใบกำกับภาษีเพื่อใช้ในการออกรายงานภาษี
            </div>
          </group>
        </group>
        <group string="Auto VAT Information (from Bill)" invisible="not bill_has_vat">
          <group>
            <field name="bill_has_vat" invisible="1"/>
            <field name="bill_vat_amount" readonly="1"/>
            <field name="bill_amount_untaxed" readonly="1"/>
            <field name="payment_percentage" readonly="1" widget="percentage"/>
          </group>
        </group>
        <group string="Withholding Tax Certificate" invisible="wht_amount &lt;= 0">
          <field name="wht_tax_id" domain="[('account_id', '!=', False)]" 
                 placeholder="Select withholding tax for certificate generation"/>
          <field name="wht_cert_income_type" required="wht_tax_id"/>
        </group>
        <footer>
          <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
