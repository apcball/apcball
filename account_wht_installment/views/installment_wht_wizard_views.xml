<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_wht_installment_wizard_form" model="ir.ui.view">
    <field name="name">wht.installment.payment.wizard.form</field>
    <field name="model">wht.installment.payment.wizard</field>
    <field name="arch" type="xml">
      <form string="Installment Payment (WHT)">
        <group>
          <group>
            <field name="move_id" readonly="1"/>
            <field name="partner_id" readonly="1"/>
            <field name="date"/>
            <field name="journal_id" options="{'no_create': False}"/>
            <field name="memo"/>
          </group>
          <group>
            <field name="currency_id" invisible="1"/>
            <field name="company_id" invisible="1"/>
          </group>
        </group>
        <group string="Amounts">
          <field name="amount_to_clear"/>
          <field name="wht_percent"/>
          <field name="wht_amount" readonly="1"/>
          <field name="net_pay_amount" readonly="1"/>
        </group>
        <group string="Withholding Tax Certificate" invisible="wht_amount &lt;= 0">
          <field name="wht_tax_id" domain="[('account_id', '!=', False)]" 
                 placeholder="Select withholding tax for certificate generation"/>
          <field name="wht_cert_income_type" required="wht_tax_id"/>
        </group>
        <footer>
          <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
