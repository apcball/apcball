<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_res_config_settings_wht" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.wht.th</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="account.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//app[@name='account']" position="inside">
        <block title="Withholding Tax (TH)" id="account_wht_installment_settings">
          <setting id="wht_payable_account_setting" company_dependent="1">
            <field name="wht_payable_account_id" options="{'no_create': False}"/>
          </setting>
          <setting id="default_wht_percent_setting" company_dependent="1">
            <field name="default_wht_percent"/>
          </setting>
          <setting id="bank_charge_account_setting" company_dependent="1">
            <field name="bank_charge_account_id" options="{'no_create': False}"/>
          </setting>
          <setting id="enable_vat_partial_payment_setting" company_dependent="1">
            <field name="enable_vat_on_partial_payment"/>
            <div class="text-muted">
              When enabled, partial payments on vendor bills with VAT will automatically calculate and record proportional VAT amounts.
            </div>
          </setting>
        </block>
      </xpath>
    </field>
  </record>
</odoo>
