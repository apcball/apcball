<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- AI Bot User Group -->
        <record id="group_ai_bot_user" model="res.groups">
            <field name="name">AI Bot User</field>
            <field name="comment">Users who can interact with AI Bot in discuss channels.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- AI Bot Manager Group -->
        <record id="group_ai_bot_manager" model="res.groups">
            <field name="name">AI Bot Manager</field>
            <field name="comment">Managers who can configure AI Bot channels and settings.</field>
            <field name="category_id" ref="base.module_category_discuss"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="implied_ids" eval="[(4, ref('group_ai_bot_user'))]"/>
        </record>

        <!-- Record Rules for AI Config -->
        <!-- Users can read AI Config but api_key field is hidden via field-level access -->
        <record id="ai_discuss_config_read_rule" model="ir.rule">
            <field name="name">AI Discuss Config: Read All</field>
            <field name="model_id" ref="model_ai_discuss_config"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ai_discuss_bot.group_ai_bot_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers have full access -->
        <record id="ai_discuss_config_manager_rule" model="ir.rule">
            <field name="name">AI Discuss Config: Manager Full Access</field>
            <field name="model_id" ref="model_ai_discuss_config"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ai_discuss_bot.group_ai_bot_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
