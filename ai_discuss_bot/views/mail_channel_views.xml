<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Mail Channel Form View Extension -->
        <record id="mail_channel_view_form_inherit" model="ir.ui.view">
            <field name="name">discuss.channel.view.form.inherit</field>
            <field name="model">discuss.channel</field>
            <field name="inherit_id" ref="mail.discuss_channel_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="before">
                    <group name="ai_bot_settings" string="AI Bot Settings">
                        <field name="is_ai_bot_channel"/>
                        <field name="ai_bot_partner_id" invisible="not is_ai_bot_channel"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
