<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ====================== Variance Pivot ====================== -->
    <record id="view_monthly_budget_variance_pivot" model="ir.ui.view">
        <field name="name">monthly.budget.variance.pivot</field>
        <field name="model">monthly.budget.variance</field>
        <field name="arch" type="xml">
            <pivot string="Budget Variance Analysis" disable_linking="True" display_quantity="0">
                <field name="plan_id" type="row"/>
                <field name="analytic_account_id" type="row"/>
                <field name="budget_amount" type="measure"/>
                <field name="used_amount" type="measure"/>
                <field name="variance_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ====================== Variance List ====================== -->
    <record id="view_monthly_budget_variance_list" model="ir.ui.view">
        <field name="name">monthly.budget.variance.list</field>
        <field name="model">monthly.budget.variance</field>
        <field name="arch" type="xml">
            <tree string="Budget Variance Analysis" create="false" edit="false" delete="false"
                  decoration-danger="status == 'over'"
                  decoration-warning="status == 'warning'"
                  decoration-success="status == 'ok'">
                <field name="plan_name"/>
                <field name="analytic_account_id"/>
                <field name="department_id" optional="show"/>
                <field name="project_id" optional="show"/>
                <field name="category" optional="show"/>
                <field name="budget_amount" widget="monetary" sum="Budget"/>
                <field name="used_amount" widget="monetary" sum="Actual"/>
                <field name="variance_amount" widget="monetary" sum="Variance"/>
                <field name="variance_pct" widget="percentage" string="Var %"/>
                <field name="status" widget="badge"
                       decoration-danger="status == 'over'"
                       decoration-warning="status == 'warning'"
                       decoration-success="status == 'ok'"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ====================== Variance Form (Drill-down APIs) ====================== -->
    <record id="view_monthly_budget_variance_form" model="ir.ui.view">
        <field name="name">monthly.budget.variance.form</field>
        <field name="model">monthly.budget.variance</field>
        <field name="arch" type="xml">
            <form string="Variance Details" create="false" edit="false" delete="false">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Purchase</span>
                                <span class="o_stat_text">Orders</span>
                            </div>
                        </button>
                        <button name="action_view_invoices" type="object"
                                class="oe_stat_button" icon="fa-pencil-square-o">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Vendor</span>
                                <span class="o_stat_text">Bills</span>
                            </div>
                        </button>
                        <button name="action_view_requisitions" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Purchase</span>
                                <span class="o_stat_text">Requis.</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="Dimension">
                            <field name="plan_id"/>
                            <field name="analytic_account_id"/>
                            <field name="department_id" invisible="not department_id"/>
                            <field name="project_id" invisible="not project_id"/>
                            <field name="category" invisible="not category"/>
                        </group>
                        <group string="Financials">
                            <field name="budget_amount" widget="monetary"/>
                            <field name="used_amount" widget="monetary"/>
                            <field name="variance_amount" widget="monetary"/>
                            <field name="variance_pct" widget="percentage"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ====================== Variance Search ====================== -->
    <record id="view_monthly_budget_variance_search" model="ir.ui.view">
        <field name="name">monthly.budget.variance.search</field>
        <field name="model">monthly.budget.variance</field>
        <field name="arch" type="xml">
            <search string="Variance Analysis">
                <field name="plan_id"/>
                <field name="analytic_account_id"/>
                <filter string="Over Budget" name="over" domain="[('status','=','over')]"/>
                <filter string="Near Limit" name="warning" domain="[('status','=','warning')]"/>
                <group expand="0" string="Group By">
                    <filter string="Plan" name="group_plan" context="{'group_by': 'plan_id'}"/>
                    <filter string="Analytic Account" name="group_analytic" context="{'group_by': 'analytic_account_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ====================== Action ====================== -->
    <record id="action_monthly_budget_variance" model="ir.actions.act_window">
        <field name="name">Variance Analysis</field>
        <field name="res_model">monthly.budget.variance</field>
        <field name="view_mode">tree,pivot,form</field>
        <field name="context">{'search_default_group_plan': 1}</field>
    </record>
</odoo>
