<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== Add Monthly Budget Check tab to PR form ===== -->
    <record id="view_employee_purchase_requisition_form_monthly_budget" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.form.monthly.budget</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_form"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='requisition_deadline']" position="after">
                <field name="payment_date"/>
            </xpath>
            <xpath expr="//sheet/*[1]" position="before">
                <widget name="web_ribbon" title="Cancelled" bg_color="bg-danger" invisible="state not in ('cancel', 'cancelled')"/>
                <widget name="web_ribbon" title="Budget Approved" bg_color="bg-success" invisible="buz_budget_approval_state != 'approved'"/>
                <widget name="web_ribbon" title="Budget Rejected" bg_color="bg-danger" invisible="buz_budget_approval_state != 'rejected'"/>
                <widget name="web_ribbon" title="Pending Budget" bg_color="bg-warning" invisible="buz_budget_approval_state != 'pending'"/>
                <widget name="web_ribbon" title="Budget Reserved" bg_color="bg-info" invisible="not is_budget_reserved or state in ('cancel', 'cancelled')"/>
                <field name="is_budget_reserved" invisible="1"/>
                <field name="buz_budget_approval_state" invisible="1"/>
                <field name="budget_warning" invisible="1"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Monthly Budget Check" name="monthly_budget_check">
                    <group>
                        <group>
                            <button name="action_check_monthly_budget"
                                    string="Check Monthly Budget"
                                    type="object"
                                    class="btn-primary mb-3"
                                    icon="fa-calculator"/>
                        </group>
                        <group>
                            <button name="action_request_monthly_budget_approval"
                                    string="Request Budget Approval"
                                    type="object"
                                    class="btn-warning mb-3"
                                    icon="fa-exclamation-triangle"
                                    invisible="not budget_warning or buz_budget_approval_state == 'approved'"/>
                            <div invisible="not buz_budget_approval_id">
                                <label for="buz_budget_approval_id" string="Approval Request: "/>
                                <field name="buz_budget_approval_id" readonly="1" options="{'no_open': False}"/>
                            </div>
                        </group>
                    </group>
                    <field name="monthly_budget_check_result" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extend Purchase Requisition Tree -->
    <record id="view_employee_purchase_requisition_tree_monthly_budget" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.tree.monthly.budget</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_tree"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="buz_budget_approval_state" string="Budget Status" widget="badge"
                       decoration-success="buz_budget_approval_state == 'approved'"
                       decoration-danger="buz_budget_approval_state == 'rejected'"
                       decoration-warning="buz_budget_approval_state == 'pending'"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
