<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_openclaw_user" model="res.groups">
            <field name="name">OpenClaw User</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Users with access to OpenClow AI audit features</field>
        </record>

        <record id="group_openclaw_manager" model="res.groups">
            <field name="name">OpenClaw Manager</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_openclaw_user')), (4, ref('account.group_account_manager'))]"/>
            <field name="comment">Full access to manage OpenClow configuration</field>
        </record>
    </data>
</odoo>
