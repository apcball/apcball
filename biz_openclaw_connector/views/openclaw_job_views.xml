<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_openclaw_job" model="ir.actions.act_window">
        <field name="name">OpenClaw Jobs</field>
        <field name="res_model">openclaw.job</field>
        <field name="view_mode">tree,form</field>
        <field name="help">View and manage OpenClow AI audit jobs</field>
    </record>

    <menuitem id="menu_openclaw_jobs" name="Jobs" parent="menu_openclaw_config" action="action_openclaw_job" sequence="2"/>

    <record id="view_openclaw_job_tree" model="ir.ui.view">
        <field name="name">openclaw.job.tree</field>
        <field name="model">openclaw.job</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="model_name"/>
                <field name="record_id"/>
                <field name="event_type"/>
                <field name="state" widget="badge" decoration-info="state == 'pending'" decoration-warning="state == 'processing'" decoration-success="state == 'done'" decoration-danger="state == 'error'"/>
                <field name="retry_count"/>
                <field name="attempted_at"/>
                <field name="suggestion_count" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_openclaw_job_form" model="ir.ui.view">
        <field name="name">openclaw.job.form</field>
        <field name="model">openclaw.job</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_retry" string="Retry" type="object" invisible="state != 'error'"/>
                    <button name="action_mark_done" string="Mark Done" type="object" invisible="state in ['done', 'error']"/>
                    <button name="action_mark_error" string="Mark Error" type="object" invisible="state in ['done', 'error']"/>
                    <button name="open_record" string="Open Record" type="object" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,processing,done,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_name" readonly="1"/>
                            <field name="record_id" readonly="1"/>
                            <field name="event_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="config_id" readonly="1"/>
                            <field name="retry_count" readonly="1"/>
                            <field name="max_retries" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="attempted_at" readonly="1"/>
                            <field name="completed_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="suggestion_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload_json" widget="text" readonly="1"/>
                        </page>
                        <page string="Response">
                            <field name="response_json" widget="text" readonly="1"/>
                        </page>
                        <page string="Error" invisible="not error_message">
                            <field name="error_message" readonly="1"/>
                        </page>
                        <page string="Suggestions">
                            <field name="suggestion_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="suggestion_type"/>
                                    <field name="risk_score"/>
                                    <field name="confidence"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
