<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_budget_exceeded" model="mail.template">
            <field name="name">Weekly Budget: Exceeded Notification</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">Budget Exceeded Alert - {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
            <field name="email_to">{{ ctx.get('notify_email', '') }}</field>
            <field name="body_html"><![CDATA[
<div style="margin: 0px; padding: 0px;">
    <table style="width: 600px; margin: 0 auto; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px;">
        <tr>
            <td style="padding: 20px; background: #dc3545; color: white; border-radius: 8px 8px 0 0;">
                <h2 style="margin: 0;">&#9888; Weekly Budget Exceeded</h2>
            </td>
        </tr>
        <tr>
            <td style="padding: 20px;">
                <p>Dear <strong>{{ ctx.get('notify_name', 'Manager') }}</strong>,</p>
                <p>A Purchase Order has been <strong>blocked</strong> because it exceeds the weekly budget limit.</p>

                <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
                    <tr style="background: #f8f9fa;">
                        <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Purchase Order</strong></td>
                        <td style="padding: 8px; border: 1px solid #dee2e6;">{{ object.name }}</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Vendor</strong></td>
                        <td style="padding: 8px; border: 1px solid #dee2e6;">{{ object.partner_id.name }}</td>
                    </tr>
                    <tr style="background: #f8f9fa;">
                        <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Attempted by</strong></td>
                        <td style="padding: 8px; border: 1px solid #dee2e6;">{{ ctx.get('po_user', '') }}</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>PO Total</strong></td>
                        <td style="padding: 8px; border: 1px solid #dee2e6;">{{ "%.2f"|format(object.amount_total) }} {{ object.currency_id.name }}</td>
                    </tr>
                </table>

                <h3 style="color: #dc3545;">Budget Violation Details:</h3>
                % for detail in ctx.get('violation_details', []):
                <table style="width: 100%; border-collapse: collapse; margin: 10px 0;">
                    <tr style="background: #fff3cd;">
                        <td colspan="2" style="padding: 8px; border: 1px solid #dee2e6;">
                            <strong>{{ detail.get('week_name', '') }} ({{ detail.get('plan_name', '') }})</strong>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border: 1px solid #dee2e6;">Budget Limit</td>
                        <td style="padding: 8px; border: 1px solid #dee2e6; text-align: right;">{{ detail.get('limit', '0') }}</td>
                    </tr>
                    <tr style="background: #f8f9fa;">
                        <td style="padding: 8px; border: 1px solid #dee2e6;">Already Used</td>
                        <td style="padding: 8px; border: 1px solid #dee2e6; text-align: right;">{{ detail.get('used', '0') }}</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border: 1px solid #dee2e6;">This PO Amount</td>
                        <td style="padding: 8px; border: 1px solid #dee2e6; text-align: right;">{{ detail.get('po_amount', '0') }}</td>
                    </tr>
                    <tr style="background: #f8d7da;">
                        <td style="padding: 8px; border: 1px solid #dee2e6;"><strong>Over by</strong></td>
                        <td style="padding: 8px; border: 1px solid #dee2e6; text-align: right; color: #dc3545;">
                            <strong>{{ detail.get('overage', '0') }}</strong>
                        </td>
                    </tr>
                </table>
                % endfor

                <p style="margin-top: 20px;">Please review and adjust the budget if necessary.</p>
            </td>
        </tr>
        <tr>
            <td style="padding: 15px; background: #f8f9fa; text-align: center; border-radius: 0 0 8px 8px; font-size: 12px; color: #6c757d;">
                This is an automated notification from the Weekly Budget Control system.
            </td>
        </tr>
    </table>
</div>
]]></field>
        </record>

    </data>
</odoo>
