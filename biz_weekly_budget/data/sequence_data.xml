<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_weekly_budget_plan" model="ir.sequence">
            <field name="name">Weekly Budget Plan</field>
            <field name="code">weekly.budget.plan</field>
            <field name="prefix">WB/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_monthly_budget_plan" model="ir.sequence">
            <field name="name">Monthly Budget Plan</field>
            <field name="code">monthly.budget.plan</field>
            <field name="prefix">MB/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_budget_approval_request" model="ir.sequence">
            <field name="name">Budget Approval Request</field>
            <field name="code">buz.budget.approval.request</field>
            <field name="prefix">BUD-APPV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
