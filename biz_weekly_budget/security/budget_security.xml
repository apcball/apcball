<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module Category -->
        <record id="module_category_weekly_budget" model="ir.module.category">
            <field name="name">Weekly Budget</field>
            <field name="sequence">50</field>
        </record>

        <!-- Budget User Group -->
        <record id="group_budget_user" model="res.groups">
            <field name="name">Budget User</field>
            <field name="category_id" ref="module_category_weekly_budget"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Budget Manager Group -->
        <record id="group_budget_manager" model="res.groups">
            <field name="name">Budget Manager</field>
            <field name="category_id" ref="module_category_weekly_budget"/>
            <field name="implied_ids" eval="[(4, ref('group_budget_user'))]"/>
        </record>

        <!-- Record Rules -->
        <!-- Budget User: read all confirmed plans -->
        <record id="rule_budget_plan_user" model="ir.rule">
            <field name="name">Budget Plan: User Read</field>
            <field name="model_id" ref="model_weekly_budget_plan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_budget_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Budget Manager: full access -->
        <record id="rule_budget_plan_manager" model="ir.rule">
            <field name="name">Budget Plan: Manager Full Access</field>
            <field name="model_id" ref="model_weekly_budget_plan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_budget_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Budget Line: User Read -->
        <record id="rule_budget_line_user" model="ir.rule">
            <field name="name">Budget Line: User Read</field>
            <field name="model_id" ref="model_weekly_budget_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_budget_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Budget Line: Manager Full Access -->
        <record id="rule_budget_line_manager" model="ir.rule">
            <field name="name">Budget Line: Manager Full Access</field>
            <field name="model_id" ref="model_weekly_budget_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_budget_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
