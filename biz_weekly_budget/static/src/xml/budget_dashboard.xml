<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="biz_weekly_budget.WeeklyBudgetDashboard" owl="1">
        <div class="o_weekly_budget_dashboard p-4 bg-light h-100 overflow-auto">
            <div class="container-fluid">
                <!-- Header / Title + Filters -->
                <div class="row mb-4 align-items-center">
                    <div class="col-md-5">
                        <h2 class="text-primary font-weight-bold mb-0">
                            <i class="fa fa-dashboard mr-2"/> Weekly Budget Smart Dashboard
                        </h2>
                    </div>
                    <div class="col-md-7 d-flex justify-content-end" style="gap: 12px;">
                        <!-- Filter by Year -->
                        <div style="min-width: 160px;">
                            <label class="small text-muted mb-1">Filter by Year</label>
                            <select class="form-control custom-select" t-on-change="onYearChange">
                                <option value="all">All Years</option>
                                <t t-foreach="state.years" t-as="yr" t-key="yr">
                                    <option t-att-value="yr" t-esc="yr"/>
                                </t>
                            </select>
                        </div>
                        <!-- Filter by Budget Plan -->
                        <div style="min-width: 220px;">
                            <label class="small text-muted mb-1">Filter by Budget Plan</label>
                            <select class="form-control custom-select" t-on-change="onPlanChange">
                                <option value="all">All Budget Plans</option>
                                <t t-foreach="state.plans" t-as="plan" t-key="plan.id">
                                    <option t-att-value="plan.id" t-esc="plan.name"/>
                                </t>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- KPI Cards: 5 cards -->
                <div class="row mb-4">
                    <div class="col-md-2">
                        <div class="card shadow-sm border-0 bg-white rounded-lg">
                            <div class="card-body text-center p-3">
                                <h6 class="text-muted text-uppercase small font-weight-bold">Total Budget</h6>
                                <h3 class="text-info mb-0" t-esc="formatCurrency(state.summary.total_budget || 0)"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 rounded-lg" style="background-color:#fff7ed;">
                            <div class="card-body text-center p-3">
                                <h6 class="text-uppercase small font-weight-bold" style="color:#c2410c;">Reserved</h6>
                                <h3 class="mb-0" style="color:#ea580c;" t-esc="formatCurrency(state.summary.total_reserved || 0)"/>
                                <small class="text-muted">PR + RFQ pending</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 bg-white rounded-lg">
                            <div class="card-body text-center p-3">
                                <h6 class="text-muted text-uppercase small font-weight-bold">Actual Spending</h6>
                                <h3 class="text-danger mb-0" t-esc="formatCurrency(state.summary.total_actual || 0)"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card shadow-sm border-0 bg-white rounded-lg">
                            <div class="card-body text-center p-3">
                                <h6 class="text-muted text-uppercase small font-weight-bold">Remaining</h6>
                                <h3 class="text-success mb-0" t-esc="formatCurrency(state.summary.remaining || 0)"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card shadow-sm border-0 bg-white rounded-lg">
                            <div class="card-body text-center p-3">
                                <h6 class="text-muted text-uppercase small font-weight-bold">Utilization %</h6>
                                <h3 class="text-warning mb-0" t-esc="(state.summary.utilization || 0).toFixed(1) + '%'"/>
                                <div class="progress mt-2" style="height: 5px;">
                                    <div class="progress-bar bg-warning" role="progressbar"
                                         t-attf-style="width: {{Math.min(state.summary.utilization || 0, 100)}}%"
                                         t-att-aria-valuenow="state.summary.utilization" aria-valuemin="0" aria-valuemax="100"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Row: Bar + Pie side by side -->
                <div class="row mb-4">
                    <!-- Bar Chart: Weekly Trend -->
                    <div class="col-md-8">
                        <div class="card shadow-sm border-0 bg-white rounded-lg h-100">
                            <div class="card-header bg-white border-0 py-3">
                                <h5 class="card-title text-muted mb-0 font-weight-bold">
                                    <i class="fa fa-bar-chart mr-2"/>Weekly Performance Trend
                                </h5>
                            </div>
                            <div class="card-body" style="min-height: 340px; position: relative;">
                                <canvas t-ref="chart"/>
                            </div>
                        </div>
                    </div>

                    <!-- Pie / Doughnut Chart: Spent vs Remaining -->
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0 bg-white rounded-lg h-100">
                            <div class="card-header bg-white border-0 py-3">
                                <h5 class="card-title text-muted mb-0 font-weight-bold">
                                    <i class="fa fa-pie-chart mr-2"/>Budget Utilization
                                </h5>
                            </div>
                            <div class="card-body d-flex flex-column align-items-center justify-content-center" style="min-height: 340px; position: relative;">
                                <div class="o_pie_chart_wrapper w-100" style="max-height: 280px; position: relative;">
                                    <canvas t-ref="pieChart"/>
                                </div>
                                <div class="o_pie_center_label text-center mt-2">
                                    <small class="text-muted">
                                        <t t-esc="(state.summary.utilization || 0).toFixed(1)"/>% Used
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Summary Table -->
                <div class="row mt-2">
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0 bg-white rounded-lg">
                            <div class="card-header bg-white border-0 py-3">
                                <h5 class="card-title text-muted mb-0 font-weight-bold">
                                    <i class="fa fa-table mr-2"/>Weekly Breakdown
                                </h5>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light text-muted small text-uppercase font-weight-bold">
                                        <tr>
                                            <th class="pl-4">Week Reference</th>
                                            <th class="text-right">Budget Limit</th>
                                            <th class="text-right" style="color:#ea580c;">Reserved</th>
                                            <th class="text-right">Actual Used</th>
                                            <th class="text-right">Available</th>
                                            <th class="text-center pr-4">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="state.weeks.length === 0">
                                            <tr>
                                                <td colspan="5" class="text-center text-muted py-4">
                                                    No data found for the selected filters.
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-foreach="state.weeks" t-as="week" t-key="week.name">
                                            <tr>
                                                <td class="pl-4 font-weight-bold" t-esc="week.name"/>
                                                <td class="text-right" t-esc="formatCurrency(week.budget)"/>
                                                <td class="text-right font-weight-bold" style="color:#ea580c;"
                                                    t-esc="formatCurrency(week.reserved || 0)"/>
                                                <td class="text-right" t-esc="formatCurrency(week.actual)"/>
                                                <td class="text-right font-weight-bold"
                                                    t-attf-class="{{(week.budget - week.actual - (week.reserved||0)) >= 0 ? 'text-success' : 'text-danger'}}"
                                                    t-esc="formatCurrency(week.budget - week.actual - (week.reserved||0))"/>
                                                <td class="text-center pr-4">
                                                    <span t-if="(week.budget - week.actual - (week.reserved||0)) >= 0" class="badge badge-success px-2 py-1">Under Budget</span>
                                                    <span t-else="" class="badge badge-danger px-2 py-1">Over Budget</span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
