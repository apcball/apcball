<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="biz_weekly_budget.BudgetMatrixPlanner" owl="1">
        <div class="o_budget_matrix_planner h-100 bg-light d-flex flex-column">
            <!-- Header -->
            <div class="bg-white p-3 border-bottom d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="mb-0 text-primary">
                        <i class="fa fa-th mr-2"/> Analytic Budget Matrix Planner
                    </h2>
                    <p class="text-muted mb-0 small mt-1">Plan budgets across weeks and departments</p>
                </div>
                <div>
                    <select class="form-control" t-on-change="onPlanChange">
                        <t t-foreach="state.plans" t-as="plan" t-key="plan.id">
                            <option t-att-value="plan.id" t-att-selected="plan.id == state.selectedPlanId" t-esc="plan.name"/>
                        </t>
                    </select>
                </div>
            </div>
            
            <!-- Main Content -->
            <div class="flex-grow-1 overflow-auto p-4">
                <div t-if="state.loading" class="text-center p-5">
                    <i class="fa fa-circle-o-notch fa-spin fa-3x text-primary"/>
                    <p class="mt-3 text-muted">Loading Matrix...</p>
                </div>
                
                <div t-elif="state.rows.length === 0" class="text-center p-5 bg-white rounded shadow-sm">
                    <img src="/web/static/img/empty_bg.png" style="width: 150px; opacity: 0.5;"/>
                    <h4 class="text-muted mt-4">No Budget Data Found</h4>
                    <p class="text-muted">Ensure the plan has generated weekly lines and dimension data.</p>
                </div>

                <div t-else="" class="card shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0 matrix-table">
                            <thead class="bg-light sticky-top">
                                <tr>
                                    <th class="align-middle dimension-col">Department / Analytic</th>
                                    <t t-foreach="state.weeks" t-as="week" t-key="week.date_from">
                                        <th class="text-center week-col">
                                            <div class="font-weight-bold" t-esc="week.label"/>
                                            <div class="small text-muted" t-esc="week.date_from + ' to ' + week.date_to"/>
                                        </th>
                                    </t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.rows" t-as="row" t-key="row.key">
                                    <tr>
                                        <td class="font-weight-bold align-middle bg-white dimension-col" t-esc="row.label"/>
                                        <t t-foreach="state.weeks" t-as="week" t-key="week.date_from">
                                            <t t-set="cell" t-value="row.cells[week.date_from]"/>
                                            <td t-if="cell" class="cell-budget p-0" t-att-class="cell.available &lt; 0 ? 'bg-danger-light' : 'bg-success-light'">
                                                <div class="cell-content p-2">
                                                    <div class="d-flex align-items-center mb-1">
                                                        <span class="text-muted small mr-1" style="width: 30px;">Limit:</span>
                                                        <input type="number" 
                                                               class="form-control form-control-sm cell-input font-weight-bold text-center" 
                                                               t-att-value="cell.limit" 
                                                               t-on-change="(ev) => this.updateCellLimit(cell.line_id, ev)"/>
                                                    </div>
                                                    <div class="d-flex align-items-center mb-1">
                                                        <span class="text-muted small mr-1" style="width: 30px;">Fcst:</span>
                                                        <input type="number" 
                                                               class="form-control form-control-sm cell-input text-center" 
                                                               t-att-value="cell.forecast" 
                                                               t-on-change="(ev) => this.updateCellForecast(cell.line_id, ev)"/>
                                                    </div>
                                                    
                                                    <div class="cell-details small mt-1">
                                                        <div class="d-flex justify-content-between text-muted">
                                                            <span>Used:</span>
                                                            <span t-esc="formatCurrency(cell.used)"/>
                                                        </div>
                                                        <div class="d-flex justify-content-between text-orange">
                                                            <span>Resv:</span>
                                                            <span t-esc="formatCurrency(cell.reserved)"/>
                                                        </div>
                                                        <div class="d-flex justify-content-between font-weight-bold mt-1 border-top pt-1" 
                                                             t-att-class="cell.available &lt; 0 ? 'text-danger' : 'text-success'">
                                                            <span>Avail:</span>
                                                            <span t-esc="formatCurrency(cell.available)"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td t-else="" class="bg-light text-center align-middle text-muted small">
                                                N/A
                                            </td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
