<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Budget Move Search View -->
    <record id="view_budget_move_search" model="ir.ui.view">
        <field name="name">budget.move.search</field>
        <field name="model">budget.move</field>
        <field name="arch" type="xml">
            <search string="Budget Moves Analysis">
                <field name="name"/>
                <field name="company_id"/>
                <field name="source_model"/>
                <field name="source_id"/>
                <field name="department_id"/>
                <field name="allocation_id"/>
                <field name="plan_id"/>
                <field name="date"/>
                
                <filter string="Reserved" name="filter_reserved" domain="[('move_type', '=', 'reserved')]"/>
                <filter string="Used" name="filter_used" domain="[('move_type', '=', 'used')]"/>
                
                <separator/>
                
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_company" context="{'group_by':'company_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by':'department_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by':'move_type'}"/>
                    <filter string="Source Document Type" name="group_source_model" context="{'group_by':'source_model'}"/>
                    <filter string="Budget Plan" name="group_plan" context="{'group_by':'plan_id'}"/>
                    <filter string="Month" name="group_month" context="{'group_by':'month_key'}"/>
                    <filter string="Week" name="group_week" context="{'group_by':'week_key'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Budget Move Tree View -->
    <record id="view_budget_move_tree" model="ir.ui.view">
        <field name="name">budget.move.tree</field>
        <field name="model">budget.move</field>
        <field name="arch" type="xml">
            <!-- Ensure tree cannot create, edit manually, must track actuals -->
            <tree string="Budget Moves List" default_order="date desc, id desc" create="0" edit="0" delete="0">
                <field name="date"/>
                <field name="company_id" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="plan_id" optional="show"/>
                <field name="name" string="Document Line"/>
                <field name="source_model" optional="show"/>
                <field name="source_id" optional="hide"/>
                <field name="move_type" widget="badge" 
                       decoration-info="move_type == 'reserved'" 
                       decoration-success="move_type == 'used'"
                       decoration-warning="move_type == 'forecast'"/>
                <field name="amount" sum="Total Amount"/>
            </tree>
        </field>
    </record>

    <!-- Budget Move Pivot View -->
    <record id="view_budget_move_pivot" model="ir.ui.view">
        <field name="name">budget.move.pivot</field>
        <field name="model">budget.move</field>
        <field name="arch" type="xml">
            <pivot string="Budget Moves Matrix" disable_linking="False">
                <field name="department_id" type="row"/>
                <field name="move_type" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Budget Move Graph View -->
    <record id="view_budget_move_graph" model="ir.ui.view">
        <field name="name">budget.move.graph</field>
        <field name="model">budget.move</field>
        <field name="arch" type="xml">
            <graph string="Budget Moves Chart" type="bar" stacked="True">
                <field name="department_id"/>
                <field name="move_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Budget Move Window Action -->
    <record id="action_budget_move_report" model="ir.actions.act_window">
        <field name="name">Budget Moves Analysis</field>
        <field name="res_model">budget.move</field>
        <field name="view_mode">tree,pivot,graph</field>
        <field name="search_view_id" ref="view_budget_move_search"/>
        <!-- Grouping natively out of the box to split Reserved vs Used per department -->
        <field name="context">{'search_default_group_department': 1, 'search_default_group_type': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No budget transactions found
            </p>
            <p>
                This report tracks all Reserved and Used budget amounts across your PRs, MRs, and POs automatically.
            </p>
        </field>
    </record>

    <!-- Weekly Budget Move Pivot View -->
    <record id="view_weekly_budget_pivot" model="ir.ui.view">
        <field name="name">weekly.budget.pivot</field>
        <field name="model">budget.move</field>
        <field name="arch" type="xml">
            <pivot string="Weekly Budget Matrix" disable_linking="False">
                <field name="department_id" type="row"/>
                <field name="week_key" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Weekly Budget Move Graph View -->
    <record id="view_weekly_budget_graph" model="ir.ui.view">
        <field name="name">weekly.budget.graph</field>
        <field name="model">budget.move</field>
        <field name="arch" type="xml">
            <graph string="Weekly Budget Chart" type="bar" stacked="True">
                <field name="week_key"/>
                <field name="move_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Weekly Budget Move Window Action -->
    <record id="action_weekly_budget_report" model="ir.actions.act_window">
        <field name="name">Weekly Budget Analysis</field>
        <field name="res_model">budget.move</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="search_view_id" ref="view_budget_move_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_weekly_budget_pivot')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_weekly_budget_graph')}),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_budget_move_tree')})
        ]"/>
        <field name="context">{'search_default_group_department': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No budget transactions found
            </p>
            <p>
                This report tracks all Reserved and Used budget amounts across your PRs, MRs, and POs automatically by week.
            </p>
        </field>
    </record>

</odoo>
