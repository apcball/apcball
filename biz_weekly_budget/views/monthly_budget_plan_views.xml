<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_monthly_budget_plan_tree" model="ir.ui.view">
        <field name="name">monthly.budget.plan.tree</field>
        <field name="model">monthly.budget.plan</field>
        <field name="arch" type="xml">
            <tree string="Monthly Budget Plans" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="month"/>
                <field name="year"/>
                <field name="company_id" optional="show"/>
                <field name="all_companies" optional="show"/>
                <field name="total_budget"/>
                <field name="total_remaining"/>
                <field name="usage_percentage" widget="progressbar"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <record id="view_monthly_budget_plan_form" model="ir.ui.view">
        <field name="name">monthly.budget.plan.form</field>
        <field name="model">monthly.budget.plan</field>
        <field name="arch" type="xml">
            <form string="Monthly Budget Plan">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark as Done" type="object" invisible="state != 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('cancelled')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done','cancelled')"/>
                    <button name="action_recompute_all_budgets" string="Recompute All Budgets" type="object" class="btn-danger" confirm="This will wipe and recalculate ALL budget reservations across the system. Ensure no one is working. Proceed?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="month" readonly="state != 'draft'"/>
                            <field name="year" readonly="state != 'draft'"/>
                            <field name="all_companies" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" invisible="all_companies" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_budget" widget="monetary" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Department Allocation" name="department_allocation">
                            <field name="allocation_ids" readonly="state != 'draft'">
                                <tree editable="bottom" decoration-danger="status == 'exceeded'">
                                    <field name="department_id" required="0"/>
                                    <field name="percentage"/>
                                    <field name="amount" sum="Total Limit"/>
                                    <field name="amount_used" sum="Total Used" readonly="1"/>
                                    <field name="amount_reserved" sum="Total Reserved" readonly="1"/>
                                    <field name="forecast_amount" sum="Total Forecast" readonly="1"/>
                                    <field name="amount_available" sum="Total Available" readonly="1"/>
                                    <field name="usage_percentage" widget="progressbar"/>
                                    <field name="status" invisible="1"/>
                                    <button name="action_adjust_budget" type="object" string="Adjust" icon="fa-pencil" invisible="parent.state != 'confirmed'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_monthly_budget_plan_search" model="ir.ui.view">
        <field name="name">monthly.budget.plan.search</field>
        <field name="model">monthly.budget.plan</field>
        <field name="arch" type="xml">
            <search string="Search Monthly Budget Plans">
                <field name="name"/>
                <field name="month"/>
                <field name="year"/>
                <field name="company_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_all_companies" string="All Companies" domain="[('all_companies', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'month'}"/>
                    <filter name="group_year" string="Year" context="{'group_by': 'year'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_monthly_budget_plan" model="ir.actions.act_window">
        <field name="name">Monthly Budget Plans</field>
        <field name="res_model">monthly.budget.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_monthly_budget_plan_search"/>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create a new Monthly Budget Plan
          </p>
        </field>
    </record>
</odoo>
