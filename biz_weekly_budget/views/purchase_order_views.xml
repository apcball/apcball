<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Purchase Order Form: Add Budget Check Section -->
    <record id="view_purchase_order_form_budget" model="ir.ui.view">
        <field name="name">purchase.order.form.budget</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Budget Check" name="budget_check">
                    <group>
                        <button name="action_check_budget"
                                string="Check Budget"
                                type="object"
                                class="btn-primary mb-3"
                                icon="fa-search"/>
                    </group>
                    <field name="budget_warning" invisible="1"/>
                    <field name="budget_check_result" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
