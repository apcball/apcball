<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Employee Purchase Requisition Form: Add Budget Approval Button -->
    <record id="view_employee_purchase_requisition_form_budget" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.form.budget</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="buz_budget_approval_id" invisible="1"/>
                <field name="buz_budget_approval_state" invisible="1"/>
                <field name="budget_warning" invisible="1"/>
                <button name="action_request_budget_approval"
                        string="ขอเพิ่มงบประมาณ"
                        type="object"
                        class="btn-warning"
                        invisible="buz_budget_approval_state in ('pending', 'approved') or not budget_warning"
                        icon="fa-exclamation-triangle"/>
                <button name="action_request_budget_approval"
                        string="รอการอนุมัติงบ..."
                        type="object"
                        class="btn-secondary"
                        invisible="buz_budget_approval_state != 'pending'"
                        icon="fa-clock-o"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <field name="is_budget_reserved" invisible="1"/>
                <widget name="web_ribbon" title="Budget Reserved" bg_color="bg-info" invisible="not is_budget_reserved"/>
                <widget name="web_ribbon" title="Cancelled" bg_color="bg-danger" invisible="state != 'cancelled'"/>
                <widget name="web_ribbon" title="Budget Rejected" bg_color="bg-danger" invisible="buz_budget_approval_state != 'rejected'"/>
                <widget name="web_ribbon" title="Budget Approved" bg_color="bg-success" invisible="buz_budget_approval_state != 'approved'"/>
            </xpath>
            <xpath expr="//field[@name='requisition_deadline']" position="after">
                <field name="payment_date" string="Expected Payment"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Budget Check" name="budget_check">
                    <group>
                        <button name="action_check_budget"
                                string="Check Budget"
                                type="object"
                                class="btn-primary mb-3"
                                icon="fa-search"/>
                    </group>
                    <field name="budget_check_result" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extend Purchase Requisition Tree -->
    <record id="view_employee_purchase_requisition_tree_budget" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.tree.budget</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_tree"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="buz_budget_approval_state" string="Budget Status" widget="badge"
                       decoration-success="buz_budget_approval_state == 'approved'"
                       decoration-danger="buz_budget_approval_state == 'rejected'"
                       decoration-warning="buz_budget_approval_state == 'pending'"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
