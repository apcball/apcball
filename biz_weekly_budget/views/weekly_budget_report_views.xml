<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Graph View: Comparison Dashboard -->
    <record id="view_weekly_budget_report_graph" model="ir.ui.view">
        <field name="name">weekly.budget.report.graph</field>
        <field name="model">weekly.budget.report</field>
        <field name="arch" type="xml">
            <graph string="Budget vs Actual Trend" type="line" sample="1">
                <field name="budget_line_id"/>
                <field name="entry_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View: Power BI Style Summary -->
    <record id="view_weekly_budget_report_pivot" model="ir.ui.view">
        <field name="name">weekly.budget.report.pivot</field>
        <field name="model">weekly.budget.report</field>
        <field name="arch" type="xml">
            <pivot string="Budget Utilization Analysis" sample="1" display_quantity="0">
                <field name="plan_id" type="row"/>
                <field name="budget_line_id" type="row"/>
                <field name="budget_amt" type="measure"/>
                <field name="actual_amt" type="measure"/>
                <field name="remaining_amt" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_weekly_budget_report_tree" model="ir.ui.view">
        <field name="name">weekly.budget.report.tree</field>
        <field name="model">weekly.budget.report</field>
        <field name="arch" type="xml">
            <tree string="Budget Details" create="0" edit="0" delete="0" decoration-danger="remaining_amt &lt; 0">
                <field name="date"/>
                <field name="name"/>
                <field name="entry_type" widget="badge"
                       decoration-info="entry_type == 'budget'"
                       decoration-success="entry_type == 'actual'"/>
                <field name="plan_id"/>
                <field name="budget_line_id"/>
                <field name="budget_amt" sum="Total Budget" optional="show"/>
                <field name="actual_amt" sum="Total Actual" optional="show"/>
                <field name="remaining_amt" sum="Total Remaining" 
                       decoration-danger="remaining_amt &lt; 0"
                       decoration-success="remaining_amt &gt;= 0"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_weekly_budget_report_search" model="ir.ui.view">
        <field name="name">weekly.budget.report.search</field>
        <field name="model">weekly.budget.report</field>
        <field name="arch" type="xml">
            <search string="Budget Search">
                <field name="name"/>
                <field name="plan_id"/>
                <field name="budget_line_id"/>
                <filter string="Actual Spending" name="filter_actual" domain="[('entry_type', '=', 'actual')]"/>
                <filter string="Budget Limits" name="filter_budget" domain="[('entry_type', '=', 'budget')]"/>
                <separator/>
                <filter string="Budget Exceeded" name="filter_exceeded" domain="[('remaining_amt', '&lt;', 0)]"/>
                <group expand="1" string="Group By">
                    <filter string="Budget Plan" name="group_plan" context="{'group_by': 'plan_id'}"/>
                    <filter string="Budget Week" name="group_budget_line" context="{'group_by': 'budget_line_id'}"/>
                </group>
                <searchpanel>
                    <field name="plan_id" string="Budget Plan" icon="fa-filter" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_weekly_budget_report" model="ir.actions.act_window">
        <field name="name">Budget Analysis</field>
        <field name="res_model">weekly.budget.report</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_weekly_budget_report_search"/>
        <field name="context">{'search_default_group_budget_line': 1, 'graph_measure': 'amount', 'graph_mode': 'line'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Power BI Dashboard Data Loading...
            </p>
            <p>
                This modern dashboard provides a real-time comparison between your defined weekly budgets and actual purchase expenditures.
            </p>
        </field>
    </record>

</odoo>
