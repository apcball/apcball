<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper Format for Payment Voucher -->
    <record id="paperformat_payment_voucher" model="report.paperformat">
        <field name="name">Payment Voucher A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Payment Voucher Report Action -->
    <record id="action_report_account_payment_voucher" model="ir.actions.report">
        <field name="name">Payment Voucher</field>
        <field name="model">account.payment.voucher</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_account_receipt.report_account_payment_voucher</field>
        <field name="report_file">buz_account_receipt.report_account_payment_voucher</field>
        <field name="print_report_name">'Payment Voucher - %s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_payment_voucher"/>
        <field name="binding_model_id" ref="model_account_payment_voucher"/>
        <field name="binding_type">report</field>
    </record>
</odoo>