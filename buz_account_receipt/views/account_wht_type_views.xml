<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_account_wht_type_tree" model="ir.ui.view">
        <field name="name">account.wht.type.tree</field>
        <field name="model">account.wht.type</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="rate"/>
                <field name="account_id"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_account_wht_type" model="ir.actions.act_window">
        <field name="name">WHT Types</field>
        <field name="res_model">account.wht.type</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Withholding Tax Type
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_account_wht_type"
              parent="account.account_account_menu"
              action="action_account_wht_type"
              sequence="20"/>
</odoo>
