<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.buz.account.receipt</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Receipt Settings" string="Receipt Settings" invisible="not context.get('default_buz_account_receipt_settings')">
                    <h2>Receipt Settings</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="buz_receipt_autopost"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="buz_receipt_autopost" string="Auto-Post Receipts"/>
                                <div class="text-muted">
                                    Automatically post receipts after creation
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>