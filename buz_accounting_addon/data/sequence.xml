
<odoo>
  <data noupdate="0">
    <record id="seq_buz_accounting_addon" model="ir.sequence">
      <field name="name">buz Account Receipt</field>
      <field name="code">buz.account.receipt</field>
      <field name="prefix">RV/%(y)s/%(month)s/</field>
      <field name="padding">4</field>
    </record>
    
    <record id="seq_buz_accounting_addon_voucher" model="ir.sequence">
      <field name="name">buz Account Receipt Voucher</field>
      <field name="code">buz.account.receipt.voucher</field>
      <field name="prefix">RVE/%(year)s/</field>
      <field name="padding">4</field>
    </record>
    
    <record id="seq_buz_account_payment_voucher" model="ir.sequence">
      <field name="name">buz Account Payment Voucher</field>
      <field name="code">buz.account.payment.voucher</field>
      <field name="prefix">PV/%(year)s/</field>
      <field name="padding">4</field>
    </record>

    <record id="seq_account_bank_transfer" model="ir.sequence">
      <field name="name">Bank Transfer</field>
      <field name="code">account.bank.transfer</field>
      <field name="prefix">TR%(y)s</field>
      <field name="padding">4</field>
    </record>
  </data>
</odoo>
