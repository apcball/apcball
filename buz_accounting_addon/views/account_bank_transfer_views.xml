<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_account_bank_transfer_tree" model="ir.ui.view">
        <field name="name">account.bank.transfer.tree</field>
        <field name="model">account.bank.transfer</field>
        <field name="arch" type="xml">
            <tree string="Bank Transfers">
                <field name="date"/>
                <field name="name"/>
                <field name="journal_id"/>
                <field name="destination_journal_id"/>
                <field name="amount"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'posted'" decoration-muted="state == 'cancel'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_account_bank_transfer_form" model="ir.ui.view">
        <field name="name">account.bank.transfer.form</field>
        <field name="model">account.bank.transfer</field>
        <field name="arch" type="xml">
            <form string="Bank Transfer">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                         <button name="action_view_payment" type="object" class="oe_stat_button" icon="fa-money" invisible="not payment_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Payment</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="journal_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="destination_journal_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="ref" readonly="state != 'draft'"/>
                            <field name="payment_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_account_bank_transfer" model="ir.actions.act_window">
        <field name="name">Bank Transfer</field>
        <field name="res_model">account.bank.transfer</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Bank Transfer
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_account_bank_transfer"
              name="Bank Transfer"
              parent="account.menu_finance_payables"
              action="action_account_bank_transfer"
              sequence="11"/>

</odoo>
