<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_buz_auto_analytic" model="ir.ui.view">
        <field name="name">account.move.form.inherit.buz.auto.analytic</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="analytic_auto_sync" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
