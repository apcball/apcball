<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_buz_auto_analytic" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.buz.auto.analytic</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
             <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="analytic_auto_sync" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
