<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_analytic_sync" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.analytic.sync</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="analytic_auto_sync" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
