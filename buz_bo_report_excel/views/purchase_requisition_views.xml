<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Server action: Export Excel from selection ────────── -->
    <record id="action_bo_report_excel_from_selection" model="ir.actions.server">
        <field name="name">Export Blanket Orders to Excel</field>
        <field name="model_id" ref="purchase_requisition.model_purchase_requisition"/>
        <field name="binding_model_id" ref="purchase_requisition.model_purchase_requisition"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code"><![CDATA[
wizard = env['bo.report.excel.wizard'].create({
    'requisition_ids': [(6, 0, records.ids)],
})
action = wizard.action_export_excel()
        ]]></field>
    </record>

</odoo>
