<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_commercial_invoice" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.commercial.invoice</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[1]" position="after">
                <page id="commercial_invoice_tab" string="Commercial Invoice">
                    <group string="Document" name="doc">
                        <field name="commercial_invoice_enabled" widget="boolean_toggle"/>
                        <field name="commercial_invoice_number" readonly="True"/>
                        <field name="packing_list_enabled" widget="boolean_toggle"/>
                        <field name="packing_list_number" readonly="True"/>
                        <field name="show_hscode" widget="boolean_toggle"/>
                    </group>
                    <group string="Shipping" name="shipping">
                        <field name="incoterms_id"/>
                        <field name="loading_date"/>
                        <field name="shipping_mark"/>
                        <field name="shipping_by"/>
                        <field name="ship_to"/>
                        <field name="bank_info"/>
                    </group>
                    <group string="Amount in Words" name="amount">
                        <field name="amount_text" readonly="True"/>
                    </group>
                    <div name="print_buttons">
                        <div>
                            <button name="action_print_commercial_invoice"
                                    type="object"
                                    string="Print CIV"
                                    class="btn-primary"
                                    invisible="not commercial_invoice_enabled"/>
                        </div>
                        <div class="mt-4">
                            <button name="action_print_packing_list"
                                    type="object"
                                    string="Print Packing List"
                                    class="btn-primary"
                                    invisible="not packing_list_enabled"/>
                        </div>
                    </div>
                </page>
            </xpath>

            <xpath expr="//field[@name='order_line']//tree//field[@name='product_id']" position="after">
                <field name="hscode" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_tree_inherit_commercial_invoice" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.commercial.invoice</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="commercial_invoice_number"/>
                <field name="packing_list_number"/>
            </xpath>
        </field>
    </record>
</odoo>
