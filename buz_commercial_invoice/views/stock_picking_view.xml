<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_commercial_invoice" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.commercial.invoice</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_commercial_invoice" string="Print Commercial Invoice" type="object" class="btn-secondary" invisible="picking_type_code != 'outgoing'"/>
            </xpath>
        </field>
    </record>
</odoo>