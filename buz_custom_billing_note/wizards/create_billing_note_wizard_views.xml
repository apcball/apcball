<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_create_billing_note_wizard_form" model="ir.ui.view">
        <field name="name">create.billing.note.wizard.form</field>
        <field name="model">create.billing.note.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Billing Note">
                <group>
                    <field name="date"/>
                    <field name="note_type" invisible="1"/>
                    <field name="invoice_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_create_billing_note"
                            string="Create"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_billing_note_wizard" model="ir.actions.act_window">
        <field name="name">Create Billing Note</field>
        <field name="res_model">create.billing.note.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
    </record>
</odoo>
