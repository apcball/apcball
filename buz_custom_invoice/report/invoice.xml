                                            <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                    </tr>
                                    <t t-set="current_line_number" t-value="current_line_number + 1"/>
                                </t>


                                                                 <t t-foreach="range(len(group), max_lines)" t-as="empty_line">
