<odoo>
    <template id="report_invoice_document_style_new">
        <style>
            @font-face {
                font-family: 'Sarabun';
                src: url('/buz_custom_invoice/static/fonts/Sarabun-Regular.ttf') format('truetype');
                font-weight: normal;
            }

            @font-face {
                font-family: 'Sarabun';
                src: url('/buz_custom_invoice/static/fonts/Sarabun-Bold.ttf') format('truetype');
                font-weight: bold;
            }

            .page {
                font-family: 'Sarabun', sans-serif;
                font-size: 13px;
                color: #000;
                padding: 0;
                margin: 0;
            }

            .invoice-page {
                position: relative;
                width: 100%;
            }

            .doc-header {
                position: relative;
                padding-top: 4px;
            }

            .original-badge {
                position: absolute;
                right: 0;
                top: 0;
                border: 2px solid #000;
                border-radius: 12px;
                padding: 4px 16px;
                font-size: 18px;
                font-weight: bold;
                text-align: center;
                background: #fff;
                line-height: 1.1;
            }

            .top-brand {
                display: flex;
                justify-content: space-between;
                gap: 12px;
                align-items: flex-start;
                margin-top: 18px;
            }

            .company-block {
                width: 68%;
                line-height: 1.2;
            }

            .company-name {
                font-size: 20px;
                font-weight: bold;
            }

            .company-line {
                font-size: 14px;
            }

            .logo-box {
                width: 30%;
                text-align: right;
            }

            .logo-box img {
                max-width: 170px;
                max-height: 70px;
                object-fit: contain;
            }

            .title-wrap {
                text-align: center;
                margin: 8px 0 10px;
            }

            .title-badge {
                display: inline-block;
                min-width: 300px;
                padding: 8px 30px 6px;
                border: 2px solid #000;
                border-radius: 18px;
                font-size: 22px;
                font-weight: bold;
                line-height: 1.15;
                background: #fff;
            }

            .title-badge .en {
                display: block;
                font-size: 15px;
            }

            .info-grid {
                width: 100%;
                border-collapse: collapse;
                margin: 3px 0 8px;
            }

            .info-grid td {
                vertical-align: top;
            }

            .box {
                border: 1px solid #000;
                border-radius: 4px;
                padding: 6px 8px;
                min-height: 92px;
                box-sizing: border-box;
            }

            .info-left {
                width: 48%;
                padding-right: 5px;
            }

            .info-right {
                width: 52%;
                padding-left: 5px;
            }

            .meta-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 13px;
            }

            .meta-table td {
                padding: 1px 0;
                vertical-align: top;
            }

            .meta-label {
                width: 40%;
                font-weight: bold;
                white-space: nowrap;
            }

            .meta-colon {
                width: 2%;
                text-align: center;
            }

            .meta-value {
                width: 58%;
            }

            .line-table {
                width: 100%;
                border-collapse: collapse;
                table-layout: fixed;
                margin-top: 6px;
            }

            .line-table th,
            .line-table td {
                border: 1px solid #000;
                padding: 3px 4px;
                font-size: 12px;
                line-height: 1.2;
                vertical-align: middle;
                word-wrap: break-word;
            }

            .line-table th {
                font-weight: bold;
                text-align: center;
            }

            .line-no { width: 5%; text-align: center; }
            .line-desc { width: 42%; text-align: left; }
            .line-qty { width: 8%; text-align: center; }
            .line-unit { width: 8%; text-align: center; }
            .line-price { width: 14%; text-align: right; }
            .line-disc { width: 8%; text-align: right; }
            .line-amount { width: 15%; text-align: right; }

            .line-table tbody tr {
                height: 21px;
            }

            .totals-area {
                display: flex;
                gap: 10px;
                margin-top: 8px;
                align-items: flex-start;
            }

            .amount-words {
                width: 62%;
                border: 1px solid #000;
                min-height: 100px;
                padding: 8px;
                box-sizing: border-box;
                font-size: 13px;
                line-height: 1.35;
            }

            .amount-words .heading {
                font-weight: bold;
            }

            .amount-right {
                width: 38%;
            }

            .totals-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 13px;
            }

            .totals-table td {
                border: 1px solid #000;
                padding: 4px 6px;
            }

            .totals-label {
                width: 68%;
                font-weight: bold;
                text-align: right;
            }

            .totals-value {
                width: 32%;
                text-align: right;
            }

            .notes {
                margin-top: 8px;
                border: 1px solid #000;
                padding: 6px 8px;
                font-size: 12px;
                line-height: 1.35;
                min-height: 74px;
                box-sizing: border-box;
            }

            .notes .heading {
                font-weight: bold;
                margin-bottom: 2px;
            }

            .footer-boxes {
                display: flex;
                gap: 8px;
                margin-top: 8px;
            }

            .footer-box {
                flex: 1;
                border: 1px solid #000;
                min-height: 110px;
                padding: 8px;
                font-size: 12px;
                line-height: 1.35;
                box-sizing: border-box;
            }

            .footer-box.center,
            .footer-box.right {
                text-align: center;
            }

            .signature-line {
                display: block;
                border-bottom: 1px solid #000;
                margin: 14px 18px 4px;
                height: 14px;
            }
        </style>
    </template>

    <template id="report_invoice_new">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="doc">
                <div class="page invoice-page">
                    <t t-set="line_list" t-value="doc.invoice_line_ids.filtered(lambda l: not l.display_type)"/>
                    <t t-set="company" t-value="doc.company_id"/>
                    <t t-set="ship_partner" t-value="doc.partner_shipping_id or doc.partner_id"/>
                    <t t-set="customer_partner" t-value="doc.partner_id"/>
                    <t t-set="doc_ref" t-value="doc.invoice_partner_ref or doc.custom_reference or doc.invoice_origin or ''"/>

                    <div class="doc-header">
                        <div class="original-badge">ต้นฉบับ</div>
                        <div class="top-brand">
                            <div class="company-block">
                                <div class="company-name">บริษัท โมเก้น จำกัด (สำนักงานใหญ่)</div>
                                <div class="company-line">9 หมู่ที่ 12 ตำบลบึงคำพร้อย อำเภอลำลูกกา จังหวัดปทุมธานี 12150</div>
                                <div class="company-line">โทรศัพท์ 02-150-9709-13 E-mail : contact@mogen.co.th</div>
                                <div class="company-line">เลขประจำตัวผู้เสียภาษี 0105547076103</div>
                            </div>
                            <div class="logo-box">
                                <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Company Logo"/>
                            </div>
                        </div>

                        <div class="title-wrap">
                            <div class="title-badge">
                                ใบแจ้งหนี้
                                <span class="en">INVOICE</span>
                            </div>
                        </div>
                    </div>

                    <table class="info-grid">
                        <tr>
                            <td class="info-left">
                                <div class="box">
                                    <table class="meta-table">
                                        <tr>
                                            <td class="meta-label">ชื่อลูกค้า / Customer Name</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="customer_partner.name"/></td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">เลขประจำตัวผู้เสียภาษีลูกค้า</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="customer_partner.vat"/></td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">ที่อยู่ / Address</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value">
                                                <span t-field="customer_partner.street"/>
                                                <t t-if="customer_partner.street2"> <span t-field="customer_partner.street2"/></t>
                                                <t t-if="customer_partner.city"> ตำบล<span t-field="customer_partner.city"/></t>
                                                <t t-if="customer_partner.state_id"> จังหวัด<span t-field="customer_partner.state_id.name"/></t>
                                                <t t-if="customer_partner.zip"> <span t-field="customer_partner.zip"/></t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">โทรศัพท์</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="customer_partner.phone"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </td>
                            <td class="info-right">
                                <div class="box">
                                    <table class="meta-table">
                                        <tr>
                                            <td class="meta-label">เลขที่เอกสาร / No.</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="doc.name"/></td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">วันที่ / Date</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="doc.invoice_date" t-options='{"widget": "date"}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">เลขที่อ้างอิง</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><t t-esc="doc_ref"/></td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">ที่อยู่จัดส่ง</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value">
                                                <span t-field="ship_partner.street"/>
                                                <t t-if="ship_partner.street2"> <span t-field="ship_partner.street2"/></t>
                                                <t t-if="ship_partner.city"> ตำบล<span t-field="ship_partner.city"/></t>
                                                <t t-if="ship_partner.state_id"> จังหวัด<span t-field="ship_partner.state_id.name"/></t>
                                                <t t-if="ship_partner.zip"> <span t-field="ship_partner.zip"/></t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">ติดต่อ</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="ship_partner.phone"/></td>
                                        </tr>
                                        <tr>
                                            <td class="meta-label">เงื่อนไข</td>
                                            <td class="meta-colon">:</td>
                                            <td class="meta-value"><span t-field="doc.invoice_payment_term_id.name"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <table class="line-table">
                        <thead>
                            <tr>
                                <th class="line-no">ลำดับ</th>
                                <th class="line-desc">รายละเอียด</th>
                                <th class="line-qty">จำนวน</th>
                                <th class="line-unit">หน่วย</th>
                                <th class="line-price">ราคา/หน่วย</th>
                                <th class="line-disc">ส่วนลด</th>
                                <th class="line-amount">รวมเงิน</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_no" t-value="1"/>
                            <t t-foreach="line_list" t-as="line">
                                <tr>
                                    <td class="line-no"><t t-esc="line_no"/></td>
                                    <td class="line-desc">
                                        <t t-if="line.product_id.default_code">
                                            <span t-esc="'[%s] %s' % (line.product_id.default_code, line.name or '')"/>
                                        </t>
                                        <t t-else="">
                                            <span t-esc="line.name or ''"/>
                                        </t>
                                    </td>
                                    <td class="line-qty"><span t-field="line.quantity"/></td>
                                    <td class="line-unit"><span t-field="line.product_uom_id.name"/></td>
                                    <td class="line-price"><span t-esc="'{:,.2f}'.format(line.price_unit or 0.0)"/></td>
                                    <td class="line-disc"><span t-esc="'{:,.2f}'.format(line.discount or 0.0)"/></td>
                                    <td class="line-amount"><span t-esc="'{:,.2f}'.format(line.price_subtotal or 0.0)"/></td>
                                </tr>
                                <t t-set="line_no" t-value="line_no + 1"/>
                            </t>
                            <t t-set="blank_rows" t-value="max(0, 12 - len(line_list))"/>
                            <t t-foreach="range(blank_rows)" t-as="r">
                                <tr>
                                    <td class="line-no">&#160;</td>
                                    <td class="line-desc">&#160;</td>
                                    <td class="line-qty">&#160;</td>
                                    <td class="line-unit">&#160;</td>
                                    <td class="line-price">&#160;</td>
                                    <td class="line-disc">&#160;</td>
                                    <td class="line-amount">&#160;</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="totals-area">
                        <div class="amount-words">
                            <div class="heading">จำนวนเงินตัวอักษร / Amount in Words</div>
                            <div style="margin-top: 6px;">
                                <span t-esc="doc.amount_total_words or ''"/>
                            </div>
                        </div>
                        <div class="amount-right">
                            <table class="totals-table">
                                <tr>
                                    <td class="totals-label">รวม</td>
                                    <td class="totals-value"><span t-esc="'{:,.2f}'.format(doc.total_amount or 0.0)"/></td>
                                </tr>
                                <tr>
                                    <td class="totals-label">หักเงินมัดจำ</td>
                                    <td class="totals-value"><span t-esc="'{:,.2f}'.format(doc.deposit or 0.0)"/></td>
                                </tr>
                                <tr>
                                    <td class="totals-label">ยอดเงินหลังหักมัดจำ</td>
                                    <td class="totals-value"><span t-esc="'{:,.2f}'.format(doc.sub_total or 0.0)"/></td>
                                </tr>
                                <tr>
                                    <td class="totals-label">VAT 7%</td>
                                    <td class="totals-value"><span t-esc="'{:,.2f}'.format(doc.vat_7_percent or 0.0)"/></td>
                                </tr>
                                <tr>
                                    <td class="totals-label">ยอดสุทธิ</td>
                                    <td class="totals-value"><span t-esc="'{:,.2f}'.format(doc.grand_total or 0.0)"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="notes">
                        <div class="heading">หมายเหตุ</div>
                        <t t-if="doc.notes">
                            <div style="white-space: pre-line;"><t t-esc="doc.notes"/></div>
                        </t>
                        <t t-else="">
                            <div>1. ได้รับทราบกำหนดเวลาชำระเงินตามที่ระบุไว้ข้างต้นแล้ว</div>
                            <div>2. กรุณาสั่งจ่ายเช็คขีดคร่อมสั่งจ่าย บจ.โมเก้น</div>
                            <div>3. หรือโอนเข้าบัญชี Kasikorn Bank ( KBANK = กสิกรไทย ) MOGEN CO., LTD Account number 464-1-00774-4</div>
                            <div>4. ในกรณีผิดนัดชำระหนี้ ทางบริษัทฯ จะคิดดอกเบี้ย 1.25 ต่อเดือน ของยอดหนี้ค่าสินค้า</div>
                        </t>
                    </div>

                    <div class="footer-boxes">
                        <div class="footer-box">
                            สินค้าตามรายการข้างต้น แม้จะได้ส่งมอบให้แก่ผู้ซื้อแล้วแต่ยังเป็นกรรมสิทธิ์ของผู้ขาย จนกว่า ผู้ซื้อจะได้รับชำระเงินให้แก่ บริษัทฯ ดังกล่าวแล้วเท่านั้น
                            <div style="text-align:center; margin-top: 8px;">
                                <div>*กรุณาจ่ายเช็คขีดคร่อมสั่งจ่าย*</div>
                                <div>*บริษัท โมเก้น จำกัด* และผู้ถือ</div>
                            </div>
                        </div>
                        <div class="footer-box center">
                            ได้รับสินค้าดังกล่าวไว้ถูกต้องในสภาพเรียบร้อยแล้ว
                            <div class="signature-line"></div>
                            ผู้รับของ
                            <div style="height: 14px;"></div>
                            วันที่ .......... / .......... / ..........
                            <div style="height: 10px;"></div>
                            ผู้ส่งของ
                            <div class="signature-line"></div>
                            วันที่ .......... / .......... / ..........
                        </div>
                        <div class="footer-box right">
                            ในนาม
                            <div style="font-weight: bold;">บริษัท โมเก้น จำกัด</div>
                            <div>สำนักงานใหญ่</div>
                            <div class="signature-line"></div>
                            ผู้มีอำนาจลงนาม
                            <div style="margin-top: 8px; font-weight: bold;">AUTHORIZED</div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_invoice" model="ir.actions.report">
        <field name="name">Invoice/Tax Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_custom_invoice.report_invoice_new</field>
        <field name="report_file">buz_custom_invoice.report_invoice_new</field>
        <field name="paperformat_id" ref="paperformat_invoice"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
