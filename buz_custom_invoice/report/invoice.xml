                                              <t t-set="so" t-value="doc.invoice_line_ids and doc.invoice_line_ids[0].sale_line_ids and doc.invoice_line_ids[0].sale_line_ids[0].order_id"/>
                                              <span t-esc="(so and so.client_order_ref) or (so and so.name) or ''"/>
                                            </div>
                                          </div>
                                        <div style="display: block; margin-top: 2px; margin-bottom:2px;">
                                            <div style="width: 65%;">
                                                <strong style="display: inline-block; width: 90px; margin-right: 10px;">พนักงานขาย :</strong>
                                                <span t-field="doc.invoice_user_id.employee_id.name"/>
                                            </div>
                                            <div style="width: 35%;">
                                                <strong style="display: inline-block; width: 90px; margin-right: 10px;">เงื่อนไข :</strong>
                                            </div>
                                        </div>
                                        <div style="display: block; margin-top: 2px; margin-bottom:2px;">
                                            <div style="width: 65%;">
                                                <strong style="display: inline-block; width: 90px; margin-right: 10px;">วันครบกำหนด :</strong>
                                                <span t-field="doc.invoice_date_due" t-options='{"format": "dd/MM/yyyy"}'/>
                                            </div>
                                            <div style="width: 35%;">
                                                <strong style="display: inline-block; width: 90px; margin-right: 10px;">Credit :</strong>
                                                <span t-esc="doc.invoice_payment_term_id.name or ''"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                          <!-- Product Lines and -->
                         <div class="product-section" style="font-size: 12px;">
                          <table class="product-table" style="width: 100%; border-collapse: collapse; table-layout: fixed; margin-top: 5px; font-size: 12px;">
                            <thead>
                                <tr>
                                    <th style="width: 6%; text-align: center; border: 1px solid black; padding: 2px;">ลำดับ<br/>
                                        <span style="font-size: 12px;">(No)</span></th>
                                    <th style="width: 62%; text-align: center; border: 1px solid black; padding: 2px;">รายการ<br/>
                                        <span style="font-size: 12px;">(Description)</span></th>
                                    <th style="width: 7%; text-align: center; border: 1px solid black; padding: 2px;">หน่วย<br/>
                                        <span style="font-size: 12px;">(Unit)</span></th>
                                    <th style="width: 7%; text-align: center; border: 1px solid black; padding: 2px;">ราคา/หน่วย<br/>
                                        <span style="font-size: 12px;">(Unit Price)</span></th>
                                    <th style="width: 7%; text-align: center; border: 1px solid black; padding: 2px;">ส่วนลด<br/>
                                        <span style="font-size: 12px;">(Discount)</span></th>
                                    <th style="width: 12%; text-align: center; border: 1px solid black; padding: 2px;">จำนวนเงิน<br/>
                                        <span style="font-size: 12px;">(Amount)</span></th>
                                </tr>
                            </thead>
                            <tbody style="height: 240px;">
                                <t t-set="max_lines" t-value="10"/>
                                <t t-set="line_number" t-value="((page_number - 1) * max_lines) + 1"/>
                                <t t-set="current_line_number" t-value="line_number"/>

                                <t t-foreach="group" t-as="line">
                                    <tr style="font-size: 12px; height: 30px;">
                                        <td style="border-left: 1px solid black; border-right: 1px solid black; border-top: none; border-bottom: none; text-align: center; vertical-align: middle;">
                                            <span t-esc="current_line_number"/>
                                        </td>
                                        <td style="border-left: 1px solid black; border-right: 1px solid black; border-top: none; border-bottom: none; text-align: left; vertical-align: middle; padding-left: 4px;">
                                            <div style="
                                                display: -webkit-box;
                                                -webkit-box-orient: vertical;
                                                -webkit-line-clamp: 2;
                                                overflow: hidden;
                                                text-overflow: ellipsis;
