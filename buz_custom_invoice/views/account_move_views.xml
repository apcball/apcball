<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group" position="inside">
                    <group name="custom_fields" string="Custom Information">
                        <field name="custom_reference"/>
                        <field name="delivery_note"/>
                        <field name="show_original_invoice"/>
                        <field name="original_invoice_number" invisible="not show_original_invoice" required="show_original_invoice"/>
                        <field name="original_invoice_date" invisible="not show_original_invoice"/>
                        <field name="original_tax_invoice_amount"/>
                        <field name="purchase_order_number"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>