<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_order_form_inherit_warehouse" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.warehouse</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='warehouse_id']" position="replace"/>
                <xpath expr="//field[@name='sale_order_template_id']" position="after">
                    <field name="warehouse_id" 
                           options="{'no_create': True}" 
                           groups="stock.group_stock_multi_warehouses"/>
                </xpath>
                <xpath expr="//page[@name='customer_signature']" position="after">
                    <page name="signature_approved_sale_order"
                          string="Signature Approved Sale Order">
                        <group string="Signatures Used BY Proforma Invoice">
                            <field name="approver_id"
                                   class="oe_inline"
                                   style="width: 150px;"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="approval_signature"
                                   widget="signature"
                                   class="oe_inline"
                                   style="width: 200px; height: 70px;"
                                   readonly="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
</odoo>