<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Paper Format -->
    <record id="paperformat_buz_receipt" model="report.paperformat">
        <field name="name">BUZ Receipt A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_receipt_custom" model="ir.actions.report">
        <field name="name">ใบรับสินค้า / Receipt Slip</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_delivery_report.report_picking_receipt_custom</field>
        <field name="report_file">buz_delivery_report.report_picking_receipt_custom</field>
        <field name="paperformat_id" ref="paperformat_buz_receipt"/>
        <field name="print_report_name">'%s - %s' % (object.picking_type_id.name, object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Receipt Template -->
    <template id="report_picking_receipt_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
            <style>
              @font-face {
                font-family: 'Sarabun';
                src: url('/buz_delivery_report/static/fonts/Sarabun-Bold.ttf') format('truetype');
              }
              .page {
                font-family: 'Sarabun', sans-serif;
                font-size: 20px;
                padding: 0;
                width: 100%;
                height: 100%;
                margin: 0;
                color: #000000;
              }
              .company-header {
                font-size: 20px;
                font-weight: bold;
                color: #000000;
              }
              .company-info {
                font-size: 18px;
                color: #000000;
              }
              .doc-title {
                font-size: 25px;
                font-weight: bold;
                color: #000000;
              }
              .table-header {
                font-size: 18px;
                font-weight: bold;
                color: #000000;
              }
              .info-box {
                color: black !important;
                font-size: 20px !important;
                border: 1px solid #000 !important;
                padding: 10px;
              }
              .table-content {
                font-size: 18px;
                color: #000000;
              }
              .table-product {
                width: 100%;
                border-collapse: collapse;
                font-size: 20px !important;
              }
              .table-product th {
                border: 1px solid #000;
                padding: 8px 10px;
                font-weight: bold;
                font-size: 18px !important;
                vertical-align: middle;
              }
              .table-product td {
                border: 1px solid #000;
                padding: 8px 10px;
                font-size: 20px !important;
                vertical-align: middle;
              }
              .table-product .product-code {
                font-weight: bold;
              }
              .table-product .quantity {
                text-align: right;
              }
            </style>

            <!-- Paginate: ทุกหน้าซ้ำ header header (บริษัท + โลโก้ + ชื่อเอกสาร + ข้อมูลคู่ค้า) -->
            <t t-set="chunks" t-value="doc._get_move_chunks(10)"/>
            <t t-set="total_pages" t-value="len(chunks)"/>
            <t t-foreach="enumerate(chunks)" t-as="ci">
            <t t-set="page_num" t-value="ci[0]"/>
            <t t-set="move_chunk" t-value="ci[1]"/>
            <div t-attf-style="#{page_num &gt; 0 and 'page-break-before: always;' or ''}">

            <!-- Company Info Section -->
            <div class="row mb-2">
              <div class="col-8">
                <div class="company-header mb-1">บริษัท โมเก้น จำกัด (สำนักงานใหญ่)</div>
                <div class="company-info">9 หมู่ 12 ตําบลบึงคําพร้อย อําเภอลําลูกกา จ.ปทุมธานี 12150</div>
                <div class="company-info">เลขที่ประจําตัวผู้เสียภาษี 0105547076103</div>
                <div class="company-info">โทร 02 1509710 แฟกซ์ 02 1528803 E-mail: contact@mogen.co.th</div>
              </div>
              <div class="col-4 text-end">
                <img src="/buz_delivery_report/static/img/LOGO MOGEN.png"
                     style="width: 150px; height: auto; object-fit: contain;"
                     alt="Company Logo"/>
              </div>
            </div>

            <!-- Document Title -->
            <div class="row mb-3">
                <div class="col-12">
                    <div class="row">
                        <div class="col-12 text-center">
                            <div class="doc-title">ใบรับสินค้า / Receipt Slip</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Document Info -->
            <div class="row mb-3">
                <!-- Left: Vendor Info -->
                <div class="col-6">
                    <div class="info-box" style="height: 200px;">
                        <div class="mb-2">
                            <strong style="width: 10%; display: inline-block;">ผู้ขาย:</strong>
                            <span t-field="doc.partner_id.name"/>
                        </div>
                        <div class="mb-2">
                            <strong style="width: 10%; display: inline-block;">ที่อยู่:</strong>
                            <span t-field="doc.partner_id.street"/> <span t-field="doc.partner_id.street2"/>
                            <br/>
                            <span t-field="doc.partner_id.city"/> <span t-field="doc.partner_id.state_id.name"/>
                            <span t-field="doc.partner_id.zip"/>
                        </div>
                        <div class="mb-2">
                            <strong style="width: 20%; display: inline-block;">โทรศัพท์:</strong>
                            <span t-field="doc.partner_id.phone"/>
                        </div>
                        <div class="mb-2">
                            <strong style="width: 30%; display: inline-block;">เลขประจำตัวผู้เสียภาษี:</strong>
                            <span t-field="doc.partner_id.vat"/>
                        </div>
                    </div>
                </div>
                <!-- Right: Document Details -->
                <div class="col-6">
                    <div class="info-box" style="height: 200px;">
                        <div class="mb-2">
                            <strong style="width: 20%; display: inline-block;">วันที่เอกสาร:</strong>
                            <span t-field="doc.date" t-options='{"widget": "date"}'/>
                            <span class="ml-4">
                                <strong style="width: 20%; display: inline-block;">วันที่จัดส่ง:</strong>
                                <span t-field="doc.scheduled_date" t-options='{"widget": "date"}'/>
                            </span>
                        </div>
                        <div class="mb-2">
                            <strong style="width: 20%; display: inline-block;">เลขที่เอกสาร:</strong>
                            <span t-field="doc.name"/>
                            <span class="ml-4">
                                <strong style="width: 20%; display: inline-block;">เลขที่ใบสั่งซื้อ:</strong>
                                <span t-field="doc.origin"/>
                            </span>
                        </div>
                        <div class="mb-2">
                            <t t-set="vendor_bill" t-value="doc.purchase_id.invoice_ids[:1] if doc.purchase_id else False"/>
                            <strong style="width: 30%; display: inline-block;">เลขที่ใบกำกับภาษี:</strong>
                            <span t-if="vendor_bill" t-field="vendor_bill.name"/>
                            <span t-else="">-</span>
                        </div>
                        <div class="mb-2">
                            <strong style="width: 20%; display: inline-block;">ที่อยู่จัดส่ง:</strong>
                            <span t-field="doc.location_dest_id.warehouse_id.name"/>
                        </div>
                        <div class="mb-2">
                            <strong style="width: 20%; display: inline-block;">หน้า/PAGE:</strong>
                            <span t-esc="page_num + 1"/> / <span t-esc="total_pages"/>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Products Table -->
            <t t-set="line_number" t-value="page_num * 10 + 1"/>
            <table class="table table-sm table-product" style="border: 1px solid #000;">
                <thead>
                    <tr class="table-header">
                        <th style="width: 5%; text-align: center;">No.<br/>ลำดับ</th>
                        <th style="width: 15%; text-align: center;">Code<br/>รหัสสินค้า</th>
                        <th style="width: 48%; text-align: center;">Product<br/>สินค้า</th>
                        <th style="width: 10%; text-align: center;">Ordered<br/>จำนวนสั่ง</th>
                        <th style="width: 10%; text-align: center;">Delivered<br/>จำนวนส่ง</th>
                        <th style="width: 12%; text-align: center;">Amount<br/>จำนวนเงิน</th>
                    </tr>
                </thead>
                <tbody class="table-content">
                    <t t-foreach="move_chunk" t-as="move">
                        <tr>
                            <td class="text-center">
                                <span t-esc="line_number"/>
                                <t t-set="line_number" t-value="line_number + 1"/>
                            </td>
                            <td class="text-center">
                                <span t-field="move.product_id.default_code"/>
                            </td>
                            <td>
                                <span t-field="move.product_id.name"/>
                            </td>
                            <td class="quantity">
                                <span t-esc="move.product_uom_qty" t-options='{"widget": "float", "precision": 2}'/>
                                <span t-field="move.product_uom.name"/>
                            </td>
                            <td class="quantity">
                                <t t-set="delivered_qty" t-value="sum(ml.quantity for ml in move.move_line_ids)"/>
                                <span t-esc="delivered_qty" t-options='{"widget": "float", "precision": 2}'/>
                                <span t-field="move.product_uom.name"/>
                            </td>
                            <td class="text-center">
                                <t t-set="line_amount"
                                   t-value="0.0 if not move.purchase_line_id else delivered_qty * move.purchase_line_id.price_unit"/>
                                <span t-esc="line_amount"
                                      t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            </div>
            </t>

            <!-- Total Section -->
            <t t-set="subtotal" t-value="sum(
                sum(ml.quantity for ml in move.move_line_ids) * (move.purchase_line_id.price_unit or 0.0)
                for move in doc.move_ids_without_package
            )"/>
            <t t-set="vat_amount" t-value="subtotal * 0.07"/>
            <t t-set="total_amount" t-value="subtotal + vat_amount"/>
            <div class="row mt-3">
                <div class="col-6">
                    <div>
                        <div class="row">
                            <div class="col-12">
                                <strong>หมายเหตุ / Note:</strong>
                            </div>
                            <div class="col-12 mt-1">
                                <span t-if="doc.delivery_note" t-field="doc.delivery_note"/>
                                <span t-else="">-</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="info-box" style="height: 100%;">
                        <div class="row">
                            <div class="col-6">
                                <strong>จำนวนเงิน / Subtotal:</strong>
                            </div>
                            <div class="col-6 text-right">
                                <span t-esc="subtotal" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <strong>ภาษีมูลค่าเพิ่ม / VAT 7%:</strong>
                            </div>
                            <div class="col-6 text-right">
                                <span t-esc="vat_amount" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                            </div>
                        </div>
                        <div class="row" style="border-top: 1px solid #000;">
                            <div class="col-6">
                                <strong>จำนวนเงินรวม / Total:</strong>
                            </div>
                            <div class="col-6 text-right">
                                <strong>
                                    <span t-esc="total_amount" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                </strong>
                            </div>
                            <div class="col-12 mt-2">
                                <strong>(</strong>
                                <span t-esc="doc.amount_to_text_th(total_amount)"/>
                                <strong>)</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-5">
                <div class="col-6">
                    <div class="text-center signature-section">
                        <p>________________________</p>
                        <p>ผู้รับสินค้า / Received By</p>
                        <p>วันที่ / Date: ___________</p>
                    </div>
                </div>
                <div class="col-6">
                    <div class="text-center signature-section">
                        <p>________________________</p>
                        <p>ผู้อนุมัติ / Approved By</p>
                        <p>วันที่ / Date: ___________</p>
                    </div>
                </div>
            </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>