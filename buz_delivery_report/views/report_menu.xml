<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_inherited" model="ir.ui.view">
        <field name="name">stock.picking.form.inherited</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Print Receipt button in header for incoming only -->
            <header position="inside">
                <button name="%(buz_delivery_report.action_report_receipt_custom)d"
                        type="action" string="พิมพ์ใบรับสินค้า"
                        class="btn-primary"
                        invisible="picking_type_code != 'incoming' or state == 'draft'"/>
            </header>
            <notebook position="inside">
                <page string="Delivery Details" name="delivery_details">
                    <group>
                        <field name="delivery_note"/>
                        <field name="customer_reference"/>
                        <field name="delivery_instructions"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>