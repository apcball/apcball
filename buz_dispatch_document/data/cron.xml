<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Auto-validate dispatch documents at 05:00 ICT daily -->
        <record id="cron_dispatch_document_auto_validate" model="ir.cron">
            <field name="name">Dispatch Document: Auto-Validate at 05:00</field>
            <field name="model_id" ref="model_buz_dispatch_document"/>
            <field name="state">code</field>
            <field name="code">model.action_validate_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall">2024-01-01 22:00:00</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>