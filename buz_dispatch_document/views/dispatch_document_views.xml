<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Tree View -->
    <record id="view_dispatch_document_tree" model="ir.ui.view">
        <field name="name">buz.dispatch.document.tree</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <tree string="Dispatch Documents"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'confirmed'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="document_date"/>
                <field name="partner_id"/>
                <field name="origin"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- 2. Form View -->
    <record id="view_dispatch_document_form" model="ir.ui.view">
        <field name="name">buz.dispatch.document.form</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <form string="Dispatch Document">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_validate" string="Validate"
                            type="object" class="oe_highlight"
                            invisible="state != 'confirmed'"/>
                    <button name="action_set_draft" string="Set to Draft"
                            type="object"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"
                           clickable="False"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Auto-generated on confirm..."/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="document_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="state"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Delivery Order" name="delivery_order">
                            <group>
                                <field name="stock_picking_id"
                                       context="{'default_state': 'assigned'}"/>
                                <field name="partner_id"/>
                                <field name="sale_id"/>
                                <field name="origin"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- 3. Search View -->
    <record id="view_dispatch_document_search" model="ir.ui.view">
        <field name="name">buz.dispatch.document.search</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <search string="Search Dispatch Documents">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="stock_picking_id"/>
                <field name="origin"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Done" name="done"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Today" name="today"
                        domain="[('document_date', '=', context_today())]"/>
                <filter string="Overdue" name="overdue"
                        domain="[('document_date', '&lt;', context_today()), ('state', '!=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Document Date" name="group_date"
                            context="{'group_by': 'document_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 4. Action Window -->
    <record id="action_buz_dispatch_document" model="ir.actions.act_window">
        <field name="name">Dispatch Documents</field>
        <field name="res_model">buz.dispatch.document</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_dispatch_document_search"/>
        <field name="context">{}</field>
        <field name="domain">[]</field>
    </record>

    <!-- 5. Menu Items -->
    <menuitem id="menu_buz_dispatch_document_root"
              name="Dispatch"
              parent="stock.menu_stock_warehouse_mgmt"
              sequence="50"/>

    <menuitem id="menu_buz_dispatch_document"
              name="Dispatch Documents"
              parent="menu_buz_dispatch_document_root"
              action="action_buz_dispatch_document"
              sequence="10"/>
</odoo>