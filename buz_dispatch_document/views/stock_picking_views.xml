<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Show dispatch documents on stock picking form -->
    <record id="view_stock_picking_form_dispatch_doc" model="ir.ui.view">
        <field name="name">stock.picking.form.dispatch.documents</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[1]" position="before">
                <field name="state" invisible="1"/>
                <field name="sale_id" invisible="1"/>
                <field name="picking_type_code" invisible="1"/>
                <button name="action_create_dispatch_document"
                        string="Create DP"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'done' or picking_type_code != 'outgoing'"/>
            </xpath>
            <div name="button_box" position="inside">
                <button class="oe_stat_button"
                        name="action_view_dispatch_documents"
                        type="object"
                        icon="fa-file-text-o">
                    <field name="buz_dispatch_document_count"
                           widget="statinfo"
                           string="Dispatch Docs"/>
                </button>
            </div>
        </field>
    </record>

    <!-- Add Dispatch Document column to Deliveries tree -->
    <record id="view_stock_picking_tree_dispatch_doc" model="ir.ui.view">
        <field name="name">stock.picking.tree.dispatch.documents</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="buz_dispatch_document_name"
                       string="Dispatch Document"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>