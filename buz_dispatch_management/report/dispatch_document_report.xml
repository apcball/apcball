<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_dispatch_document" model="report.paperformat">
        <field name="name">Dispatch Document A4</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="dpi">90</field>
    </record>

    <template id="report_dispatch_document_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <t t-if="o.print_count &gt; 1">
                            <div class="watermark">
                                COPY
                            </div>
                        </t>

                        <style>
                            .watermark {
                                position: fixed;
                                top: 40%;
                                left: 25%;
                                font-size: 80pt;
                                color: rgba(200, 200, 200, 0.3);
                                transform: rotate(-30deg);
                                font-weight: bold;
                                z-index: 1000;
                                pointer-events: none;
                            }
                            .table-sm th, .table-sm td {
                                padding: 4px 6px;
                                vertical-align: top;
                                font-size: 11px;
                            }
                            .signature-area {
                                border: 1px solid #333;
                                height: 80px;
                                margin-top: 4px;
                            }
                        </style>

                        <div class="text-center mb-3">
                            <h2><strong>DISPATCH DOCUMENT</strong></h2>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td style="width: 140px;"><strong>Dispatch No:</strong></td>
                                        <td><span t-field="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Dispatch Date:</strong></td>
                                        <td><span t-field="o.dispatch_date" t-options='{"format": "dd/MM/yyyy"}'/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td style="width: 100px;"><strong>Reference:</strong></td>
                                        <td><span t-field="o.picking_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>SO No:</strong></td>
                                        <td><span t-field="o.sale_id.name"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td style="width: 100px;"><strong>Customer:</strong></td>
                                        <td>
                                            <span t-field="o.partner_id.name"/>
                                            <t t-if="o.partner_id.street">
                                                <br/><span t-field="o.partner_id.street"/>
                                            </t>
                                            <t t-if="o.partner_id.city or o.partner_id.state_id or o.partner_id.zip">
                                                <br/><span t-field="o.partner_id.city"/>
                                                <span t-field="o.partner_id.state_id"/>
                                                <span t-field="o.partner_id.zip"/>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            <th class="text-center" style="width: 5%">#</th>
                                            <th style="width: 12%">Code</th>
                                            <th style="width: 33%">Description</th>
                                            <th class="text-center" style="width: 12%">Ordered</th>
                                            <th class="text-center" style="width: 12%">Dispatched</th>
                                            <th class="text-center" style="width: 8%">UoM</th>
                                            <th style="width: 18%">Remark</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.line_ids" t-as="line">
                                            <td class="text-center"><span t-esc="line_index + 1"/></td>
                                            <td><span t-field="line.product_id.default_code"/></td>
                                            <td><span t-field="line.product_id.name"/></td>
                                            <td class="text-center">
                                                <span t-field="line.ordered_qty" t-options='{"widget": "float", "precision": 2}'/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="line.dispatch_qty" t-options='{"widget": "float", "precision": 2}'/>
                                            </td>
                                            <td class="text-center"><span t-field="line.product_uom_id.name"/></td>
                                            <td><span t-field="line.remark"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td style="width: 80px;"><strong>Driver:</strong></td>
                                        <td><span t-field="o.driver_name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Vehicle:</strong></td>
                                        <td><span t-field="o.vehicle_no"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Receiver Signature</strong>
                                <div class="signature-area">
                                    <t t-if="o.receiver_signature">
                                        <img t-att-src="'data:image/png;base64,%s' % o.receiver_signature"
                                             style="max-height: 75px;"/>
                                    </t>
                                </div>
                                <div class="mt-1">
                                    Name: <span t-field="o.receiver_name"/>
                                    &#160;&#160; Date: ___/___/______
                                </div>
                            </div>
                            <div class="col-6">
                                <strong>Delivery Confirmation</strong>
                                <div class="signature-area"></div>
                                <div class="mt-1">
                                    Name: ___________________ &#160;&#160; Date: ___/___/______
                                </div>
                            </div>
                        </div>

                        <t t-if="o.note">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <strong>Remarks:</strong>
                                    <p t-field="o.note"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_dispatch_document" model="ir.actions.report">
        <field name="name">Dispatch Document</field>
        <field name="model">buz.dispatch.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_dispatch_management.report_dispatch_document_document</field>
        <field name="report_file">buz_dispatch_management.report_dispatch_document_document</field>
        <field name="print_report_name">'Dispatch - %s' % object.name</field>
        <field name="binding_model_id" ref="model_buz_dispatch_document"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_dispatch_document"/>
    </record>
</odoo>