<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_dispatch_management" model="ir.module.category">
            <field name="name">Dispatch Management</field>
            <field name="description">Manage dispatch documents and stock posting</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_dispatch_user" model="res.groups">
            <field name="name">Dispatch User</field>
            <field name="category_id" ref="module_category_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_dispatch_manager" model="res.groups">
            <field name="name">Dispatch Manager</field>
            <field name="category_id" ref="module_category_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dispatch_user'))]"/>
        </record>

        <record id="rule_dispatch_document_user" model="ir.rule">
            <field name="name">Dispatch Document: User Access</field>
            <field name="model_id" ref="model_buz_dispatch_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_dispatch_document_manager" model="ir.rule">
            <field name="name">Dispatch Document: Manager Full Access</field>
            <field name="model_id" ref="model_buz_dispatch_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_dispatch_document_line_user" model="ir.rule">
            <field name="name">Dispatch Document Line: User Access</field>
            <field name="model_id" ref="model_buz_dispatch_document_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_dispatch_document_line_manager" model="ir.rule">
            <field name="name">Dispatch Document Line: Manager Full Access</field>
            <field name="model_id" ref="model_buz_dispatch_document_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
