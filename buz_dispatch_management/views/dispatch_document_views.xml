<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dispatch_document_tree" model="ir.ui.view">
        <field name="name">buz.dispatch.document.tree</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <tree string="Dispatch Documents"
                  decoration-success="state == 'posted'"
                  decoration-info="state in ('printed', 'in_transit')"
                  decoration-warning="state == 'delivered'"
                  decoration-muted="state == 'draft'"
                  decoration-danger="state == 'cancel'">
                <field name="name"/>
                <field name="dispatch_date"/>
                <field name="partner_id"/>
                <field name="origin" optional="show"/>
                <field name="driver_name"/>
                <field name="vehicle_no"/>
                <field name="carrier_id" optional="show"/>
                <field name="weight" optional="show"/>
                <field name="number_of_packages" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'posted'"
                       decoration-info="state in ('printed', 'in_transit')"
                       decoration-warning="state == 'delivered'"
                       decoration-muted="state == 'draft'"/>
                <field name="print_count" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_dispatch_document_form" model="ir.ui.view">
        <field name="name">buz.dispatch.document.form</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <form string="Dispatch Document">
                <header>
                    <button name="action_print" string="Print" type="object"
                            class="oe_highlight"
                            invisible="state in ('posted', 'cancel')"/>
                    <button name="action_in_transit" string="Mark In Transit" type="object"
                            invisible="state not in ('draft', 'printed')"/>
                    <button name="action_deliver" string="Mark Delivered" type="object"
                            class="btn-success"
                            invisible="state != 'in_transit'"/>
                    <button name="action_post" string="Post Dispatch" type="object"
                            class="oe_highlight"
                            invisible="state not in ('delivered', 'in_transit')"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-danger"
                            invisible="state in ('posted', 'cancel')"/>
                    <button name="action_set_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('cancel',)"
                            groups="buz_dispatch_management.group_dispatch_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,printed,in_transit,delivered,posted"
                           clickable="False"/>
                </header>

                <sheet>
                    <div class="oe_button_box o_button_box">
                        <button type="object" class="oe_stat_button" icon="fa-truck"
                                name="action_open_picking">
                            <field name="picking_id" widget="statinfo" string="Delivery Order"/>
                        </button>
                        <button type="object" class="oe_stat_button" icon="fa-file-pdf-o"
                                name="action_print">
                            <field name="print_count" widget="statinfo" string="Prints"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Auto-generated"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="dispatch_date"/>
                            <field name="posted_date"/>
                            <field name="origin"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="driver_name"/>
                            <field name="vehicle_no"/>
                            <field name="receiver_name"/>
                            <field name="carrier_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Contact Information">
                        <field name="partner_id" widget="contact"
                               options='{"fields": ["address", "name", "phone", "email"], "no_marker": true}'
                               readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Products" name="products">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_uom_id"/>
                                    <field name="ordered_qty"/>
                                    <field name="dispatch_qty"/>
                                    <field name="remark"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Delivery Info" name="delivery_info">
                            <group string="Delivery Order">
                                <field name="picking_id"/>
                                <field name="sale_id"/>
                                <field name="origin"/>
                                <field name="carrier_id" readonly="1"/>
                            </group>
                            <group string="Dates" colspan="2">
                                <field name="scheduled_date"/>
                                <field name="date_deadline"/>
                                <field name="dispatch_date"/>
                                <field name="posted_date"/>
                            </group>
                            <group string="Shipping Details">
                                <field name="weight"/>
                                <field name="number_of_packages"/>
                            </group>
                        </page>
                        <page string="Notes &amp; Attachments" name="notes">
                            <field name="note"/>
                            <field name="attachment_ids" widget="many2many_binary"
                                   nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_dispatch_document_kanban" model="ir.ui.view">
        <field name="name">buz.dispatch.document.kanban</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="dispatch_date"/>
                <field name="partner_id"/>
                <field name="driver_name"/>
                <field name="vehicle_no"/>
                <field name="carrier_id"/>
                <field name="origin"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_title">
                                    <field name="name"/>
                                </div>
                                <div class="o_kanban_tags_section">
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'posted'"
                                           decoration-info="state in ('printed', 'in_transit')"
                                           decoration-warning="state == 'delivered'"
                                           decoration-muted="state == 'draft'"/>
                                </div>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_card_content">
                                    <div>Customer: <field name="partner_id"/></div>
                                    <div>Date: <field name="dispatch_date"/></div>
                                    <t t-if="record.origin.raw_value">
                                        <div>Ref: <field name="origin"/></div>
                                    </t>
                                    <t t-if="record.driver_name.raw_value">
                                        <div>Driver: <field name="driver_name"/></div>
                                    </t>
                                    <t t-if="record.vehicle_no.raw_value">
                                        <div>Vehicle: <field name="vehicle_no"/></div>
                                    </t>
                                    <t t-if="record.carrier_id.raw_value">
                                        <div>Carrier: <field name="carrier_id"/></div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dispatch_document_search" model="ir.ui.view">
        <field name="name">buz.dispatch.document.search</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <search string="Search Dispatch Documents">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="picking_id"/>
                <field name="driver_name"/>
                <field name="vehicle_no"/>
                <field name="origin"/>
                <field name="carrier_id"/>
                <separator/>
                <filter string="My Dispatches" name="my_dispatches"
                        domain="[('create_uid', '=', uid)]"/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Printed" name="printed"
                        domain="[('state', '=', 'printed')]"/>
                <filter string="In Transit" name="in_transit"
                        domain="[('state', '=', 'in_transit')]"/>
                <filter string="Delivered" name="delivered"
                        domain="[('state', '=', 'delivered')]"/>
                <filter string="Posted" name="posted"
                        domain="[('state', '=', 'posted')]"/>
                <separator/>
                <filter string="Today" name="today"
                        domain="[('dispatch_date', '=', context_today())]"/>
                <filter string="This Week" name="this_week"
                        domain="[('dispatch_date', '>=', (context_today() - (context_today().weekday())).strftime('%Y-%m-%d')), ('dispatch_date', '&lt;=', context_today())]"/>
                <filter string="This Month" name="this_month"
                        domain="[('dispatch_date', '>=', context_today().strftime('%Y-%m-01'))]"/>
                <filter string="Waiting for Posting" name="waiting_posting"
                        domain="[('state', '=', 'delivered')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Dispatch Date" name="group_date"
                            context="{'group_by': 'dispatch_date'}"/>
                    <filter string="Driver" name="group_driver"
                            context="{'group_by': 'driver_name'}"/>
                    <filter string="Customer" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Delivery Method" name="group_carrier"
                            context="{'group_by': 'carrier_id'}"/>
                    <filter string="Source Document" name="group_origin"
                            context="{'group_by': 'origin'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_dispatch_document_pivot" model="ir.ui.view">
        <field name="name">buz.dispatch.document.pivot</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <pivot string="Dispatch Analysis" disable_linking="True">
                <field name="state" type="row"/>
                <field name="carrier_id" type="row"/>
                <field name="dispatch_date" type="col"/>
                <field name="id" type="measure" string="Count"/>
            </pivot>
        </field>
    </record>

    <record id="view_dispatch_document_graph" model="ir.ui.view">
        <field name="name">buz.dispatch.document.graph</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <graph string="Dispatch Trends" type="bar" stacked="True">
                <field name="dispatch_date" type="row"/>
                <field name="state" type="col"/>
                <field name="id" type="measure" string="Count"/>
            </graph>
        </field>
    </record>

    <record id="action_buz_dispatch_document" model="ir.actions.act_window">
        <field name="name">Dispatch Documents</field>
        <field name="res_model">buz.dispatch.document</field>
        <field name="view_mode">tree,form,kanban,pivot,graph</field>
        <field name="search_view_id" ref="view_dispatch_document_search"/>
        <field name="context">{}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Dispatch Document
            </p>
            <p>
                Dispatch Documents separate the physical delivery process
                from stock deduction. Create a dispatch from a validated
                Delivery Order, print it, and post it when goods are delivered.
            </p>
        </field>
    </record>

    <record id="view_dispatch_document_dashboard" model="ir.ui.view">
        <field name="name">buz.dispatch.document.dashboard</field>
        <field name="model">buz.dispatch.document</field>
        <field name="arch" type="xml">
            <form string="Dispatch Dashboard">
                <sheet>
                    <group string="KPI Summary">
                        <group>
                            <field name="id" string="Total Dispatch"
                                   widget="statinfo"
                                   modifiers='{"readonly": true}'/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_buz_dispatch_document_dashboard" model="ir.actions.act_window">
        <field name="name">Dispatch Dashboard</field>
        <field name="res_model">buz.dispatch.document</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_dispatch_document_dashboard"/>
        <field name="target">inline</field>
    </record>
</odoo>
