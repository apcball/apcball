<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_batch_payment_wizard_form" model="ir.ui.view">
        <field name="name">buz.batch.payment.wizard.form</field>
        <field name="model">buz.batch.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Batch Payment Allocation">
                <field name="state" invisible="1"/>
                <field name="remaining_balance" invisible="1"/>

                <!-- ─── STEP 1: Settlement Information ─── -->
                <div class="alert alert-info" role="alert" invisible="state != 'setup'">
                    <strong>Step 1: Settlement Information &amp; Filters</strong><br/>
                    Enter the <strong>gross</strong> amount customers paid (before bank fee deduction).
                    Bank Charge will be posted as a separate expense — the net bank deposit
                    will be: <em>Received − Bank Charge − Difference</em>.
                </div>

                <group invisible="state != 'setup'">
                    <group string="Settlement Information">
                        <field name="payment_date"/>
                        <field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="currency_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="received_amount"/>
                        <field name="reference"/>
                    </group>
                    <group string="Adjustments (Optional)">
                        <field name="bank_charge"/>
                        <field name="bank_fee_account_id"
                               invisible="not bank_charge"
                               required="bank_charge"
                               options="{'no_create': True}"/>
                        <field name="difference_amount"/>
                        <field name="difference_account_id"
                               invisible="not difference_amount"
                               required="difference_amount"
                               options="{'no_create': True}"/>
                    </group>
                </group>

                <group invisible="state != 'setup'" string="Clearing Customer">
                    <field name="paying_partner_id"
                           options="{'no_create': True, 'no_open': True}"
                           help="The customer through which the lump-sum payment was received."/>
                </group>

                <group invisible="state != 'setup'" string="Invoice Filters (Optional)">
                    <group>
                        <field name="vat" placeholder="e.g. 0123456789012"/>
                        <field name="trade_channel"/>
                    </group>
                    <group>
                        <label for="date_from" string="Invoice Date Range"/>
                        <div class="o_row">
                            <field name="date_from"
                                   widget="daterange"
                                   options="{'related_end_date': 'date_to'}"/>
                            <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow" title="Arrow"/>
                            <field name="date_to"
                                   widget="daterange"
                                   options="{'related_start_date': 'date_from'}"/>
                        </div>
                    </group>
                </group>

                <!-- ─── STEP 2: Invoice Allocation ─── -->
                <div class="alert alert-info" role="alert" invisible="state != 'allocate'">
                    <strong>Step 2: Invoice Allocation</strong><br/>
                    Select invoices and assign amounts manually, or use <em>Auto Allocate</em> to distribute via FIFO.
                </div>

                <group invisible="state != 'allocate'" string="Allocation Summary">
                    <group>
                        <field name="received_amount" readonly="1"
                               string="Total Received from Customers"/>
                        <field name="bank_charge" readonly="1" invisible="not bank_charge"/>
                        <field name="difference_amount" readonly="1" invisible="not difference_amount"/>
                        <field name="total_invoice_amount" readonly="1"/>
                    </group>
                    <group>
                        <field name="total_allocated" string="Currently Allocated" readonly="1"/>
                        <!-- Fully zero: green -->
                        <field name="remaining_balance"
                               class="text-success fw-bold"
                               invisible="remaining_balance != 0"
                               string="Fully Allocated ✓"
                               readonly="1"/>
                        <!-- 0 &lt; remaining &lt;= adjustments: blue (absorbed, OK) -->
                        <field name="remaining_balance"
                               class="text-primary fw-bold"
                               invisible="remaining_balance &lt;= 0 or remaining_balance &gt; (bank_charge + difference_amount)"
                               string="Absorbed by Bank Charge ✓"
                               readonly="1"/>
                        <!-- remaining > adjustments: red (error) -->
                        <field name="remaining_balance"
                               class="text-danger fw-bold"
                               invisible="remaining_balance &lt;= (bank_charge + difference_amount)"
                               string="Still to Allocate"
                               readonly="1"/>
                    </group>
                </group>

                <field name="allocation_line_ids" invisible="state != 'allocate'" mode="tree">
                    <tree string="Invoices"
                          editable="bottom"
                          create="0"
                          delete="0"
                          decoration-success="selected"
                          decoration-muted="not selected">
                        <field name="selected" widget="boolean_toggle"/>
                        <field name="invoice_id" readonly="1"/>
                        <field name="invoice_date" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="partner_tax_id" string="VAT" readonly="1"/>
                        <field name="trade_channel" string="Channel" readonly="1" optional="show"/>
                        <field name="currency_id" column_invisible="True"/>
                        <field name="residual" sum="Total Residual" readonly="1"/>
                        <field name="allocate_amount" sum="Total Allocated"/>
                    </tree>
                </field>

                <div invisible="state != 'allocate'" class="mt-2">
                    <button string="⚡ Auto Allocate (FIFO)"
                            name="action_auto_allocate"
                            type="object"
                            class="btn-secondary"/>
                </div>

                <!-- ─── STEP 3: Review &amp; Confirm ─── -->
                <div class="alert alert-success" role="alert" invisible="state != 'review'">
                    <strong>Step 3: Review &amp; Confirm</strong><br/>
                    Review the settlement summary below and click <em>Confirm &amp; Post</em> to generate the payment and clearing journals.
                </div>

                <group invisible="state != 'review'" string="Settlement Summary">
                    <group>
                        <field name="paying_partner_id" readonly="1"/>
                        <field name="payment_date" readonly="1"/>
                        <field name="journal_id" readonly="1"/>
                        <field name="received_amount" readonly="1"/>
                    </group>
                    <group>
                        <field name="bank_charge" readonly="1" invisible="not bank_charge"/>
                        <field name="difference_amount" readonly="1" invisible="not difference_amount"/>
                        <field name="total_invoice_amount" readonly="1"/>
                        <field name="total_allocated" readonly="1"/>
                        <field name="remaining_balance" class="text-success fw-bold" readonly="1"/>
                    </group>
                </group>

                <!-- ─── Footer ─── -->
                <footer>
                    <button name="action_previous"
                            string="← Previous"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'setup'"/>
                    <button name="action_next"
                            string="Next →"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'review'"/>
                    <button name="action_confirm_and_post"
                            string="✔ Confirm &amp; Post"
                            type="object"
                            class="btn-success"
                            invisible="state != 'review'"
                            confirm="This will create the payment and clear the selected invoices. Proceed?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_buz_batch_payment_wizard" model="ir.actions.act_window">
        <field name="name">Batch Payment Allocation</field>
        <field name="res_model">buz.batch.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_batch_payment_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
