<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action -->
    <record id="action_ic_request_report" model="ir.actions.report">
        <field name="name">Internal Consumption Request Report</field>
        <field name="model">ic.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_internal_consumption.report_ic_request_template</field>
        <field name="report_file">buz_internal_consumption.report_ic_request_template</field>
        <field name="print_report_name">'IC - %s' % (object.name)</field>
        <field name="attachment_use" eval="True"/>
    </record>

    <!-- Report Template -->
    <template id="report_ic_request_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.internal_layout">
                    <div class="page">
                        <h2><span t-esc="doc.name"/></h2>
                        
                        <div class="row mt32">
                            <div class="col-xs-6">
                                <div class="row">
                                    <div class="col-xs-5">
                                        <strong>Request Date:</strong>
                                    </div>
                                    <div class="col-xs-7">
                                        <span t-esc="doc.date_request"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-5">
                                        <strong>Requester:</strong>
                                    </div>
                                    <div class="col-xs-7">
                                        <span t-esc="doc.requester_id.name"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-5">
                                        <strong>Department:</strong>
                                    </div>
                                    <div class="col-xs-7">
                                        <span t-esc="doc.department_id.name or ''"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-5">
                                        <strong>Location:</strong>
                                    </div>
                                    <div class="col-xs-7">
                                        <span t-esc="doc.location_id.complete_name"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-5">
                                        <strong>State:</strong>
                                    </div>
                                    <div class="col-xs-7">
                                        <span t-esc="doc.state"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt32">
                            <h4>Request Lines</h4>
                            <table class="table table-condensed">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-right">Quantity</th>
                                        <th class="text-right">Unit Cost</th>
                                        <th class="text-right">Subtotal</th>
                                        <th>Expense Account</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.line_ids" t-as="line">
                                        <td>
                                            <span t-field="line.product_id.display_name"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-esc="line.qty"/>
                                            <span t-esc="line.uom_id.name" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-esc="line.unit_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-esc="line.subtotal_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                        <td>
                                            <span t-esc="line.expense_account_id.code and line.expense_account_id.name or ''"/>
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3"><strong>Total</strong></td>
                                        <td class="text-right">
                                            <strong>
                                                <span t-esc="doc.amount_total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                            </strong>
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        
                        <div class="mt32" t-if="doc.note">
                            <h4>Note</h4>
                            <p t-field="doc.note"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>