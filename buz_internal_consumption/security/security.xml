<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Groups Definition -->
    <record id="group_ic_user" model="res.groups">
        <field name="name">IC User</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Create and edit own requests, submit for approval</field>
    </record>

    <record id="group_ic_manager" model="res.groups">
        <field name="name">IC Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Approve/reject requests, modify some fields, manage approval teams</field>
        <field name="implied_ids" eval="[(4, ref('group_ic_user'))]"/>
    </record>

    <record id="group_ic_store" model="res.groups">
        <field name="name">IC Store</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Issue products from stock, validate stock moves</field>
        <field name="implied_ids" eval="[(4, ref('group_ic_user'))]"/>
    </record>

    <record id="group_ic_accountant" model="res.groups">
        <field name="name">IC Accountant</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Create and validate account moves</field>
        <field name="implied_ids" eval="[(4, ref('group_ic_user'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="rule_ic_request_personal" model="ir.rule">
        <field name="name">IC Request Personal</field>
        <field name="model_id" ref="model_ic_request"/>
        <field name="groups" eval="[(4, ref('group_ic_user'))]"/>
        <field name="domain_force">[('requester_id', '=', user.id)]</field>
    </record>

    <record id="rule_ic_request_manager" model="ir.rule">
        <field name="name">IC Request for Managers</field>
        <field name="model_id" ref="model_ic_request"/>
        <field name="groups" eval="[(4, ref('group_ic_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_ic_request_store" model="ir.rule">
        <field name="name">IC Request for Store</field>
        <field name="model_id" ref="model_ic_request"/>
        <field name="groups" eval="[(4, ref('group_ic_store'))]"/>
        <field name="domain_force">[('state', 'in', ['manager_approved', 'store_done', 'accounted'])]</field>
    </record>

    <record id="rule_ic_request_accountant" model="ir.rule">
        <field name="name">IC Request for Accountant</field>
        <field name="model_id" ref="model_ic_request"/>
        <field name="groups" eval="[(4, ref('group_ic_accountant'))]"/>
        <field name="domain_force">[('state', 'in', ['store_done', 'accounted'])]</field>
    </record>
</odoo>