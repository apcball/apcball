<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_ic_request_tree" model="ir.ui.view">
        <field name="name">ic.request.tree</field>
        <field name="model">ic.request</field>
        <field name="arch" type="xml">
            <tree string="Internal Consumption Requests">
                <field name="name"/>
                <field name="date_request"/>
                <field name="requester_id"/>
                <field name="department_id"/>
                <field name="amount_total_cost"/>
                <field name="state"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ic_request_form" model="ir.ui.view">
        <field name="name">ic.request.form</field>
        <field name="model">ic.request</field>
        <field name="arch" type="xml">
            <form string="Internal Consumption Request">
                <header>
                    <button name="action_submit" type="object" string="Submit for Approval" 
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve" 
                            invisible="state != 'submitted'" class="btn-success"/>
                    <button name="action_reject" type="object" string="Reject" 
                            invisible="state != 'submitted'" class="btn-danger"/>
                    <button name="action_done" type="object" string="Done (Issue)" 
                            invisible="state != 'manager_approved'" class="btn-primary"/>
                    <button name="action_create_account_move" type="object" string="Create Accounting Entry" 
                            invisible="state != 'store_done'" class="btn-info"/>
                    <button name="action_cancel" type="object" string="Cancel" 
                            invisible="state not in ['draft', 'submitted', 'manager_approved', 'store_done']" class="btn-danger"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" 
                            invisible="state != 'canceled'" class="btn-default"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,manager_approved,store_done,accounted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(stock.stock_move_action)d" type="action" 
                                context="{'search_default_ic_request_id': active_id, 'default_ic_request_id': active_id}"
                                class="oe_stat_button" icon="fa-exchange">
                            <field name="id" invisible="1"/>
                            <field string="Stock Moves" name="id" widget="statinfo"/>
                        </button>
                        <button name="%(account.action_move_journal_line)d" type="action" 
                                context="{'search_default_ref': 'IC: ' + name, 'default_ref': 'IC: ' + name}"
                                class="oe_stat_button" icon="fa-book">
                            <field name="id" invisible="1"/>
                            <field string="Journal Entries" name="id" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date_request" readonly="state != 'draft'"/>
                            <field name="requester_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="department_id" readonly="state not in ['draft', 'submitted']"/>
                            <field name="analytic_account_id" readonly="state not in ['draft', 'submitted']"/>
                            <field name="analytic_tag_ids" widget="many2many_tags" readonly="state not in ['draft', 'submitted']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="location_id" readonly="state != 'draft'"/>
                            <field name="dest_location_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="expense_policy" readonly="state != 'draft'"/>
                            <field name="journal_id" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request Lines">
                            <field name="line_ids" readonly="state not in ['draft']">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="uom_id" options="{'no_create': True}"/>
                                    <field name="qty" sum="Total Qty"/>
                                    <field name="available_qty" readonly="1"/>
                                    <field name="unit_cost" sum="Total Cost"/>
                                    <field name="subtotal_cost" sum="Subtotal"/>
                                    <field name="expense_account_id"/>
                                    <field name="analytic_account_id"/>
                                    <field name="analytic_tag_ids" widget="many2many_tags"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ic_request_search" model="ir.ui.view">
        <field name="name">ic.request.search</field>
        <field name="model">ic.request</field>
        <field name="arch" type="xml">
            <search string="Internal Consumption Requests">
                <field name="name"/>
                <field name="requester_id"/>
                <field name="department_id"/>
                <field name="date_request"/>
                <field name="state"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'manager_approved')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'store_done')]"/>
                <filter name="accounted" string="Accounted" domain="[('state', '=', 'accounted')]"/>
                <filter name="canceled" string="Canceled" domain="[('state', '=', 'canceled')]"/>
                <group string="Group By">
                    <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_requester" string="Requester" context="{'group_by': 'requester_id'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_ic_request" model="ir.actions.act_window">
        <field name="name">Internal Consumption Requests</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ic.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_ic_request_search"/>
        <field name="context">{'search_default_draft': 1}</field>
    </record>
</odoo>