<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_ic" model="ir.ui.view">
        <field name="name">res.company.form.inherit.ic</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Internal Consumption Settings">
                    <group>
                        <group>
                            <field name="ic_default_expense_account_id"/>
                            <field name="ic_default_consumption_location_id"/>
                        </group>
                        <group>
                            <field name="ic_default_journal_id"/>
                            <field name="ic_costing_policy"/>
                            <field name="ic_auto_post_journal_entries"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>