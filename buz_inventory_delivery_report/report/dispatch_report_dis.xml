<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Paper Format for delivery document Reports -->
    <record id="paperformat_dispatch_report_dis" model="report.paperformat">
        <field name="name">Dispatch Report Dis</field>
        <field name="default" eval="True"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>
    
    <template id="dispatch_report_dis_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <style>
                         html, body {
        position: relative;
        min-height: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
    }

    body::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/buz_inventory_delivery_report/static/src/img/Dispatch_Report.jpg');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: top center;
        opacity: 0.2;  /* ← ปรับค่าความจางได้ตามต้องการ เช่น 0.1 = จางมาก, 0.5 = กลางๆ */
        z-index: -1;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
    }
                    </style>
                    <div class="page">
                        <div class="dispatch-content">
                        

                        <style>
                            
                             @font-face {
                                font-family: 'Sarabun';
                                src: url('/buz_inventory_delivery_report/static/fonts/Sarabun-Bold.ttf') format('truetype');
                            }
                            
                            @page {
                                margin-top: 0mm;
                                margin-bottom: 10mm;
                                margin-left: 10mm;
                                margin-right: 10mm;
                            }
                            
                            body, .page, .row {
                                margin-top: 0 !important;
                                padding-top: 0 !important;
                            }
                            
                            html, body, page, table, th, td, div, p, span, h1, h2, h3, h4, h5, h6 {
                                font-family: 'Sarabun', sans-serif !important;
                                font-size: 18px;
                            }
                            
                            .table {
                                border-collapse: collapse !important;
                                width: 100%;
                            }
                            
                            .table td,
.table th {
    border: none !important;
    padding: 0;
}

                            .order-line-table th,
                            .order-line-table td {
                                padding-top: 10px !important;
                                padding-bottom: 10px !important;
                               line-height: 1.1 !important;
                            }
                            
                            .no-inner-borders td,
                            .no-inner-borders th {
                                border: none !important;
                            }
                            
                            .table-bordered,
                            .table-bordered td,
                            .table-bordered th {
                                border: none !important;
                            }

                            .page {
                                page-break-after: always;
                            }
                            .page:last-child {
                                page-break-after: auto;
                            }

                            .page-break {
                                page-break-after: always;
                              }

                            .vendor-info, .delivery-info {
                                font-size: 14px;
                            }
                            .order-line-table.no-border,
                            .order-line-table.no-border th,
                            .order-line-table.no-border td {
                              border: none !important;
                              background-color: transparent !important;
                            }
                            .order-line-table thead tr th {
                                border-bottom: none !important;  /* ซ่อนเส้นล่างหัวตาราง */
                            }

                            .order-line-table tbody tr td {
                                border: none !important;  /* ซ่อนเส้นทั้งหมดในตัวตาราง */
                            }
                        </style>

                        
                         <!-- Order Lines -->
                         <t t-set="move_list" t-value="o.move_ids"/>
                         <t t-set="groups_of_9" t-value="[move_list[i:i+9] for i in range(0, len(move_list), 9)]"/>
                         <t t-set="page_number" t-value="1"/>
                         <t t-set="total_pages" t-value="groups_of_9 and len(groups_of_9) or 0"/>
                         <t t-set="page_number" t-value="1"/>
                         <t t-foreach="groups_of_9" t-as="group">
                             <div t-attf-style="#{page_number != 1 and 'page-break-before: always;' or ''}">
                          <t t-set="groups_of_9" t-value="[move_list[i:i+9] for i in range(0, len(move_list), 9)]"/>

                          <t t-if="groups_of_9">
                              <div>
                             <!-- เงื่อนไขแสดงเลขหน้าเฉพาะถ้ามีหลายหน้า -->
                                    <t t-if="total_pages &gt; 1">
                                        <div style="text-align: right; font-weight: bold; font-size: 14px; margin-bottom: 5px;">
                                            หน้า <t t-esc="page_number"/> / <t t-esc="total_pages"/>
                                        </div>
                                    </t>

                           <!-- Company Info Section -->
                         <div class="row mb-1 align-items-start" style="visibility: hidden;">
                             <!-- โลโก้ -->
                             <div class="col-auto" style="margin-top: 40px; margin-left: 25px;">
                                 <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                                      style="width: 200px; height: auto; object-fit: contain;" alt="Company Logo"/>
                             </div>

                             <!-- ชื่อบริษัท -->
                             <div class="col ps-3" style="margin-top: 40px;">
                                 <div class="company-header mb-1" style="font-size: 24px; font-weight: bold;">
                                     บริษัท โมเก้น จำกัด (สำนักงานใหญ่)
                                 </div>
                                 <div class="company-info" style="font-size: 20px;">
                                     9 หมู่ 12 ตําบลบึงคําพร้อย อําเภอลําลูกกา จ.ปทุมธานี 12150
                                 </div>
                                 <div class="company-info" style="font-size: 20px;">
                                     โทร 02 1509710 แฟกซ์ 02 1528803
                                 </div>
                                 <div class="company-info" style="font-size: 20px;">
                                     E-mail: contact@mogen.co.th
                                 </div>
                             </div>
                         </div>

                           <!-- Document Title -->
                           <div class="row mb-3" style="margin-top: 30px; margin-bottom: 60px; color: transparent;">
                               <div class="col-12 text-center">
                                   <div style="font-size: 25px; font-family: 'TH SarabunPSK', 'THSarabunNew', Tahoma, Arial, sans-serif; display: inline-block; padding: 12px 44px; border-radius: 10px; color: transparent;">
                                       ใบจ่ายสินค้า
                                   </div>
                               </div>
                           </div>
                           <!-- Customer and Document Info -->
                           <div class="row" style="display: flex; align-items: flex-start; margin-bottom: -10px;">
                              <!-- Left side: Customer name -->
                               <div class="col-6" style="text-align: left; padding-right: 0; margin-top: 65px;">
                                   <div>
                                       <strong style="display: inline-block; width: 15%; font-size: 20px; visibility: hidden;">ชื่อลูกค้า </strong>
                                       <span t-field="o.partner_id.name" style="font-size: 20px; margin-left: 60px;"/>
                                   </div>
                                   <div class="company-header mb-1" style="font-size: 20px; font-weight: bold; visibility: hidden;">
                                       (Customer Name)
                                   </div>
                                   <div style="margin-top: 10px;">
                                       <strong style="display: inline-block; width: 20%; font-size: 20px; visibility: hidden;">สถานที่ส่งสินค้า</strong>
                                       <span t-field="o.partner_id.street" style="font-size: 20px;margin-left: 60px;margin-top: -20px;"/>
                                   </div>
                                   <div class="company-header mb-1" style="font-size: 20px; font-weight: bold; visibility: hidden;">
                                       (Ship To)
                                   </div>
                                   <div style="margin-top: 10px;">
                                     <strong style="display: inline-block; width: 20%; font-size: 20px; visibility: hidden;">สถานที่จ่ายสินค้า</strong>
                                     <span t-field="o.ship_from_partner_id.name" style="font-size: 20px;padding-top: -100px;"/>
                                   </div>
                                     <div class="company-header mb-1" style="font-size: 20px; font-weight: bold; visibility: hidden;">
                                      (Ship From)
                                </div>
                               </div>
                               <!-- Right side: Document info -->
                               <div class="col-6" style="text-align: right; padding-right: 45px; margin-top: -40px;">
                                   <div class="info-box" style="font-size: 20px;">
                                       <div class="mb-2">
                                           <strong style="width:75%; display: inline-block; font-size: 20px; visibility: hidden;">เลขที่ (Shipment No):</strong>
                                           <span t-field="o.name" style="font-size: 20px;padding-right: 60px;"/>
                                       </div>
                                       <div class="mb-2">
                                           <strong style="width: 65%; display: inline-block; font-size: 20px; visibility: hidden;">วันที่ (Date):</strong>
                                           <span t-field="o.scheduled_date" t-options='{"widget": "date"}' style="font-size: 20px;padding-right: 70px;margin-top: -20px;"/>
                                       </div>
                                   </div>
                               </div>
                           </div>

                          <table style="width: 100%; table-layout: fixed; text-align: center; border-collapse: collapse; font-size: 14px; margin-bottom: 60px;">
                               <thead style="visibility: hidden;">
                                   <tr>
                                       <th style="border: 1px solid transparent; font-size:14px; padding: 2px; visibility: hidden;">เลขที่ใบสั่งซื้อ</th>
                                       <th style="border: 1px solid transparent; font-size:14px; padding: 2px; visibility: hidden;">ประเภทรถ</th>
                                       <th style="border: 1px solid transparent; font-size:14px; padding: 2px; visibility: hidden;">ทะเบียนรถ</th>
                                       <th style="border: 1px solid transparent; font-size:14px; padding: 2px; visibility: hidden;">พนักงานขับรถ</th>
                                   </tr>
                               </thead>
                               <tbody>
                                   <tr>
                                   <td style="border: 1px solid transparent; font-size:14px; padding: 50px 8px 8px 8px;">
    <t t-if="o.sale_id">
        <span t-field="o.sale_id.name"/>
    </t>
</td>
                                       <td style="visibility: hidden; border: none;"><div style="height: 2em;"></div></td>
                                       <td style="visibility: hidden; border: none;"><div style="height: 2em;"></div></td>
                                       <td style="visibility: hidden; border: none;"><div style="height: 2em;"></div></td>
                                   </tr>
                               </tbody>
                           </table>

                      <div style="height: 490px; margin-top: 20px;">
                        <table style="border-collapse: collapse; width: 100%; border: none;">
                            <thead style="display: none;">
                                <tr>
                                    <th style="width: 8%; padding: 1px; text-align: center; vertical-align: middle; border: none; font-size: 18px; background-color: #f8f9fa; font-weight: bold;">
                                        ลำดับ<br/><span style="font-size: 14px; font-weight: normal;">(No)</span>
                                    </th>
                                    <th style="width: 8%; padding: 8px; text-align: center; vertical-align: middle;border: none; font-size: 18px; background-color: #f8f9fa; font-weight: bold;">
                                        รหัสสินค้า<br/><span style="font-size: 14px; font-weight: normal;">(Item No)</span>
                                    </th>
                                    <th style="width: 55%; padding: 26px; text-align: center; vertical-align: middle; border: none; font-size: 18px; background-color: #f8f9fa; font-weight: bold;">
                                        รายการสินค้า<br/><span style="font-size: 14px; font-weight: normal;">(Description)</span>
                                    </th>
                                    <th style="width: 10%; padding: 9px; text-align: center; vertical-align: middle; border: none; font-size: 18px; background-color: #f8f9fa; font-weight: bold;">
                                        จำนวน<br/><span style="font-size: 14px; font-weight: normal;">(Qty)</span>
                                    </th>
                                    <th style="width: 9%; padding: 11px; text-align: center; vertical-align: middle;border: none; font-size: 18px; background-color: #f8f9fa; font-weight: bold;">
                                        หน่วย<br/><span style="font-size: 14px; font-weight: normal;">(Unit)</span>
                                    </th>
                                    <th style="width: 13%; padding: 8px; text-align: center; vertical-align: middle;border: none; font-size: 18px; background-color: #f8f9fa; font-weight: bold;">
                                        หมายเหตุ<br/><span style="font-size: 14px; font-weight: normal;">(Remark)</span>
                                    </th>
                                </tr>
                            </thead>
                           <tbody>
                                           <t t-set="line_number" t-value="((page_number - 1) * 9) + 1"/>
                                           <t t-set="current_line_number" t-value="line_number"/>
                                           <t t-foreach="group" t-as="move">
                                               <tr class="data-row" style="font-size: 22px;">
                                                   <td style="width: 7%; text-align: center; border: none;"><span t-esc="current_line_number"/></td>
                                                   <td style="width: 9%; border: none;"><span t-field="move.product_id.default_code"/></td>
                                                   <td style="width: 42%; border: none;"><span t-field="move.product_id"/></td>
                                                   <td style="width: 9%; text-align: center; border: none;">
                                                       <t t-set="move_qty" t-value="move.product_uom_qty"/>
                                                       <span t-esc="'%.0f' % move_qty"/>
                                                   </td>
                                                   <td style="width: 9%; text-align: center; border: none;">
                                                       <span t-field="move.product_uom.name"/>
                                                   </td>
                                                   <td style="width: 13%; text-align: center; border: none;"><span t-field="move.lot_ids"/></td>
                                               </tr>
                                               <t t-set="current_line_number" t-value="current_line_number + 1"/>
                                           </t>

                                           <!-- เติมแถวเปล่าให้ครบ 9 แถวต่อหน้า -->
                                           <t t-if="len(group) &lt; 9">
                                            <t t-set="empty_rows" t-value="9 - len(group)"/>
                                            <t t-foreach="range(empty_rows)" t-as="i">
                                                <tr class="data-row" style="font-size: 22px; height: 50px; line-height: 50px;">
                                                    <td style="width: 8%; text-align: center; border: none;"></td>
                                                    <td style="width: 15%; border: none;"></td><td style="width: 40%; border: none;"></td><td style="width: 10%; border: none;"></td><td style="width: 10%; border: none;"></td><td style="width: 17%; border: none;"></td>
                                                </tr>
                                            </t>
                                        </t>
                                       </tbody>
                                   </table>
                                </div>
                             </div>
                       </t>
                    </div>
                               <t t-set="page_number" t-value="page_number + 1"/></t>

                                   <!-- เงื่อนไขแสดงลายเซ็นเฉพาะหน้าสุดท้าย -->
                                   <t t-if="page_number == len(groups_of_9)">
                                       <!-- ลายเซ็นหรือหมายเหตุ -->
                                   </t>

                       

                                  <!-- หมายเหตุ -->
                                 <div style="padding: 15px; font-size: 22px; margin-top: 10px; line-height: 1.6; visibility: hidden; ">
                                     <!-- หมายเหตุข้อ 1 -->
                                     <div style="font-size: 22px;">
                                         <span style="font-weight: bold;">หมายเหตุ:</span>
                                         <span>1. การซื้อขายสมบูรณ์ เมื่อมีการส่งมอบสินค้า / บริษัทฯ สงวนสิทธิ์ที่จะปรับปรุงราคาให้เท่ากับราคาซื้อขายในวันรับสินค้า</span>
                                     </div>

                                     <!-- หมายเหตุข้อ 2 -->
                                    <div style="margin-left: 50px; font-size: 22px;">
                                         <span style="display: inline-block; width: 2ch;">2.</span>
                                         <span>ได้รับสินค้าตามรายการข้างล่าง ในสภาพที่ดีและจำนวนถูกต้องแล้ว</span>
                                     </div>

                                     <!-- หมายเหตุเพิ่มเติม -->
                                    <div t-if="o.note" style="margin-top: 10px; margin-left: 10px; font-size: 22px;">
                                         <span t-field="o.note"/>
                                     </div>
                                 </div>




                               

                              
                        </div>
                    </div>
                    
              </t>
           </t>     
         </t>                 
    </template>


    <record id="action_dispatch_report_dis" model="ir.actions.report">
        <field name="name">ใบจ่ายสินค้า Tast</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_inventory_delivery_report.dispatch_report_dis_document</field>
        <field name="report_file">buz_inventory_delivery_report.dispatch_report_dis_document</field>
        <field name="print_report_name">'Delivery Report - %s' % object.name</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_dispatch_report_dis"/>
    </record>
</odoo>
