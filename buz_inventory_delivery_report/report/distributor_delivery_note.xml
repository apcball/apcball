<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Paper Format for delivery document Reports -->
    <record id="paperformat_distributor_delivery_note" model="report.paperformat">
        <field name="name">Distributor delivery note A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record> 

    <template id="distributor_delivery_note_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="config" t-value="request.env['dispatch.report.config'].sudo().get_default_config() if 'dispatch.report.config' in request.env else None"/>
                <t t-call="web.external_layout">
                    
                    <style>
                        @font-face {
                            font-family: 'Sarabun';
                            src: url('/buz_inventory_delivery_report/static/fonts/Sarabun-Bold.ttf') format('truetype');
                        }
                        @page {
                            size: A4 portrait;
                            margin: 3mm;
                        }
                        body, .page {
                            font-family: 'Sarabun', sans-serif !important;
                            font-size: 20px;
                            color: #000;
                            margin: 0;
                            padding: 0;
                        }
                        .table-bordered th, .table-bordered td {
                            border: 1px solid #000 !important;
                            padding: 4px;
                        }
                        .doc-title {
                            text-align: center;
                            font-size: 28px;
                            font-weight: bold;
                            margin: 20px 0;
                        }
                        table, tr, td, th, .table th, .table td, .table tr {
                            background-color: #ffffff !important;
                        }
                        .table th {
                            text-align: center;
                            vertical-align: middle;
                            font-weight: bold;
                        }
                        .empty-row td {
                            color: transparent;
                        }
                    </style>

                    <t t-set="move_list" t-value="o.move_ids"/>
                    <t t-set="po" t-value="o.purchase_id or (move_list.mapped('purchase_line_id.order_id') and move_list.mapped('purchase_line_id.order_id')[0]) or (move_list.mapped('origin_returned_move_id.purchase_line_id.order_id') and move_list.mapped('origin_returned_move_id.purchase_line_id.order_id')[0]) or False"/>
                    <t t-set="groups_of_10" t-value="[move_list[i:i+10] for i in range(0, len(move_list), 10)] if move_list else [[]]"/>
                    <t t-set="total_pages" t-value="len(groups_of_10)"/>
                    <t t-set="total_qty" t-value="0"/>
                    <t t-set="total_amount" t-value="0"/>

                    <t t-foreach="groups_of_10" t-as="group" t-index="group_index">
                        <t t-set="page_number" t-value="group_index + 1"/>
                        <div class="page" t-attf-style="#{page_number != 1 and 'page-break-before: always;' or ''}">
                            
                            <!-- Header -->
                            <table style="width: 100%; margin-bottom: 15px; border: none;">
                                <tr>
                                    <td style="width: 30%; vertical-align: middle; border: none; padding: 0;">
                                        <img src="/buz_inventory_delivery_report/static/img/LOGO%20MOGEN.png"
                                             style="width: 100%; max-height: 80px; object-fit: contain;" alt="Logo"/>
                                    </td>
                                    <td style="width: 70%; vertical-align: middle; border: none; padding-left: 20px;">
                                        <div style="font-size: 18px; font-weight: bold; margin-bottom: 5px;">บริษัท โมเก้น จำกัด</div>
                                        <div style="font-size: 14px;">9 หมู่ 12 ตำบลบึงคำพร้อย อำเภอลำลูกกา จ ปทุมธานี 12150</div>
                                        <div style="font-size: 14px;">โทร 02 150 9709 13 แฟกซ์ 02 152 8801 02 E mail : contact@mogen.co.th</div>
                                    </td>
                                </tr>
                            </table>

                            <!-- Title -->
                            <div class="doc-title">
                                ใบแจ้งคืนสินค้า[ผู้จัดจำหน่าย]
                            </div>

                            <!-- Info -->
                            <table style="width: 100%; border: none; margin-bottom: 15px;">
                                <tr>
                                    <td style="width: 60%; vertical-align: top; border: none; padding: 0;">
                                        <table style="width: 100%; border: none;">
                                            <tr>
                                                <td style="width: 80px; vertical-align: top; border: none; padding: 3px 0;"><strong>ชื่อ</strong></td>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;"><span t-field="o.partner_id.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;"><strong>ที่อยู่</strong></td>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;">
                                                    <span t-field="o.partner_id.street"/><br t-if="o.partner_id.street"/>
                                                    <span t-field="o.partner_id.street2"/><br t-if="o.partner_id.street2"/>
                                                    <span t-field="o.partner_id.city"/> <span t-field="o.partner_id.state_id.name"/> <span t-field="o.partner_id.zip"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;"><strong>โทรศัพท์</strong></td>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;"><span t-field="o.partner_id.phone"/></td>
                                            </tr>
                                        </table>
                                    </td>
                                    <td style="width: 40%; vertical-align: top; border: none; padding: 0;">
                                        <table style="width: 100%; border: none;">
                                            <tr>
                                                <td style="width: 100px; vertical-align: top; border: none; padding: 3px 0; text-align: right; padding-right: 15px;">เลขที่เอกสาร</td>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;"><span t-field="o.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top; border: none; padding: 3px 0; text-align: right; padding-right: 15px;">วันที่</td>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;"><span t-field="o.scheduled_date" t-options='{"widget": "date"}'/></td>
                                            </tr>
                                            <tr>
                                                <td style="vertical-align: top; border: none; padding: 3px 0; text-align: right; padding-right: 15px;">Ref</td>
                                                <td style="vertical-align: top; border: none; padding: 3px 0;">
                                                    <t t-set="bills" t-value="po.invoice_ids.filtered(lambda i: i.state != 'cancel').mapped('name') if po else []"/>
                                                    <span t-esc="', '.join([b for b in bills if b and b != '/']) if bills and any(b != '/' for b in bills) else o.origin"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Table -->
                            <table class="table table-bordered" style="width: 100%; border-collapse: collapse; margin-top: 10px;">
                                <thead>
                                    <tr>
                                        <th rowspan="2" style="width: 5%;">ลำดับ</th>
                                        <th rowspan="2" style="width: 15%;">รหัสสินค้า</th>
                                        <th rowspan="2" style="width: 30%;">ชื่อสินค้า</th>
                                        <th colspan="4" style="width: 50%;">ส่งคืนผู้ขาย</th>
                                    </tr>
                                    <tr>
                                        <th style="width: 15%;">เลขที่เอกสาร</th>
                                        <th style="width: 10%;">ราคาต่อหน่วย</th>
                                        <th style="width: 10%;">จำนวนที่</th>
                                        <th style="width: 15%;">จำนวนเงิน</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="offset" t-value="(page_number - 1) * 10"/>
                                    <t t-foreach="group" t-as="move" t-index="move_index">
                                        <!-- Calculate price_unit and amount safely from Return Origin or PO -->
                                        <t t-set="orig_move" t-value="move.origin_returned_move_id"/>
                                        <t t-set="po_line" t-value="move.purchase_line_id or (orig_move and orig_move.purchase_line_id)"/>
                                        <t t-set="price_unit" t-value="po_line.price_unit if po_line else (orig_move.price_unit if orig_move else move.price_unit)"/>
                                        
                                        <t t-if="not price_unit and po">
                                            <t t-set="fallback_line" t-value="po.order_line.filtered(lambda l: l.product_id == move.product_id)"/>
                                            <t t-set="price_unit" t-value="fallback_line[0].price_unit if fallback_line else 0.0"/>
                                        </t>
                                        
                                        <t t-set="amount" t-value="price_unit * move.product_uom_qty"/>
                                        <tr style="height: 30px;">
                                            <td class="text-center"><span t-esc="offset + move_index + 1"/></td>
                                            <td><span t-field="move.product_id.default_code"/></td>
                                            <td>
                                                <span t-field="move.product_id.name"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-esc="o.return_doc_no if o.return_doc_no else o.origin"/>
                                            </td>
                                            <td class="text-right" style="text-align: right;"><span t-esc="price_unit" t-options='{"widget": "float", "precision": 2}'/></td>
                                            <td class="text-right" style="text-align: right;"><span t-esc="'%.2f' % move.product_uom_qty"/></td>
                                            <td class="text-right" style="text-align: right;"><span t-esc="amount" t-options='{"widget": "float", "precision": 2}'/></td>
                                        </tr>
                                        <t t-set="total_qty" t-value="total_qty + move.product_uom_qty"/>
                                        <t t-set="total_amount" t-value="total_amount + amount"/>
                                    </t>
                                    
                                    <!-- Pad empty rows to maintain table height -->
                                    <t t-if="len(group) &lt; 10">
                                        <t t-foreach="range(10 - len(group))" t-as="i">
                                            <tr style="height: 30px;">
                                                <td><span style="color: transparent;">-</span></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                            </tr>
                                        </t>
                                    </t>

                                    <!-- Footer rows inside table, only on last page -->
                                    <t t-if="page_number == total_pages">
                                        <tr>
                                            <td colspan="5" rowspan="3" style="vertical-align: top; border-bottom: 1px solid #000;">
                                                <div style="display: flex;">
                                                    <strong style="width: 80px; padding-left: 5px;">หมายเหตุ</strong>
                                                    <span>
                                                        <span t-field="o.note"/>
                                                    </span>
                                                </div>
                                            </td>
                                            <td class="text-right" style="text-align: right; border-left: 1px solid #000;">จำนวนเงิน</td>
                                            <td class="text-right" style="text-align: right;"><span t-esc="total_amount" t-options='{"widget": "float", "precision": 2}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-right" style="text-align: right; border-left: 1px solid #000;">VAT</td>
                                            <td class="text-right" style="text-align: right;"><span t-esc="total_amount * 0.07" t-options='{"widget": "float", "precision": 2}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-right" style="text-align: right; border-left: 1px solid #000;">รวมจำนวน</td>
                                            <td class="text-right" style="text-align: right;"><span t-esc="total_amount * 1.07" t-options='{"widget": "float", "precision": 2}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <!-- Signatures, only on last page -->
                            <t t-if="page_number == total_pages">
                                <div style="margin-top: 30px; page-break-inside: avoid;">
                                    <table style="width: 100%; text-align: center; table-layout: fixed; border: none;">
                                        <tr>
                                            <td style="border: none;">
                                                <p style="margin-bottom: 5px;">_______________________</p>
                                                <p style="margin-bottom: 2px;">ผู้จัดทำ</p>
                                                <p>......./......./.......</p>
                                            </td>
                                            <td style="border: none;">
                                                <p style="margin-bottom: 5px;">_______________________</p>
                                                <p style="margin-bottom: 2px;">แผนกจัดซื้อ<br/>(ตรวจสอบ)</p>
                                                <p>......./......./.......</p>
                                            </td>
                                            <td style="border: none;">
                                                <p style="margin-bottom: 5px;">_______________________</p>
                                                <p style="margin-bottom: 2px;">วันที่แจ้งผู้รับ</p>
                                                <p>......./......./.......</p>
                                            </td>
                                            <td style="border: none;">
                                                <p style="margin-bottom: 5px;">_______________________</p>
                                                <p style="margin-bottom: 2px;">บัญชี</p>
                                                <p>......./......./.......</p>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </t>

                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>
    <record id="action_distributor_delivery_note" model="ir.actions.report">
        <field name="name">ใบแจ้งคืนสินค้า ผู้จัดจำหน่าย</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_inventory_delivery_report.distributor_delivery_note_document</field>
        <field name="report_file">buz_inventory_delivery_report.distributor_delivery_note_document</field>
        <field name="print_report_name">'Delivery Report - %s' % object.name</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_distributor_delivery_note"/>
    </record>
</odoo>