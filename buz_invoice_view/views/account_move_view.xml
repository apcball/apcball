<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_move_form_inherit_buz_invoice_view" model="ir.ui.view">
            <field name="name">account.move.form.inherit.buz.invoice.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='purchase_order_number']" position="after">
                    <field name="sale_client_order_ref" string="Customer Reference (PO)"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
