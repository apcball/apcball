<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_it_asset_agent" model="ir.rule">
        <field name="name">Agent: company IT assets</field>
        <field name="model_id" ref="model_buz_it_asset"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_agent'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_it_asset_manager" model="ir.rule">
        <field name="name">Manager: company IT assets</field>
        <field name="model_id" ref="model_buz_it_asset"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_it_asset_category_manager" model="ir.rule">
        <field name="name">Manager: IT asset categories</field>
        <field name="model_id" ref="model_buz_it_asset_category"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_manager'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_it_asset_spec_category_manager" model="ir.rule">
        <field name="name">Manager: IT asset specification categories</field>
        <field name="model_id" ref="model_buz_it_asset_spec_category"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_manager'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_it_asset_spec_line_agent" model="ir.rule">
        <field name="name">Agent: company IT asset specifications</field>
        <field name="model_id" ref="model_buz_it_asset_spec_line"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_agent'))]"/>
        <field name="domain_force">[('asset_id.company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_it_asset_spec_line_manager" model="ir.rule">
        <field name="name">Manager: company IT asset specifications</field>
        <field name="model_id" ref="model_buz_it_asset_spec_line"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_manager'))]"/>
        <field name="domain_force">[('asset_id.company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_it_asset_software_manager" model="ir.rule">
        <field name="name">Manager: IT asset software</field>
        <field name="model_id" ref="model_buz_it_asset_software"/>
        <field name="groups" eval="[(4, ref('buz_it_helpdesk.group_it_helpdesk_manager'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
