<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_it_helpdesk" model="ir.module.category">
        <field name="name">IT Management</field>
        <field name="sequence">30</field>
    </record>
    <record id="group_it_helpdesk_requester" model="res.groups">
        <field name="name">Requester</field>
        <field name="category_id" ref="module_category_it_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_it_helpdesk_agent" model="res.groups">
        <field name="name">Support Agent</field>
        <field name="category_id" ref="module_category_it_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
    </record>
    <record id="group_it_helpdesk_manager" model="res.groups">
        <field name="name">Helpdesk Manager</field>
        <field name="category_id" ref="module_category_it_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_it_helpdesk_agent'))]"/>
    </record>

    <record id="rule_ticket_requester" model="ir.rule">
        <field name="name">Requester: own tickets in allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_ticket"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('requester_id', '=', user.id)]</field>
    </record>
    <record id="rule_ticket_agent" model="ir.rule">
        <field name="name">Agent: all tickets in allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_ticket"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_agent'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_ticket_manager" model="ir.rule">
        <field name="name">Manager: all company tickets</field>
        <field name="model_id" ref="model_it_helpdesk_ticket"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_stage_company" model="ir.rule">
        <field name="name">Helpdesk stages: allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_stage"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_category_company" model="ir.rule">
        <field name="name">Helpdesk categories: allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_category"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_priority_company" model="ir.rule">
        <field name="name">Helpdesk priorities: allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_priority"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_sla_company" model="ir.rule">
        <field name="name">Helpdesk SLA: allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_sla"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_agent'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_tag_company" model="ir.rule">
        <field name="name">Helpdesk tags: allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_tag"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_article_company" model="ir.rule">
        <field name="name">Knowledge articles: allowed companies</field>
        <field name="model_id" ref="model_it_helpdesk_knowledge_article"/>
        <field name="groups" eval="[(4, ref('group_it_helpdesk_requester'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
