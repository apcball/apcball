<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="buz_it_helpdesk.HelpdeskDashboard">
        <div class="o_helpdesk_dashboard container-fluid py-3">
            <div class="d-flex justify-content-between align-items-center mb-3"><div><h2 class="mb-0">IT Helpdesk Overview</h2><span class="text-muted">Ticket and SLA summary</span></div><button class="btn btn-outline-secondary" t-on-click="resetFilters"><i class="fa fa-refresh me-1"/> Reset</button></div>
            <div class="card shadow-sm mb-3"><div class="card-body"><div class="row g-2">
                <t t-foreach="[['company_id','Company','companies'],['team_id','Helpdesk Team','teams'],['assignee_id','Assignee','assignees'],['priority_id','Priority','priorities'],['category_id','Category','categories']]" t-as="filter" t-key="filter[0]"><div class="col-12 col-md-2"><label class="form-label" t-esc="filter[1]"/><select class="form-select" t-att-name="filter[0]" t-on-change="onFilterChange"><option value="">All</option><t t-foreach="state.data?.options?.[filter[2]] || []" t-as="option" t-key="option.id"><option t-att-value="option.id" t-att-selected="String(state.filters[filter[0]]) === String(option.id)" t-esc="option.label"/></t></select></div></t>
                <div class="col-12 col-md-2"><label class="form-label">Date From</label><input class="form-control" type="date" name="date_from" t-att-value="state.filters.date_from" t-on-change="onFilterChange"/></div><div class="col-12 col-md-2"><label class="form-label">Date To</label><input class="form-control" type="date" name="date_to" t-att-value="state.filters.date_to" t-on-change="onFilterChange"/></div>
            </div></div></div>
            <div t-if="state.loading" class="text-center py-5"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="state.data and !state.loading">
                <div class="row g-3 mb-3"><t t-foreach="state.data.kpis" t-as="kpi" t-key="kpi.code"><div class="col-12 col-sm-6 col-xl-3"><button class="o_helpdesk_kpi card shadow-sm w-100 text-start" t-on-click="() => openTickets(kpi, kpi.label)"><div class="card-body"><div class="text-muted small" t-esc="kpi.label"/><div class="fs-2 fw-bold" t-esc="kpi.count"/></div></button></div></t></div>
                <div class="row g-3"><div class="col-12 col-xl-6"><div class="card shadow-sm h-100"><div class="card-header fw-bold">Ticket Status Overview</div><div class="card-body"><t t-foreach="state.data.status_overview" t-as="item" t-key="item.code"><button class="o_helpdesk_bar-row" t-on-click="() => openTickets(item, item.label)"><span class="o_helpdesk_bar-label" t-esc="item.label"/><span class="o_helpdesk_bar-track"><span class="o_helpdesk_bar-fill bg-primary" t-att-style="'width: ' + barWidth(item.count)"/></span><span class="o_helpdesk_bar-value" t-esc="item.count"/></button></t></div></div></div>
                    <div class="col-12 col-xl-6"><div class="card shadow-sm h-100"><div class="card-header fw-bold">Ticket Trend</div><div class="card-body"><t t-if="state.data.trend.length"><t t-foreach="state.data.trend" t-as="item" t-key="item.label"><div class="o_helpdesk_bar-row"><span class="o_helpdesk_bar-label" t-esc="item.label"/><span class="o_helpdesk_bar-track"><span class="o_helpdesk_bar-fill bg-info" t-att-style="'width: ' + barWidth(item.count)"/></span><span class="o_helpdesk_bar-value" t-esc="item.count"/></div></t></t><span t-else="" class="text-muted">No tickets in this period.</span></div></div></div>
                    <t t-foreach="[['by_team','Tickets by Team'],['by_assignee','Tickets by Assignee'],['by_priority','Tickets by Priority'],['by_category','Tickets by Category']]" t-as="section" t-key="section[0]"><div class="col-12 col-md-6"><div class="card shadow-sm h-100"><div class="card-header fw-bold" t-esc="section[1]"/><div class="card-body"><t t-foreach="state.data[section[0]]" t-as="item" t-key="item.id || item.label"><button class="o_helpdesk_bar-row" t-on-click="() => openTickets(item, item.label)"><span class="o_helpdesk_bar-label" t-esc="item.label"/><span class="o_helpdesk_bar-track"><span class="o_helpdesk_bar-fill bg-secondary" t-att-style="'width: ' + barWidth(item.count)"/></span><span class="o_helpdesk_bar-value" t-esc="item.count"/></button></t><span t-if="!state.data[section[0]].length" class="text-muted">No data.</span></div></div></div></t>
                </div>
            </t>
        </div>
    </t>
</templates>
