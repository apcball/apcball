<?xml version="1.0" encoding="utf-8"?><odoo>
<template id="portal_helpdesk_tickets" name="Portal Helpdesk Tickets"><t t-call="portal.portal_layout"><div class="container"><h2>My Helpdesk Tickets</h2><a href="/my/helpdesk/new" class="btn btn-primary mb-3">Create Ticket</a><table class="table"><tr><th>Ticket</th><th>Subject</th><th>Status</th><th>Priority</th></tr><t t-foreach="tickets" t-as="ticket"><tr><td><t t-esc="ticket.name"/></td><td><t t-esc="ticket.subject"/></td><td><t t-esc="ticket.stage_id.name"/></td><td><t t-esc="ticket.priority_id.name"/></td></tr></t></table></div></t></template>
<template id="portal_helpdesk_new" name="New Helpdesk Ticket"><t t-call="portal.portal_layout"><div class="container"><h2>Report an IT Problem</h2><form action="/my/helpdesk/new" method="post" enctype="multipart/form-data"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><div class="mb-3"><label>Subject</label><input name="subject" required="required" class="form-control"/></div><div class="mb-3"><label>Category</label><select name="category_id" class="form-control"><t t-foreach="categories" t-as="category"><option t-att-value="category.id"><t t-esc="category.name"/></option></t></select></div><div class="mb-3"><label>Priority</label><select name="priority_id" class="form-control"><t t-foreach="priorities" t-as="priority"><option t-att-value="priority.id"><t t-esc="priority.name"/></option></t></select></div><div class="mb-3"><label>Description</label><textarea name="description" required="required" class="form-control"/><label>Attachment</label><input type="file" name="attachment" class="form-control"/><button class="btn btn-primary" type="submit">Submit Ticket</button></div></form></div></t></template></odoo>
