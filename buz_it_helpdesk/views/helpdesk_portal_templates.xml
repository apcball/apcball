<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="portal_helpdesk_tickets" name="Portal Helpdesk Tickets"><t t-call="portal.portal_layout"><div class="container"><h2>My Helpdesk Tickets</h2><a href="/my/helpdesk/new" class="btn btn-primary mb-3">Create Ticket</a><table class="table"><tr><th>Ticket</th><th>Subject</th><th>Status</th><th>Priority</th></tr><t t-foreach="tickets" t-as="ticket"><tr><td><a t-att-href="'/my/helpdesk/%s' % ticket.id"><t t-esc="ticket.name"/></a></td><td><t t-esc="ticket.subject"/></td><td><t t-esc="ticket.stage_id.name"/></td><td><t t-esc="ticket.priority_id.name"/></td></tr></t></table></div></t></template>
<template id="portal_helpdesk_ticket" name="Portal Helpdesk Ticket Detail"><t t-call="portal.portal_layout"><div class="container"><a href="/my/helpdesk">Back to tickets</a><h2><t t-esc="ticket.name"/> - <t t-esc="ticket.subject"/></h2><p>Status: <strong><t t-esc="ticket.stage_id.name"/></strong> | Priority: <t t-esc="ticket.priority_id.name"/></p><t t-if="ticket.stage_id.name == 'Draft'"><form t-att-action="'/my/helpdesk/%s/confirm' % ticket.id" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><button class="btn btn-primary mb-3" type="submit">Confirm</button></form></t><div class="card mb-3"><div class="card-body"><t t-raw="ticket.description"/></div></div><h4>Conversation</h4><t t-foreach="ticket.message_ids.sorted(key=lambda m: m.date)" t-as="message"><div class="border rounded p-2 mb-2"><small><t t-esc="message.author_id.name or 'System'"/> - <t t-esc="message.date"/></small><div t-raw="message.body"/></div></t><form t-att-action="'/my/helpdesk/%s/reply' % ticket.id" method="post" enctype="multipart/form-data"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><textarea name="body" class="form-control mb-2" required="required"/><input type="file" name="attachments" multiple="multiple" class="form-control mb-2"/><button class="btn btn-primary" type="submit">Reply</button></form><h4 class="mt-4">Attachments</h4><ul><t t-foreach="ticket.attachment_ids" t-as="attachment"><li><a t-att-href="'/web/content/%s?download=true' % attachment.id"><t t-esc="attachment.name"/></a></li></t></ul></div></t></template>
<template id="portal_helpdesk_new" name="New Helpdesk Ticket"><t t-call="portal.portal_layout"><div class="container"><h2>Report an IT Problem</h2><form action="/my/helpdesk/new" method="post" enctype="multipart/form-data"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><div class="mb-3"><label>Subject</label><input name="subject" required="required" class="form-control"/></div><div class="mb-3"><label>Category</label><select name="category_id" class="form-control"><t t-foreach="categories" t-as="category"><option t-att-value="category.id"><t t-esc="category.name"/></option></t></select></div><div class="mb-3"><label>Priority</label><select name="priority_id" class="form-control"><t t-foreach="priorities" t-as="priority"><option t-att-value="priority.id"><t t-esc="priority.name"/></option></t></select></div><div class="mb-3"><label>Description</label><textarea name="description" required="required" class="form-control"/><label>Attachments</label><input type="file" name="attachments" multiple="multiple" class="form-control"/><button class="btn btn-primary" type="submit">Submit Ticket</button></div></form></div></t></template>
</odoo>