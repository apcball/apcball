<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_ticket_list" model="ir.ui.view"><field name="name">it.helpdesk.ticket.list</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><tree decoration-danger="is_overdue" decoration-warning="is_response_overdue"><field name="name"/><field name="subject"/><field name="requester_id"/><field name="assigned_to"/><field name="team_id"/><field name="assignee_ids" widget="many2many_tags"/><field name="category_id"/><field name="priority_code" column_invisible="1"/><field name="priority_id" widget="badge" decoration-success="priority_code == &quot;low&quot;" decoration-info="priority_code == &quot;medium&quot;" decoration-warning="priority_code == &quot;high&quot;" decoration-danger="priority_code == &quot;critical&quot;"/><field name="stage_id" widget="badge"/><field name="sla_deadline"/><field name="response_deadline"/><field name="is_overdue" column_invisible="1"/><field name="is_response_overdue" column_invisible="1"/><field name="company_id" column_invisible="1"/></tree></field></record>
    <record id="view_helpdesk_ticket_kanban" model="ir.ui.view"><field name="name">it.helpdesk.ticket.kanban</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><kanban default_group_by="stage_id"><field name="is_overdue"/><templates><t t-name="kanban-box"><div class="oe_kanban_global_click"><strong><field name="name"/> - <field name="subject"/></strong><div class="text-muted"><field name="requester_id"/> - <field name="assigned_to"/></div><div t-if="record.is_overdue.raw_value" class="text-danger">SLA overdue</div></div></t></templates></kanban></field></record>
    <record id="view_helpdesk_ticket_form" model="ir.ui.view"><field name="name">it.helpdesk.ticket.form</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><form><header><field name="can_confirm" invisible="1"/><field name="can_assign_to_me" invisible="1"/><field name="can_set_pending_user" invisible="1"/><field name="can_edit_ticket" invisible="1"/><field name="can_edit_protected_fields" invisible="1"/><button name="action_confirm" type="object" string="Confirm" class="oe_highlight" groups="buz_it_helpdesk.group_it_helpdesk_requester" invisible="not can_confirm"/><button name="action_assign" type="object" string="Assign to Me" class="oe_highlight" groups="buz_it_helpdesk.group_it_helpdesk_agent" invisible="not can_assign_to_me"/><button name="action_pending_user" type="object" string="Pending User" groups="buz_it_helpdesk.group_it_helpdesk_agent" invisible="not can_set_pending_user"/><button name="action_resolve" type="object" string="Resolve" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><button name="action_close" type="object" string="Close" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><button name="action_reopen" type="object" string="Reopen" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><field name="stage_id" widget="statusbar" options="{'clickable': false}" readonly="not can_edit_protected_fields"/></header><sheet><div class="oe_title"><h1><field name="subject" placeholder="Describe the issue..." readonly="not can_edit_ticket"/></h1></div><group><group><field name="name"/><field name="requester_id" readonly="not can_edit_ticket"/><field name="department" readonly="not can_edit_protected_fields"/><field name="source" readonly="not can_edit_ticket"/></group><group><field name="assigned_to" readonly="not can_edit_ticket"/><field name="team_id" readonly="not can_edit_ticket"/><field name="assignee_ids" widget="many2many_tags" readonly="not can_edit_ticket"/><field name="category_id" readonly="not can_edit_ticket"/><field name="priority_id" readonly="not can_edit_ticket"/></group></group><notebook><page string="Details"><field name="description" readonly="not can_edit_ticket"/><field name="tag_ids" widget="many2many_tags" readonly="not can_edit_ticket"/></page><page string="SLA"><group><field name="sla_id"/><field name="response_deadline"/><field name="first_response_at"/><field name="is_response_overdue"/><field name="sla_deadline"/><field name="due_date" readonly="not can_edit_ticket"/><field name="is_overdue"/></group></page><page string="Organisation"><group><field name="company_id" readonly="not can_edit_ticket"/><field name="branch_id" readonly="not can_edit_ticket"/><field name="attachment_ids" widget="many2many_binary" readonly="not can_edit_ticket"/><field name="knowledge_article_ids" widget="many2many_tags" readonly="not can_edit_ticket"/><field name="suggested_article_ids" widget="many2many_tags" readonly="1"/></group></page></notebook></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div></form></field></record>
    <record id="view_helpdesk_ticket_search" model="ir.ui.view"><field name="name">it.helpdesk.ticket.search</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><search><field name="name"/><field name="subject"/><field name="requester_id"/><field name="assigned_to"/><field name="team_id"/><field name="assignee_ids" widget="many2many_tags"/><field name="category_id"/><filter name="my_tickets" string="My Tickets" domain="['|', ('requester_id', '=', uid), ('assigned_to', '=', uid)]"/><filter name="open" string="Open" domain="[('stage_id.is_closed', '=', False)]"/><filter name="overdue" string="SLA Overdue" domain="[('is_overdue', '=', True)]"/><filter name="response_overdue" string="Response SLA Overdue" domain="[('is_response_overdue', '=', True)]"/><group string="Group By"><filter name="stage" string="Stage" context="{'group_by': 'stage_id'}"/><filter name="priority" string="Priority" context="{'group_by': 'priority_id'}"/><filter name="category" string="Category" context="{'group_by': 'category_id'}"/></group></search></field></record>
    <record id="view_helpdesk_ticket_graph" model="ir.ui.view"><field name="name">it.helpdesk.ticket.graph</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><graph string="Helpdesk Dashboard" type="bar"><field name="stage_id" type="row"/><field name="priority_id" type="col"/><field name="company_id" invisible="1"/></graph></field></record>
    <record id="view_helpdesk_stage_list" model="ir.ui.view"><field name="name">it.helpdesk.stage.list</field><field name="model">it.helpdesk.stage</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence"/><field name="name"/><field name="fold"/><field name="is_closed"/></tree></field></record>
    <record id="view_helpdesk_category_list" model="ir.ui.view"><field name="name">it.helpdesk.category.list</field><field name="model">it.helpdesk.category</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence"/><field name="name"/><field name="active"/></tree></field></record>
    <record id="view_helpdesk_priority_list" model="ir.ui.view"><field name="name">it.helpdesk.priority.list</field><field name="model">it.helpdesk.priority</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence"/><field name="name" decoration-success="code == &quot;low&quot;" decoration-info="code == &quot;medium&quot;" decoration-warning="code == &quot;high&quot;" decoration-danger="code == &quot;critical&quot;"/><field name="code"/><field name="color" widget="color_picker"/></tree></field></record>
    <record id="view_helpdesk_sla_list" model="ir.ui.view"><field name="name">it.helpdesk.sla.list</field><field name="model">it.helpdesk.sla</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence"/><field name="name"/><field name="category_id"/><field name="priority_id"/><field name="response_hours"/><field name="resolution_hours"/><field name="company_id" column_invisible="1"/></tree></field></record>
    <record id="view_helpdesk_tag_list" model="ir.ui.view"><field name="name">it.helpdesk.tag.list</field><field name="model">it.helpdesk.tag</field><field name="arch" type="xml"><tree editable="bottom"><field name="name"/><field name="color"/></tree></field></record>
    <record id="view_helpdesk_article_list" model="ir.ui.view"><field name="name">it.helpdesk.article.list</field><field name="model">it.helpdesk.knowledge.article</field><field name="arch" type="xml"><tree><field name="name"/><field name="category_id"/><field name="state" widget="badge"/><field name="published_date"/><field name="usage_count"/><field name="company_id" column_invisible="1"/></tree></field></record>
    <record id="view_helpdesk_article_form" model="ir.ui.view"><field name="name">it.helpdesk.article.form</field><field name="model">it.helpdesk.knowledge.article</field><field name="arch" type="xml"><form><header><button name="action_create_ticket" type="object" string="Create Ticket" class="oe_highlight"/><button name="action_publish" type="object" string="Publish" class="oe_highlight" invisible="state == 'published'"/><button name="action_unpublish" type="object" string="Unpublish" invisible="state == 'draft'"/><field name="state" widget="statusbar"/></header><sheet><div class="oe_title"><h1><field name="name"/></h1></div><group><field name="category_id"/><field name="tag_ids" widget="many2many_tags"/><field name="company_id"/></group><field name="content"/></sheet></form></field></record>
    <record id="view_helpdesk_ticket_dashboard_kanban" model="ir.ui.view">
        <field name="name">it.helpdesk.ticket.dashboard.kanban</field>
        <field name="model">it.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" default_order="priority_id desc, create_date desc" class="o_kanban_small_column">
                <field name="name"/>
                <field name="subject"/>
                <field name="requester_id"/>
                <field name="assigned_to"/>
                <field name="category_id"/>
                <field name="priority_id"/>
                <field name="priority_code"/>
                <field name="stage_id"/>
                <field name="response_deadline"/>
                <field name="first_response_at"/>
                <field name="is_response_overdue"/>
                <field name="sla_deadline"/>
                <field name="is_overdue"/><field name="company_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong class="text-primary"><field name="name"/></strong>
                                <field name="priority_id" widget="badge" decoration-success="priority_code == 'low'" decoration-info="priority_code == 'medium'" decoration-warning="priority_code == 'high'" decoration-danger="priority_code == 'critical'"/>
                            </div>
                            <div class="fw-bold mb-2"><field name="subject"/></div>
                            <div class="text-muted mb-1">
                                <i class="fa fa-user me-1" title="Requester"/>
                                <field name="requester_id"/>
                            </div>
                            <div class="text-muted mb-1">
                                <i class="fa fa-tag me-1" title="Category"/>
                                <field name="category_id"/>
                            </div>
                            <div class="text-muted">
                                <i class="fa fa-user-circle me-1" title="Assigned To"/>
                                <field name="assigned_to" placeholder="Unassigned"/>
                            </div>
                            <div class="mt-2 pt-2 border-top">
                                <span t-if="record.response_deadline.value" class="text-muted d-block">
                                    <i class="fa fa-clock-o me-1" title="Response SLA Deadline"/>
                                    Response: <field name="response_deadline"/>
                                </span>
                                <span t-if="record.is_response_overdue.raw_value" class="text-warning d-block">
                                    <i class="fa fa-exclamation-triangle me-1"/> Response SLA overdue
                                </span>
                                <span t-if="record.sla_deadline.value" class="text-muted">
                                    <i class="fa fa-clock-o me-1" title="SLA Deadline"/>
                                    <field name="sla_deadline"/>
                                </span>
                                <span t-if="record.is_overdue.raw_value" class="text-danger float-end">
                                    <i class="fa fa-exclamation-triangle me-1"/> SLA overdue
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_helpdesk_dashboard" model="ir.actions.act_window"><field name="name">Dashboard</field><field name="res_model">it.helpdesk.ticket</field><field name="view_mode">kanban,graph,tree,form</field><field name="view_id" ref="view_helpdesk_ticket_dashboard_kanban"/><field name="search_view_id" ref="view_helpdesk_ticket_search"/><field name="context">{'search_default_open': 1, 'create': False, 'edit': False, 'delete': False}</field></record>
    <record id="action_helpdesk_tickets" model="ir.actions.act_window"><field name="name">Tickets</field><field name="res_model">it.helpdesk.ticket</field><field name="view_mode">kanban,tree,form,graph,pivot</field><field name="search_view_id" ref="view_helpdesk_ticket_search"/></record>
    <record id="action_helpdesk_my_tickets" model="ir.actions.act_window"><field name="name">My Tickets</field><field name="res_model">it.helpdesk.ticket</field><field name="view_mode">tree,form,kanban</field><field name="view_id" ref="view_helpdesk_ticket_list"/><field name="search_view_id" ref="view_helpdesk_ticket_search"/><field name="context">{'search_default_my_tickets': 1}</field></record>
    <record id="action_helpdesk_stages" model="ir.actions.act_window"><field name="name">Stages</field><field name="res_model">it.helpdesk.stage</field><field name="view_mode">tree,form</field></record>
    <record id="action_helpdesk_categories" model="ir.actions.act_window"><field name="name">Categories</field><field name="res_model">it.helpdesk.category</field><field name="view_mode">tree,form</field></record>
    <record id="action_helpdesk_priorities" model="ir.actions.act_window"><field name="name">Priorities</field><field name="res_model">it.helpdesk.priority</field><field name="view_mode">tree,form</field></record>
    <record id="action_helpdesk_slas" model="ir.actions.act_window"><field name="name">SLA</field><field name="res_model">it.helpdesk.sla</field><field name="view_mode">tree,form</field></record>
    <record id="action_helpdesk_articles" model="ir.actions.act_window"><field name="name">Knowledge Base</field><field name="res_model">it.helpdesk.knowledge.article</field><field name="view_mode">tree,form</field></record>
    <record id="action_helpdesk_tags" model="ir.actions.act_window"><field name="name">Tags</field><field name="res_model">it.helpdesk.tag</field><field name="view_mode">tree,form</field></record>
</odoo>
