    <record id="view_helpdesk_ticket_form" model="ir.ui.view"><field name="name">it.helpdesk.ticket.form</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><form><header><button name="action_assign" type="object" string="Assign to Me" class="oe_highlight" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><button name="action_resolve" type="object" string="Resolve" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><button name="action_close" type="object" string="Close" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><button name="action_reopen" type="object" string="Reopen" groups="buz_it_helpdesk.group_it_helpdesk_agent"/><field name="stage_id" widget="statusbar" options="{'clickable': true}"/></header><sheet><div class="oe_title"><h1><field name="subject" placeholder="Describe the issue..."/></h1></div><group><group><field name="name"/><field name="requester_id"/><field name="department"/><field name="source"/></group><group><field name="assigned_to"/><field name="category_id"/><field name="priority_id"/><field name="stage_id"/></group></group><notebook><page string="Details"><field name="description"/><field name="tag_ids" widget="many2many_tags"/></page><page string="SLA"><group><field name="sla_id"/><field name="sla_deadline"/><field name="due_date"/><field name="is_overdue"/></group></page><page string="Organisation"><group><field name="company_id"/><field name="branch_id"/><field name="follower_ids" widget="many2many_tags"/></group></page></notebook></sheet><div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div></form></field></record>
    <record id="view_helpdesk_ticket_search" model="ir.ui.view"><field name="name">it.helpdesk.ticket.search</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><search><field name="name"/><field name="subject"/><field name="requester_id"/><field name="assigned_to"/><field name="category_id"/><filter name="my_tickets" string="My Tickets" domain="['|', ('requester_id', '=', uid), ('assigned_to', '=', uid)]"/><filter name="open" string="Open" domain="[('stage_id.is_closed', '=', False)]"/><filter name="overdue" string="SLA Overdue" domain="[('is_overdue', '=', True)]"/><group string="Group By"><filter name="stage" string="Stage" context="{'group_by': 'stage_id'}"/><filter name="priority" string="Priority" context="{'group_by': 'priority_id'}"/><filter name="category" string="Category" context="{'group_by': 'category_id'}"/></group></search></field></record>
    <record id="view_helpdesk_ticket_graph" model="ir.ui.view"><field name="name">it.helpdesk.ticket.graph</field><field name="model">it.helpdesk.ticket</field><field name="arch" type="xml"><graph string="Helpdesk Dashboard" type="bar"><field name="stage_id" type="row"/><field name="priority_id" type="col"/></graph></field></record>
