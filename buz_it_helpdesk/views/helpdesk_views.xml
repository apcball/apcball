    <record id="view_helpdesk_priority_list" model="ir.ui.view"><field name="name">it.helpdesk.priority.list</field><field name="model">it.helpdesk.priority</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence"/><field name="name" decoration-success="code == &quot;low&quot;" decoration-info="code == &quot;medium&quot;" decoration-warning="code == &quot;high&quot;" decoration-danger="code == &quot;critical&quot;"/><field name="code"/><field name="color" widget="color_picker"/></tree></field></record>
    <record id="view_helpdesk_sla_list" model="ir.ui.view"><field name="name">it.helpdesk.sla.list</field><field name="model">it.helpdesk.sla</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence"/><field name="name"/><field name="category_id"/><field name="priority_id"/><field name="response_hours"/><field name="resolution_hours"/></tree></field></record>
    <record id="view_helpdesk_tag_list" model="ir.ui.view"><field name="name">it.helpdesk.tag.list</field><field name="model">it.helpdesk.tag</field><field name="arch" type="xml"><tree editable="bottom"><field name="name"/><field name="color"/></tree></field></record>
    <record id="view_helpdesk_article_list" model="ir.ui.view"><field name="name">it.helpdesk.article.list</field><field name="model">it.helpdesk.knowledge.article</field><field name="arch" type="xml"><tree><field name="name"/><field name="category_id"/><field name="state" widget="badge"/><field name="published_date"/></tree></field></record>
    <record id="view_helpdesk_article_form" model="ir.ui.view"><field name="name">it.helpdesk.article.form</field><field name="model">it.helpdesk.knowledge.article</field><field name="arch" type="xml"><form><header><button name="action_publish" type="object" string="Publish" class="oe_highlight" invisible="state == 'published'"/><button name="action_unpublish" type="object" string="Unpublish" invisible="state == 'draft'"/><field name="state" widget="statusbar"/></header><sheet><div class="oe_title"><h1><field name="name"/></h1></div><group><field name="category_id"/><field name="tag_ids" widget="many2many_tags"/><field name="company_id"/></group><field name="content"/></sheet></form></field></record>
