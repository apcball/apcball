<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buz_it_asset_list" model="ir.ui.view">
        <field name="name">buz.it.asset.list</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'available'" decoration-info="status == 'in_use'" decoration-warning="status == 'repair'" decoration-danger="status in ('lost', 'retired')">
                <field name="name" string="Asset Number"/>
                <field name="asset_type" widget="badge"/><field name="asset_name" string="Asset Name" invisible="asset_type == 'printer'"/>
                <field name="assigned_user_id" string="Responsible User"/>
                <field name="user_nickname" string="Nickname" invisible="asset_type == 'printer'"/>
                <field name="computer_username" string="User Name" invisible="asset_type == 'printer'"/>
                <field name="category_id" string="Equipment Type" invisible="asset_type != 'computer'" required="asset_type == 'computer'"/>
                <field name="status" string="Usage Status" widget="badge"/>
                <field name="brand" string="Brand" invisible="asset_type not in ('computer', 'printer')"/>
                <field name="model_name" string="Series" invisible="asset_type not in ('computer', 'printer')"/>
                <field name="model_code" string="Model" invisible="asset_type not in ('computer', 'printer')"/>
                <field name="software_ids" widget="many2many_tags"/>
                <field name="company_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_buz_it_asset_kanban" model="ir.ui.view">
        <field name="name">buz.it.asset.kanban</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/><field name="asset_type"/><field name="asset_name" invisible="asset_type == 'printer'"/><field name="assigned_user_id"/><field name="user_nickname"/><field name="computer_username"/><field name="category_id"/><field name="status"/>
                <templates><t t-name="kanban-box"><div class="oe_kanban_global_click"><strong><field name="name"/> - <field name="asset_name" invisible="asset_type == 'printer'"/></strong><div class="text-muted"><field name="category_id"/> | <field name="assigned_user_id"/></div><div><field name="status" widget="badge"/></div></div></t></templates>
            </kanban>
        </field>
    </record>

    <record id="view_buz_it_asset_form" model="ir.ui.view">
        <field name="name">buz.it.asset.form</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <form string="IT Asset"><header><button name="action_set_under_repair" type="object" string="Under Repair" class="btn-warning" invisible="status == 'repair'"/><button name="action_set_damaged" type="object" string="Lost" class="btn-danger" invisible="status == 'lost'"/><button name="action_set_retired" type="object" string="Retired" class="btn-secondary" invisible="status == 'retired'"/></header>
                <sheet>
                    <field name="status" invisible="1"/><field name="company_id" invisible="1"/>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" text="Available" bg_color="text-bg-success" invisible="status != 'available'"/>
                    <widget name="web_ribbon" text="In Use" bg_color="text-bg-success" invisible="status != 'in_use'"/>
                    <widget name="web_ribbon" text="Under Repair" bg_color="text-bg-warning" invisible="status != 'repair'"/>
                    <widget name="web_ribbon" text="Lost" bg_color="text-bg-danger" invisible="status != 'lost'"/>
                    <widget name="web_ribbon" text="Retired" bg_color="text-bg-secondary" invisible="status != 'retired'"/>
                    <div class="oe_title" invisible="asset_type == 'printer'"><label for="asset_name"/><h1><field name="asset_name" placeholder="e.g. FIN-PC-001" required="asset_type != 'printer'"/></h1></div>
                    <group>
                        <group>
                            <field name="asset_type" string="Type" readonly="1"/><field name="name" string="Asset Number" readonly="1" invisible="asset_type == 'printer'"/>
                            <field name="assigned_user_id" string="Responsible User" domain="[('share', '=', False)]"/>
                            <field name="user_nickname" string="Nickname" invisible="asset_type == 'printer'"/>
                            <field name="computer_username" string="User Name" invisible="asset_type == 'printer'"/>
                            <field name="service_name" invisible="asset_type not in ('email', 'system_account')"/>
                            <field name="account_username" invisible="asset_type not in ('email', 'system_account')"/>
                            <field name="account_email" invisible="asset_type != 'email'"/>
                            <field name="account_url" invisible="asset_type not in ('email', 'system_account')"/>
                            <field name="license_product" invisible="asset_type != 'software_license'"/>
                            <field name="license_key" widget="password" groups="buz_it_helpdesk.group_it_helpdesk_manager" invisible="asset_type != 'software_license'"/>
                            <field name="license_expiry_date" invisible="asset_type != 'software_license'"/>
                            <field name="license_seats" invisible="asset_type != 'software_license'"/>
                            <field name="password" widget="password" groups="buz_it_helpdesk.group_it_helpdesk_manager" invisible="asset_type not in ('email', 'system_account')"/>
                            <field name="software_ids" string="Installed Software" widget="many2many_tags" invisible="asset_type != 'computer'"/>
                        </group>
                        <group>
                            <field name="image_1920" string="Asset Image" widget="image" options="{'preview_image': 'image_1920', 'zoom': true, 'zoom_delay': 0, 'size': [90, 90]}"/>
                            <field name="brand" string="Brand" invisible="asset_type not in ('computer', 'printer')"/>
                            <field name="model_name" string="Series" invisible="asset_type not in ('computer', 'printer')"/>
                            <field name="model_code" string="Model" invisible="asset_type not in ('computer', 'printer')"/>
                            <field name="category_id" string="Equipment Type" invisible="asset_type != 'computer'" required="asset_type == 'computer'"/>

                        </group>
                    </group>
                    <group string="Computer Specifications" col="1" invisible="asset_type != 'computer'">
                        <field name="spec_line_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="company_id" column_invisible="1"/>
                                <field name="sequence" widget="handle"/>
                                <field name="category_id"/>
                                <field name="value" placeholder="e.g. Intel Core i7, 32 GB, RTX 4060, 1 TB NVMe"/>
                            </tree>
                        </field>
                    </group>
                    <group string="Files &amp; Images" col="1" invisible="asset_type == 'printer'">
                        <field name="attachment_ids" widget="helpdesk_attachment_preview" nolabel="1"/>
                    </group>
                    <group string="Note" invisible="asset_type == 'printer'"><field name="notes" placeholder="Internal note..." nolabel="1"/></group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_buz_it_asset_search" model="ir.ui.view">
        <field name="name">buz.it.asset.search</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="asset_type"/><field name="name"/><field name="asset_name"/><field name="assigned_user_id"/><field name="user_nickname"/><field name="computer_username"/><field name="category_id"/><field name="brand"/><field name="model_code"/><field name="spec_line_ids" string="Specifications" filter_domain="['|', ('spec_line_ids.category_id.name', 'ilike', self), ('spec_line_ids.value', 'ilike', self)]"/><field name="software_ids"/><field name="status"/>
                <separator/>
                <filter name="available" string="Available" domain="[('status', '=', 'available')]"/>
                <filter name="in_use" string="In Use" domain="[('status', '=', 'in_use')]"/>
                <filter name="under_repair" string="Under Repair" domain="[('status', '=', 'repair')]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By"><filter name="group_status" string="Usage Status" context="{'group_by': 'status'}"/><filter name="group_asset_type" string="Asset Type" context="{'group_by': 'asset_type'}"/><filter name="group_type" string="Equipment Type" context="{'group_by': 'category_id'}"/><filter name="group_user" string="User" context="{'group_by': 'assigned_user_id'}"/></group>
            </search>
        </field>
    </record>

        <record id="action_buz_it_assets" model="ir.actions.act_window"><field name="name">All Hardware</field><field name="res_model">buz.it.asset</field><field name="view_mode">kanban,tree,form</field><field name="domain">[('asset_type', 'in', ('computer', 'printer'))]</field><field name="context">{'default_asset_type': 'computer', 'create': False}</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_asset_computers" model="ir.actions.act_window"><field name="name">Computers</field><field name="res_model">buz.it.asset</field><field name="view_mode">kanban,tree,form</field><field name="domain">[('asset_type', '=', 'computer')]</field><field name="context">{'default_asset_type': 'computer'}</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_asset_printers" model="ir.actions.act_window"><field name="name">Printers</field><field name="res_model">buz.it.asset</field><field name="view_mode">kanban,tree,form</field><field name="domain">[('asset_type', '=', 'printer')]</field><field name="context">{'default_asset_type': 'printer'}</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_asset_software_licenses" model="ir.actions.act_window"><field name="name">Software Licenses</field><field name="res_model">buz.it.asset</field><field name="view_mode">tree,form</field><field name="domain">[('asset_type', '=', 'software_license')]</field><field name="context">{'default_asset_type': 'software_license'}</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_asset_email_accounts" model="ir.actions.act_window"><field name="name">Email Accounts</field><field name="res_model">buz.it.asset</field><field name="view_mode">tree,form</field><field name="domain">[('asset_type', '=', 'email')]</field><field name="context">{'default_asset_type': 'email'}</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_asset_system_accounts" model="ir.actions.act_window"><field name="name">System Accounts</field><field name="res_model">buz.it.asset</field><field name="view_mode">tree,form</field><field name="domain">[('asset_type', '=', 'system_account')]</field><field name="context">{'default_asset_type': 'system_account'}</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_my_assets" model="ir.actions.act_window"><field name="name">My Assets</field><field name="res_model">buz.it.asset</field><field name="view_mode">tree,form</field><field name="domain">[('assigned_user_id', '=', uid)]</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>

    <record id="view_buz_it_asset_category_list" model="ir.ui.view"><field name="name">buz.it.asset.category.list</field><field name="model">buz.it.asset.category</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence" widget="handle"/><field name="name"/><field name="company_id"/><field name="active"/></tree></field></record>
    <record id="view_buz_it_asset_category_form" model="ir.ui.view"><field name="name">buz.it.asset.category.form</field><field name="model">buz.it.asset.category</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="sequence"/><field name="company_id"/><field name="active"/></group><field name="description"/></sheet></form></field></record>
    <record id="action_buz_it_asset_categories" model="ir.actions.act_window"><field name="name">Asset Categories</field><field name="res_model">buz.it.asset.category</field><field name="view_mode">tree,form</field></record>

    <record id="view_buz_it_asset_spec_category_list" model="ir.ui.view"><field name="name">buz.it.asset.spec.category.list</field><field name="model">buz.it.asset.spec.category</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence" widget="handle"/><field name="name"/><field name="company_id"/><field name="active"/></tree></field></record>
    <record id="action_buz_it_asset_spec_categories" model="ir.actions.act_window"><field name="name">Computer Specification Categories</field><field name="res_model">buz.it.asset.spec.category</field><field name="view_mode">tree,form</field></record>
    <record id="view_buz_it_asset_software_list" model="ir.ui.view"><field name="name">buz.it.asset.software.list</field><field name="model">buz.it.asset.software</field><field name="arch" type="xml"><tree editable="bottom"><field name="name"/><field name="version"/><field name="company_id"/><field name="active"/></tree></field></record>
    <record id="action_buz_it_asset_software" model="ir.actions.act_window"><field name="name">Installed Software</field><field name="res_model">buz.it.asset.software</field><field name="view_mode">tree,form</field></record>
</odoo>