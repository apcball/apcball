<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buz_it_asset_list" model="ir.ui.view">
        <field name="name">buz.it.asset.list</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'available'" decoration-info="status == 'in_use'" decoration-warning="status == 'repair'" decoration-danger="status in ('lost', 'retired')">
                <field name="name" string="Asset Number"/>
                <field name="asset_name" string="Computer Name"/>
                <field name="assigned_user_id" string="User"/>
                <field name="user_nickname" string="Nickname"/>
                <field name="computer_username" string="User Name"/>
                <field name="category_id" string="Equipment Type"/>
                <field name="status" string="Usage Status" widget="badge"/>
                <field name="brand"/>
                <field name="model_name" string="Series"/>
                <field name="model_code" string="Model"/>
                <field name="software_ids" widget="many2many_tags"/>
                <field name="company_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_buz_it_asset_kanban" model="ir.ui.view">
        <field name="name">buz.it.asset.kanban</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/><field name="asset_name"/><field name="assigned_user_id"/><field name="user_nickname"/><field name="computer_username"/><field name="category_id"/><field name="status"/>
                <templates><t t-name="kanban-box"><div class="oe_kanban_global_click"><strong><field name="name"/> - <field name="asset_name"/></strong><div class="text-muted"><field name="category_id"/> | <field name="assigned_user_id"/></div><div><field name="status" widget="badge"/></div></div></t></templates>
            </kanban>
        </field>
    </record>

    <record id="view_buz_it_asset_form" model="ir.ui.view">
        <field name="name">buz.it.asset.form</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <form string="IT Asset">
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title"><label for="asset_name"/><h1><field name="asset_name" placeholder="e.g. FIN-PC-001"/></h1></div>
                    <group>
                        <group>
                            <field name="name" string="Asset Number" readonly="1"/>
                            <field name="assigned_user_id" string="User" domain="[('share', '=', False)]"/>
                            <field name="user_nickname" string="Nickname"/>
                            <field name="computer_username" string="User Name"/>
                            <field name="password" widget="password" groups="buz_it_helpdesk.group_it_helpdesk_agent,buz_it_helpdesk.group_it_helpdesk_manager"/>
                            <field name="software_ids" string="Installed Software" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920', 'zoom': true, 'zoom_delay': 0}"/>
                            <field name="brand"/>
                            <field name="model_name" string="Series"/>
                            <field name="model_code" string="Model"/>
                            <field name="category_id" string="Equipment Type"/>
                            <field name="status" string="Usage Status"/>
                        </group>
                    </group>
                    <group string="Computer Specifications" col="1">
                        <field name="spec_line_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="company_id" column_invisible="1"/>
                                <field name="sequence" widget="handle"/>
                                <field name="category_id"/>
                                <field name="value" placeholder="e.g. Intel Core i7, 32 GB, RTX 4060, 1 TB NVMe"/>
                            </tree>
                        </field>
                    </group>
                    <group string="Files &amp; Images" col="1">
                        <field name="attachment_ids" widget="helpdesk_attachment_preview" nolabel="1"/>
                    </group>
                    <group string="Note"><field name="notes" placeholder="Internal note..." nolabel="1"/></group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_buz_it_asset_search" model="ir.ui.view">
        <field name="name">buz.it.asset.search</field>
        <field name="model">buz.it.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/><field name="asset_name"/><field name="assigned_user_id"/><field name="user_nickname"/><field name="computer_username"/><field name="category_id"/><field name="brand"/><field name="model_code"/><field name="spec_line_ids" string="Specifications" filter_domain="['|', ('spec_line_ids.category_id.name', 'ilike', self), ('spec_line_ids.value', 'ilike', self)]"/><field name="software_ids"/><field name="status"/>
                <separator/>
                <filter name="available" string="Available" domain="[('status', '=', 'available')]"/>
                <filter name="in_use" string="In Use" domain="[('status', '=', 'in_use')]"/>
                <filter name="under_repair" string="Under Repair" domain="[('status', '=', 'repair')]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By"><filter name="group_status" string="Usage Status" context="{'group_by': 'status'}"/><filter name="group_type" string="Equipment Type" context="{'group_by': 'category_id'}"/><filter name="group_user" string="User" context="{'group_by': 'assigned_user_id'}"/></group>
            </search>
        </field>
    </record>

    <record id="action_buz_it_assets" model="ir.actions.act_window"><field name="name">All Assets</field><field name="res_model">buz.it.asset</field><field name="view_mode">kanban,tree,form</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>
    <record id="action_buz_it_my_assets" model="ir.actions.act_window"><field name="name">My Assets</field><field name="res_model">buz.it.asset</field><field name="view_mode">tree,form</field><field name="domain">[('assigned_user_id', '=', uid)]</field><field name="search_view_id" ref="view_buz_it_asset_search"/></record>

    <record id="view_buz_it_asset_category_list" model="ir.ui.view"><field name="name">buz.it.asset.category.list</field><field name="model">buz.it.asset.category</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence" widget="handle"/><field name="name"/><field name="company_id"/><field name="active"/></tree></field></record>
    <record id="view_buz_it_asset_category_form" model="ir.ui.view"><field name="name">buz.it.asset.category.form</field><field name="model">buz.it.asset.category</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="sequence"/><field name="company_id"/><field name="active"/></group><field name="description"/></sheet></form></field></record>
    <record id="action_buz_it_asset_categories" model="ir.actions.act_window"><field name="name">Asset Categories</field><field name="res_model">buz.it.asset.category</field><field name="view_mode">tree,form</field></record>

    <record id="view_buz_it_asset_spec_category_list" model="ir.ui.view"><field name="name">buz.it.asset.spec.category.list</field><field name="model">buz.it.asset.spec.category</field><field name="arch" type="xml"><tree editable="bottom"><field name="sequence" widget="handle"/><field name="name"/><field name="company_id"/><field name="active"/></tree></field></record>
    <record id="action_buz_it_asset_spec_categories" model="ir.actions.act_window"><field name="name">Computer Specification Categories</field><field name="res_model">buz.it.asset.spec.category</field><field name="view_mode">tree,form</field></record>
    <record id="view_buz_it_asset_software_list" model="ir.ui.view"><field name="name">buz.it.asset.software.list</field><field name="model">buz.it.asset.software</field><field name="arch" type="xml"><tree editable="bottom"><field name="name"/><field name="version"/><field name="company_id"/><field name="active"/></tree></field></record>
    <record id="action_buz_it_asset_software" model="ir.actions.act_window"><field name="name">Installed Software</field><field name="res_model">buz.it.asset.software</field><field name="view_mode">tree,form</field></record>
</odoo>