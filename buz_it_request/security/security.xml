<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_it_request" model="ir.module.category">
            <field name="name">IT Request</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_it_request_user" model="res.groups">
            <field name="name">IT Request User</field>
            <field name="category_id" ref="module_category_it_request"/>
        </record>

        <record id="group_it_request_officer" model="res.groups">
            <field name="name">IT Request Officer</field>
            <field name="category_id" ref="module_category_it_request"/>
            <field name="implied_ids" eval="[(4, ref('group_it_request_user'))]"/>
        </record>

        <record id="group_it_request_manager" model="res.groups">
            <field name="name">IT Request Manager</field>
            <field name="category_id" ref="module_category_it_request"/>
            <field name="implied_ids" eval="[(4, ref('group_it_request_officer'))]"/>
        </record>

        <record id="rule_it_request_user" model="ir.rule">
            <field name="name">IT Request: user sees own</field>
            <field name="model_id" ref="model_it_request"/>
            <field name="domain_force">[('requester_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_it_request_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_it_request_officer" model="ir.rule">
            <field name="name">IT Request: officer sees all</field>
            <field name="model_id" ref="model_it_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_request_officer'))]"/>
        </record>
    </data>
</odoo>
