<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard Kanban View -->
    <record id="view_it_dashboard_kanban" model="ir.ui.view">
        <field name="name">it.dashboard.kanban</field>
        <field name="model">it.ticket.issue</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard o_salesteam_dashboard">
                <field name="name"/>
                <field name="state"/>
                <field name="priority"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_td_label">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="progress" title="Overall completion">
                                    <div class="progress-bar" 
                                         role="progressbar" 
                                         t-att-style="'width: ' + (Math.round(100 * (kanban_getcolor(record.priority.raw_value)) / 4) || 0) + '%;'"
                                         t-att-aria-valuenow="kanban_getcolor(record.priority.raw_value)"
                                         aria-valuemin="0" 
                                         aria-valuemax="4">
                                    </div>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection" 
                                           options="{'classes': {'draft': 'default', 'triage': 'info', 'in_progress': 'warning', 'done': 'success', 'cancel': 'danger'}}"/>
                                </div>
                                <div t-if="record.priority.raw_value" class="oe_kanban_bottom_left">
                                    <span class="fa fa-lg"
                                          t-attf-class="'fa-arrow-circle-down ' + (record.priority.raw_value == '0' ? 'oe_kanban_text_red' : record.priority.raw_value == '1' ? 'oe_kanban_text_blue' : record.priority.raw_value == '2' ? 'oe_kanban_text_orange' : 'oe_kanban_text_red')"
                                          title="Priority"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>