<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         TREE
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_tree" model="ir.ui.view">
        <field name="name">it.request.tree</field>
        <field name="model">it.request</field>
        <field name="arch" type="xml">
            <tree decoration-danger="priority == 'critical' and state not in ('done','cancel')"
                  decoration-info="priority == 'high' and state not in ('done','cancel')"
                  decoration-warning="sla_state == 'at_risk'"
                  decoration-muted="state in ('done','cancel')">
                <field name="name"/>
                <field name="subject"/>
                <field name="category_id" optional="show"/>
                <field name="request_type" widget="badge" optional="show"/>
                <field name="priority" widget="priority" optional="show"/>
                <field name="impact" optional="hide"/>
                <field name="urgency" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"
                       decoration-warning="state == 'waiting'"/>
                <field name="sla_state" widget="badge"
                       decoration-success="sla_state == 'on_track'"
                       decoration-warning="sla_state == 'at_risk'"
                       decoration-danger="sla_state == 'breached'"
                       optional="show"/>
                <field name="sla_deadline" optional="show" readonly="state in ('done', 'cancel')"/>
                <field name="requester_id" optional="show"/>
                <field name="assigned_to_id" widget="many2one_avatar_user" optional="show"/>
                <field name="department_id" optional="hide"/>
                <field name="team_id" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         FORM
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_form" model="ir.ui.view">
        <field name="name">it.request.form</field>
        <field name="model">it.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_assign_to_me" type="object" string="Assign to Me"
                            invisible="state not in ('submitted','in_progress')"
                            groups="buz_it_request.group_it_request_officer"/>
                    <button name="action_in_progress" type="object" string="Start Progress"
                            invisible="state not in ('submitted','waiting')"
                            groups="buz_it_request.group_it_request_officer"/>
                    <button name="action_waiting" type="object" string="Awaiting Info"
                            invisible="state != 'in_progress'"
                            groups="buz_it_request.group_it_request_officer"/>
                    <button name="action_done" type="object" string="Mark Done"
                            class="btn-primary"
                            invisible="state not in ('in_progress','waiting')"
                            groups="buz_it_request.group_it_request_officer"/>
                    <button name="action_cancel" type="object" string="Cancel Request"
                            invisible="state not in ('draft','submitted','in_progress','waiting')"/>
                    <button name="action_draft" type="object" string="Reopen"
                            invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,in_progress,waiting,done"
                           clickable="True"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <field name="active" invisible="1"/>

                    <!-- ── Title ─────────────────────────────────── -->
                    <div class="oe_title o_it_request_form_title">
                        <label for="name" string="Reference" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Auto-generated"/></h1>
                        <div class="o_it_form_meta">
                            <field name="priority" widget="priority"/>
                            <span class="o_it_form_meta_state">
                                <field name="kanban_state" widget="kanban_state_selection"/>
                            </span>
                        </div>
                        <h3 class="o_it_form_subject">
                            <field name="subject" placeholder="Summarise the request"/>
                        </h3>
                    </div>

                    <!-- ── SLA / Blocked alerts ──────────────────── -->
                    <div class="alert alert-danger o_it_form_alert" role="alert"
                         invisible="kanban_state != 'blocked'">
                        <i class="fa fa-exclamation-triangle me-2" title="Blocked"/>
                        <strong>This request is currently blocked and needs attention.</strong>
                    </div>
                    <div class="alert alert-warning o_it_form_alert" role="alert"
                         invisible="sla_state == 'breached'">
                        <i class="fa fa-clock-o me-2" title="SLA"/>
                        <strong>SLA has been breached!</strong>
                    </div>
                    <div class="alert alert-info o_it_form_alert" role="alert"
                         invisible="sla_state != 'at_risk'">
                        <i class="fa fa-clock-o me-2" title="SLA"/>
                        <strong>SLA is at risk — deadline approaching.</strong>
                    </div>

                    <!-- ── Main content ──────────────────────────── -->
                    <group>
                        <group string="Requester Information">
                            <field name="requester_id"
                                   options="{'no_create': True}"
                                   context="{'default_employee_type': 'employee'}"/>
                            <field name="department_id" options="{'no_create': True}"/>
                            <field name="work_location_id" options="{'no_create': True}"/>
                            <field name="requester_phone" readonly="1"/>
                            <field name="requester_email" readonly="1"/>
                        </group>
                        <group string="Ticket Information">
                            <field name="category_id" options="{'no_create': True}"/>
                            <field name="sub_category_id"
                                   options="{'no_create': True}"
                                   domain="[('category_id', '=', category_id)]"/>
                            <field name="request_type"/>
                            <field name="module_name"
                                   placeholder="e.g. buz_sale, buz_accounting"/>
                            <field name="impact"/>
                            <field name="urgency"/>
                        </group>
                    </group>

                    <group>
                        <group string="Assignment">
                            <field name="team_id" options="{'no_create': True}"/>
                            <field name="assigned_to_id" widget="many2one_avatar_user"
                                   options="{'no_create': True}"
                                   domain="[('share', '=', False)]"/>
                        </group>
                        <group string="Dates &amp; SLA">
                            <field name="create_date" readonly="1"/>
                            <field name="response_date" readonly="1"/>
                            <field name="sla_deadline" readonly="state in ('done', 'cancel')"/>
                            <field name="sla_state" widget="badge"
                                   decoration-success="sla_state == 'on_track'"
                                   decoration-warning="sla_state == 'at_risk'"
                                   decoration-danger="sla_state == 'breached'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"
                                   placeholder="Describe the problem or feature request in detail..."/>
                        </page>
                        <page string="Attachments">
                            <field name="image_ids" nolabel="1">
                                <tree editable="bottom" string="Images">
                                    <field name="image" widget="image" class="oe_avatar_small"/>
                                    <field name="name" placeholder="Description"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="image" widget="image"/>
                                        <field name="name"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Resolution"
                              invisible="state not in ('done','cancel','in_progress','waiting')">
                            <group>
                                <group>
                                    <field name="resolution_notes"
                                           placeholder="Describe how the issue was resolved..."/>
                                </group>
                                <group>
                                    <field name="close_date" readonly="1"/>
                                    <field name="resolution_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         KANBAN
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_kanban" model="ir.ui.view">
        <field name="name">it.request.kanban</field>
        <field name="model">it.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile o_it_request_kanban_view">
                <field name="color"/>
                <field name="name"/>
                <field name="subject"/>
                <field name="request_type"/>
                <field name="priority"/>
                <field name="urgency"/>
                <field name="impact"/>
                <field name="sla_state"/>
                <field name="kanban_state"/>
                <field name="assigned_to_id"/>
                <field name="create_date"/>
                <field name="description"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="o_it_request_card oe_kanban_global_click oe_kanban_card
                                o_it_request_card_type_#{record.request_type.raw_value}
                                o_it_request_state_#{record.kanban_state.raw_value}"
                             t-att-data-priority="record.priority.raw_value">

                            <!-- 1 · Header: type tag (L) + kanban state (R) -->
                            <div class="o_it_request_card_top">
                                <span class="o_it_request_type">
                                    <t t-if="record.request_type.raw_value === 'problem'">
                                        <i class="fa fa-exclamation-triangle"/>
                                    </t>
                                    <t t-elif="record.request_type.raw_value === 'feature_request'">
                                        <i class="fa fa-plus-circle"/>
                                    </t>
                                    <t t-elif="record.request_type.raw_value === 'it_equipment_purchase'">
                                        <i class="fa fa-shopping-cart"/>
                                    </t>
                                    <t t-elif="record.request_type.raw_value === 'it_equipment_repair'">
                                        <i class="fa fa-wrench"/>
                                    </t>
                                    <span class="o_it_request_type_label"><field name="request_type"/></span>
                                </span>
                                <div class="o_it_request_card_tools">
                                    <field name="kanban_state" widget="kanban_state_selection"/>
                                </div>
                            </div>

                            <!-- 2 · Subject (hero) -->
                            <div class="o_it_request_subject">
                                <field name="subject"/>
                            </div>

                            <!-- 3 · Description (optional) -->
                            <div class="o_it_request_desc" t-if="record.description.raw_value">
                                <field name="description"/>
                            </div>

                            <!-- 4 · Meta: ref + date + urgency/impact (L), SLA badge (R) -->
                            <div class="o_it_request_meta">
                                <span class="o_it_request_meta_ref">
                                    <field name="name"/>
                                    <span class="o_it_request_meta_dot">·</span>
                                    <i class="fa fa-calendar-o"/>
                                    <field name="create_date" widget="date"/>
                                    <span class="o_it_request_meta_dot">·</span>
                                    <span t-attf-class="o_it_request_urgency o_it_request_urgency_#{record.urgency.raw_value}"
                                          t-att-title="record.urgency.raw_value">
                                        <span class="o_it_request_dim">U:</span>
                                        <t t-if="record.urgency.raw_value === 'low'">L</t>
                                        <t t-elif="record.urgency.raw_value === 'medium'">M</t>
                                        <t t-elif="record.urgency.raw_value === 'high'">H</t>
                                        <t t-elif="record.urgency.raw_value === 'urgent'">U</t>
                                    </span>
                                    <span t-attf-class="o_it_request_impact o_it_request_impact_#{record.impact.raw_value}"
                                          t-att-title="record.impact.raw_value">
                                        <span class="o_it_request_dim">I:</span>
                                        <t t-if="record.impact.raw_value === 'low'">L</t>
                                        <t t-elif="record.impact.raw_value === 'medium'">M</t>
                                        <t t-elif="record.impact.raw_value === 'high'">H</t>
                                        <t t-elif="record.impact.raw_value === 'urgent'">U</t>
                                    </span>
                                </span>
                                <t t-if="record.sla_state.raw_value === 'at_risk' or record.sla_state.raw_value === 'breached'">
                                    <span t-attf-class="o_it_request_sla o_it_request_sla_#{record.sla_state.raw_value}">
                                        <i class="fa fa-clock-o"/>
                                        <t t-if="record.sla_state.raw_value === 'breached'">Breached</t>
                                        <t t-elif="record.sla_state.raw_value === 'at_risk'">At Risk</t>
                                    </span>
                                </t>
                            </div>
                            <!-- 5 · Footer: priority (L) + assignee + activity (R) -->
                            <div class="o_it_request_card_foot">
                                <span class="o_it_request_priority">
                                    <field name="priority" widget="priority"/>
                                </span>
                                <div class="o_it_request_people">
                                    <t t-if="record.assigned_to_id.raw_value">
                                        <field name="assigned_to_id"
                                               widget="many2one_avatar_user"
                                               options="{'no_open': True}"/>
                                    </t>
                                    <t t-else="">
                                        <span class="o_it_request_unassigned">—</span>
                                    </t>
                                    <field name="activity_ids" widget="kanban_activity"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         PIVOT
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_pivot" model="ir.ui.view">
        <field name="name">it.request.pivot</field>
        <field name="model">it.request</field>
        <field name="arch" type="xml">
            <pivot string="IT Requests Summary" display_quantity="1">
                <field name="state" type="row"/>
                <field name="request_type" type="col"/>
                <field name="category_id" type="row"/>
                <field name="priority" type="row"/>
            </pivot>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         GRAPH
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_graph" model="ir.ui.view">
        <field name="name">it.request.graph</field>
        <field name="model">it.request</field>
        <field name="arch" type="xml">
            <graph string="Requests by Month" type="bar">
                <field name="create_date" interval="month"/>
                <field name="state" type="row"/>
            </graph>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         SEARCH
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_search" model="ir.ui.view">
        <field name="name">it.request.search</field>
        <field name="model">it.request</field>
        <field name="arch" type="xml">
            <search>
                <!-- Full-text -->
                <field name="name" string="Request Number"/>
                <field name="subject" string="Subject"/>
                <field name="description" string="Description"/>
                <field name="module_name" string="Module"/>
                <field name="requester_id" string="Requester"/>

                <separator/>

                <!-- Quick filters -->
                <filter name="my_requests" string="My Requests"
                        domain="[('requester_id.user_id','=',uid)]"/>
                <filter name="my_assignments" string="My Assignments"
                        domain="[('assigned_to_id','=',uid),('state','not in',('done','cancel'))]"/>

                <separator/>

                <!-- By type -->
                <filter name="f_problem" string="Report Problem"
                        domain="[('request_type','=','problem')]"/>
                <filter name="f_feature_request" string="Feature Request"
                        domain="[('request_type','=','feature_request')]"/>
                <filter name="f_it_equipment_purchase" string="IT Equipment Purchase"
                        domain="[('request_type','=','it_equipment_purchase')]"/>
                <filter name="f_it_equipment_repair" string="IT Equipment Repair"
                        domain="[('request_type','=','it_equipment_repair')]"/>

                <separator/>

                <!-- By state -->
                <filter name="f_draft" string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="f_submitted" string="Submitted"
                        domain="[('state','=','submitted')]"/>
                <filter name="f_in_progress" string="In Progress"
                        domain="[('state','=','in_progress')]"/>
                <filter name="f_waiting" string="Waiting"
                        domain="[('state','=','waiting')]"/>
                <filter name="f_done" string="Done"
                        domain="[('state','=','done')]"/>
                <filter name="f_cancel" string="Cancelled"
                        domain="[('state','=','cancel')]"/>

                <separator/>

                <!-- By SLA -->
                <filter name="f_sla_breached" string="SLA Breached"
                        domain="[('sla_state','=','breached')]"/>
                <filter name="f_sla_at_risk" string="SLA At Risk"
                        domain="[('sla_state','=','at_risk')]"/>

                <separator/>

                <!-- By date -->
                <filter name="f_today" string="Today"
                        domain="[('create_date','>=',context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="f_this_week" string="This Week"
                        date="create_date"/>
                <filter name="f_overdue" string="Overdue (No update 7d)"
                        domain="[('state','not in',('done','cancel')),('write_date','&lt;',(context_today() - relativedelta(days=7)).strftime('%%Y-%%m-%%d'))]"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter name="group_state" string="State"
                            context="{'group_by':'state'}"/>
                    <filter name="group_type" string="Request Type"
                            context="{'group_by':'request_type'}"/>
                    <filter name="group_category" string="Category"
                            context="{'group_by':'category_id'}"/>
                    <filter name="group_priority" string="Priority"
                            context="{'group_by':'priority'}"/>
                    <filter name="group_requester" string="Requester"
                            context="{'group_by':'requester_id'}"/>
                    <filter name="group_assigned" string="Assigned To"
                            context="{'group_by':'assigned_to_id'}"/>
                    <filter name="group_team" string="Team"
                            context="{'group_by':'team_id'}"/>
                    <filter name="group_created_month" string="Created (Month)"
                            context="{'group_by':'create_date:month'}"/>
                    <filter name="group_department" string="Department"
                            context="{'group_by':'department_id'}"/>
                    <filter name="group_module" string="Module"
                            context="{'group_by':'module_name'}"/>
                    <filter name="group_sla" string="SLA State"
                            context="{'group_by':'sla_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         CATEGORY VIEWS
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_category_tree" model="ir.ui.view">
        <field name="name">it.request.category.tree</field>
        <field name="model">it.request.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_it_request_category_form" model="ir.ui.view">
        <field name="name">it.request.category.form</field>
        <field name="model">it.request.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Sub-Categories">
                            <field name="sub_category_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         TEAM VIEWS
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_it_request_team_tree" model="ir.ui.view">
        <field name="name">it.request.team.tree</field>
        <field name="model">it.request.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="leader_id"/>
            </tree>
        </field>
    </record>

    <record id="view_it_request_team_form" model="ir.ui.view">
        <field name="name">it.request.team.form</field>
        <field name="model">it.request.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="leader_id"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         ACTIONS
    ═══════════════════════════════════════════════════════════════ -->
    <record id="action_it_request" model="ir.actions.act_window">
        <field name="name">IT Requests</field>
        <field name="res_model">it.request</field>
        <field name="view_mode">kanban,tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_it_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new IT request
            </p>
            <p>
                Report system problems or request new features
                from submission through resolution.
            </p>
        </field>
    </record>

    <record id="action_my_it_requests" model="ir.actions.act_window">
        <field name="name">My Requests</field>
        <field name="res_model">it.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('requester_id.user_id','=',uid)]</field>
        <field name="search_view_id" ref="view_it_request_search"/>
    </record>

    <record id="action_my_assignments" model="ir.actions.act_window">
        <field name="name">My Assignments</field>
        <field name="res_model">it.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('assigned_to_id','=',uid),('state','not in',('done','cancel'))]</field>
        <field name="search_view_id" ref="view_it_request_search"/>
    </record>

    <record id="action_it_request_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">it.request.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_it_request_team" model="ir.actions.act_window">
        <field name="name">IT Teams</field>
        <field name="res_model">it.request.team</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
