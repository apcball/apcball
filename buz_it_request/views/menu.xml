<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main root -->
    <menuitem id="menu_it_request_root"
              name="IT Request"
              sequence="10"
              groups="buz_it_request.group_it_request_user"/>

    <!-- User: my requests -->
