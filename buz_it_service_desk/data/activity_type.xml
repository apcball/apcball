<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- SLA Warning Activity Type -->
        <record id="mail_activity_sla_warning" model="mail.activity.type">
            <field name="name">SLA Warning</field>
            <field name="icon">fa-exclamation-triangle</field>
            <field name="category">default</field>
            <field name="res_model">it.ticket</field>
            <field name="delay_count">1</field>
            <field name="delay_unit">days</field>
            <field name="summary">SLA Warning</field>
        </record>

        <!-- Ticket Assignment Activity Type -->
        <record id="mail_activity_ticket_assignment" model="mail.activity.type">
            <field name="name">Ticket Assignment</field>
            <field name="icon">fa-user</field>
            <field name="category">default</field>
            <field name="res_model">it.ticket</field>
            <field name="delay_count">1</field>
            <field name="delay_unit">days</field>
            <field name="summary">Ticket Assignment</field>
        </record>

        <!-- Service Request Approval Activity Type -->
        <record id="mail_activity_service_approval" model="mail.activity.type">
            <field name="name">Service Request Approval</field>
            <field name="icon">fa-check-circle</field>
            <field name="category">default</field>
            <field name="res_model">it.service.request</field>
            <field name="delay_count">1</field>
            <field name="delay_unit">days</field>
            <field name="summary">Service Request Approval</field>
        </record>

        <!-- Purchase Request Approval Activity Type -->
        <record id="mail_activity_purchase_approval" model="mail.activity.type">
            <field name="name">Purchase Request Approval</field>
            <field name="icon">fa-dollar</field>
            <field name="category">default</field>
            <field name="res_model">it.purchase.request</field>
            <field name="delay_count">1</field>
            <field name="delay_unit">days</field>
            <field name="summary">Purchase Request Approval</field>
        </record>
    </data>
</odoo>