<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- IT Ticket Sequence -->
        <record id="sequence_it_ticket" model="ir.sequence">
            <field name="name">IT Ticket</field>
            <field name="code">it.ticket.sequence</field>
            <field name="prefix">IT</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- IT Service Request Sequence -->
        <record id="sequence_it_service_request" model="ir.sequence">
            <field name="name">IT Service Request</field>
            <field name="code">it.service.request.sequence</field>
            <field name="prefix">SR</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- IT Purchase Request Sequence -->
        <record id="sequence_it_purchase_request" model="ir.sequence">
            <field name="name">IT Purchase Request</field>
            <field name="code">it.purchase.request.sequence</field>
            <field name="prefix">PR</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>