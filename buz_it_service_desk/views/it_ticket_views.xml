<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- IT Ticket Tree View -->
    <record id="view_it_ticket_tree" model="ir.ui.view">
        <field name="name">it.ticket.tree</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <tree string="IT Tickets">
                <field name="name"/>
                <field name="subject"/>
                <field name="ticket_type"/>
                <field name="priority"/>
                <field name="requester_id"/>
                <field name="assigned_to_id"/>
                <field name="state"/>
                <field name="sla_deadline"/>
            </tree>
        </field>
    </record>

    <!-- IT Ticket Form View -->
    <record id="view_it_ticket_form" model="ir.ui.view">
        <field name="name">it.ticket.form</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <form string="IT Ticket">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_assign_to_me" string="Assign to Me" type="object"
                            invisible="state not in ['submitted', 'in_progress']" class="btn-primary"/>
                    <button name="action_in_progress" string="In Progress" type="object"
                            invisible="state not in ['submitted', 'waiting']"/>
                    <button name="action_waiting" string="Waiting" type="object"
                            invisible="state != 'in_progress'"/>
                    <button name="action_done" string="Done" type="object"
                            invisible="state not in ['in_progress', 'waiting']" class="btn-primary"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state not in ['draft', 'submitted', 'in_progress', 'waiting']"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancel'"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,in_progress,waiting,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="create_service_request" type="object"
                                class="oe_stat_button" icon="fa-users"
                                invisible="ticket_type != 'service'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="service_request_count" widget="statinfo"/>
                                </span>
                                <span class="o_stat_text">Service Requests</span>
                            </div>
                        </button>
                        <button name="create_purchase_request" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="ticket_type != 'purchase'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="purchase_request_count" widget="statinfo"/>
                                </span>
                                <span class="o_stat_text">Purchase Requests</span>
                            </div>
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="subject"/>
                            <field name="ticket_type"/>
                            <field name="category_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="requester_id"/>
                            <field name="assigned_to_id"/>
                            <field name="department_id"/>
                            <field name="sla_deadline"/>
                            <field name="close_date"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                        
                        <page string="Incident Details" invisible="ticket_type != 'incident'">
                            <group>
                                <group>
                                    <field name="asset_tag"/>
                                    <field name="serial_no"/>
                                </group>
                                <group>
                                    <field name="impact_level"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- IT Ticket Kanban View -->
    <record id="view_it_ticket_kanban" model="ir.ui.view">
        <field name="name">it.ticket.kanban</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="subject"/>
                <field name="ticket_type"/>
                <field name="priority"/>
                <field name="requester_id"/>
                <field name="assigned_to_id"/>
                <field name="state"/>
                <field name="sla_deadline"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <progressbar field="activity_state" colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.priority.raw_value == 'critical' ? 'oe_kanban_color_4' : record.priority.raw_value == 'high' ? 'oe_kanban_color_2' : ''}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_manage_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/> - <field name="subject"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_manage_button_section">
                                    <a class="o_kanban_manage_toggle_button" href="#" tabindex="-1">
                                        <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage"/>
                                    </a>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <img t-att-src="kanban_image('res.users', 'avatar_128', record.requester_id.raw_value)" 
                                             t-att-title="record.requester_id.value" t-att-alt="record.requester_id.value" 
                                             class="oe_kanban_avatar"/>
                                        <field name="ticket_type"/>
                                        <field name="priority" widget="priority"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- IT Ticket Search View -->
    <record id="view_it_ticket_search" model="ir.ui.view">
        <field name="name">it.ticket.search</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <search string="IT Tickets">
                <field name="name"/>
                <field name="subject"/>
                <field name="requester_id"/>
                <field name="assigned_to_id"/>
                <field name="category_id"/>
                <filter string="My Tickets" name="my_tickets" domain="[('requester_id', '=', uid)]"/>
                <filter string="My Assignments" name="my_assignments" domain="[('assigned_to_id', '=', uid)]"/>
                <separator/>
                <filter string="Incident" name="incident" domain="[('ticket_type', '=', 'incident')]"/>
                <filter string="Service Request" name="service" domain="[('ticket_type', '=', 'service')]"/>
                <filter string="Purchase Request" name="purchase" domain="[('ticket_type', '=', 'purchase')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Waiting" name="waiting" domain="[('state', '=', 'waiting')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Overdue SLA" name="overdue_sla" domain="[('sla_deadline', '&lt;', context_today().strftime('%Y-%m-%d 23:59:59')), ('state', 'not in', ['done', 'cancel'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Ticket Type" name="group_ticket_type" context="{'group_by': 'ticket_type'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Requester" name="group_requester" context="{'group_by': 'requester_id'}"/>
                    <filter string="Assigned To" name="group_assigned" context="{'group_by': 'assigned_to_id'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- IT Ticket Action -->
    <record id="action_it_ticket" model="ir.actions.act_window">
        <field name="name">IT Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first IT Ticket
            </p>
            <p>
                Create and manage IT tickets for incidents, service requests, and purchase requests.
            </p>
        </field>
    </record>

    <!-- My Tickets Action -->
    <record id="action_my_it_tickets" model="ir.actions.act_window">
        <field name="name">My Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('requester_id', '=', uid)]</field>
        <field name="context">{'default_requester_id': uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You have no tickets yet
            </p>
            <p>
                Create a new ticket to request IT support.
            </p>
        </field>
    </record>

    <!-- My Assignments Action -->
    <record id="action_my_assignments" model="ir.actions.act_window">
        <field name="name">My Assignments</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('assigned_to_id', '=', uid), ('state', 'not in', ['done', 'cancel'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You have no assigned tickets
            </p>
            <p>
                Tickets assigned to you will appear here.
            </p>
        </field>
    </record>

    <!-- Create Ticket Action -->
    <record id="action_create_ticket" model="ir.actions.act_window">
        <field name="name">Create Ticket</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'default_requester_id': uid}</field>
    </record>

    <!-- My Incidents Action -->
    <record id="action_my_incidents" model="ir.actions.act_window">
        <field name="name">My Incidents</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('ticket_type', '=', 'incident'), ('requester_id', '=', uid)]</field>
        <field name="context">{'default_ticket_type': 'incident', 'default_requester_id': uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You have no incidents yet
            </p>
            <p>
                Create a new incident to report IT problems.
            </p>
        </field>
    </record>

    <!-- All Incidents Action -->
    <record id="action_all_incidents" model="ir.actions.act_window">
        <field name="name">All Incidents</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('ticket_type', '=', 'incident')]</field>
        <field name="context">{'default_ticket_type': 'incident'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No incidents found
            </p>
            <p>
                IT incidents will appear here.
            </p>
        </field>
    </record>
</odoo>