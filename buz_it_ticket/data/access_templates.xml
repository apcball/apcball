<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Access Templates -->
        <record id="access_template_new_employee" model="it.access.template">
            <field name="name">New Employee Access</field>
            <field name="description">Standard access package for new employees</field>
        </record>
        
        <record id="access_template_new_employee_line_1" model="it.access.template.line">
            <field name="template_id" ref="access_template_new_employee"/>
            <field name="access_type">email</field>
            <field name="name">Company Email Account</field>
            <field name="access_payload">{"domain": "company.com", "mailbox_size": "10GB"}</field>
        </record>
        
        <record id="access_template_new_employee_line_2" model="it.access.template.line">
            <field name="template_id" ref="access_template_new_employee"/>
            <field name="access_type">erp</field>
            <field name="name">ERP User Access</field>
            <field name="access_payload">{"modules": ["sales", "purchase", "inventory"], "role": "user"}</field>
        </record>
        
        <record id="access_template_new_employee_line_3" model="it.access.template.line">
            <field name="template_id" ref="access_template_new_employee"/>
            <field name="access_type">drive</field>
            <field name="name">Shared Drive Access</field>
            <field name="access_payload">{"folders": ["shared", "department"], "permissions": ["read", "write"]}</field>
        </record>
        
        <record id="access_template_sales_manager" model="it.access.template">
            <field name="name">Sales Manager Access</field>
            <field name="description">Enhanced access for sales managers</field>
        </record>
        
        <record id="access_template_sales_manager_line_1" model="it.access.template.line">
            <field name="template_id" ref="access_template_sales_manager"/>
            <field name="access_type">erp</field>
            <field name="name">ERP Manager Access</field>
            <field name="access_payload">{"modules": ["sales", "crm", "accounting"], "role": "manager"}</field>
        </record>
        
        <record id="access_template_sales_manager_line_2" model="it.access.template.line">
            <field name="template_id" ref="access_template_sales_manager"/>
            <field name="access_type">vpn</field>
            <field name="name">VPN Access</field>
            <field name="access_payload">{"type": "ssl_vpn", "duration": "24h"}</field>
        </record>
        
        <record id="access_template_sales_manager_line_3" model="it.access.template.line">
            <field name="template_id" ref="access_template_sales_manager"/>
            <field name="access_type">shared_folder</field>
            <field name="name">Sales Reports Folder</field>
            <field name="access_payload">{"folder": "\\\\server\\sales\\reports", "permissions": ["read", "write", "delete"]}</field>
        </record>
        
        <record id="access_template_it_staff" model="it.access.template">
            <field name="name">IT Staff Access</field>
            <field name="description">Full system access for IT staff</field>
        </record>
        
        <record id="access_template_it_staff_line_1" model="it.access.template.line">
            <field name="template_id" ref="access_template_it_staff"/>
            <field name="access_type">erp</field>
            <field name="name">ERP Admin Access</field>
            <field name="access_payload">{"modules": "all", "role": "admin"}</field>
        </record>
        
        <record id="access_template_it_staff_line_2" model="it.access.template.line">
            <field name="template_id" ref="access_template_it_staff"/>
            <field name="access_type">vpn</field>
            <field name="name">Admin VPN Access</field>
            <field name="access_payload">{"type": "ssl_vpn", "duration": "unlimited", "admin_access": true}</field>
        </record>
        
        <record id="access_template_it_staff_line_3" model="it.access.template.line">
            <field name="template_id" ref="access_template_it_staff"/>
            <field name="access_type">software</field>
            <field name="name">Admin Software Licenses</field>
            <field name="access_payload">{"software": ["server_admin", "network_monitor", "backup_system"]}</field>
        </record>
        
        <record id="access_template_remote_worker" model="it.access.template">
            <field name="name">Remote Worker Access</field>
            <field name="description">Access package for remote employees</field>
        </record>
        
        <record id="access_template_remote_worker_line_1" model="it.access.template.line">
            <field name="template_id" ref="access_template_remote_worker"/>
            <field name="access_type">vpn</field>
            <field name="name">Remote VPN Access</field>
            <field name="access_payload">{"type": "ssl_vpn", "duration": "12h", "2fa_required": true}</field>
        </record>
        
        <record id="access_template_remote_worker_line_2" model="it.access.template.line">
            <field name="template_id" ref="access_template_remote_worker"/>
            <field name="access_type">erp</field>
            <field name="name">ERP Remote Access</field>
            <field name="access_payload">{"modules": ["hr", "timesheet"], "role": "user", "remote_access": true}</field>
        </record>
        
        <record id="access_template_remote_worker_line_3" model="it.access.template.line">
            <field name="template_id" ref="access_template_remote_worker"/>
            <field name="access_type">drive</field>
            <field name="name">Cloud Storage Access</field>
            <field name="access_payload">{"service": "cloud_drive", "storage": "50GB", "sync_enabled": true}</field>
        </record>
    </data>
</odoo>