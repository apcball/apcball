<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- SLA Breach Check Cron Job -->
        <record id="ir_cron_sla_breach_check" model="ir.cron">
            <field name="name">Check IT Ticket SLA Breaches</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="state">code</field>
            <field name="code">model.check_sla_breaches()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>