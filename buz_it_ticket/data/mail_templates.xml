<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Ticket Submitted Template -->
        <record id="mail_template_ticket_submitted" model="mail.template">
            <field name="name">IT Ticket - Submitted</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="subject">IT Ticket ${object.name} - ${object.category} - ${object.state}</field>
            <field name="email_from">${object.company_id.email or 'noreply@company.com'}</field>
            <field name="partner_to">${object.employee_id.user_id.partner_id.id}</field>
            <field name="auto_delete">True</field>
            <field name="lang">${object.employee_id.user_id.lang}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>Dear ${object.employee_id.name},</p>
                    <p>Your IT ticket has been successfully submitted with the following details:</p>
                    <table border="1" style="width:100%; border-collapse: collapse;">
                        <tr>
                            <td style="padding:5px;"><strong>Ticket Number:</strong></td>
                            <td style="padding:5px;">${object.name}</td>
                        </tr>
                        <tr>
                            <td style="padding:5px;"><strong>Category:</strong></td>
                            <td style="padding:5px;">${object.category}</td>
                        </tr>
                        <tr>
                            <td style="padding:5px;"><strong>Priority:</strong></td>
                            <td style="padding:5px;">${object.sla_level}</td>
                        </tr>
                        <tr>
                            <td style="padding:5px;"><strong>Description:</strong></td>
                            <td style="padding:5px;">${object.description}</td>
                        </tr>
                    </table>
                    <p>You will be notified of any updates to your ticket.</p>
                    <p>Best regards,<br/>IT Support Team</p>
                </div>
            </field>
        </record>
    </data>
</odoo>