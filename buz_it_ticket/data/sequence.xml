<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequences for different ticket categories -->
        <record id="sequence_it_ticket_issue" model="ir.sequence">
            <field name="name">IT Ticket Issue Sequence</field>
            <field name="code">it.ticket.issue</field>
            <field name="prefix">ISS/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <record id="sequence_it_ticket_access" model="ir.sequence">
            <field name="name">IT Ticket Access Sequence</field>
            <field name="code">it.ticket.access</field>
            <field name="prefix">ACS/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <record id="sequence_it_ticket_purchase" model="ir.sequence">
            <field name="name">IT Ticket Purchase Sequence</field>
            <field name="code">it.ticket.purchase</field>
            <field name="prefix">PRC/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>