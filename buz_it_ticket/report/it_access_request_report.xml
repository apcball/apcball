<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Access Request Report Template -->
        <template id="report_it_access_request_document">
            <t t-call="web.external_layout">
                <t t-set="o" t-value="o.with_context({'lang': o.employee_id.user_id.lang or o.env.user.lang})"/>
                <div class="page">
                    <div class="oe_structure"/>
                    
                    <!-- Header -->
                    <div class="row">
                        <div class="col-6">
                            <h2>IT Access Request Form</h2>
                            <p class="text-muted">ISO Document: <span t-field="o.iso_doc_code"/></p>
                        </div>
                        <div class="col-6 text-right">
                            <h4><span t-field="o.name"/></h4>
                            <p class="text-muted">Revision: <span t-field="o.revision"/></p>
                        </div>
                    </div>
                    
                    <hr/>
                    
                    <!-- Request Information -->
                    <h3>Request Information</h3>
                    <table class="table table-sm">
                        <tr>
                            <th width="20%">Ticket Number:</th>
                            <td width="30%"><span t-field="o.name"/></td>
                            <th width="20%">Request Date:</th>
                            <td width="30%"><span t-field="o.create_date"/></td>
                        </tr>
                        <tr>
                            <th>Requester:</th>
                            <td><span t-field="o.employee_id.name"/></td>
                            <th>Department:</th>
                            <td><span t-field="o.department_id.name"/></td>
                        </tr>
                        <tr>
                            <th>Position:</th>
                            <td><span t-field="o.employee_id.job_id.name"/></td>
                            <th>Email:</th>
                            <td><span t-field="o.employee_id.work_email"/></td>
                        </tr>
                        <tr>
                            <th>Priority:</th>
                            <td><span t-field="o.priority"/></td>
                            <th>IT Responsible:</th>
                            <td><span t-field="o.it_responsible_id.name"/></td>
                        </tr>
                    </table>
                    
                    <!-- Access Details -->
                    <h3>Access Details</h3>
                    <table class="table table-bordered">
                        <thead class="thead-light">
                            <tr>
                                <th>Access Type</th>
                                <th>Access Name</th>
                                <th>Details</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.access_line_ids" t-as="line">
                                <tr>
                                    <td><span t-field="line.access_type"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td><span t-field="line.access_payload"/></td>
                                    <td><span t-field="line.notes"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    
                    <!-- Justification -->
                    <h3>Justification</h3>
                    <div class="border p-3">
                        <span t-field="o.description"/>
                    </div>
                    
                    <!-- Approval Process -->
                    <h3>Approval Process</h3>
                    <table class="table table-sm">
                        <tr>
                            <th width="20%">Submitted:</th>
                            <td width="30%"><span t-field="o.create_date"/></td>
                            <th width="20%">Manager Approval:</th>
                            <td width="30%">
                                <t t-if="o.state in ['approved', 'implementing', 'closed']">
                                    <span class="text-success">Approved</span>
                                </t>
                                <t t-elif="o.state == 'rejected'">
                                    <span class="text-danger">Rejected</span>
                                </t>
                                <t t-else="">
                                    <span class="text-warning">Pending</span>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <th>Implementation:</th>
                            <td>
                                <t t-if="o.state in ['implementing', 'closed']">
                                    <span class="text-success">Completed</span>
                                </t>
                                <t t-else="">
                                    <span class="text-warning">Pending</span>
                                </t>
                            </td>
                            <th>Completed Date:</th>
                            <td><span t-field="o.resolved_at"/></td>
                        </tr>
                    </table>
                    
                    <!-- Access Template (if used) -->
                    <t t-if="o.access_template_id">
                        <h3>Access Template Used</h3>
                        <table class="table table-sm">
                            <tr>
                                <th width="20%">Template Name:</th>
                                <td width="30%"><span t-field="o.access_template_id.name"/></td>
                                <th width="20%">Department:</th>
                                <td width="30%"><span t-field="o.access_template_id.department_id.name"/></td>
                            </tr>
                            <tr>
                                <th>Description:</th>
                                <td colspan="3"><span t-field="o.access_template_id.description"/></td>
                            </tr>
                        </table>
                    </t>
                    
                    <!-- Signatures -->
                    <div class="row mt-5">
                        <div class="col-4">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>Requester</strong></p>
                                <p class="text-center"><span t-field="o.employee_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>Manager Approval</strong></p>
                                <p class="text-center"><span t-field="o.manager_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>IT Implementation</strong></p>
                                <p class="text-center"><span t-field="o.it_responsible_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Footer -->
                    <div class="text-center mt-5">
                        <p class="text-muted">Printed by: <span t-field="o.printed_by.name"/> on <span t-field="o.printed_at"/> (Print Count: <span t-field="o.printed_count"/>)</p>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Access Request Report Action -->
        <record id="action_report_it_access_request" model="ir.actions.report">
            <field name="name">Access Request Report</field>
            <field name="model">it.ticket</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">buz_it_ticket.report_it_access_request_document</field>
            <field name="report_file">IT_Access_<span t-field="o.name"/>.pdf</field>
            <field name="binding_model_id" ref="model_it_ticket"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>