<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Purchase Request Report Template -->
        <template id="report_it_purchase_request_document">
            <t t-call="web.external_layout">
                <t t-set="o" t-value="o.with_context({'lang': o.employee_id.user_id.lang or o.env.user.lang})"/>
                <div class="page">
                    <div class="oe_structure"/>
                    
                    <!-- Header -->
                    <div class="row">
                        <div class="col-6">
                            <h2>IT Purchase Request</h2>
                            <p class="text-muted">ISO Document: <span t-field="o.iso_doc_code"/></p>
                        </div>
                        <div class="col-6 text-right">
                            <h4><span t-field="o.name"/></h4>
                            <p class="text-muted">Revision: <span t-field="o.revision"/></p>
                        </div>
                    </div>
                    
                    <hr/>
                    
                    <!-- Request Information -->
                    <h3>Request Information</h3>
                    <table class="table table-sm">
                        <tr>
                            <th width="20%">Ticket Number:</th>
                            <td width="30%"><span t-field="o.name"/></td>
                            <th width="20%">Request Date:</th>
                            <td width="30%"><span t-field="o.create_date"/></td>
                        </tr>
                        <tr>
                            <th>Requester:</th>
                            <td><span t-field="o.employee_id.name"/></td>
                            <th>Department:</th>
                            <td><span t-field="o.department_id.name"/></td>
                        </tr>
                        <tr>
                            <th>Position:</th>
                            <td><span t-field="o.employee_id.job_id.name"/></td>
                            <th>Priority:</th>
                            <td><span t-field="o.sla_level"/></td>
                        </tr>
                        <tr>
                            <th>IT Responsible:</th>
                            <td><span t-field="o.it_responsible_id.name"/></td>
                            <th>Purchase Order:</th>
                            <td>
                                <t t-if="o.purchase_id">
                                    <span t-field="o.purchase_id.name"/>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Not created</span>
                                </t>
                            </td>
                        </tr>
                    </table>
                    
                    <!-- Purchase Items -->
                    <h3>Purchase Items</h3>
                    <table class="table table-bordered">
                        <thead class="thead-light">
                            <tr>
                                <th>Product</th>
                                <th>Description</th>
                                <th>Quantity</th>
                                <th>Unit</th>
                                <th>Est. Cost</th>
                                <th>Total Est. Cost</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.purchase_line_ids" t-as="line">
                                <tr>
                                    <td><span t-field="line.product_id.name"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-right"><span t-field="line.quantity"/></td>
                                    <td><span t-field="line.uom_id.name"/></td>
                                    <td class="text-right"><span t-field="line.estimated_cost"/></td>
                                    <td class="text-right"><span t-esc="line.quantity * line.estimated_cost"/></td>
                                    <td><span t-field="line.notes"/></td>
                                </tr>
                            </t>
                            <tr class="font-weight-bold">
                                <td colspan="5" class="text-right">Total Estimated Cost:</td>
                                <td class="text-right">
                                    <span t-esc="sum(line.quantity * line.estimated_cost for line in o.purchase_line_ids)"/>
                                </td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <!-- Justification -->
                    <h3>Justification</h3>
                    <div class="border p-3">
                        <span t-field="o.description"/>
                    </div>
                    
                    <!-- Approval Process -->
                    <h3>Approval Process</h3>
                    <table class="table table-sm">
                        <tr>
                            <th width="20%">Submitted:</th>
                            <td width="30%"><span t-field="o.create_date"/></td>
                            <th width="20%">Manager Approval:</th>
                            <td width="30%">
                                <t t-if="o.state in ['waiting_it', 'po_created', 'received', 'closed']">
                                    <span class="text-success">Approved</span>
                                </t>
                                <t t-elif="o.state == 'rejected'">
                                    <span class="text-danger">Rejected</span>
                                </t>
                                <t t-else="">
                                    <span class="text-warning">Pending</span>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <th>IT Review:</th>
                            <td>
                                <t t-if="o.state in ['po_created', 'received', 'closed']">
                                    <span class="text-success">Approved</span>
                                </t>
                                <t t-else="">
                                    <span class="text-warning">Pending</span>
                                </t>
                            </td>
                            <th>PO Created:</th>
                            <td>
                                <t t-if="o.purchase_id">
                                    <span class="text-success"><span t-field="o.purchase_id.name"/></span>
                                </t>
                                <t t-else="">
                                    <span class="text-warning">Pending</span>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <th>Items Received:</th>
                            <td>
                                <t t-if="o.state in ['received', 'closed']">
                                    <span class="text-success">Yes</span>
                                </t>
                                <t t-else="">
                                    <span class="text-warning">Pending</span>
                                </t>
                            </td>
                            <th>Completed Date:</th>
                            <td><span t-field="o.resolved_at"/></td>
                        </tr>
                    </table>
                    
                    <!-- Purchase Order Details (if created) -->
                    <t t-if="o.purchase_id">
                        <h3>Purchase Order Details</h3>
                        <table class="table table-sm">
                            <tr>
                                <th width="20%">PO Number:</th>
                                <td width="30%"><span t-field="o.purchase_id.name"/></td>
                                <th width="20%">Vendor:</th>
                                <td width="30%"><span t-field="o.purchase_id.partner_id.name"/></td>
                            </tr>
                            <tr>
                                <th>Order Date:</th>
                                <td><span t-field="o.purchase_id.date_order"/></td>
                                <th>Expected Date:</th>
                                <td><span t-field="o.purchase_id.date_planned"/></td>
                            </tr>
                            <tr>
                                <th>Total Amount:</th>
                                <td><span t-field="o.purchase_id.amount_total"/></td>
                                <th>State:</th>
                                <td><span t-field="o.purchase_id.state"/></td>
                            </tr>
                        </table>
                    </t>
                    
                    <!-- Signatures -->
                    <div class="row mt-5">
                        <div class="col-3">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>Requester</strong></p>
                                <p class="text-center"><span t-field="o.employee_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>Manager Approval</strong></p>
                                <p class="text-center"><span t-field="o.manager_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>IT Review</strong></p>
                                <p class="text-center"><span t-field="o.it_responsible_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="border-top pt-3">
                                <p class="text-center">_________________________</p>
                                <p class="text-center"><strong>Receiver</strong></p>
                                <p class="text-center"><span t-field="o.employee_id.name"/></p>
                                <p class="text-center"><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Footer -->
                    <div class="text-center mt-5">
                        <p class="text-muted">Printed by: <span t-field="o.printed_by.name"/> on <span t-field="o.printed_at"/> (Print Count: <span t-field="o.printed_count"/>)</p>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Purchase Request Report Action -->
        <record id="action_report_it_purchase_request" model="ir.actions.report">
            <field name="name">Purchase Request Report</field>
            <field name="model">it.ticket</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">buz_it_ticket.report_it_purchase_request_document</field>
            <field name="report_file">IT_Purchase_<span t-field="o.name"/>.pdf</field>
            <field name="binding_model_id" ref="model_it_ticket"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>