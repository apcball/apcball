<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Security Groups -->
        <record id="group_it_requester" model="res.groups">
            <field name="name">IT Requester</field>
            <field name="comment">Employees who can create IT tickets</field>
        </record>
        
        <record id="group_it_user" model="res.groups">
            <field name="name">IT User</field>
            <field name="comment">IT staff who handle tickets</field>
            <field name="implied_ids" eval="[(4, ref('group_it_requester'))]"/>
        </record>
        
        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
            <field name="comment">IT managers with full access</field>
            <field name="implied_ids" eval="[(4, ref('group_it_user'))]"/>
        </record>
        
        <record id="group_it_approver" model="res.groups">
            <field name="name">IT Approver</field>
            <field name="comment">Managers/HR/Finance who can approve requests</field>
        </record>
        
        <record id="group_it_iso_auditor" model="res.groups">
            <field name="name">IT ISO Auditor</field>
            <field name="comment">Users who can read and print ISO reports</field>
        </record>

        <!-- Record Rules -->
        <!-- Requester can only see their own tickets -->
        <record id="it_ticket_rule_requester" model="ir.rule">
            <field name="name">IT Ticket: Requester can see own tickets</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_it_requester'))]"/>
        </record>
        
        <!-- IT User/Manager can see tickets in their company -->
        <record id="it_ticket_rule_company" model="ir.rule">
            <field name="name">IT Ticket: See tickets in company</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_it_user')), (4, ref('group_it_manager'))]"/>
        </record>
        
        <!-- IT ISO Auditor can see all tickets for reporting -->
        <record id="it_ticket_rule_iso_auditor" model="ir.rule">
            <field name="name">IT Ticket: ISO Auditor can see all</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_iso_auditor'))]"/>
        </record>
        
        <!-- Ticket Line Rules -->
        <record id="it_ticket_line_rule_requester" model="ir.rule">
            <field name="name">IT Ticket Line: Requester can see own ticket lines</field>
            <field name="model_id" ref="model_it_ticket_line"/>
            <field name="domain_force">[('ticket_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_it_requester'))]"/>
        </record>
        
        <record id="it_ticket_line_rule_company" model="ir.rule">
            <field name="name">IT Ticket Line: See lines in company</field>
            <field name="model_id" ref="model_it_ticket_line"/>
            <field name="domain_force">['|', ('ticket_id.company_id', '=', False), ('ticket_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_it_user')), (4, ref('group_it_manager'))]"/>
        </record>
    </data>
</odoo>