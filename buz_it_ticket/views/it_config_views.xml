<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- SLA Policy Views -->
        <record id="view_it_sla_policy_form" model="ir.ui.view">
            <field name="name">it.sla.policy.form</field>
            <field name="model">it.sla.policy</field>
            <field name="arch" type="xml">
                <form string="SLA Policy">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="category"/>
                                <field name="sla_level"/>
                                <field name="subtype"/>
                            </group>
                            <group>
                                <field name="response_time_hours"/>
                                <field name="resolve_time_hours"/>
                                <field name="active"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_it_sla_policy_tree" model="ir.ui.view">
            <field name="name">it.sla.policy.tree</field>
            <field name="model">it.sla.policy</field>
            <field name="arch" type="xml">
                <tree string="SLA Policies">
                    <field name="name"/>
                    <field name="category"/>
                    <field name="sla_level"/>
                    <field name="response_time_hours"/>
                    <field name="resolve_time_hours"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>
        
        <!-- Access Template Views -->
        <record id="view_it_access_template_form" model="ir.ui.view">
            <field name="name">it.access.template.form</field>
            <field name="model">it.access.template</field>
            <field name="arch" type="xml">
                <form string="Access Template">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="department_id"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                        <notebook>
                            <page string="Access Lines">
                                <field name="line_ids">
                                    <tree editable="bottom">
                                        <field name="access_type"/>
                                        <field name="name"/>
                                        <field name="access_payload"/>
                                        <field name="notes"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_it_access_template_tree" model="ir.ui.view">
            <field name="name">it.access.template.tree</field>
            <field name="model">it.access.template</field>
            <field name="arch" type="xml">
                <tree string="Access Templates">
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>
        
        <!-- Access Template Line Views -->
        <record id="view_it_access_template_line_form" model="ir.ui.view">
            <field name="name">it.access.template.line.form</field>
            <field name="model">it.access.template.line</field>
            <field name="arch" type="xml">
                <form string="Access Template Line">
                    <sheet>
                        <group>
                            <group>
                                <field name="access_type"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="template_id" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="access_payload"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_it_access_template_line_tree" model="ir.ui.view">
            <field name="name">it.access.template.line.tree</field>
            <field name="model">it.access.template.line</field>
            <field name="arch" type="xml">
                <tree string="Access Template Lines">
                    <field name="template_id"/>
                    <field name="access_type"/>
                    <field name="name"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>