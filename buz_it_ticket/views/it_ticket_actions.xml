<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Window Actions -->
        <record id="action_it_ticket" model="ir.actions.act_window">
            <field name="name">IT Tickets</field>
            <field name="res_model">it.ticket</field>
            <field name="view_mode">kanban,tree,form,graph,pivot</field>
            <field name="view_id" ref="view_it_ticket_kanban_custom"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first IT ticket!
                </p>
                <p>
                    Use IT tickets to track issues, access requests, and purchase requests.
                </p>
            </field>
        </record>
        
        <record id="action_it_ticket_issue" model="ir.actions.act_window">
            <field name="name">Issue/Repair Tickets</field>
            <field name="res_model">it.ticket</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('category', '=', 'issue')]</field>
            <field name="context">{'default_category': 'issue'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first issue ticket!
                </p>
                <p>
                    Report issues or repair requests through IT tickets.
                </p>
            </field>
        </record>
        
        <record id="action_it_ticket_access" model="ir.actions.act_window">
            <field name="name">Access Request Tickets</field>
            <field name="res_model">it.ticket</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('category', '=', 'access')]</field>
            <field name="context">{'default_category': 'access'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first access request!
                </p>
                <p>
                    Request access to systems, applications, or resources.
                </p>
            </field>
        </record>
        
        <record id="action_it_ticket_purchase" model="ir.actions.act_window">
            <field name="name">Purchase Request Tickets</field>
            <field name="res_model">it.ticket</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('category', '=', 'purchase')]</field>
            <field name="context">{'default_category': 'purchase'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first purchase request!
                </p>
                <p>
                    Request IT equipment or software purchases.
                </p>
            </field>
        </record>
        
        <!-- Configuration Actions -->
        <record id="action_it_sla_policy" model="ir.actions.act_window">
            <field name="name">SLA Policies</field>
            <field name="res_model">it.sla.policy</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first SLA policy!
                </p>
                <p>
                    Define Service Level Agreement policies for different ticket categories and priorities.
                </p>
            </field>
        </record>
        
        <record id="action_it_access_template" model="ir.actions.act_window">
            <field name="name">Access Templates</field>
            <field name="res_model">it.access.template</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first access template!
                </p>
                <p>
                    Define templates for common access requests to speed up ticket creation.
                </p>
            </field>
        </record>
        
        <!-- Server Actions -->
        <record id="action_purchase_order_from_ticket" model="ir.actions.server">
            <field name="name">View Purchase Order</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="state">code</field>
            <field name="code">
                if record.purchase_id:
                    action = {
                        'type': 'ir.actions.act_window',
                        'name': 'Purchase Order',
                        'res_model': 'purchase.order',
                        'res_id': record.purchase_id.id,
                        'view_mode': 'form',
                        'view_type': 'form',
                        'target': 'current',
                    }
            </field>
        </record>
    </data>
</odoo>