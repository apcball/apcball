<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Kanban View -->
        <record id="view_it_ticket_kanban_custom" model="ir.ui.view">
            <field name="name">it.ticket.kanban.custom</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column" js_class="it_ticket_kanban">
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_color_#{record.priority.raw_value or '0'} #{record.sla_breached.raw_value and 'oe_kanban_color_4' or ''}">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <div class="o_kanban_record_subtitle">
                                            <field name="employee_id"/> - <field name="category"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_manage_button_section">
                                        <a class="o_kanban_manage_toggle_button" href="#" tabindex="-1">
                                            <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage"/>
                                        </a>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="description"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                        <t t-if="record.deadline_sla.raw_value">
                                            <span t-attf-class="badge #{record.sla_breached.raw_value and 'badge-danger' or 'badge-warning'}">
                                                SLA: <field name="deadline_sla"/>
                                            </span>
                                        </t>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <img t-att-src="kanban_image('res.users', 'avatar_small', record.it_responsible_id.raw_value)" 
                                             t-att-title="record.it_responsible_id.value" 
                                             t-att-alt="record.it_responsible_id.value" 
                                             width="24" height="24" 
                                             class="oe_kanban_avatar"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>