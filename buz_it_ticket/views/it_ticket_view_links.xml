        <record id="action_it_ticket_issue_view_link" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_id" ref="view_it_ticket_issue_form"/>
            <field name="view_mode">form</field>
            <field name="act_window_id" ref="action_it_ticket_issue"/>
