<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_it_ticket_form" model="ir.ui.view">
            <field name="name">it.ticket.form</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <form string="IT Ticket">
                    <header>
                        <!-- Issue/Repair buttons -->
                        <button name="action_issue_submit" string="Submit Issue" type="object" 
                                invisible="category != 'issue' or state != 'draft'" class="btn-primary" />
                        <button name="action_issue_start_work" string="Start Work" type="object" 
                                invisible="category != 'issue' or state != 'submitted'" />
                        <button name="action_issue_need_info" string="Need Info" type="object" 
                                invisible="category != 'issue' or state not in ['in_progress', 'pending_info']" />
                        <button name="action_issue_resolve" string="Resolve" type="object" 
                                invisible="category != 'issue' or state not in ['in_progress', 'pending_info']" />
                        <button name="action_issue_close" string="Close Issue" type="object" 
                                invisible="category != 'issue' or state != 'resolved'" />
                        <button name="action_issue_cancel" string="Cancel" type="object" 
                                invisible="category != 'issue' or state == 'closed'" />
                        
                        <!-- Access buttons -->
                        <button name="action_access_submit" string="Submit Request" type="object" 
                                invisible="category != 'access' or state != 'draft'" class="btn-primary" />
                        <button name="action_access_manager_approve" string="Approve" type="object" 
                                invisible="category != 'access' or state != 'waiting_manager'" />
                        <button name="action_access_manager_reject" string="Reject" type="object" 
                                invisible="category != 'access' or state != 'waiting_manager'" />
                        <button name="action_access_start_implement" string="Start Implement" type="object" 
                                invisible="category != 'access' or state != 'approved'" />
                        <button name="action_access_mark_done" string="Mark Done" type="object" 
                                invisible="category != 'access' or state != 'implementing'" />
                        <button name="action_access_cancel" string="Cancel" type="object" 
                                invisible="category != 'access' or state == 'closed'" />
                        
                        <!-- Purchase buttons -->
                        <button name="action_purchase_submit" string="Submit Request" type="object" 
                                invisible="category != 'purchase' or state != 'draft'" class="btn-primary" />
                        <button name="action_purchase_manager_approve" string="Approve" type="object" 
                                invisible="category != 'purchase' or state != 'waiting_manager'" />
                        <button name="action_purchase_manager_reject" string="Reject" type="object" 
                                invisible="category != 'purchase' or state != 'waiting_manager'" />
                        <button name="action_purchase_create_po" string="Create PO" type="object" 
                                invisible="category != 'purchase' or state != 'waiting_it'" />
                        <button name="action_purchase_mark_received" string="Mark Received" type="object" 
                                invisible="category != 'purchase' or state != 'po_created'" />
                        <button name="action_purchase_close" string="Close Purchase" type="object" 
                                invisible="category != 'purchase' or state not in ['received', 'po_created']" />
                        <button name="action_purchase_cancel" string="Cancel" type="object" 
                                invisible="category != 'purchase' or state == 'closed'" />
                        
                        <!-- Common buttons -->
                        <button name="action_record_print" string="Print Report" type="object" 
                                invisible="state == 'draft'" />
                        
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,waiting_manager,approved,implementing,closed" />
                    </header>
                    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_purchase_order" type="object"
                                    class="oe_stat_button" icon="fa-shopping-cart"
                                    invisible="purchase_id == False" >
                                <field name="purchase_id" widget="statinfo" string="Purchase Order" />
                            </button>
                            <button name="action_view_activities" type="object" class="oe_stat_button" icon="fa-clock-o"
                                    invisible="activity_ids == []" >
                                <field name="activity_ids" widget="statinfo" string="Activities" />
                            </button>
                            <button class="oe_stat_button" icon="fa-print" name="action_print_iso_report" type="object">
                                <field name="printed_count" widget="statinfo" string="Printed" />
                            </button>
                        </div>
                        
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1" />
                            </h1>
                        </div>
                        
                        <group>
                            <group>
                                <field name="category" required="1" />
                                <field name="priority" />
                                <field name="employee_id" required="1" />
                                <field name="manager_id" />
                                <field name="department_id" />
                                <field name="it_responsible_id" />
                            </group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company" />
                                <field name="user_id" readonly="1" />
                                <field name="create_date" readonly="1" />
                                <field name="sla_policy_id" />
                                <field name="deadline_sla" />
                                <field name="sla_breached" widget="boolean_toggle" />
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Description">
                                <field name="description" placeholder="Describe the issue or request..." />
                                <field name="attachment_ids" widget="many2many_attachments" />
                            </page>
                            
                            <page string="Access Details" invisible="category != 'access'">
                                <group>
                                    <field name="access_template_id" />
                                </group>
                                <field name="access_line_ids">
                                    <tree editable="bottom">
                                        <field name="access_type" />
                                        <field name="name" />
                                        <field name="access_payload" />
                                        <field name="notes" />
                                    </tree>
                                </field>
                            </page>
                            
                            <page string="Purchase Details" invisible="category != 'purchase'">
                                <field name="purchase_line_ids">
                                    <tree editable="bottom">
                                        <field name="product_id" />
                                        <field name="name" />
                                        <field name="quantity" />
                                        <field name="uom_id" />
                                        <field name="estimated_cost" />
                                        <field name="notes" />
                                    </tree>
                                </field>
                                <group>
                                    <field name="purchase_id" readonly="purchase_id != False" />
                                </group>
                            </page>
                            
                            <page string="SLA Tracking">
                                <group>
                                    <group>
                                        <field name="responded_at" readonly="1" />
                                        <field name="resolved_at" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="ttr_respond" readonly="1" />
                                        <field name="ttr_resolve" readonly="1" />
                                    </group>
                                </group>
                            </page>
                            
                            <page string="ISO Information">
                                <group>
                                    <group>
                                        <field name="iso_doc_code" />
                                        <field name="revision" />
                                    </group>
                                    <group>
                                        <field name="printed_count" readonly="1" />
                                        <field name="printed_by" readonly="1" />
                                        <field name="printed_at" readonly="1" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    
                    <div class="oe_chatter">
                        <field name="message_follower_ids" />
                        <field name="activity_ids" />
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>
        
        <!-- List View -->
        <record id="view_it_ticket_list" model="ir.ui.view">
            <field name="name">it.ticket.list</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <tree string="IT Tickets">
                    <field name="name" />
                    <field name="category" />
                    <field name="employee_id" />
                    <field name="department_id" />
                    <field name="priority" />
                    <field name="state" />
                    <field name="it_responsible_id" />
                    <field name="create_date" />
                    <field name="deadline_sla" />
                    <field name="sla_breached" widget="boolean_toggle" />
                </tree>
            </field>
        </record>
        
        <!-- Kanban View -->
        <record id="view_it_ticket_kanban" model="ir.ui.view">
            <field name="name">it.ticket.kanban</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="name" />
                    <field name="category" />
                    <field name="employee_id" />
                    <field name="priority" />
                    <field name="state" />
                    <field name="deadline_sla" />
                    <field name="sla_breached" />
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.sla_breached.raw_value ? 'oe_kanban_color_4' : ''}">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name" />
                                        </strong>
                                        <div class="o_kanban_record_subtitle">
                                            <field name="employee_id" /> - <field name="category" />
                                        </div>
                                    </div>
                                    <div class="o_kanban_manage_button_section">
                                        <a class="o_kanban_manage_toggle_button" href="#" tabindex="-1">
                                            <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage" />
                                        </a>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="description" />
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority" />
                                        <t t-if="record.deadline_sla.raw_value">
                                            <t t-if="record.sla_breached.raw_value">
                                                <span class="badge badge-danger">
                                                    SLA: <field name="deadline_sla" />
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge badge-warning">
                                                    SLA: <field name="deadline_sla" />
                                                </span>
                                            </t>
                                        </t>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <img t-att-src="kanban_image('res.users', 'avatar_small', record.it_responsible_id.raw_value)" 
                                             t-att-title="record.it_responsible_id.value" 
                                             t-att-alt="record.it_responsible_id.value" 
                                             width="24" height="24" 
                                             class="oe_kanban_avatar" />
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Search View -->
        <record id="view_it_ticket_search" model="ir.ui.view">
            <field name="name">it.ticket.search</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <search string="IT Tickets">
                    <field name="name" />
                    <field name="employee_id" />
                    <field name="category" />
                    <field name="state" />
                    <field name="priority" />
                    <field name="department_id" />
                    <field name="it_responsible_id" />
                    
                    <filter string="My Tickets" name="my_tickets" domain="[('employee_id.user_id', '=', uid)]" />
                    <filter string="My Department" name="my_department" domain="[('department_id.member_ids.user_id', '=', uid)]" />
                    <filter string="SLA Breached" name="sla_breached" domain="[('sla_breached', '=', True)]" />
                    
                    <separator />
                    <filter string="Issue" name="category_issue" domain="[('category', '=', 'issue')]" />
                    <filter string="Access" name="category_access" domain="[('category', '=', 'access')]" />
                    <filter string="Purchase" name="category_purchase" domain="[('category', '=', 'purchase')]" />
                    
                    <separator />
                    <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]" />
                    <filter string="Submitted" name="state_submitted" domain="[('state', '=', 'submitted')]" />
                    <filter string="In Progress" name="state_in_progress" domain="[('state', '=', 'in_progress')]" />
                    <filter string="Closed" name="state_closed" domain="[('state', '=', 'closed')]" />
                    
                    <separator />
                    <filter string="Urgent" name="priority_urgent" domain="[('priority', '=', '3')]" />
                    <filter string="High" name="priority_high" domain="[('priority', '=', '2')]" />
                    
                    <group expand="0" string="Group By">
                        <filter string="Category" name="group_category" context="{'group_by': 'category'}" />
                        <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                        <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}" />
                        <filter string="Department" name="group_department" context="{'group_by': 'department_id'}" />
                        <filter string="IT Responsible" name="group_it_responsible" context="{'group_by': 'it_responsible_id'}" />
                        <filter string="Create Date" name="group_create_date" context="{'group_by': 'create_date:month'}" />
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Graph View -->
        <record id="view_it_ticket_graph" model="ir.ui.view">
            <field name="name">it.ticket.graph</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <graph string="IT Tickets Analysis">
                    <field name="category" />
                    <field name="state" />
                    <field name="priority" />
                </graph>
            </field>
        </record>
        
        <!-- Pivot View -->
        <record id="view_it_ticket_pivot" model="ir.ui.view">
            <field name="name">it.ticket.pivot</field>
            <field name="model">it.ticket</field>
            <field name="arch" type="xml">
                <pivot string="IT Tickets Analysis">
                    <field name="category" type="row" />
                    <field name="priority" type="row" />
                    <field name="state" type="col" />
                </pivot>
            </field>
        </record>
    </data>
</odoo>