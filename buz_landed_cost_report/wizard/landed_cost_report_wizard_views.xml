<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_landed_cost_report_wizard_form" model="ir.ui.view">
        <field name="name">buz.landed.cost.report.wizard.form</field>
        <field name="model">buz.landed.cost.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Landed Cost Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="product_categ_id"/>
                        <field name="landed_cost_ids" widget="many2many_tags"/>
                    </group>
                </group>
                <footer>
                    <button name="action_open_pivot" type="object" string="Pivot Preview" class="btn-secondary"/>
                    <button name="action_export_excel" type="object" string="Export Excel" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_landed_cost_report_wizard" model="ir.actions.act_window">
        <field name="name">Landed Cost Report</field>
        <field name="res_model">buz.landed.cost.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_landed_cost_report"
              name="Landed Cost Report"
              parent="stock.menu_warehouse_report"
              action="action_landed_cost_report_wizard"
              sequence="100"/>
</odoo>
