<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_marketplace_fetch_orders" model="ir.cron">
            <field name="name">Marketplace: Fetch Orders</field>
            <field name="model_id" ref="model_buz_marketplace_account"/>
            <field name="state">code</field>
            <field name="code">model._cron_fetch_orders()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <record id="cron_marketplace_sync_stock" model="ir.cron">
            <field name="name">Marketplace: Sync Stock to Marketplace</field>
            <field name="model_id" ref="model_buz_marketplace_product"/>
            <field name="state">code</field>
            <field name="code">model._cron_push_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <record id="cron_marketplace_refresh_token" model="ir.cron">
            <field name="name">Marketplace: Refresh Shopee Token</field>
            <field name="model_id" ref="model_buz_marketplace_account"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_tokens()</field>
            <field name="interval_number">12</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
