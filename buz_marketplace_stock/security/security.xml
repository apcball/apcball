<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_marketplace_user" model="res.groups">
            <field name="name">Marketplace User</field>
            <field name="category_id" ref="base.module_category_inventory_warehouse"/>
        </record>

        <record id="group_marketplace_manager" model="res.groups">
            <field name="name">Marketplace Manager</field>
            <field name="category_id" ref="base.module_category_inventory_warehouse"/>
            <field name="implied_ids" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>

        <record id="rule_marketplace_account_company" model="ir.rule">
            <field name="name">Marketplace Account: Multi-Company</field>
            <field name="model_id" ref="model_buz_marketplace_account"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>

        <record id="rule_marketplace_product_company" model="ir.rule">
            <field name="name">Marketplace Product: Multi-Company</field>
            <field name="model_id" ref="model_buz_marketplace_product"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>

        <record id="rule_marketplace_order_company" model="ir.rule">
            <field name="name">Marketplace Order: Multi-Company</field>
            <field name="model_id" ref="model_buz_marketplace_order"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>

        <record id="rule_marketplace_order_line_company" model="ir.rule">
            <field name="name">Marketplace Order Line: Multi-Company</field>
            <field name="model_id" ref="model_buz_marketplace_order_line"/>
            <field name="domain_force">[('order_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>

        <record id="rule_marketplace_api_log_company" model="ir.rule">
            <field name="name">Marketplace API Log: Multi-Company</field>
            <field name="model_id" ref="model_buz_marketplace_api_log"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>

        <record id="rule_marketplace_stock_history_company" model="ir.rule">
            <field name="name">Marketplace Stock History: Multi-Company</field>
            <field name="model_id" ref="model_buz_marketplace_stock_history"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_marketplace_user'))]"/>
        </record>
    </data>
</odoo>
