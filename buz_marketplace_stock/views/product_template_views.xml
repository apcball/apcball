<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_marketplace" model="ir.ui.view">
        <field name="name">product.template.form.inherit.marketplace</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='sales']" position="after">
                <page name="marketplace" string="Marketplace" groups="buz_marketplace_stock.group_marketplace_user">
                    <group>
                        <field name="marketplace_sku"/>
                        <field name="marketplace_product_count" widget="statinfo"/>
                    </group>
                    <field name="marketplace_product_ids">
                        <tree>
                            <field name="account_id"/>
                            <field name="marketplace_name"/>
                            <field name="marketplace_sku"/>
                            <field name="marketplace_stock"/>
                            <field name="odoo_buffer_stock"/>
                            <field name="last_sync_date"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
