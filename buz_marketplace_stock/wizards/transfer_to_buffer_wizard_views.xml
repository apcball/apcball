<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_transfer_to_buffer_wizard_form" model="ir.ui.view">
        <field name="name">buz.marketplace.transfer.to.buffer.wizard.form</field>
        <field name="model">buz.marketplace.transfer.to.buffer.wizard</field>
        <field name="arch" type="xml">
            <form string="Transfer to Buffer Location">
                <group>
                    <field name="marketplace_product_id" invisible="1"/>
                    <field name="product_id"/>
                    <field name="current_buffer_stock"/>
                    <field name="transfer_qty"/>
                    <field name="source_location_id"/>
                </group>
                <footer>
                    <button name="action_transfer" string="Transfer" type="object"
                        class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_transfer_to_buffer_wizard" model="ir.actions.act_window">
        <field name="name">Transfer to Buffer</field>
        <field name="res_model">buz.marketplace.transfer.to.buffer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_buz_marketplace_product"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>
