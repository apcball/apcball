<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_mps" model="ir.module.category">
        <field name="name">Master Production Schedule</field>
        <field name="sequence">51</field>
    </record>

    <record id="group_mps_user" model="res.groups">
        <field name="name">MPS User</field>
        <field name="category_id" ref="module_category_mps"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('buz_planning.group_planning_user'))]"/>
    </record>

    <record id="group_mps_manager" model="res.groups">
        <field name="name">MPS Manager</field>
        <field name="category_id" ref="module_category_mps"/>
        <field name="implied_ids" eval="[(4, ref('buz_mps.group_mps_user'))]"/>
    </record>
</odoo>
