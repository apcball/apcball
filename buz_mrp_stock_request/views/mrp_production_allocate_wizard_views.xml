<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_allocate_wizard_form" model="ir.ui.view">
        <field name="name">mrp.production.allocate.wizard.form</field>
        <field name="model">mrp.production.allocate.wizard</field>
        <field name="arch" type="xml">
            <form string="Allocate Materials">
                <sheet>
                    <field name="has_unallocated_materials" invisible="1"/>

                    <!-- Header -->
                    <div class="row mb-3">
                        <div class="col">
                            <label for="mo_id" class="o_form_label text-muted" style="font-size:11px; text-transform:uppercase; letter-spacing:.5px;">Manufacturing Order</label>
                            <field name="mo_id" readonly="1" nolabel="1"
                                   style="font-size:16px; font-weight:600;"/>
                        </div>
                    </div>

                    <!-- Materials table -->
                    <field name="line_ids" nolabel="1">
                        <tree create="false" delete="false" editable="bottom"
                              decoration-muted="qty_to_consume == 0"
                              string="Materials to Allocate">
                            <field name="product_id" readonly="1" string="Product"/>
                            <field name="available_qty" readonly="1" string="Available" widget="float"/>
                            <field name="qty_to_consume" string="Qty" widget="float"/>
                            <field name="uom_id" readonly="1" string="Unit"/>
                            <field name="tracking" column_invisible="1"/>
                            <field name="lot_id"
                                   optional="show"
                                   string="Lot/Serial"
                                   domain="[('product_id', '=', product_id)]"
                                   context="{'default_product_id': product_id}"
                                   invisible="tracking == 'none'"/>
                            <field name="request_line_id" column_invisible="1"/>
                        </tree>
                    </field>

                    <!-- Empty state -->
                    <div class="text-center text-muted py-4" invisible="line_ids">
                        <i class="fa fa-inbox fa-2x mb-2"/>
                        <p class="mb-0">ไม่มีวัสดุที่รอจัดสรร</p>
                        <small>ตรวจสอบว่า Stock Request ถูก validate แล้ว</small>
                    </div>

                    <!-- Tip -->
                    <div class="text-muted mt-2" style="font-size:12px;" invisible="not line_ids">
                        <i class="fa fa-info-circle"/> ปรับ Qty ที่ต้องการ — ใส่ 0 เพื่อข้ามรายการนั้น
                    </div>
                </sheet>

                <footer>
                    <button name="action_allocate" type="object"
                            string="Allocate"
                            class="btn-primary"
                            invisible="not line_ids"/>
                    <button name="action_mark_as_done" type="object"
                            string="Mark as Done"
                            class="btn-secondary"
                            invisible="not has_unallocated_materials"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
