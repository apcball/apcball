<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Allocation Wizard Form View -->
    <record id="view_mrp_stock_request_allocate_wizard_form" model="ir.ui.view">
        <field name="name">mrp.stock.request.allocate.wizard.form</field>
        <field name="model">mrp.stock.request.allocate.wizard</field>
        <field name="arch" type="xml">
            <form string="Allocate Materials to Manufacturing Orders">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="company_id" invisible="1"/>
                </group>
                <notebook>
                    <page string="Allocation Lines" name="allocation_lines">
                        <field name="line_ids">
                            <tree string="Allocations" editable="bottom">
                                <field name="wizard_id" column_invisible="1"/>
                                <field name="request_line_id" column_invisible="1"/>
                                <field name="company_id" column_invisible="1"/>
                                <field name="available_mo_ids" column_invisible="1"/>
                                <field name="product_id" readonly="1"/>
                                <field name="uom_id" readonly="1"/>
                                <field name="available_to_allocate" readonly="1"/>
                                <field name="mo_id" required="1"/>
                                <field name="qty_to_consume" required="1"/>
                                <field name="tracking" column_invisible="1"/>
                                <field name="lot_id" 
                                    attrs="{'required': [('tracking', '!=', 'none')], 
                                            'invisible': [('tracking', '=', 'none')]}"/>
                                <field name="notes"/>
                            </tree>
                        </field>
                        <group>
                            <p class="text-muted">
                                <strong>Instructions:</strong><br/>
                                • Select the Manufacturing Order to allocate materials to<br/>
                                • Enter the quantity to consume (must not exceed "Available to Allocate")<br/>
                                • For tracked products, select the Lot/Serial Number<br/>
                                • You can add multiple lines to allocate the same product to different MOs
                            </p>
                        </group>
                    </page>
                </notebook>
                <footer>
                    <button string="Confirm Allocation" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Allocation Wizard Action -->
    <record id="action_mrp_stock_request_allocate_wizard" model="ir.actions.act_window">
        <field name="name">Allocate Materials to MO</field>
        <field name="res_model">mrp.stock.request.allocate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_mrp_stock_request"/>
    </record>

</odoo>
