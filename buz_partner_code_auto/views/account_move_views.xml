<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="view_move_form_inherit_partner_code" model="ir.ui.view">
        <field name="name">account.move.form.inherit.partner.code</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add partner_code before partner_id on invoice form -->
            <field name="partner_id" position="before">
                <field name="partner_code" placeholder="Enter Partner Code"/>
            </field>
            <!-- Add partner_code column in journal entry lines tree -->
            <xpath expr="//field[@name='line_ids']/tree/field[@name='partner_id']" position="before">
                <field name="partner_code"/>
            </xpath>
        </field>
    </record>
    </data>
</odoo>