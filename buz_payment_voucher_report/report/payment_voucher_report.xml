<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payment Voucher Report QWeb PDF Template -->
    <template id="report_payment_voucher_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <!-- Custom CSS for Payment Voucher Report -->
                    <style>
                        .page {
                            font-family: Arial, sans-serif;
                            font-size: 10px;
                            color: #000;
                        }
                        .report-title {
                            font-size: 18px;
                            font-weight: bold;
                            text-align: center;
                            margin-bottom: 15px;
                            text-transform: uppercase;
                        }
                        .header-table {
                            width: 100%;
                            margin-bottom: 10px;
                        }
                        .header-table td {
                            padding: 3px 10px;
                            vertical-align: top;
                        }
                        .header-label {
                            font-weight: bold;
                            text-align: right;
                            width: 150px;
                        }
                        .journal-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-top: 10px;
                            font-size: 9px;
                        }
                        .journal-table th {
                            background-color: #f0f0f0;
                            border: 1px solid #ccc;
                            padding: 5px;
                            text-align: center;
                            font-weight: bold;
                        }
                        .journal-table td {
                            border: 1px solid #ccc;
                            padding: 4px;
                        }
                        .text-right {
                            text-align: right;
                        }
                        .text-center {
                            text-align: center;
                        }
                        .total-row {
                            font-weight: bold;
                            background-color: #f9f9f9;
                        }
                        .unbalanced {
                            color: #dc3545;
                            font-weight: bold;
                        }
                        .balanced {
                            color: #28a745;
                        }
                        .reconciled-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-top: 15px;
                            font-size: 9px;
                        }
                        .reconciled-table th {
                            background-color: #e8f4f8;
                            border: 1px solid #ccc;
                            padding: 5px;
                            text-align: center;
                            font-weight: bold;
                        }
                        .reconciled-table td {
                            border: 1px solid #ccc;
                            padding: 4px;
                        }
                        .footer-section {
                            margin-top: 30px;
                            page-break-inside: avoid;
                        }
                        .signature-table {
                            width: 100%;
                            margin-top: 40px;
                        }
                        .signature-cell {
                            text-align: center;
                            padding: 20px;
                            border-top: 1px solid #000;
                            width: 25%;
                        }
                        .page-info {
                            text-align: right;
                            font-size: 8px;
                            margin-top: 10px;
                        }
                    </style>

                    <div class="page">
                        <!-- Report Title -->
                        <div class="report-title">Payment Voucher</div>

                        <!-- Payment Header Information -->
                        <table class="header-table">
                            <tr>
                                <td class="header-label">Payment Number:</td>
                                <td><t t-out="o.payment_reference or o.move_id.name if o.move_id else ''"/></td>
                                <td class="header-label">Payment Date:</td>
                                <td><span t-field="o.move_id.date" t-options='{"format": "dd/MM/yyyy"}'/></td>
                            </tr>
                            <tr>
                                <td class="header-label">Partner:</td>
                                <td><span t-field="o.partner_id.name"/></td>
                                <td class="header-label">Journal:</td>
                                <td><span t-field="o.journal_id.name"/></td>
                            </tr>
                            <tr>
                                <td class="header-label">Payment Method:</td>
                                <td><span t-field="o.payment_method_id.name"/></td>
                                <td class="header-label">Currency:</td>
                                <td><span t-field="o.currency_id.name"/></td>
                            </tr>
                            <tr>
                                <td class="header-label">Payment Type:</td>
                                <td>
                                    <t t-if="o.payment_type == 'inbound'">Customer Payment</t>
                                    <t t-elif="o.payment_type == 'outbound'">Vendor Payment</t>
                                    <t t-else="">Internal Transfer</t>
                                </td>
                                <td class="header-label">Reference:</td>
                                <td><t t-out="o.payment_reference or ''"/></td>
                            </tr>
                            <tr>
                                <td class="header-label">Memo:</td>
                                <td><t t-out="o.payment_reference or ''"/></td>
                                <td class="header-label">Move Number:</td>
                                <td><t t-out="o.move_id.name if o.move_id else ''"/></td>
                            </tr>
                            <tr>
                                <td class="header-label">Created By:</td>
                                <td><span t-field="o.create_uid.name"/></td>
                                <td class="header-label">State:</td>
                                <td>
                                    <t t-if="o.state == 'draft'">Draft</t>
                                    <t t-elif="o.state == 'posted'">Posted</t>
                                    <t t-elif="o.state == 'sent'">Sent</t>
                                    <t t-else=""><t t-out="o.state"/></t>
                                </td>
                            </tr>
                        </table>

                        <!-- Journal Items (Move Lines) -->
                        <table class="journal-table">
                            <thead>
                                <tr>
                                    <th style="width: 10%;">Account Code</th>
                                    <th style="width: 20%;">Chart of Account</th>
                                    <th style="width: 15%;">Partner</th>
                                    <th style="width: 20%;">Label</th>
                                    <th style="width: 8%;">Currency</th>
                                    <th style="width: 10%;">Amount Currency</th>
                                    <th style="width: 8%;">Debit</th>
                                    <th style="width: 8%;">Credit</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.move_id.line_ids" t-as="line">
                                    <td><t t-out="line.account_id.code"/></td>
                                    <td><t t-out="line.account_id.name"/></td>
                                    <td><t t-out="line.partner_id.name if line.partner_id else ''"/></td>
                                    <td><t t-out="line.name"/></td>
                                    <td class="text-center"><t t-out="o.currency_id.name"/></td>
                                    <td class="text-right">
                                        <t t-if="line.amount_currency">
                                            <span t-field="line.amount_currency" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.debit" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.credit" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                            <!-- Totals Row -->
                            <t t-set="total_debit" t-value="sum(line.debit for line in o.move_id.line_ids)"/>
                            <t t-set="total_credit" t-value="sum(line.credit for line in o.move_id.line_ids)"/>
                            <t t-set="difference" t-value="total_debit - total_credit"/>
                            <tr class="total-row">
                                <td colspan="6" class="text-right"><strong>Totals:</strong></td>
                                <td class="text-right">
                                    <strong><span t-esc="total_debit" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/></strong>
                                </td>
                                <td class="text-right">
                                    <strong><span t-esc="total_credit" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/></strong>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" class="text-right"><strong>Difference:</strong></td>
                                <td colspan="2" class="text-right">
                                    <strong>
                                        <span t-esc="difference" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                    </strong>
                                    <t t-if="abs(difference) > 0.01">
                                        <span class="unbalanced"> (UNBALANCED)</span>
                                    </t>
                                    <t t-else="">
                                        <span class="balanced"> (Balanced)</span>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <!-- Reconciled Documents -->
                        <t t-set="reconciled_invoices" t-value="o._get_reconciled_invoices()"/>
                        <t t-if="reconciled_invoices">
                            <div style="margin-top: 20px;">
                                <h4 style="font-size: 12px; font-weight: bold;">Reconciled Documents</h4>
                                <table class="reconciled-table">
                                    <thead>
                                        <tr>
                                            <th>Invoice Number</th>
                                            <th>Invoice Date</th>
                                            <th>Partner</th>
                                            <th>Total Amount</th>
                                            <th>Residual</th>
                                            <th>Paid Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="reconciled_invoices" t-as="inv">
                                            <td><t t-out="inv.name"/></td>
                                            <td class="text-center"><span t-field="inv.invoice_date" t-options='{"format": "dd/MM/yyyy"}'/></td>
                                            <td><span t-field="inv.partner_id.name"/></td>
                                            <td class="text-right">
                                                <span t-field="inv.amount_total" t-options='{"widget": "monetary", "display_currency": inv.currency_id}'/>
                                            </td>
                                            <td class="text-right">
                                                <span t-field="inv.amount_residual" t-options='{"widget": "monetary", "display_currency": inv.currency_id}'/>
                                            </td>
                                            <td class="text-right">
                                                <t t-set="paid_amount" t-value="inv.amount_total - inv.amount_residual"/>
                                                <span t-esc="paid_amount" t-options='{"widget": "monetary", "display_currency": inv.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Footer Section -->
                        <div class="footer-section">
                            <table class="signature-table">
                                <tr>
                                    <td class="signature-cell">Prepared By</td>
                                    <td class="signature-cell">Checked By</td>
                                    <td class="signature-cell">Approved By</td>
                                    <td class="signature-cell">Received By</td>
                                </tr>
                                <tr>
                                    <td class="text-center" style="padding-top: 30px;">
                                        (<span t-field="o.create_uid.name"/>)
                                    </td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </table>

                            <!-- Page Info -->
                            <div class="page-info">
                                <span>Print Date: </span>
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M:%S')"/>
                                <span> | Page </span>
                                <span class="page"/>
                                <span> of </span>
                                <span class="topage"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
