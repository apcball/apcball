<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PDF Report Action for Payment Voucher -->
    <record id="action_report_payment_voucher" model="ir.actions.report">
        <field name="name">Payment Voucher (PDF)</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_payment_voucher_report.report_payment_voucher_document</field>
        <field name="report_file">buz_payment_voucher_report.report_payment_voucher_document</field>
        <field name="print_report_name">'Payment Voucher - %s' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_payment_voucher"/>
    </record>

    <!-- XLSX Report Action for Payment Voucher -->
    <record id="action_report_payment_voucher_xlsx" model="ir.actions.report">
        <field name="name">Payment Voucher (XLSX)</field>
        <field name="model">account.payment</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">buz_payment_voucher_report.report_payment_voucher_xlsx</field>
        <field name="report_file">buz_payment_voucher_report.report_payment_voucher_xlsx</field>
        <field name="print_report_name">'Payment Voucher - %s' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
