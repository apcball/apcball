<odoo>

    <!-- Wizard Form View -->
    <record id="payment_voucher_wizard_form" model="ir.ui.view">
        <field name="name">payment.voucher.wizard.form</field>
        <field name="model">buz.payment.voucher.wizard</field>
        <field name="arch" type="xml">
            <form string="Payment Voucher Export">
                <sheet>
                    <group name="filters">
                        <group string="Date Range">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Entity Filters">
                            <field name="partner_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="journal_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="company_id" options="{'no_open': True, 'no_create': True}"/>
                        </group>
                    </group>
                    <group name="attributes">
                        <group string="Payment Attributes">
                            <field name="payment_type"/>
                            <field name="state"/>
                        </group>
                        <group string="Sort Options">
                            <field name="sort_by"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_xlsx"
                            string="Export Excel"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Cancel"
                            type="object"
                            class="oe_link"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_payment_voucher_wizard" model="ir.actions.act_window">
        <field name="name">Payment Voucher Export</field>
        <field name="res_model">buz.payment.voucher.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

</odoo>
