<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_signature" model="ir.ui.view">
        <field name="name">hr.employee.form.signature</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='personal_information']" position="inside">
                <group string="Signature">
                    <field name="signature_image" widget="signature"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
