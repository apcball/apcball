<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="po_landing_page" name="Purchase Order Landing Page">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <style>
                    body {
                        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
                        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                        min-height: 100vh;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        margin: 0;
                        padding: 20px;
                    }
                    .landing-container {
                        background: white;
                        border-radius: 20px;
                        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                        max-width: 500px;
                        width: 100%;
                        padding: 40px 30px;
                        text-align: center;
                    }
                    .icon-wrapper {
                        width: 80px;
                        height: 80px;
                        background: linear-gradient(135deg, #06C755 0%, #05b34a 100%);
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        margin: 0 auto 30px;
                        box-shadow: 0 10px 30px rgba(6, 199, 85, 0.3);
                    }
                    .icon-wrapper svg {
                        width: 40px;
                        height: 40px;
                        fill: white;
                    }
                    h1 {
                        color: #2d3748;
                        font-size: 28px;
                        font-weight: 700;
                        margin: 0 0 15px;
                    }
                    .subtitle {
                        color: #718096;
                        font-size: 16px;
                        margin: 0 0 30px;
                        line-height: 1.6;
                    }
                    .po-info {
                        background: #f7fafc;
                        border-radius: 12px;
                        padding: 20px;
                        margin: 30px 0;
                        text-align: left;
                    }
                    .po-info-item {
                        display: flex;
                        justify-content: space-between;
                        padding: 10px 0;
                        border-bottom: 1px solid #e2e8f0;
                    }
                    .po-info-item:last-child {
                        border-bottom: none;
                    }
                    .po-info-label {
                        color: #718096;
                        font-size: 14px;
                        font-weight: 500;
                    }
                    .po-info-value {
                        color: #2d3748;
                        font-size: 14px;
                        font-weight: 600;
                        text-align: right;
                    }
                    .open-browser-btn {
                        display: inline-block;
                        background: linear-gradient(135deg, #06C755 0%, #05b34a 100%);
                        color: white;
                        text-decoration: none;
                        padding: 16px 40px;
                        border-radius: 12px;
                        font-size: 18px;
                        font-weight: 600;
                        box-shadow: 0 10px 30px rgba(6, 199, 85, 0.3);
                        transition: all 0.3s ease;
                        border: none;
                        cursor: pointer;
                        width: 100%;
                        margin-top: 10px;
                    }
                    .open-browser-btn:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 15px 40px rgba(6, 199, 85, 0.4);
                        color: white;
                        text-decoration: none;
                    }
                    .instruction {
                        background: #fff5f5;
                        border-left: 4px solid #fc8181;
                        padding: 15px;
                        margin: 20px 0;
                        border-radius: 8px;
                        text-align: left;
                    }
                    .instruction-title {
                        color: #c53030;
                        font-weight: 600;
                        font-size: 14px;
                        margin: 0 0 8px;
                    }
                    .instruction-text {
                        color: #742a2a;
                        font-size: 13px;
                        line-height: 1.6;
                        margin: 0;
                    }
                    .action-badge {
                        display: inline-block;
                        padding: 6px 16px;
                        border-radius: 20px;
                        font-size: 13px;
                        font-weight: 600;
                        margin-bottom: 20px;
                    }
                    .action-badge.approve {
                        background: #c6f6d5;
                        color: #22543d;
                    }
                    .action-badge.reject {
                        background: #fed7d7;
                        color: #742a2a;
                    }
                </style>
            </t>
            <div class="landing-container">
                <div class="icon-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                    </svg>
                </div>

                <t t-if="action == 'approve'">
                    <span class="action-badge approve">✓ อนุมัติ</span>
                </t>
                <t t-elif="action == 'reject'">
                    <span class="action-badge reject">✗ ไม่อนุมัติ</span>
                </t>

                <h1>Purchase Order Approval</h1>
                <p class="subtitle">กรุณาเปิดในเบราว์เซอร์เพื่อดำเนินการต่อ</p>

                <div class="po-info">
                    <div class="po-info-item">
                        <span class="po-info-label">เลขที่ PO:</span>
                        <span class="po-info-value"><t t-esc="po.name"/></span>
                    </div>
                    <div class="po-info-item">
                        <span class="po-info-label">ผู้ขาย:</span>
                        <span class="po-info-value"><t t-esc="po.partner_id.name"/></span>
                    </div>
                    <t t-if="po.amount_total">
                        <div class="po-info-item">
                            <span class="po-info-label">จำนวนเงิน:</span>
                            <span class="po-info-value">
                                <t t-esc="'{:,.2f}'.format(po.amount_total)"/> 
                                <t t-esc="po.currency_id.name"/>
                            </span>
                        </div>
                    </t>
                </div>

                <div class="instruction">
                    <p class="instruction-title">⚠️ วิธีการเปิดในเบราว์เซอร์</p>
                    <p class="instruction-text">
                        1. กดปุ่ม "เปิดในเบราว์เซอร์" ด้านล่าง<br/>
                        2. หรือกดที่เมนู ⋮ (มุมบนขวา) แล้วเลือก "เปิดในเบราว์เซอร์"<br/>
                        3. เลือกเบราว์เซอร์ที่ต้องการ (Safari, Chrome, ฯลฯ)
                    </p>
                </div>

                <a t-att-href="approval_url" class="open-browser-btn">
                    🌐 เปิดในเบราว์เซอร์
                </a>
            </div>
        </t>
    </template>
</odoo>
