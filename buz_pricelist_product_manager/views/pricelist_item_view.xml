<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add 'Use Installation Price' checkbox on the pricelist form -->
    <record id="product_pricelist_view_form_inherit_installation_price" model="ir.ui.view">
        <field name="name">product.pricelist.form.installation.price</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <field name="currency_id" position="after">
                <field name="use_installation_price"/>
            </field>
        </field>
    </record>
</odoo>
