<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_invoice_excel" model="ir.actions.report">
        <field name="name">Invoice Excel Report</field>
        <field name="model">account.move</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">buz_report_invoice_excel.report_invoice_xlsx</field>
        <field name="report_file">buz_report_invoice_excel.report_invoice_xlsx</field>
        <field name="print_report_name">'Invoice_Report_%s' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_invoice_excel_wizard" model="ir.actions.report">
        <field name="name">Invoice Excel Report</field>
        <field name="model">buz.invoice.report.excel.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">buz_report_invoice_excel.report_invoice_xlsx_wizard</field>
        <field name="report_file">buz_report_invoice_excel.report_invoice_xlsx_wizard</field>
        <field name="print_report_name">object.report_filename</field>
    </record>
</odoo>
