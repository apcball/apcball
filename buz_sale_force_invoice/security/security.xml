<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_force_invoice_manager" model="res.groups">
            <field name="name">Force Invoice Manager</field>
            <field name="category_id" ref="base.module_category_sales_sales"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="comment">Users in this group can force invoice Sales Orders before delivery.</field>
        </record>

        <record id="rule_force_invoice_wizard_multi_company" model="ir.rule">
            <field name="name">Force Invoice Wizard: multi-company</field>
            <field name="model_id" ref="model_sale_force_invoice_wizard"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
