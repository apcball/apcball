<odoo>
    <record id="view_order_form_inherit_margin" model="ir.ui.view">
        <field name="name">sale.order.form.margin</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
             <!-- Prevent selecting Standard Cost Pricelist -->
             <field name="pricelist_id" position="attributes">
                <attribute name="domain">['&amp;', ('is_standard_cost_pricelist', '=', False), '|', ('company_id', '=', False), ('company_id', '=', company_id)]</attribute>
             </field>
        </field>
    </record>
</odoo>
