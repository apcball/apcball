<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_sales_analytics" model="ir.module.category">
        <field name="name">Sales Analytics</field>
        <field name="parent_id" ref="base.module_category_sales_sales"/>
    </record>

    <record id="group_sales_analytics_user" model="res.groups">
        <field name="name">Sales Analytics User</field>
        <field name="category_id" ref="module_category_sales_analytics"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sales_analytics_manager" model="res.groups">
        <field name="name">Sales Analytics Manager</field>
        <field name="category_id" ref="module_category_sales_analytics"/>
        <field name="implied_ids" eval="[(4, ref('group_sales_analytics_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
