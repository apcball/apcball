<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Nightly full rebuild - safety net for any missed event hooks. -->
    <record id="cron_spe_rebuild_all" model="ir.cron">
        <field name="name">SPE: Rebuild Performance Results</field>
        <field name="model_id" ref="model_buz_sales_performance_result"/>
        <field name="state">code</field>
        <field name="code">model._cron_rebuild_all()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Daily achievement notifications. -->
    <record id="cron_spe_notify_achievements" model="ir.cron">
        <field name="name">SPE: Notify Target Achievements</field>
        <field name="model_id" ref="model_buz_sales_performance_target"/>
        <field name="state">code</field>
        <field name="code">model._cron_notify_achievements()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
