<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================= -->
    <!-- Groups                                                        -->
    <!-- ============================================================= -->
    <record id="group_spe_user" model="res.groups">
        <field name="name">Sales Performance: Own Records</field>
        <field name="category_id" ref="module_category_sales_performance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Access only the performance data where the user is the salesperson.</field>
    </record>

    <record id="group_spe_team_lead" model="res.groups">
        <field name="name">Sales Performance: Team Lead</field>
        <field name="category_id" ref="module_category_sales_performance"/>
        <field name="implied_ids" eval="[(4, ref('group_spe_user'))]"/>
        <field name="comment">Access all performance data for the teams the user leads or belongs to.</field>
    </record>

    <record id="group_spe_manager" model="res.groups">
        <field name="name">Sales Performance: Manager</field>
        <field name="category_id" ref="module_category_sales_performance"/>
        <field name="implied_ids" eval="[(4, ref('group_spe_team_lead'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="comment">Full access to all sales performance data and configuration.</field>
    </record>

    <data noupdate="1">
        <!-- ===================================================== -->
        <!-- buz.sales.performance.result                          -->
        <!-- ===================================================== -->
        <!-- User: own rows only (where salesperson = user) -->
        <record id="rule_spe_result_user_own" model="ir.rule">
            <field name="name">SPE Result: user reads own rows</field>
            <field name="model_id" ref="model_buz_sales_performance_result"/>
            <field name="domain_force">[('salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_spe_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Team lead: rows of any team the user is member or leader of -->
        <record id="rule_spe_result_team_lead" model="ir.rule">
            <field name="name">SPE Result: team lead reads team rows</field>
            <field name="model_id" ref="model_buz_sales_performance_result"/>
            <field name="domain_force">['|', ('salesperson_id', '=', user.id),
                                              ('team_id.member_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('group_spe_team_lead'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: everything -->
        <record id="rule_spe_result_manager" model="ir.rule">
            <field name="name">SPE Result: manager full access</field>
            <field name="model_id" ref="model_buz_sales_performance_result"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_spe_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Multi-company global rule -->
        <record id="rule_spe_result_company" model="ir.rule">
            <field name="name">SPE Result: multi-company</field>
            <field name="model_id" ref="model_buz_sales_performance_result"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- ===================================================== -->
        <!-- buz.sales.performance.target                          -->
        <!-- ===================================================== -->
        <record id="rule_spe_target_user_own" model="ir.rule">
            <field name="name">SPE Target: user sees own / company targets</field>
            <field name="model_id" ref="model_buz_sales_performance_target"/>
            <field name="domain_force">['|', ('target_type', '=', 'company'),
                                              ('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_spe_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_spe_target_team_lead" model="ir.rule">
            <field name="name">SPE Target: lead sees own + team targets</field>
            <field name="model_id" ref="model_buz_sales_performance_target"/>
            <field name="domain_force">['|', ('target_type', '=', 'company'),
                                              '|', ('user_id', '=', user.id),
                                                   ('team_id.member_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('group_spe_team_lead'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_spe_target_manager" model="ir.rule">
            <field name="name">SPE Target: manager full access</field>
            <field name="model_id" ref="model_buz_sales_performance_target"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_spe_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_spe_target_company" model="ir.rule">
            <field name="name">SPE Target: multi-company</field>
            <field name="model_id" ref="model_buz_sales_performance_target"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
    </data>
</odoo>
