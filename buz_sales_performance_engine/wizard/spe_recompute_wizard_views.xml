<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_spe_recompute_wizard_form" model="ir.ui.view">
        <field name="name">buz.spe.recompute.wizard.form</field>
        <field name="model">buz.spe.recompute.wizard</field>
        <field name="arch" type="xml">
            <form string="Recompute Performance">
                <group>
                    <field name="mode" widget="radio"/>
                    <field name="date_from" invisible="mode != 'range'"/>
                    <field name="date_to" invisible="mode != 'range'"/>
                    <field name="sale_order_ids" widget="many2many_tags"
                           invisible="mode != 'orders'"/>
                </group>
                <footer>
                    <button string="Recompute" type="object" name="action_recompute"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_spe_recompute_wizard" model="ir.actions.act_window">
        <field name="name">Recompute Performance</field>
        <field name="res_model">buz.spe.recompute.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
