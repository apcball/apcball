<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====== Claim Tree View ====== -->
    <record id="view_service_claim_tree" model="ir.ui.view">
        <field name="name">service.claim.tree</field>
        <field name="model">service.receipt</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <tree string="Claims"
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('waiting_replacement','product_return','replacement_delivery')"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancel'">
                <field name="claim_number"/>
                <field name="partner_id"/>
                <field name="request_date"/>
                <field name="service_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- ====== Claim Form View ====== -->
    <record id="view_service_claim_form" model="ir.ui.view">
        <field name="name">service.claim.form</field>
        <field name="model">service.receipt</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Claim">
                <header>
                    <!-- Hidden fields for invisible expressions -->
                    <field name="charge_customer" invisible="1"/>
                    <field name="invoice_status" invisible="1"/>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="return_picking_id" invisible="1"/>
                    <field name="replacement_picking_id" invisible="1"/>

                    <button name="action_print_claim_pdf" string="Print Claim PDF" type="object" class="btn-primary"/>
                    <button name="action_confirm" string="Confirm" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <!-- Claim: Return Picking -->
                    <button name="action_create_return_picking" string="Receive Return"
                            type="object" class="btn-warning"
                            invisible="state not in ['confirmed', 'product_return']"/>
                    <button name="action_view_return_picking" string="View Return"
                            type="object" class="btn-info"
                            invisible="not return_picking_id"/>
                    <!-- Claim: Replacement Delivery -->
                    <button name="action_create_replacement_picking" string="Send Replacement"
                            type="object" class="btn-warning"
                            invisible="state not in ['product_return', 'replacement_delivery']"/>
                    <button name="action_view_replacement_picking" string="View Replacement"
                            type="object" class="btn-info"
                            invisible="not replacement_picking_id"/>
                    <!-- Charge Customer: Create SO -->
                    <button name="action_create_sale_order" string="Create SO"
                            type="object" class="btn-warning"
                            invisible="invoice_status != 'to_invoice'"/>
                    <button name="action_view_sale_order" string="View SO"
                            type="object" class="btn-info"
                            invisible="not sale_order_id"/>
                    <button name="action_done" string="Done" type="object"
                            invisible="state not in ['confirmed','waiting_replacement','product_return','replacement_delivery']"
                            class="btn-success"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state == 'cancel'"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,product_return,replacement_delivery,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Smart Button: Return Picking -->
                        <button class="oe_stat_button" type="object"
                                name="action_view_return_picking" icon="fa-truck"
                                invisible="not return_picking_id"
                                help="View return picking">
                            <field name="return_picking_count" widget="statinfo" string="Return"/>
                        </button>
                        <!-- Smart Button: Replacement Picking -->
                        <button class="oe_stat_button" type="object"
                                name="action_view_replacement_picking" icon="fa-truck"
                                invisible="not replacement_picking_id"
                                help="View replacement delivery">
                            <field name="replacement_picking_count" widget="statinfo" string="Replacement"/>
                        </button>
                        <!-- Smart Button: Sale Order -->
                        <button class="oe_stat_button" type="object"
                                name="action_view_sale_order" icon="fa-shopping-cart"
                                invisible="not sale_order_id"
                                help="View sale order">
                            <field name="sale_order_count" widget="statinfo" string="SO"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="claim_number" readonly="state != 'draft'"/>
                        </h1>
                    </div>

                    <!-- Customer & Info — compact 2-col -->
                    <div class="row">
                        <div class="col-6">
                            <group string="Customer">
                                <field name="partner_id"/>
                                <field name="requester_name"/>
                                <field name="requester_phone"/>
                                <field name="service_address"/>
                            </group>
                        </div>
                        <div class="col-6">
                            <group string="Info">
                                <field name="request_date"/>
                                <field name="service_date"/>
                                <field name="replacement_date"/>
                                <field name="replacement_reason"/>
                            </group>
                        </div>
                    </div>

                    <notebook>
                        <page string="Products">
                            <field name="line_ids" context="{'default_resolution_type': 'replace'}">
                                <tree editable="bottom" string="Claim Items">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" string="Product"/>
                                    <field name="description" string="Description"/>
                                    <field name="quantity" string="Qty"/>
                                    <field name="replacement_product_id" string="Replacement Code"/>
                                    <field name="replacement_qty" string="Replacement Qty"/>
                                    <field name="price_unit" string="Extra Cost"/>
                                    <field name="issue_detail" string="Issue"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Pickings">
                            <group>
                                <group string="Return from Customer">
                                    <field name="return_picking_id" readonly="1"/>
                                    <button name="action_view_return_picking" string="View Return"
                                            type="object" class="btn-primary"
                                            invisible="not return_picking_id"/>
                                </group>
                                <group string="Replacement Delivery">
                                    <field name="replacement_picking_id" readonly="1"/>
                                    <button name="action_view_replacement_picking" string="View Replacement"
                                            type="object" class="btn-primary"
                                            invisible="not replacement_picking_id"/>
                                </group>
                            </group>
                        </page>

                        <page string="Sale Order" invisible="not sale_order_id">
                            <group>
                                <field name="sale_order_id" readonly="1"/>
                                <button name="action_view_sale_order" string="View Sale Order"
                                        type="object" class="btn-primary"/>
                            </group>
                        </page>

                        <page string="Product Condition">
                            <group>
                                <field name="box_condition"/>
                                <field name="product_condition"/>
                                <field name="accessory_condition"/>
                                <field name="repair_detail" nolabel="1" placeholder="Repair detail…"/>
                            </group>
                        </page>

                        <page string="Billing">
                            <field name="line_ids">
                                <tree editable="bottom" string="Billable Lines">
                                    <field name="product_id" string="Product"/>
                                    <field name="replacement_product_id" string="Replacement"/>
                                    <field name="bill_customer" string="Bill"/>
                                    <field name="invoice_qty" string="Invoice Qty"/>
                                    <field name="price_unit" string="Unit Price"/>
                                    <field name="invoice_description" string="Description"/>
                                </tree>
                            </field>
                            <group colspan="2">
                                <field name="invoice_status" string="Invoice Status" readonly="1"/>
                                <field name="sale_order_id" string="Sale Order" readonly="1"/>
                            </group>
                        </page>

                        <page string="Signatures">
                            <group>
                                <group string="Service Provider">
                                    <field name="service_by_name"/>
                                    <field name="service_by_date"/>
                                </group>
                                <group string="Service Receiver">
                                    <field name="customer_sign_name"/>
                                    <field name="customer_sign_date"/>
                                </group>
                                <group string="Approver">
                                    <field name="approver_name"/>
                                </group>
                            </group>
                        </page>

                        <page string="Note">
                            <field name="note" nolabel="1" placeholder="Remark / Notes…"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ====== Claim Search View ====== -->
    <record id="view_service_claim_search" model="ir.ui.view">
        <field name="name">service.claim.search</field>
        <field name="model">service.receipt</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <search string="Claims">
                <field name="claim_number"/>
                <field name="partner_id"/>
                <field name="requester_name"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Waiting Replacement" name="waiting_replacement" domain="[('state', '=', 'waiting_replacement')]"/>
                <filter string="Product Return" name="product_return" domain="[('state', '=', 'product_return')]"/>
                <filter string="Replacement Delivery" name="replacement_delivery" domain="[('state', '=', 'replacement_delivery')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('request_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Request Date" name="group_request_date" context="{'group_by': 'request_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ====== Claim Action ====== -->
    <record id="action_service_claim" model="ir.actions.act_window">
        <field name="name">Claims</field>
        <field name="res_model">service.receipt</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('service_case_type', '=', 'replacement')]</field>
        <field name="context">{'default_service_case_type': 'replacement'}</field>
        <field name="search_view_id" ref="view_service_claim_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first claim</p>
            <p>Manage product claims, track return and replacement pickings.</p>
        </field>
    </record>

    <record id="action_service_claim_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_service_claim_tree"/>
        <field name="act_window_id" ref="action_service_claim"/>
    </record>

    <record id="action_service_claim_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_service_claim_form"/>
        <field name="act_window_id" ref="action_service_claim"/>
    </record>

    <!-- ====== Claim Menu ====== -->
    <menuitem id="menu_service_claim"
              name="Claims"
              parent="menu_service_receipt_root"
              sequence="15"
              action="action_service_claim"/>

</odoo>
