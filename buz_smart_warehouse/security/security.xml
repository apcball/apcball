<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_smart_warehouse" model="ir.module.category">
        <field name="name">Smart Warehouse</field>
        <field name="sequence">60</field>
    </record>

    <record id="group_smart_warehouse_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_smart_warehouse"/>
        <field name="implied_ids" eval="[Command.link(ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_smart_warehouse_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_smart_warehouse"/>
        <field name="implied_ids" eval="[Command.link(ref('group_smart_warehouse_user'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_admin'))]"/>
    </record>
</odoo>
