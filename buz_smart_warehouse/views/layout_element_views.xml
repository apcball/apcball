<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_layout_element_tree" model="ir.ui.view">
        <field name="name">buz.warehouse.layout.element.tree</field>
        <field name="model">buz.warehouse.layout.element</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="element_type"/>
                <field name="zone_type"/>
                <field name="warehouse_id"/>
                <field name="pos_x"/>
                <field name="pos_y"/>
                <field name="width"/>
                <field name="height"/>
                <field name="rotation"/>
            </tree>
        </field>
    </record>

    <record id="view_warehouse_layout_element_form" model="ir.ui.view">
        <field name="name">buz.warehouse.layout.element.form</field>
        <field name="model">buz.warehouse.layout.element</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="element_type"/>
                            <field name="zone_type" invisible="element_type != 'zone'"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group>
                            <field name="pos_x"/>
                            <field name="pos_y"/>
                            <field name="width"/>
                            <field name="height"/>
                            <field name="rotation"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_warehouse_layout_element" model="ir.actions.act_window">
        <field name="name">Layout Elements</field>
        <field name="res_model">buz.warehouse.layout.element</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No layout elements yet</p>
            <p>
                Zones, aisles, obstacles and text labels drawn on the
                Layout Designer are stored here.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_smart_warehouse_layout_element"
        name="Layout Elements"
        parent="menu_smart_warehouse_root"
        action="action_warehouse_layout_element"
        sequence="21"
        groups="buz_smart_warehouse.group_smart_warehouse_manager"
    />
</odoo>
