<odoo>

    <record id="view_stock_current_report_tree" model="ir.ui.view">
        <field name="name">stock.current.report.tree</field>
        <field name="model">stock.current.report</field>
        <field name="arch" type="xml">
            <tree string="Current Stock Report" edit="false" create="false" delete="false"
                  decoration-danger="quantity &lt;= 0"
                  decoration-warning="quantity &gt; 0 and quantity &lt; 10"
                  decoration-info="quantity &gt;= 10">
                <field name="warehouse_id" optional="show"/>
                <field name="location_id"/>
                <field name="product_id"/>
                <field name="quantity" string="On Hand" sum="Total" widget="progressbar"/>
                <field name="free_to_use" string="Free to Use" sum="Total" optional="show"/>
                <field name="incoming" sum="Total" optional="show"/>
                <field name="outgoing" sum="Total" optional="show"/>
                <field name="unit_cost" string="Unit Cost" sum="Total" widget="monetary"/>
                <field name="total_value" string="Total Value" sum="Total" widget="monetary"/>
                <field name="uom_id" string="Unit" optional="hide"/>
                <button name="action_view_product_moves" type="object" string="Stock Moves" icon="fa-arrows-alt" invisible="quantity == 0"/>
            </tree>
        </field>
    </record>

    <record id="view_stock_current_report_form" model="ir.ui.view">
        <field name="name">stock.current.report.form</field>
        <field name="model">stock.current.report</field>
        <field name="arch" type="xml">
            <form string="Current Stock" create="false" delete="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="product_id" readonly="1"/>
                            <field name="warehouse_id" readonly="1"/>
                            <field name="location_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="unit_cost" readonly="1"/>
                            <field name="total_value" readonly="1"/>
                            <field name="uom_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Quantities">
                        <field name="quantity" readonly="1"/>
                        <field name="free_to_use" readonly="1"/>
                        <field name="incoming" readonly="1"/>
                        <field name="outgoing" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Enhanced Search View with Warehouse and Location Hierarchy -->
    <record id="view_stock_current_report_search" model="ir.ui.view">
        <field name="name">stock.current.report.search</field>
        <field name="model">stock.current.report</field>
        <field name="arch" type="xml">
            <search string="Stock Filters">
                <!-- Sidebar with Warehouse and Internal Location Hierarchy -->
                <searchpanel>
                    <field name="warehouse_id" string="Warehouse" icon="fa-building" enable_counters="1" hierarchize="1"/>
                    <field name="location_id" string="Location" icon="fa-map-marker" enable_counters="1" hierarchize="1"/>
                </searchpanel>
                
                <!-- Quick Filters -->
                <filter string="Low Stock" name="low_stock" domain="[('quantity', '&lt;', 10)]"/>
                <filter string="Out of Stock" name="out_of_stock" domain="[('quantity', '&lt;=', 0)]"/>
                <filter string="In Stock" name="in_stock" domain="[('quantity', '&gt;', 0)]"/>
                <separator/>
                <filter string="High Value" name="high_value" domain="[('total_value', '&gt;', 1000)]"/>
                <filter string="With Incoming" name="with_incoming" domain="[('incoming', '&gt;', 0)]"/>
                <filter string="With Outgoing" name="with_outgoing" domain="[('outgoing', '&gt;', 0)]"/>
                <separator/>
                <filter string="Internal Locations" name="internal_locations" domain="[('location_usage', '=', 'internal')]"/>
                <separator/>
                
                <!-- Search Fields -->
                <field name="product_id" string="Product"/>
                <field name="warehouse_id" string="Warehouse"/>
                <field name="location_id" string="Location"/>
                
                <!-- Group By Options -->
                <group expand="0" string="Group By">
                    <filter string="Warehouse" name="group_warehouse" context="{'group_by':'warehouse_id'}"/>
                    <filter string="Location" name="group_location" context="{'group_by':'location_id'}"/>
                    <filter string="Product" name="group_product" context="{'group_by':'product_id'}"/>
                    <filter string="UoM" name="group_uom" context="{'group_by':'uom_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Kanban View for Visual Stock Overview -->
    <record id="view_stock_current_report_kanban" model="ir.ui.view">
        <field name="name">stock.current.report.kanban</field>
        <field name="model">stock.current.report</field>
        <field name="arch" type="xml">
            <kanban string="Stock Overview" default_group_by="location_id"
                    class="o_kanban_small_column">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="quantity"/>
                <field name="total_value"/>
                <field name="unit_cost"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.quantity.raw_value &lt;= 0 ? 'oe_kanban_color_4' : record.quantity.raw_value &lt; 10 ? 'oe_kanban_color_2' : 'oe_kanban_color_0'}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="product_id"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle text-muted">
                                        <field name="location_id"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="row">
                                    <div class="col-6">
                                        <strong>Qty:</strong> <field name="quantity"/>
                                    </div>
                                    <div class="col-6">
                                        <strong>Value:</strong> <field name="total_value" widget="monetary"/>
                                    </div>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-6">
                                        <small class="text-muted">Unit Cost: <field name="unit_cost" widget="monetary"/></small>
                                    </div>
                                    <div class="col-6">
                                        <button class="btn btn-sm btn-primary float-right"
                                                name="action_view_product_moves" type="object">
                                            <i class="fa fa-arrows-alt"/> Moves
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_stock_current_report" model="ir.actions.act_window">
        <field name="name">Current Stock Report</field>
        <field name="res_model">stock.current.report</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_group_location': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Current Stock Report Dashboard
            </p>
            <p>
                View current stock quantities with unit cost, total value, and inbound/outbound movements.
                Use the sidebar to filter by location hierarchy and warehouse navigation.
            </p>
        </field>
    </record>

    <!-- Action with Warehouse Sidebar -->
    <record id="action_stock_current_report_sidebar" model="ir.actions.act_window">
        <field name="name">Current Stock Report with Warehouse Sidebar</field>
        <field name="res_model">stock.current.report</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_stock_current_report_kanban')}),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_stock_current_report_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_stock_current_report_form')})
        ]"/>
        <field name="context">{'search_default_group_location': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Current Stock Report with Warehouse Navigation
            </p>
            <p>
                Navigate warehouses and locations using the sidebar. Click on warehouses to expand and see locations,
                then click on any location to filter the stock report for that specific location.
            </p>
        </field>
    </record>

    <record id="action_stock_current_export_wizard" model="ir.actions.act_window">
        <field name="name">Export to Excel</field>
        <field name="res_model">stock.current.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_stock_current_report_root"
              name="Current Stock Report"
              parent="stock.menu_warehouse_report"
              sequence="15"/>

    <menuitem id="menu_stock_current_report_sidebar"
              name="Current Stock View"
              parent="menu_stock_current_report_root"
              action="action_stock_current_report_sidebar"
              sequence="5"/>

    <menuitem id="menu_stock_current_export_wizard"
              name="Export Stock to Excel"
              parent="menu_stock_current_report_root"
              action="action_stock_current_export_wizard"
              sequence="20"/>
</odoo>