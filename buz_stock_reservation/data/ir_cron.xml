<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_expire_reservations" model="ir.cron">
            <field name="name">Reservations: Expire Past-Due</field>
            <field name="model_id" ref="model_buz_stock_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_reservations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_notify_expiring_soon" model="ir.cron">
            <field name="name">Reservations: Notify Expiring Soon</field>
            <field name="model_id" ref="model_buz_stock_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_notify_expiring_soon()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
