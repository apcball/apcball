<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_buz_reservation" model="ir.module.category">
        <field name="name">Product Reservations</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_buz_reservation_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_buz_reservation"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_buz_reservation_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_buz_reservation"/>
        <field name="implied_ids" eval="[(4, ref('group_buz_reservation_user'))]"/>
    </record>

    <record id="rule_buz_reservation_company" model="ir.rule">
        <field name="name">Reservation: multi-company</field>
        <field name="model_id" ref="model_buz_stock_reservation"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
