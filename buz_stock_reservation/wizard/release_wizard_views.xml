<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="release_wizard_form_view" model="ir.ui.view">
        <field name="name">buz.reservation.release.wizard.form</field>
        <field name="model">buz.reservation.release.wizard</field>
        <field name="arch" type="xml">
            <form string="Release Reservation">
                <group>
                    <field name="reservation_id" invisible="1"/>
                    <field name="release_reason_id" options="{'no_create_edit': True}"/>
                    <field name="note"/>
                </group>
                <field name="line_ids">
                    <tree editable="bottom" create="false" delete="false">
                        <field name="reservation_line_id" column_invisible="1"/>
                        <field name="product_id"/>
                        <field name="remaining_qty"/>
                        <field name="release_qty"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_release" string="Release" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
