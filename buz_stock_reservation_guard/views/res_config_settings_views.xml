<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_stock_reservation_guard" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.stock.reservation.guard</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Stock Reservation Guard" name="buz_stock_reservation_guard">
                    <block title="Bypass Locations">
                        <setting string="Bypass Locations"
                                 help="Stock reservations from these locations will not be blocked by the guard.">
                            <field name="bypass_reservation_guard_location_ids" widget="many2many_tags"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
