<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_res_config_settings_form_inherit_stock_reservation_guard"
                model="ir.ui.view">
            <field name="name">res.config.settings.form.inherit.stock.reservation.guard</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='settings']" position="inside">
                    <block title="Stock Reservation Guard" name="stock_reservation_guard">
                        <label for="stock_reservation_guard_bypass_location_ids"
                               string="Stock Locations (Bypass Reservation Guard)"/>
                        <div>
                            <field name="stock_reservation_guard_bypass_location_ids"
                                   nolabel="1"
                                   groups="stock.group_stock_manager"/>
                        </div>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
