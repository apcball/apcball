<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_buz_tr_bank_export" model="ir.actions.report">
        <field name="name">Bank Export Document</field>
        <field name="model">buz.tr.bank.export</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">buz_tr_bank_export.report_bank_export</field>
        <field name="report_file">buz_tr_bank_export.report_bank_export</field>
        <field name="print_report_name">'Bank Export - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_buz_tr_bank_export"/>
        <field name="binding_type">report</field>
    </record>

    <record id="paperformat_bank_export" model="report.paperformat">
        <field name="name">Bank Export Paperformat</field>
        <field name="default" eval="True" />
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">10</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_buz_tr_bank_export" model="ir.actions.report">
        <field name="paperformat_id" ref="buz_tr_bank_export.paperformat_bank_export"/>
    </record>
</odoo>
