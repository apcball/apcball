<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_buz_unbuild_user" model="res.groups">
            <field name="name">Buz Unbuild User</field>
            <field name="category_id" ref="base.module_category_manufacturing_manufacturing"/>
            <field name="implied_ids" eval="[(4, ref('mrp.group_mrp_user'))]"/>
        </record>

        <record id="group_buz_unbuild_manager" model="res.groups">
            <field name="name">Buz Unbuild Manager</field>
            <field name="category_id" ref="base.module_category_manufacturing_manufacturing"/>
            <field name="implied_ids" eval="[(4, ref('group_buz_unbuild_user'))]"/>
        </record>

        <!-- Record Rules for Multi-company -->
        <record id="rule_mrp_unbuild_multi_company" model="ir.rule">
            <field name="name">Unbuild Order multi-company</field>
            <field name="model_id" ref="mrp.model_mrp_unbuild"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_buz_unbuild_user')), (4, ref('group_buz_unbuild_manager'))]"/>
        </record>
    </data>
</odoo>
