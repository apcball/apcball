<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View - Override standard mrp.unbuild tree -->
        <record id="view_mrp_unbuild_tree_buz" model="ir.ui.view">
            <field name="name">mrp.unbuild.tree</field>
            <field name="model">mrp.unbuild</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <tree string="Unbuild Orders" default_order="create_date desc">
                    <field name="name"/>
                    <field name="product_id"/>
                    <field name="bom_id"/>
                    <field name="product_qty"/>
                    <field name="picking_id"/>
                    <field name="state" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Form View - Override standard mrp.unbuild form -->
        <record id="view_mrp_unbuild_form_buz" model="ir.ui.view">
            <field name="name">mrp.unbuild.form</field>
            <field name="model">mrp.unbuild</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Unbuild Order">
                    <header>
                        <button name="action_create_picking"
                                type="object"
                                string="Create Picking"
                                class="oe_highlight"
                                invisible="state != 'draft' or picking_id"/>
                        <button name="action_done"
                                type="object"
                                string="Mark Done"
                                class="btn-primary"
                                invisible="state not in ('draft', 'picking')"/>
                        <button name="action_view_picking"
                                type="object"
                                string="Open Picking"
                                invisible="not picking_id"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,picking,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_picking"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-truck"
                                    invisible="not picking_id">
                                <field name="picking_count" widget="statinfo" string="Picking"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="product_id"/>
                                <field name="bom_id"/>
                                <field name="product_qty"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="picking_id" readonly="1"/>
                                <field name="state" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View - Override standard mrp.unbuild search -->
        <record id="view_mrp_unbuild_search_buz" model="ir.ui.view">
            <field name="name">mrp.unbuild.search</field>
            <field name="model">mrp.unbuild</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <search string="Search Unbuild Orders">
                    <field name="product_id"/>
                    <field name="bom_id"/>
                    <field name="picking_id"/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Picking" name="picking" domain="[('state', '=', 'picking')]"/>
                    <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>
