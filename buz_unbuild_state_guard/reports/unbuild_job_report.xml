<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="paperformat_buz_unbuild_job" model="report.paperformat">
            <field name="name">BUZ Unbuild Job A4</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">6</field>
            <field name="margin_right">6</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="report_unbuild_job" model="ir.actions.report">
            <field name="name">ใบเปิด/ปิด JOB แยกส่วนประกอบ</field>
            <field name="model">mrp.unbuild</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">buz_unbuild_state_guard.report_unbuild_job_document</field>
            <field name="report_file">buz_unbuild_state_guard.report_unbuild_job_document</field>
            <field name="print_report_name">'ใบเปิด Job แยกส่วนประกอบ - %s' % (object.name or '')</field>
            <field name="paperformat_id" ref="buz_unbuild_state_guard.paperformat_buz_unbuild_job"/>
            <field name="binding_model_id" ref="mrp.model_mrp_unbuild"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_unbuild_job_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <style>
                            @font-face {
                                font-family: 'Sarabun';
                                src: url('/buz_unbuild_state_guard/static/fonts/Sarabun-Bold.ttf') format('truetype');
                            }
                            .page {
                                font-family: 'Sarabun', sans-serif;
                                font-size: 20px;
                            }
                            table, td, th, div, span, h2, h5, body {
                                font-family: 'Sarabun', sans-serif !important;
                                font-weight: bold;
                            }
                        </style>
                        <div class="page">

                            <!-- Title -->
                            <div class="text-center mb-4">
                                <h2 t-if="doc.state == 'done'" style="margin:0; font-weight:bold;">ใบปิด Job แยกส่วนประกอบ</h2>
                                <h2 t-else="" style="margin:0; font-weight:bold;">ใบเปิด Job แยกส่วนประกอบ</h2>
                            </div>

                            <!-- Header Info Table -->
                            <table class="table table-sm table-bordered">
                                <tbody>
                                    <tr>
                                        <td style="width:20%; background-color:#f0f0f0; font-weight:bold;">เลขที่ Job</td>
                                        <td style="width:30%;"><span t-field="doc.name"/></td>
                                        <td style="width:20%; background-color:#f0f0f0; font-weight:bold;">วันที่</td>
                                        <td style="width:30%;"><span t-field="doc.create_date" t-options="{'widget': 'date'}"/></td>
                                    </tr>
                                    <tr>
                                        <td style="background-color:#f0f0f0; font-weight:bold;">สถานะ</td>
                                        <td>
                                            <t t-if="doc.state == 'draft'">Draft</t>
                                            <t t-elif="doc.state == 'picking'">Picking</t>
                                            <t t-elif="doc.state == 'confirm'">Confirmed</t>
                                            <t t-elif="doc.state == 'cancel'">Cancelled</t>
                                            <t t-elif="doc.state == 'done'">Done</t>
                                            <t t-else=""><span t-field="doc.state"/></t>
                                        </td>
                                        <td style="background-color:#f0f0f0; font-weight:bold;">ผู้สร้าง</td>
                                        <td><span t-field="doc.create_uid"/></td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Product Info Table -->
                            <table class="table table-sm table-bordered mt-3">
                                <tbody>
                                    <tr>
                                        <td style="width:20%; background-color:#f0f0f0; font-weight:bold;">สินค้าที่แยก</td>
                                        <td style="width:30%;"><span t-field="doc.product_id"/></td>
                                        <td style="width:20%; background-color:#f0f0f0; font-weight:bold;">จำนวน</td>
                                        <td style="width:30%;"><span t-field="doc.product_qty"/> <span t-field="doc.product_uom_id"/></td>
                                    </tr>
                                    <tr>
                                        <td style="background-color:#f0f0f0; font-weight:bold;">BOM</td>
                                        <td><span t-field="doc.bom_id"/></td>
                                        <td style="background-color:#f0f0f0; font-weight:bold;">Lot/Serial</td>
                                        <td>
                                            <span t-if="doc.lot_id" t-field="doc.lot_id"/>
                                            <span t-else="">-</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color:#f0f0f0; font-weight:bold;">ต้นทาง</td>
                                        <td><span t-field="doc.location_id"/></td>
                                        <td style="background-color:#f0f0f0; font-weight:bold;">ปลายทาง</td>
                                        <td><span t-field="doc.location_dest_id"/></td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Components Table -->
                            <div class="mt-3">
                                <h5 t-if="doc.state == 'done'" style="margin:0; font-weight:bold;">รายการส่วนประกอบที่ได้</h5>
                                <h5 t-else="" style="margin:0; font-weight:bold;">รายการส่วนประกอบที่คาดว่าจะได้</h5>
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr style="background-color:#f0f0f0;">
                                            <th style="width:5%; text-align:center;">ลำดับ</th>
                                            <th style="width:35%;">ส่วนประกอบ</th>
                                            <th style="width:10%; text-align:center;">จำนวน</th>
                                            <th style="width:10%; text-align:center;">หน่วย</th>
                                            <th style="width:15%;">ตำแหน่งปลายทาง</th>
                                            <th style="width:25%;">หมายเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- ใบปิด Job: แสดงตาม stock move จริงที่เกิดจากการแตก unbuild
                                             อิงตาม produce_line_ids แทน bom_line_ids เพราะการแตก BOM
                                             อาจได้ส่วนประกอบต่างจากใน BOM (phantom/sub-assembly/substitute) -->
                                        <t t-if="doc.produce_line_ids">
                                            <!-- แสดงเฉพาะตัวลูกที่แยกออกมา ไม่แสดงตัวแม่ (สินค้าที่ถูกแยก = doc.product_id) -->
                                            <t t-set="line_num" t-value="0"/>
                                            <t t-foreach="doc.produce_line_ids" t-as="move">
                                                <t t-if="move.product_id != doc.product_id">
                                                    <t t-set="line_num" t-value="line_num + 1"/>
                                                    <tr>
                                                        <td class="text-center"><t t-esc="line_num"/></td>
                                                        <td><span t-field="move.product_id"/></td>
                                                        <td class="text-center"><span t-field="move.quantity"/></td>
                                                        <td class="text-center"><span t-field="move.product_uom"/></td>
                                                        <td><span t-field="move.location_dest_id"/></td>
                                                        <td><span t-esc="', '.join(move.move_line_ids.mapped('lot_id').mapped('name'))"/></td>
                                                    </tr>
                                                </t>
                                            </t>
                                            <t t-if="not line_num">
                                                <tr>
                                                    <td colspan="6" class="text-center text-muted">ไม่มีข้อมูลส่วนประกอบที่แยกได้</td>
                                                </tr>
                                            </t>
                                        </t>
                                        <!-- ใบเปิด Job (ยังไม่ done): ยังไม่มี stock move จริง จึงประมาณการจาก BOM -->
                                        <t t-elif="doc.bom_id and doc.bom_id.bom_line_ids">
                                            <t t-set="line_num" t-value="0"/>
                                            <tr t-foreach="doc.bom_id.bom_line_ids" t-as="line">
                                                <t t-set="line_num" t-value="line_num + 1"/>
                                                <td class="text-center"><t t-esc="line_num"/></td>
                                                <td><span t-field="line.product_id"/></td>
                                                <td class="text-center"><span t-esc="line.product_qty * doc.product_qty"/></td>
                                                <td class="text-center"><span t-field="line.product_uom_id"/></td>
                                                <td><span t-field="doc.location_dest_id"/></td>
                                                <td></td>
                                            </tr>
                                        </t>
                                        <t t-else="">
                                            <tr>
                                                <td colspan="6" class="text-center text-muted">ไม่มีข้อมูลส่วนประกอบ</td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Picking Info -->
                            <div class="mt-3" t-if="doc.picking_id">
                                <h5 style="font-weight:bold; margin-bottom:4px;">ข้อมูล Picking</h5>
                                <table class="table table-sm table-bordered">
                                    <tbody>
                                        <tr>
                                            <td style="width:20%; background-color:#f0f0f0; font-weight:bold;">เลขที่ Picking</td>
                                            <td style="width:30%;"><span t-field="doc.picking_id"/></td>
                                            <td style="width:20%; background-color:#f0f0f0; font-weight:bold;">สถานะ Picking</td>
                                            <td style="width:30%;">
                                                <t t-if="doc.picking_id.state == 'draft'">Draft</t>
                                                <t t-elif="doc.picking_id.state == 'waiting'">Waiting</t>
                                                <t t-elif="doc.picking_id.state == 'confirmed'">Waiting Availability</t>
                                                <t t-elif="doc.picking_id.state == 'assigned'">Ready</t>
                                                <t t-elif="doc.picking_id.state == 'done'">Done</t>
                                                <t t-elif="doc.picking_id.state == 'cancel'">Cancelled</t>
                                                <t t-else=""><span t-field="doc.picking_id.state"/></t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="background-color:#f0f0f0; font-weight:bold;">ประเภท Picking</td>
                                            <td><span t-field="doc.picking_id.picking_type_id"/></td>
                                            <td style="background-color:#f0f0f0; font-weight:bold;">วันที่กำหนดส่ง</td>
                                            <td><span t-field="doc.picking_id.scheduled_date" t-options="{'widget': 'date'}"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Signature / Approval Section -->
                            <div class="mt-5">
                                <table class="table table-bordered" style="table-layout:fixed;">
                                    <tbody>
                                        <tr>
                                            <td style="width:33%; text-align:center; vertical-align:top; height:80px; padding-top:8px;">
                                                <div t-if="doc.state == 'done'" style="margin:0; font-weight:bold;">ผู้ปิด Job</div>
                                                <div t-else="" style="margin:0; font-weight:bold;">ผู้เปิด Job</div>
                                                <div style="margin-top:40px;">.........................................</div>
                                                <div>วันที่ ......./......./...........</div>
                                            </td>
                                            <td style="width:34%; text-align:center; vertical-align:top; height:80px; padding-top:8px;">
                                                <div style="font-weight:bold;">ผู้ตรวจสอบ</div>
                                                <div style="margin-top:40px;">.........................................</div>
                                                <div>วันที่ ......./......./...........</div>
                                            </td>
                                            <td style="width:33%; text-align:center; vertical-align:top; height:80px; padding-top:8px;">
                                                <div style="font-weight:bold;">ผู้อนุมัติ</div>
                                                <div style="margin-top:40px;">.........................................</div>
                                                <div>วันที่ ......./......./...........</div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
