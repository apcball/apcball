<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="buz_warranty_management.WarrantyDashboard">
        <div class="o_warranty_dashboard" style="height:100%; overflow-y:auto; overflow-x:hidden;">

            <!-- FILTER BAR -->
            <div class="o_wd_filter_bar">
                <div class="o_wd_filters_row">
                    <div class="o_wd_date_filters">
                        <input type="date" class="form-control form-control-sm"
                               t-model="state.filters.date_from"
                               t-on-change="onFilterChange"/>
                        <span class="o_wd_date_sep">-</span>
                        <input type="date" class="form-control form-control-sm"
                               t-model="state.filters.date_to"
                               t-on-change="onFilterChange"/>
                    </div>
                    <div class="o_wd_quick_buttons">
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onQuickPeriod('week')">This Week</button>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onQuickPeriod('month')">This Month</button>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onQuickPeriod('quarter')">This Quarter</button>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onQuickPeriod('year')">This Year</button>
                    </div>
                    <div class="o_wd_filter_selects">
                        <select class="form-select form-select-sm" t-model="state.filters.product_id" t-on-change="onFilterChange">
                            <option value="">All Products</option>
                            <option t-foreach="state.filterOptions.products" t-as="p" t-key="p.id" t-att-value="p.id">
                                <t t-esc="p.name"/>
                            </option>
                        </select>
                        <select class="form-select form-select-sm" t-model="state.filters.customer_id" t-on-change="onFilterChange">
                            <option value="">All Customers</option>
                            <option t-foreach="state.filterOptions.customers" t-as="c" t-key="c.id" t-att-value="c.id">
                                <t t-esc="c.name"/>
                            </option>
                        </select>
                    </div>
                    <button class="btn btn-sm btn-primary" t-on-click="onRefresh">
                        <i class="fa fa-refresh me-1"/> Refresh
                    </button>
                    <button class="btn btn-sm btn-outline-warning" t-on-click="onRebuildCache">
                        <i class="fa fa-database me-1"/> Rebuild
                    </button>
                </div>
            </div>

            <!-- LOADING -->
            <t t-if="state.loading">
                <div class="o_wd_loading text-center py-5">
                    <i class="fa fa-spinner fa-spin fa-2x text-primary mb-2"/>
                    <div>Loading warranty analytics...</div>
                </div>
            </t>

            <!-- DASHBOARD CONTENT -->
            <t t-else="">

                <!-- ROW 1: KPI CARDS -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-4 col-xl">
                        <div class="o_wd_kpi_card kpi-primary" t-on-click="openAllWarranties">
                            <div class="kpi-icon"><i class="fa fa-shield"/></div>
                            <div class="kpi-content">
                                <div class="kpi-title">Total Warranties</div>
                                <div class="kpi-value"><t t-esc="formatNumber(state.data.kpi.total_warranties)"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl">
                        <div class="o_wd_kpi_card kpi-success" t-on-click="openActiveWarranties">
                            <div class="kpi-icon"><i class="fa fa-check-circle"/></div>
                            <div class="kpi-content">
                                <div class="kpi-title">Active Warranties</div>
                                <div class="kpi-value"><t t-esc="formatNumber(state.data.kpi.active_warranties)"/></div>
                                <div class="kpi-subtitle"><t t-esc="formatPercent(state.data.kpi.active_percentage)"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl">
                        <div class="o_wd_kpi_card kpi-danger" t-on-click="openExpiredWarranties">
                            <div class="kpi-icon"><i class="fa fa-times-circle"/></div>
                            <div class="kpi-content">
                                <div class="kpi-title">Expired Warranties</div>
                                <div class="kpi-value"><t t-esc="formatNumber(state.data.kpi.expired_warranties)"/></div>
                                <div class="kpi-subtitle"><t t-esc="formatPercent(state.data.kpi.expired_percentage)"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl">
                        <div class="o_wd_kpi_card kpi-warning" t-on-click="openClaimedWarranties">
                            <div class="kpi-icon"><i class="fa fa-exclamation-triangle"/></div>
                            <div class="kpi-content">
                                <div class="kpi-title">Claimed Warranties</div>
                                <div class="kpi-value"><t t-esc="formatNumber(state.data.kpi.claimed_warranties)"/></div>
                                <div class="kpi-subtitle"><t t-esc="formatPercent(state.data.kpi.claimed_percentage)"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl">
                        <div class="o_wd_kpi_card kpi-info" t-on-click="openNearExpiryWarranties">
                            <div class="kpi-icon"><i class="fa fa-clock-o"/></div>
                            <div class="kpi-content">
                                <div class="kpi-title">Near Expiry (30d)</div>
                                <div class="kpi-value"><t t-esc="formatNumber(state.data.kpi.near_expiry_warranties)"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl">
                        <div class="o_wd_kpi_card kpi-purple" t-on-click="openWarrantyClaims">
                            <div class="kpi-icon"><i class="fa fa-wrench"/></div>
                            <div class="kpi-content">
                                <div class="kpi-title">Claims This Month</div>
                                <div class="kpi-value"><t t-esc="formatNumber(state.data.kpi.claims_this_month)"/></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ROW 2: WARRANTY STATUS + CLAIMS TREND -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-4">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-pie-chart me-2"/>Warranty Status</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="warrantyStatusChart"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-xl-8">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-line-chart me-2"/>Claims Trend (12 months)</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="claimsTrendChart"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ROW 3: TOP PRODUCTS + TOP CUSTOMERS -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-6">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-cube me-2"/>Top 10 Products by Warranties</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="topProductsChart"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-xl-6">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-users me-2"/>Top 10 Customers by Warranties</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="topCustomersChart"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ROW 4: MONTHLY COMPARISON + CLAIM TYPES -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-6">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-bar-chart me-2"/>Monthly Comparison</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="monthlyComparisonChart"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-xl-6">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-tags me-2"/>Claim Types by Month</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="claimTypesChart"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ROW 5: WARRANTY EXPIRY + RECENT WARRANTIES TABLE -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-4">
                        <div class="o_wd_panel card h-100">
                            <div class="card-header"><i class="fa fa-hourglass-end me-2"/>Upcoming Expiries</div>
                            <div class="card-body o_wd_chart_body">
                                <canvas t-ref="warrantyExpiryChart"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-xl-8">
                        <div class="o_wd_panel card">
                            <div class="card-header"><i class="fa fa-list me-2"/>Recent Warranties</div>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Code</th>
                                            <th>Customer</th>
                                            <th>Product</th>
                                            <th>Start</th>
                                            <th>End</th>
                                            <th>Status</th>
                                            <th class="text-end">Claims</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="state.data.recent_warranties" t-as="w" t-key="w.id">
                                            <td class="fw-semibold"><t t-esc="w.name"/></td>
                                            <td><t t-esc="w.partner_name"/></td>
                                            <td><t t-esc="w.product_name"/></td>
                                            <td><t t-esc="w.start_date"/></td>
                                            <td><t t-esc="w.end_date"/></td>
                                            <td>
                                                <t t-if="w.state == 'active'">
                                                    <span class="badge bg-success">Active</span>
                                                </t>
                                                <t t-elif="w.state == 'expired'">
                                                    <span class="badge bg-danger">Expired</span>
                                                </t>
                                                <t t-elif="w.state == 'draft'">
                                                    <span class="badge bg-secondary">Draft</span>
                                                </t>
                                                <t t-elif="w.state == 'cancelled'">
                                                    <span class="badge bg-warning">Cancelled</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge bg-info"><t t-esc="w.state"/></span>
                                                </t>
                                            </td>
                                            <td class="text-end"><t t-esc="w.claim_count"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </t>

        </div>
    </t>
</templates>
