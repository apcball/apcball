<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Warranty Card Tree View -->
    <record id="view_warranty_card_tree" model="ir.ui.view">
        <field name="name">warranty.card.tree</field>
        <field name="model">warranty.card</field>
        <field name="arch" type="xml">
            <tree string="Warranty Cards" decoration-danger="is_expired" decoration-warning="days_remaining &lt; 30">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="days_remaining"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'expired'"/>
                <field name="claim_count"/>
                <field name="is_expired" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Warranty Card Form View -->
    <record id="view_warranty_card_form" model="ir.ui.view">
        <field name="name">warranty.card.form</field>
        <field name="model">warranty.card</field>
        <field name="arch" type="xml">
            <form string="Warranty Card" class="warranty-card">
                <header>
                    <div class="o_statusbar_status o_statusbar_visible">
                        <div class="btn-group">
                            <button name="action_activate" string="Activate" type="object"
                                    invisible="state != 'draft'" class="oe_highlight btn-primary"/>
                            <button name="action_print_certificate" string="Print Certificate" type="object"
                                    class="btn-info"/>
                            <button name="action_cancel" string="Cancel" type="object"
                                    invisible="state not in ['draft', 'active']" class="btn-danger"/>
                        </div>
                        <field name="state" widget="statusbar" statusbar_visible="draft,active,expired"/>
                    </div>
                </header>
                <sheet>
                    <!-- Title row -->
                    <div class="oe_title mb-3">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h1 class="mb-0">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                            <div class="col-md-4 text-right">
                                <field name="source" widget="badge"
                                       decoration-success="source == 'portal'"
                                       decoration-info="source == 'manual'"/>
                            </div>
                        </div>
                    </div>

                    <!-- Claims stat button -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="oe_button_box o_button_box">
                                <button name="action_view_claims" type="object"
                                        class="oe_stat_button" icon="fa-exclamation-triangle">
                                    <field name="claim_count" widget="statinfo" string="Claims"/>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Row 1: Customer + Product -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom">
                                    <h5 class="mb-0">Customer Information</h5>
                                </div>
                                <div class="card-body">
                                    <group>
                                        <field name="partner_id"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom">
                                    <h5 class="mb-0">Product Details</h5>
                                </div>
                                <div class="card-body">
                                    <group>
                                        <field name="product_id"/>
                                        <field name="lot_id"/>
                                        <field name="warranty_type"/>
                                        <field name="serial_number_input"
                                               invisible="source != 'portal'"
                                               placeholder="Typed by customer"/>
                                        <field name="product_description"
                                               invisible="source != 'portal'"
                                               placeholder="Typed by customer"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: Purchase + Warranty -->
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom">
                                    <h5 class="mb-0">Purchase Details</h5>
                                </div>
                                <div class="card-body">
                                    <group>
                                        <field name="start_date"/>
                                        <field name="dealer_name"/>
                                        <field name="invoice_number"/>
                                        <field name="registration_date" invisible="not registration_date"/>
                                    </group>
                                    <field name="proof_attachment_ids" widget="many2many_binary"
                                           nolabel="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom">
                                    <h5 class="mb-0">Warranty Period</h5>
                                </div>
                                <div class="card-body">
                                    <group>
                                        <field name="end_date"/>
                                    </group>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="warranty_duration" string="Duration"/>
                                            <div class="input-group">
                                                <field name="warranty_duration" class="form-control"/>
                                                <field name="warranty_period_unit" class="form-control"/>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <field name="days_remaining" string="Days Remaining"
                                                   widget="statinfo"/>
                                            <field name="is_expired" invisible="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 3: Reference Documents -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light border-bottom">
                                    <h5 class="mb-0">Reference Documents</h5>
                                </div>
                                <div class="card-body">
                                    <group col="2">
                                        <field name="sale_order_id"/>
                                        <field name="picking_id"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notebook -->
                    <div class="mt-3">
                        <notebook>
                            <page string="Warranty Terms &amp; Conditions">
                                <field name="condition" nolabel="1"/>
                            </page>
                            <page string="Claims" name="claims">
                                <field name="claim_ids" nolabel="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="claim_date"/>
                                        <field name="claim_type"/>
                                        <field name="is_under_warranty" widget="boolean"/>
                                        <field name="status" widget="badge"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Warranty Card Search View -->
    <record id="view_warranty_card_search" model="ir.ui.view">
        <field name="name">warranty.card.search</field>
        <field name="model">warranty.card</field>
        <field name="arch" type="xml">
            <search string="Warranty Cards">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Expired" name="expired" domain="[('state', '=', 'expired')]"/>
                <filter string="Near Expiry (30 days)" name="near_expiry" 
                        domain="[('end_date', '&lt;=', (context_today() + datetime.timedelta(days=30)).strftime('%Y-%m-%d')), ('end_date', '>=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Start Date" name="group_start_date" context="{'group_by': 'start_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Warranty Card Action -->
    <record id="action_warranty_card" model="ir.actions.act_window">
        <field name="name">Warranty Cards</field>
        <field name="res_model">warranty.card</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Warranty Card
            </p>
            <p>
                Warranty cards are automatically created when products with warranty configuration are delivered.
            </p>
        </field>
    </record>

</odoo>
