<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Warranty Contract Sequence -->
    <record id="seq_warranty_contract" model="ir.sequence">
        <field name="name">Warranty Contract</field>
        <field name="code">buz.warranty.contract</field>
        <field name="prefix">WCT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Warranty Claim Sequence -->
    <record id="seq_warranty_claim" model="ir.sequence">
        <field name="name">Warranty Claim</field>
        <field name="code">buz.warranty.claim</field>
        <field name="prefix">WCL/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>