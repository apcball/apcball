<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Claim Cost Line Tree View -->
    <record id="view_claim_cost_line_tree" model="ir.ui.view">
        <field name="name">buz.claim.cost.line.tree</field>
        <field name="model">buz.claim.cost.line</field>
        <field name="arch" type="xml">
            <tree string="Claim Cost Lines">
                <field name="product_id"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="price_unit"/>
                <field name="tax_ids" widget="many2many_tags"/>
                <field name="subtotal"/>
                <field name="currency_id" groups="base.group_multi_currency" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Claim Cost Line Form View -->
    <record id="view_claim_cost_line_form" model="ir.ui.view">
        <field name="name">buz.claim.cost.line.form</field>
        <field name="model">buz.claim.cost.line</field>
        <field name="arch" type="xml">
            <form string="Claim Cost Line">
                <group>
                    <group>
                        <field name="claim_id"/>
                        <field name="product_id"/>
                        <field name="name"/>
                        <field name="quantity"/>
                    </group>
                    <group>
                        <field name="price_unit"/>
                        <field name="tax_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                        <field name="subtotal"/>
                        <field name="currency_id" groups="base.group_multi_currency"/>
                    </group>
                </group>
            </form>
        </field>
    </record>
</odoo>