<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Repair Order Form View to add Warranty Claim Field -->
    <record id="view_repair_order_form_inherit_warranty" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.warranty</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="before">
                <field name="buz_claim_id"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_view_warranty_claim"
                        type="object"
                        string="View Warranty Claim"
                        class="btn-secondary"
                        invisible="buz_claim_id == False"/>
            </xpath>
        </field>
    </record>
</odoo>