<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Stock Picking Form View to add Warranty Claim Field -->
    <record id="view_stock_picking_form_inherit_warranty" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.warranty</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="buz_claim_id"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_view_warranty_claim"
                        type="object"
                        string="View Warranty Claim"
                        class="btn-secondary"
                        invisible="buz_claim_id == False"/>
            </xpath>
        </field>
    </record>
</odoo>