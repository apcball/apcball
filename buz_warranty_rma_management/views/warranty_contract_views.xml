<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Warranty Contract Tree View -->
    <record id="view_warranty_contract_tree" model="ir.ui.view">
        <field name="name">buz.warranty.contract.tree</field>
        <field name="model">buz.warranty.contract</field>
        <field name="arch" type="xml">
            <tree string="Warranty Contracts">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="template_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Warranty Contract Form View -->
    <record id="view_warranty_contract_form" model="ir.ui.view">
        <field name="name">buz.warranty.contract.form</field>
        <field name="model">buz.warranty.contract</field>
        <field name="arch" type="xml">
            <form string="Warranty Contract">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expired,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_renew"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-refresh"
                                string="Renew"
                                invisible="(state != 'active') or (template_id.coverage_type != 'extended')"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="product_tmpl_id_for_domain" invisible="1"/>
                            <field name="product_id" domain="[('product_tmpl_id', '=', product_tmpl_id_for_domain)]"/>
                            <field name="lot_id" domain="[('product_id', '=', product_id)]"/>
                            <field name="start_date"/>
                        </group>
                        <group>
                            <field name="template_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="invoice_id" invisible="template_id.coverage_type != 'extended'"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Warranty Contract Search View -->
    <record id="view_warranty_contract_search" model="ir.ui.view">
        <field name="name">buz.warranty.contract.search</field>
        <field name="model">buz.warranty.contract</field>
        <field name="arch" type="xml">
            <search string="Warranty Contracts">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="template_id"/>
                <field name="state"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <filter name="active_contracts" string="Active" domain="[('state', '=', 'active')]"/>
                <filter name="expired_contracts" string="Expired" domain="[('state', '=', 'expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Template" name="group_by_template" context="{'group_by': 'template_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>