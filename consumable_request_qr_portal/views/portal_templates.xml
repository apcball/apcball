<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_request_view" name="Consumable Request Portal">
        <t t-call="website.layout">
            <div id="wrap" class="container mt-3">
            
                <!-- DONE STATE -->
                <t t-if="consumable_request.portal_confirmed">
                     <div class="row">
                        <div class="col-12 col-lg-8 offset-lg-2 text-center mt-4">
                            <i class="fa fa-check-circle text-success" style="font-size: 5rem;"></i>
                            <h2 class="mt-3">Received Successfully</h2>
                            <p class="lead text-muted">Document: <t t-esc="consumable_request.name"/></p>
                            
                            <div class="card mt-4 text-start shadow-sm">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0"><i class="fa fa-file-text-o"></i> Receipt Summary</h5>
                                </div>
                                <div class="card-body">
                                     <div class="row mb-3">
                                         <div class="col-6">
                                             <small class="text-muted">Received Date</small><br/>
                                             <strong><span t-field="consumable_request.received_date"/></strong>
                                         </div>
                                         <div class="col-6 text-end">
                                             <small class="text-muted">Picking</small><br/>
                                             <strong><t t-esc="consumable_request.picking_id.name or '-'"/></strong>
                                         </div>
                                     </div>
                                     
                                     <h6 class="border-bottom pb-2 mt-3">Items Received</h6>
                                     <div class="list-group list-group-flush">
                                         <t t-foreach="consumable_request.line_ids" t-as="line">
                                            <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                                <span><t t-esc="line.product_id.display_name"/></span>
                                                <span class="badge bg-light text-dark"><t t-esc="line.qty_requested"/> <t t-esc="line.product_uom_id.name"/></span>
                                            </div>
                                         </t>
                                     </div>
                                </div>
                                <div class="card-footer bg-white text-center py-3" t-if="consumable_request.signature">
                                    <p class="mb-1 text-muted small">Receiver Signature</p>
                                    <img t-att-src="'data:image/png;base64,' + consumable_request.signature.decode('utf-8')" class="img-fluid" style="max-height: 100px;"/>
                                </div>
                            </div>
                            <div class="mt-4 mb-5">
                                <button onClick="window.print()" class="btn btn-outline-secondary"><i class="fa fa-print"></i> Print Receipt</button>
                            </div>
                        </div>
                     </div>
                </t>
            
                <!-- ACTION STATE -->
                <div class="row" t-else="">
                    <div class="col-12 col-lg-8 offset-lg-2">
                        <!-- Status Badge -->
                        <div class="text-center mb-3">
                             <span t-if="consumable_request.state == 'approved'" class="badge rounded-pill bg-primary fs-5">Approved</span>
                             <span t-if="consumable_request.state == 'issued'" class="badge rounded-pill bg-warning text-dark fs-5">Issued - Ready to Receive</span>
                             <span t-if="consumable_request.portal_confirmed or consumable_request.state == 'done'" class="badge rounded-pill bg-success fs-5">Received</span>
                        </div>

                        <!-- Not Issued Warning -->
                        <div t-if="consumable_request.state == 'approved'" class="alert alert-info text-center mb-3">
                                <h4><i class="fa fa-clock-o"></i> Waiting for Issuance</h4>
                                <p>Please present this QR code to Warehouse Staff.</p>
                                <div class="my-3">
                                    <img t-if="consumable_request.qr_code" t-att-src="'data:image/png;base64,' + consumable_request.qr_code.decode('utf-8')" class="img-fluid" style="max-width: 200px;"/>
                                </div>
                                <button onClick="window.location.reload();" class="btn btn-outline-primary btn-sm mt-2">Check Again</button>
                        </div>

                        <!-- Summary -->
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Request: <t t-esc="consumable_request.name"/></h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-8">
                                        <p class="mb-1"><strong>Requester:</strong> <t t-esc="consumable_request.employee_id.name"/></p>
                                        <p class="mb-1"><strong>Warehouse:</strong> <t t-esc="consumable_request.warehouse_id.name"/></p>
                                        <p class="mb-1"><strong>Department:</strong> <t t-esc="consumable_request.department_id.name"/></p>
                                        <p t-if="consumable_request.issued_by" class="mb-0 text-success"><strong>Issued By:</strong> <t t-esc="consumable_request.issued_by.name"/> (<t t-esc="consumable_request.issued_date"/>)</p>
                                    </div>
                                    <div class="col-4 text-center">
                                         <img t-if="consumable_request.qr_code" t-att-src="'data:image/png;base64,' + consumable_request.qr_code.decode('utf-8')" class="img-fluid" style="max-width: 100px;"/>
                                         <div class="small text-muted mt-1">Scan to View</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Item List -->
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Items</h6>
                            </div>
                            <div class="list-group list-group-flush">
                                <t t-foreach="consumable_request.line_ids" t-as="line">
                                    <div class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1"><t t-esc="line.product_id.display_name"/></h6>
                                            <small class="text-muted"><t t-esc="line.qty_requested"/> <t t-esc="line.product_uom_id.name"/></small>
                                        </div>
                                        <small class="text-muted">Available: <t t-esc="line.available_qty"/></small>
                                        <div class="form-check mt-2" t-if="consumable_request.state == 'issued' and not consumable_request.portal_confirmed">
                                            <input class="form-check-input item-check" type="checkbox" value="" t-att-id="'check_%s' % line.id"/>
                                            <label class="form-check-label" t-att-for="'check_%s' % line.id">
                                                To Receive
                                            </label>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- Signature Pad (Only if Issued) -->
                        <div class="card mb-3" t-if="consumable_request.state == 'issued' and not consumable_request.portal_confirmed">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Sign &amp; Receive</h6>
                            </div>
                            <div class="card-body">
                                <div id="signature-pad" class="signature-pad">
                                    <div class="signature-pad--body">
                                        <canvas style="border: 1px solid #ccc; width: 100%; height: 200px;" id="signature-canvas"></canvas>
                                    </div>
                                    <div class="signature-pad--footer mt-2">
                                        <div class="description text-muted">Sign above</div>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="clear" id="btn-clear-signature">Clear</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                         <div class="d-grid gap-2 mb-5">
                            <button t-if="consumable_request.state == 'issued' and not consumable_request.portal_confirmed" id="btn-confirm-receive" class="btn btn-primary btn-lg" disabled="disabled">
                                Confirm Receive
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <input type="hidden" id="qr_token" t-att-value="token"/>
            
        </t>
    </template>
    
    <template id="portal_request_not_found">
        <t t-call="website.layout">
            <div class="container mt-5 text-center">
                <h2>Request Not Found</h2>
                <p>The link may be invalid or expired.</p>
            </div>
        </t>
    </template>
    
    <template id="portal_request_access_denied">
        <t t-call="website.layout">
            <div class="container mt-5 text-center">
                <h2>Access Denied</h2>
                <p><t t-esc="message"/></p>
            </div>
        </t>
    </template>
</odoo>