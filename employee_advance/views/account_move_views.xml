<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_advance" model="ir.ui.view">
        <field name="name">account.move.form.inherit.advance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add smart buttons for WHT certificates -->
            <div name="button_box" position="inside">
                <button name="action_create_wht_certificate" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-plus-circle"
                        invisible="not is_advance_clearing or not wht_tax_id or wht_amount &lt;= 0"
                        help="Open form to create WHT Certificate for this advance clearing">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Add WHT</span>
                        <span class="o_stat_text">Certificate</span>
                    </div>
                </button>
                
                <!-- Hidden: Duplicate with our Add WHT Certificate button -->
                <button name="action_view_wht_certificates" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-certificate"
                        invisible="1">
                    <field name="wht_cert_count" widget="statinfo" string="WHT Certificates"/>
                </button>
            </div>
            
            <xpath expr="//header" position="inside">
                <button name="action_clear_advance_from_bill" type="object" string="Clear with Advance" class="btn-primary" invisible="move_type != 'in_invoice' or state != 'posted' or amount_residual &lt;= 0"/>
                
                <button name="action_open_wht_clear_advance_wizard_from_bill" 
                        type="object" 
                        string="Clear Advance (WHT)" 
                        class="btn-warning" 
                        invisible="move_type != 'in_invoice' or state != 'posted' or amount_residual &lt;= 0"
                        help="Clear advance with withholding tax calculation"/>
                
                <button name="%(l10n_th_account_tax.action_withholding_tax_cert_menu)d" 
                        type="action" 
                        string="Print WHT Certificates" 
                        class="btn-secondary"
                        invisible="not wht_cert_ids and not has_wht_line"/>
            </xpath>
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Withholding Tax Certificates" invisible="not wht_cert_ids and not has_wht_line">
                    <field name="wht_cert_ids" nolabel="1" 
                           context="{'default_move_id': id, 'default_partner_id': partner_id}">
                        <tree string="WHT Certificates" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'">
                            <field name="number"/>
                            <field name="date"/>
                            <field name="partner_id"/>
                            <field name="income_tax_form"/>
                            <field name="state"/>
                        </tree>
                        <form string="Withholding Tax Certificate">
                            <group>
                                <field name="number"/>
                                <field name="date"/>
                                <field name="state"/>
                                <field name="partner_id"/>
                                <field name="income_tax_form"/>
                                <field name="tax_payer"/>
                            </group>
                            <notebook>
                                <page string="Lines">
                                    <field name="wht_line">
                                        <tree editable="bottom">
                                            <field name="wht_cert_income_type"/>
                                            <field name="wht_cert_income_desc"/>
                                            <field name="base"/>
                                            <field name="amount"/>
                                            <field name="wht_percent"/>
                                        </tree>
                                    </field>
                                </page>
                            </notebook>
                        </form>
                    </field>
                    <field name="has_wht_line" invisible="1"/>
                    <div class="alert alert-info" role="alert" invisible="wht_cert_ids">
                        <p>This bill has WHT taxes applied to invoice lines. You can generate WHT certificates for these taxes.</p>
                    </div>
                </page>
                <page string="Advance Info">
                    <group string="Advance Info">
                        <field name="is_expense_advance_bill" readonly="1"/>
                        <field name="advance_box_id"/>
                        <field name="expense_sheet_id"/>
                        <field name="has_wht_line" invisible="1"/>
                    </group>
                    <group string="WHT Information" invisible="not is_advance_clearing">
                        <field name="is_advance_clearing" readonly="1"/>
                        <field name="wht_tax_id" readonly="1"/>
                        <field name="wht_base_amount" readonly="1"/>
                        <field name="wht_amount" readonly="1"/>
                        <field name="wht_cert_count" invisible="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
