<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_advance" model="ir.ui.view">
        <field name="name">account.move.form.inherit.advance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_clear_advance_from_bill" type="object" string="Clear with Advance" class="btn-primary" invisible="move_type != 'in_invoice' or state != 'posted'"/>
                <button name="%(action_link_advance_wizard)d" type="action" string="Link to Advance" class="btn-secondary" invisible="move_type != 'in_invoice'"/>
            </xpath>
            <xpath expr="//sheet/notebook/page/field[@name='invoice_line_ids']" position="after">
                <group string="Advance Info">
                    <field name="is_expense_advance_bill" readonly="1"/>
                    <field name="advance_box_id"/>
                    <field name="expense_sheet_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
