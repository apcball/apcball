<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for Clear Advance Button -->
    <record id="action_clear_advance" model="ir.actions.server">
        <field name="name">Clear with Advance</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records.action_clear_advance_from_bill()
        </field>
    </record>
</odoo>