<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Employee Advance Box Action -->
    <record id="action_employee_advance_box" model="ir.actions.act_window">
        <field name="name">Employee Advance Boxes</field>
        <field name="res_model">employee.advance.box</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Employee Advance Box!
            </p>
        </field>
    </record>

    <!-- Employee Advance Box Tree View -->
    <record id="view_employee_advance_box_tree" model="ir.ui.view">
        <field name="name">employee.advance.box.tree</field>
        <field name="model">employee.advance.box</field>
        <field name="arch" type="xml">
            <tree string="Employee Advance Boxes">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="balance"/>
                <field name="remember_base_amount"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="company_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Employee Advance Box Form View -->
    <record id="view_employee_advance_box_form" model="ir.ui.view">
        <field name="name">employee.advance.box.form</field>
        <field name="model">employee.advance.box</field>
        <field name="arch" type="xml">
            <form string="Employee Advance Box">
                <header>
                    <button name="action_refill_to_base" 
                            type="object" 
                            string="Refill to Base" 
                            class="btn-primary"
                            invisible="not employee_id or not account_id or not journal_id"/>
                    <button name="action_open_settlement_wizard" 
                            type="object" 
                            string="Settle Advance" 
                            class="btn-secondary"
                            invisible="balance == 0"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_refill_to_base" 
                                type="object" 
                                string="Refill to Base" 
                                class="oe_stat_button" 
                                icon="fa-plus-circle"
                                invisible="not employee_id or not account_id or not journal_id"/>
                        <button name="action_open_settlement_wizard" 
                                type="object" 
                                string="Settle Advance" 
                                class="oe_stat_button" 
                                icon="fa-usd"
                                invisible="balance == 0"/>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="account_id"/>
                            <field name="journal_id"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="balance" readonly="1"/>
                            <field name="remember_base_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Settlement Tree View -->
    <record id="view_employee_advance_settlement_tree" model="ir.ui.view">
        <field name="name">employee.advance.box.settlement.tree</field>
        <field name="model">employee.advance.box</field>
        <field name="arch" type="xml">
            <tree string="Advance Box Settlements">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="balance"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="company_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Settlement Action -->
    <record id="action_employee_advance_settlement" model="ir.actions.act_window">
        <field name="name">Settlement</field>
        <field name="res_model">employee.advance.box</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_employee_advance_root"
              name="Employee Advance"
              sequence="10"
              groups="base.group_user"/>
    
    <menuitem id="menu_employee_advance_box"
              name="Advance Boxes"
              parent="menu_employee_advance_root"
              action="action_employee_advance_box"
              sequence="10"/>

    <menuitem id="menu_employee_advance_settlement_root"
              name="Settlement"
              parent="menu_employee_advance_root"
              sequence="20"
              groups="account.group_account_manager"/>

    <menuitem id="menu_employee_advance_settlement"
              name="Settlement"
              parent="menu_employee_advance_settlement_root"
              action="action_employee_advance_settlement"
              sequence="10"/>
</odoo>