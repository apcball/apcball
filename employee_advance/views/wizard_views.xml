<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Advance Refill Base Wizard Form View -->
    <record id="view_advance_refill_base_wizard_form" model="ir.ui.view">
        <field name="name">advance.refill.base.wizard.form</field>
        <field name="model">advance.refill.base.wizard</field>
        <field name="arch" type="xml">
            <form string="Refill Advance to Base">
                <group>
                    <field name="advance_box_id" invisible="1"/>
                    <group>
                        <field name="current_balance"/>
                        <field name="base_amount_ref"/>
                        <field name="topup_amount"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" 
                            type="object" 
                            string="Confirm" 
                            class="btn-primary"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Wizard Action -->
    <record id="action_advance_refill_base_wizard" model="ir.actions.act_window">
        <field name="name">Refill Advance to Base</field>
        <field name="res_model">advance.refill.base.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Link to Advance Wizard View -->
    <record id="view_link_advance_wizard_form" model="ir.ui.view">
        <field name="name">link.advance.wizard.form</field>
        <field name="model">link.advance.wizard</field>
        <field name="arch" type="xml">
            <form string="Link to Advance">
                <group>
                    <field name="move_id" invisible="1"/>
                    <field name="advance_box_id"/>
                    <field name="expense_sheet_id"/>
                </group>
                <footer>
                    <button name="action_link" type="object" string="Link" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_link_advance_wizard" model="ir.actions.act_window">
        <field name="name">Link to Advance</field>
        <field name="res_model">link.advance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Advance Settlement Wizard View -->
    <record id="view_advance_settlement_wizard_form" model="ir.ui.view">
        <field name="name">advance.settlement.wizard.form</field>
        <field name="model">advance.settlement.wizard</field>
        <field name="arch" type="xml">
            <form string="Settle Advance Box">
                <group>
                    <field name="box_id" invisible="1"/>
                    <field name="employee_id" readonly="1"/>
                    <field name="current_balance" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    <label for="current_balance" string="Current Balance - Positive = Company owes employee; Negative = Employee owes company"/>
                </group>
                <group>
                    <field name="settlement_date"/>
                    <field name="memo"/>
                </group>
                <group>
                    <field name="journal_id" domain="[('company_id', '=', company_id)]" required="scenario in ('pay_employee', 'employee_refund', 'write_off')"/>
                    <field name="amount_mode"/>
                    <field name="amount_to_settle" invisible="amount_mode == 'full'" required="amount_mode == 'partial'"/>
                </group>
                <group>
                    <field name="scenario"/>
                    <field name="writeoff_policy" invisible="scenario != 'write_off'"/>
                    <field name="writeoff_account_id" invisible="scenario != 'write_off'" required="writeoff_policy in ('expense', 'other_income')"/>
                </group>
                <group>
                    <field name="auto_reconcile"/>
                </group>
                <group>
                    <field name="create_activity"/>
                    <field name="activity_user_id" invisible="not create_activity"/>
                    <field name="activity_type_id" invisible="not create_activity"/>
                    <field name="activity_note" invisible="not create_activity"/>
                </group>
                <group>
                    <field name="target_amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_settle_advance" 
                            type="object" 
                            string="Settle Advance" 
                            class="btn-primary"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    
</odoo>