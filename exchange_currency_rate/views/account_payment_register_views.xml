<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    Show manual exchange rate in payment register wizard-->
    <record id="view_account_payment_register_form_inherit" model="ir.ui.view">
        <field name="name">account.payment.register.form.inherit.exchange.currency.rate</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position='after'>
                <field name="use_manual_rate" invisible="1"/>
                <field name="manual_currency_rate" 
                       readonly="1"
                       invisible="use_manual_rate == False"
                       digits="[12, 4]"/>
            </xpath>
        </field>
    </record>
</odoo>
