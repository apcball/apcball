<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Log Views -->
    <record id="view_fifo_reset_log_tree" model="ir.ui.view">
        <field name="name">fifo.reset.log.tree</field>
        <field name="model">fifo.reset.log</field>
        <field name="arch" type="xml">
            <tree string="FIFO Reset Logs" create="0" edit="0" delete="0" decoration-danger="status == 'error'" decoration-success="status == 'success'">
                <field name="execution_time"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="reset_date"/>
                <field name="status"/>
                <field name="is_dry_run" widget="boolean_toggle"/>
                <field name="total_products"/>
                <field name="total_quants"/>
                <field name="before_value"/>
                <field name="after_value"/>
            </tree>
        </field>
    </record>
    
    <record id="view_fifo_reset_log_form" model="ir.ui.view">
        <field name="name">fifo.reset.log.form</field>
        <field name="model">fifo.reset.log</field>
        <field name="arch" type="xml">
            <form string="FIFO Reset Log" create="0" edit="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="execution_time"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id"/>
                            <field name="reset_date"/>
                            <field name="status"/>
                            <field name="is_dry_run"/>
                        </group>
                        <group>
                            <field name="total_products"/>
                            <field name="total_quants"/>
                            <field name="before_value"/>
                            <field name="after_value"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Progress Detail">
                            <group>
                                <field name="warehouse_ids" widget="many2many_tags"/>
                            </group>
                            <field name="progress_detail" widget="text" nolabel="1"/>
                        </page>
                        <page string="Error Message" invisible="status == 'success'">
                            <field name="error_message"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fifo_reset_log" model="ir.actions.act_window">
        <field name="name">FIFO Reset Logs</field>
        <field name="res_model">fifo.reset.log</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
