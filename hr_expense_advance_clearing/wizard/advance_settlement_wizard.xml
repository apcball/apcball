<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_advance_settlement_wizard" model="ir.ui.view">
    <field name="name">advance.settlement.wizard.form</field>
    <field name="model">advance.settlement.wizard</field>
    <field name="arch" type="xml">
      <form string="Settle Advance">
        <group>
          <group string="Employee Information">
            <field name="employee_id"/>
            <field name="advance_box_id" options="{'no_create': True}"/>
            <field name="current_balance" readonly="1" widget="monetary"/>
            <div class="alert alert-info" invisible="current_balance &gt;= 0">
              <strong>Negative Balance:</strong> Company owes money to employee
            </div>
            <div class="alert alert-success" invisible="current_balance &lt;= 0">
              <strong>Positive Balance:</strong> Employee has advance amount
            </div>
          </group>
          <group string="Settlement Details">
            <field name="settlement_type"/>
            <field name="amount" widget="monetary"/>
            <field name="final_balance" readonly="1" widget="monetary"/>
            <div class="alert alert-warning" invisible="settlement_type != 'clear'">
              <strong>Clear Settlement:</strong> This will zero out the entire advance balance
            </div>
          </group>
          <group string="Payment Information">
            <field name="journal_id"/>
            <field name="date"/>
            <field name="description"/>
            <field name="currency_id" invisible="1"/>
          </group>
      <!-- Actions buttons moved to footer to render horizontally -->
        </group>
        <footer>
          <button name="action_settle" type="object" string="Create Settlement" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_advance_settlement_wizard" model="ir.actions.act_window">
    <field name="name">Settle Advance</field>
    <field name="res_model">advance.settlement.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="context">{'form_view_initial_mode': 'edit', 'force_detailed_view': True}</field>
  </record>

  <!-- Menu item for Settle Advance -->
  <menuitem id="menu_advance_settlement" 
            name="Settle Advance" 
            parent="hr_expense_advance_clearing.menu_employee_advance_root" 
            action="action_advance_settlement_wizard"
            sequence="30"/>

</odoo>