<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Report Action -->
        <record id="action_report_consume_slip" model="ir.actions.report">
            <field name="name">ใบจ่ายของภายใน</field>
            <field name="model">internal.consume.request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">internal_consume_request.report_consume_slip_document</field>
            <field name="report_file">internal_consume_request.report_consume_slip_document</field>
            <field name="print_report_name">'ใบจ่ายของ - %s' % (object.name)</field>
            <field name="binding_model_id" ref="model_internal_consume_request"/>
            <field name="binding_type">report</field>
        </record>

        <!-- Report Template -->
        <template id="report_consume_slip_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="oe_structure"/>
                            
                            <div class="row">
                                <div class="col-8">
                                    <h2 class="mb-4">ใบจ่ายของภายใน</h2>
                                </div>
                                <div class="col-4 text-right">
                                    <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=600&amp;height=600' % doc.name" style="width:100px;height:100px;" alt="QR Code"/>
                                </div>
                            </div>
                            
                            <div class="row mt-4 mb-4" id="informations">
                                <div class="col-auto mw-100 mb-2">
                                    <strong>เลขที่คำขอ:</strong>
                                    <p class="m-0" t-field="doc.name"/>
                                </div>
                                <div class="col-auto mw-100 mb-2">
                                    <strong>วันที่:</strong>
                                    <p class="m-0" t-field="doc.request_date"/>
                                </div>
                                <div class="col-auto mw-100 mb-2">
                                    <strong>พนักงาน:</strong>
                                    <p class="m-0" t-field="doc.employee_id"/>
                                </div>
                                <div class="col-auto mw-100 mb-2">
                                    <strong>แผนก:</strong>
                                    <p class="m-0" t-field="doc.department_id"/>
                                </div>
                                <div class="col-auto mw-100 mb-2">
                                    <strong>คลังสินค้า:</strong>
                                    <p class="m-0" t-field="doc.warehouse_id"/>
                                </div>
                            </div>
                            
                            <table class="table table-sm o_main_table">
                                <thead>
                                    <tr>
                                        <th>ลำดับ</th>
                                        <th>สินค้า</th>
                                        <th class="text-right">ขอเบิก</th>
                                        <th class="text-right">จ่าย</th>
                                        <th class="text-right">คงเหลือ</th>
                                        <th>หน่วยนับ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.line_ids" t-as="line">
                                        <tr>
                                            <td><span t-field="line.line_number"/></td>
                                            <td><span t-field="line.product_id.display_name"/></td>
                                            <td class="text-right"><span t-field="line.qty_requested"/></td>
                                            <td class="text-right"><span t-field="line.issued_qty"/></td>
                                            <td class="text-right"><span t-field="line.remaining_qty"/></td>
                                            <td><span t-field="line.product_uom_id.name"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            
                            <div t-if="doc.reason_for_requisition" class="row mt-4">
                                <div class="col-12">
                                    <strong>เหตุผลในการขอเบิก:</strong>
                                    <p t-field="doc.reason_for_requisition"/>
                                </div>
                            </div>
                            
                            <!-- Signatures -->
                            <div class="row mt-5">
                                <div class="col-6 text-center">
                                    <strong>ผู้จ่าย</strong>
                                    <br/><br/>
                                    <div t-if="doc.issuer_signature">
                                        <img t-att-src="image_data_uri(doc.issuer_signature)" style="max-height: 80px;"/>
                                    </div>
                                    <div t-else="" style="height: 80px;"></div>
                                    <br/>
                                    <span t-field="doc.issued_by.name"/>
                                    <br/>
                                    <span t-if="doc.issued_datetime" t-field="doc.issued_datetime" t-options='{"widget": "datetime"}'/>
                                </div>
                                <div class="col-6 text-center">
                                    <strong>ผู้รับ</strong>
                                    <br/><br/>
                                    <div t-if="doc.receiver_signature">
                                        <img t-att-src="image_data_uri(doc.receiver_signature)" style="max-height: 80px;"/>
                                    </div>
                                    <div t-else="" style="height: 80px;"></div>
                                    <br/>
                                    <span t-field="doc.received_by.name"/>
                                    <br/>
                                    <span>.............................................</span>
                                </div>
                            </div>
                            
                            <div class="oe_structure"/>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
