<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- WHT Tax Accounts -->
        <record id="account_wht_service_payable" model="account.account">
            <field name="name">WHT Service Tax Payable</field>
            <field name="code">2131</field>
            <field name="account_type">liability_current</field>
            <field name="reconcile">True</field>
        </record>
        
        <record id="account_wht_rental_payable" model="account.account">
            <field name="name">WHT Rental Tax Payable</field>
            <field name="code">2132</field>
            <field name="account_type">liability_current</field>
            <field name="reconcile">True</field>
        </record>
        
        <record id="account_wht_professional_payable" model="account.account">
            <field name="name">WHT Professional Service Tax Payable</field>
            <field name="code">2133</field>
            <field name="account_type">liability_current</field>
            <field name="reconcile">True</field>
        </record>
        
        <!-- WHT Tax Tags -->
        <record id="tax_tag_wht_service_3" model="account.account.tag">
            <field name="name">Service WHT 3%</field>
            <field name="applicability">taxes</field>
            <field name="color">2</field>
            <field name="country_id" ref="base.th"/>
        </record>
        
        <record id="tax_tag_wht_rental_5" model="account.account.tag">
            <field name="name">Rental WHT 5%</field>
            <field name="applicability">taxes</field>
            <field name="color">3</field>
            <field name="country_id" ref="base.th"/>
        </record>
        
        <record id="tax_tag_wht_professional_5" model="account.account.tag">
            <field name="name">Professional WHT 5%</field>
            <field name="applicability">taxes</field>
            <field name="color">4</field>
            <field name="country_id" ref="base.th"/>
        </record>
        
        <record id="tax_tag_wht_transport_1" model="account.account.tag">
            <field name="name">Transport WHT 1%</field>
            <field name="applicability">taxes</field>
            <field name="color">5</field>
            <field name="country_id" ref="base.th"/>
        </record>
        
        <!-- WHT Tax Group -->
        <record id="tax_group_wht" model="account.tax.group">
            <field name="name">Withholding Tax (WHT)</field>
            <field name="sequence">20</field>
            <field name="country_id" ref="base.th"/>
        </record>
        
        <!-- Service WHT 3% Tax -->
        <record id="tax_wht_service_3_purchase" model="account.tax">
            <field name="name">Service WHT 3%</field>
            <field name="type_tax_use">purchase</field>
            <field name="amount_type">percent</field>
            <field name="amount">-3.0</field>
            <field name="tax_group_id" ref="tax_group_wht"/>
            <field name="invoice_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_service_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_service_3')])],
                }),
            ]"/>
            <field name="refund_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_service_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_service_3')])],
                }),
            ]"/>
            <field name="country_id" ref="base.th"/>
            <field name="description">Service WHT 3%</field>
        </record>
        
        <!-- Rental WHT 5% Tax -->
        <record id="tax_wht_rental_5_purchase" model="account.tax">
            <field name="name">Rental WHT 5%</field>
            <field name="type_tax_use">purchase</field>
            <field name="amount_type">percent</field>
            <field name="amount">-5.0</field>
            <field name="tax_group_id" ref="tax_group_wht"/>
            <field name="invoice_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_rental_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_rental_5')])],
                }),
            ]"/>
            <field name="refund_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_rental_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_rental_5')])],
                }),
            ]"/>
            <field name="country_id" ref="base.th"/>
            <field name="description">Rental WHT 5%</field>
        </record>
        
        <!-- Professional WHT 5% Tax -->
        <record id="tax_wht_professional_5_purchase" model="account.tax">
            <field name="name">Professional WHT 5%</field>
            <field name="type_tax_use">purchase</field>
            <field name="amount_type">percent</field>
            <field name="amount">-5.0</field>
            <field name="tax_group_id" ref="tax_group_wht"/>
            <field name="invoice_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_professional_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_professional_5')])],
                }),
            ]"/>
            <field name="refund_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_professional_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_professional_5')])],
                }),
            ]"/>
            <field name="country_id" ref="base.th"/>
            <field name="description">Professional WHT 5%</field>
        </record>
        
        <!-- Transport WHT 1% Tax -->
        <record id="tax_wht_transport_1_purchase" model="account.tax">
            <field name="name">Transport WHT 1%</field>
            <field name="type_tax_use">purchase</field>
            <field name="amount_type">percent</field>
            <field name="amount">-1.0</field>
            <field name="tax_group_id" ref="tax_group_wht"/>
            <field name="invoice_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_service_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_transport_1')])],
                }),
            ]"/>
            <field name="refund_repartition_line_ids" eval="[
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'base',
                }),
                Command.create({
                    'factor_percent': 100,
                    'repartition_type': 'tax',
                    'account_id': ref('account_wht_service_payable'),
                    'tag_ids': [Command.set([ref('tax_tag_wht_transport_1')])],
                }),
            ]"/>
            <field name="country_id" ref="base.th"/>
            <field name="description">Transport WHT 1%</field>
        </record>
        
    </data>
</odoo>
