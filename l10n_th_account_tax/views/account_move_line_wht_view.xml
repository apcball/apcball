<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Add WHT field to invoice line form view -->
    <record id="view_move_form_wht_line" model="ir.ui.view">
        <field name="name">account.move.form.wht.line</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add WHT fields to invoice lines tree -->
            <xpath expr="//field[@name='invoice_line_ids']//tree//field[@name='tax_ids']" position="after">
                <field name="wht_tax_id" 
                       string="WHT" 
                       optional="show"
                       help="Withholding Tax for this line"/>
                <field name="wht_invoice_amount" 
                       string="WHT Amount" 
                       optional="hide"
                       readonly="1"/>
            </xpath>
            
            <!-- Add WHT summary fields to form -->
            <field name="tax_totals" position="after">
                <field name="invoice_wht_total_base" invisible="1"/>
                <field name="invoice_wht_total_tax" invisible="1"/>
            </field>
            
            <!-- Add button to create WHT certificate -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button"
                        name="action_create_wht_certificate_from_invoice"
                        string="Create WHT"
                        type="object"
                        groups="account.group_account_invoice"
                        invisible="state != 'posted' or move_type not in ('in_invoice', 'in_refund', 'out_invoice', 'out_refund') or not invoice_wht_total_tax or wht_cert_ids"
                        icon="fa-certificate"
                        title="Create WHT Certificate from Invoice Lines"/>
            </div>
        </field>
    </record>
    
    <!-- Add WHT field to invoice line form popup -->
    <record id="view_move_line_form_wht" model="ir.ui.view">
        <field name="name">account.move.line.form.wht</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tax_ids']" position="after">
                <field name="wht_tax_id" 
                       string="Withholding Tax"
                       help="Select withholding tax if applicable"/>
                <field name="wht_invoice_amount" 
                       string="WHT Amount" 
                       readonly="1"/>
                <field name="wht_invoice_base" 
                       string="WHT Base" 
                       readonly="1"/>
            </xpath>
        </field>
    </record>
    
    <!-- Add WHT field to invoice line tree view -->
    <record id="view_move_line_tree_wht" model="ir.ui.view">
        <field name="name">account.move.line.tree.wht</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tax_line_id']" position="after">
                <field name="wht_tax_id" optional="hide" string="WHT"/>
                <field name="wht_invoice_amount" optional="hide" string="WHT Amount"/>
            </xpath>
        </field>
    </record>
    
</odoo>
