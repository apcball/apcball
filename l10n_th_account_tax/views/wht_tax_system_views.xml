    <!-- Account Move (Invoice) WHT Information -->
    <record id="account_move_form_view_wht_info" model="ir.ui.view">
        <field name="name">account.move.form.wht.info</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add WHT Information in header -->
            <xpath expr="//sheet//group[last()]" position="after">
                <group string="Withholding Tax Summary" 
                       invisible="not line_ids or move_type not in ('in_invoice', 'in_refund', 'out_invoice', 'out_refund')">
                    <group col="4">
                        <label for="total_withholding_base" string="WHT Base Amount"/>
                        <div>
                            <field name="total_withholding_base" nolabel="1" class="oe_inline"/>
                            <span class="oe_inline"> (Base amount subject to WHT)</span>
                        </div>
                        <label for="total_withholding_tax" string="WHT Tax Amount"/>
                        <div>
                            <field name="total_withholding_tax" nolabel="1" class="oe_inline"/>
                            <span class="oe_inline"> (Withholding tax amount)</span>
                        </div>
                    </group>
                    <div invisible="total_withholding_tax == 0" class="alert alert-info">
                        <strong>Note:</strong> This invoice contains withholding tax. 
                        The WHT amount will be deducted from payment and WHT certificates will be generated automatically.
                    </div>
                </group>
            </xpath>
        </field>
    </record>
    
    <!-- Withholding Tax Cert with Payment Link -->
    <record id="withholding_tax_cert_form_view_payment" model="ir.ui.view">
        <field name="name">withholding.tax.cert.form.payment</field>
        <field name="model">withholding.tax.cert</field>
        <field name="inherit_id" ref="l10n_th_account_tax.withholding_tax_cert_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="payment_id" readonly="1" invisible="not payment_id"/>
                <field name="auto_generated" invisible="1"/>
                <div invisible="not auto_generated" class="alert alert-success">
                    <i class="fa fa-check-circle"/> This certificate was automatically generated from payment processing.
                </div>
            </field>
        </field>
    </record>
    
</odoo>
