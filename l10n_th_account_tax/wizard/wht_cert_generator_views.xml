<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wht_cert_generator_form" model="ir.ui.view">
        <field name="name">wht.cert.generator.form</field>
        <field name="model">wht.cert.generator</field>
        <field name="arch" type="xml">
            <form string="Generate WHT Certificate">
                <sheet>
                    <group>
                        <group>
                            <field name="payment_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="income_tax_form" required="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="WHT Certificate Lines">
                            <field name="wht_cert_line_ids">
                                <tree editable="bottom">
                                    <field name="partner_id" readonly="1"/>
                                    <field name="wht_cert_income_type" required="1"/>
                                    <field name="base_amount" required="1"/>
                                    <field name="wht_amount" required="1"/>
                                    <field name="tax_id" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_generate_wht_cert" string="Generate Certificate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wht_cert_generator" model="ir.actions.act_window">
        <field name="name">Generate WHT Certificate</field>
        <field name="res_model">wht.cert.generator</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_wht_cert_generator_form"/>
    </record>
</odoo>
