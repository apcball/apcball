<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for opening the wizard -->
    <record id="action_wht_manual_create_wizard" model="ir.actions.act_window">
        <field name="name">Create WHT Certificate</field>
        <field name="res_model">wht.manual.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

    <record id="view_wht_manual_create_wizard_form" model="ir.ui.view">
        <field name="name">WHT Manual Create Wizard</field>
        <field name="model">wht.manual.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Create WHT Certificate Manually">
                <group>
                    <group>
                        <field name="payment_id" readonly="1" invisible="not payment_id"/>
                        <field name="move_id" readonly="1" invisible="not move_id"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="amount_total" readonly="1" invisible="not payment_id"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="income_tax_form"/>
                        <field name="wht_cert_income_type"/>
                    </group>
                </group>
                <group string="WHT Tax Information">
                    <group>
                        <field name="wht_tax_rate"/>
                        <field name="wht_tax_amount"/>
                    </group>
                    <group>
                        <field name="wht_base_amount"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_wht_cert" type="object" string="Create WHT Certificate" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
