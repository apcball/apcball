<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_trade_channel_tab" model="ir.ui.view">
        <field name="name">account.move.form.inherit.trade.channel.tab</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add a Marketplace tab to the invoice notebook and show trade_channel there -->
            <xpath expr="(//notebook)[1]" position="inside">
                <page string="Marketplace" name="marketplace_tab">
                    <group>
                        <field name="trade_channel"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
