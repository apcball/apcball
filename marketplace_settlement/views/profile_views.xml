<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_marketplace_settlement_profile_tree" model="ir.ui.view">
        <field name="name">marketplace.settlement.profile.tree</field>
        <field name="model">marketplace.settlement.profile</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="trade_channel"/>
                <field name="marketplace_partner_id"/>
                <field name="journal_id"/>
                <field name="settlement_account_id"/>
            </tree>
        </field>
    </record>

    <record id="view_marketplace_settlement_profile_form" model="ir.ui.view">
        <field name="name">marketplace.settlement.profile.form</field>
        <field name="model">marketplace.settlement.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="trade_channel"/>
                        <field name="marketplace_partner_id"/>
                        <field name="journal_id"/>
                        <field name="settlement_account_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_marketplace_settlement_profile" model="ir.actions.act_window">
        <field name="name">Marketplace Profiles</field>
        <field name="res_model">marketplace.settlement.profile</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Configure default partner/journal/account per trade channel.</p>
        </field>
    </record>

    <menuitem id="menu_marketplace_profiles" name="Profiles" parent="menu_marketplace_settlement" action="action_marketplace_settlement_profile"/>

    <!-- Reconcile action: point to account.move.line unreconciled items -->
    <record id="action_marketplace_reconcile" model="ir.actions.act_window">
        <field name="name">Reconcile Models</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_unreconciled': 1}</field>
        <field name="help" type="html">
            <p>Use this view to manually reconcile marketplace-related journal items such as fees.</p>
        </field>
    </record>

</odoo>
