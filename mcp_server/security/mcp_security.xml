<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- MCP API Key: users can only see their own keys (unless admin) -->
        <record id="mcp_api_key_user_rule" model="ir.rule">
            <field name="name">MCP API Key: own keys only</field>
            <field name="model_id" ref="model_mcp_api_key"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="mcp_api_key_admin_rule" model="ir.rule">
            <field name="name">MCP API Key: admin sees all</field>
            <field name="model_id" ref="model_mcp_api_key"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>
    </data>
</odoo>
