<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mcp_api_key_tree" model="ir.ui.view">
        <field name="name">mcp.api.key.tree</field>
        <field name="model">mcp.api.key</field>
        <field name="arch" type="xml">
            <tree string="MCP API Keys">
                <field name="name"/>
                <field name="user_id"/>
                <field name="policy"/>
                <field name="active"/>
                <field name="last_used"/>
                <field name="usage_count"/>
            </tree>
        </field>
    </record>

    <record id="view_mcp_api_key_form" model="ir.ui.view">
        <field name="name">mcp.api.key.form</field>
        <field name="model">mcp.api.key</field>
        <field name="arch" type="xml">
            <form string="MCP API Key">
                <header>
                    <button name="regenerate_key" type="object" string="🔄 Regenerate Key"
                            confirm="Are you sure? The old key will stop working immediately."
                            class="btn-warning"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="API Key Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id"/>
                            <field name="policy" widget="radio"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="key" readonly="1"/>
                            <field name="last_used" readonly="1"/>
                            <field name="usage_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Notes about this API key..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mcp_api_key" model="ir.actions.act_window">
        <field name="name">MCP API Keys</field>
        <field name="res_model">mcp.api.key</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first MCP API Key
            </p>
        </field>
    </record>

    <menuitem id="menu_mcp_api_key"
              name="MCP API Keys"
              parent="base.menu_custom"
              action="action_mcp_api_key"
              sequence="10"/>
</odoo>
