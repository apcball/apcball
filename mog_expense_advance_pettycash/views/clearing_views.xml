
<odoo>
    <record id="view_expense_clearing_tree" model="ir.ui.view">
        <field name="name">expense.clearing.tree</field>
        <field name="model">hr.expense.advance.clearing</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="advance_id"/>
                <field name="expense_sheet_id"/>
                <field name="amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_expense_clearing_form" model="ir.ui.view">
        <field name="name">expense.clearing.form</field>
        <field name="model">hr.expense.advance.clearing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post" type="object" string="Post" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="advance_id"/>
                        <field name="expense_sheet_id"/>
                        <field name="amount"/>
                        <field name="diff_move_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_expense_clearings" model="ir.actions.act_window">
        <field name="name">Advance Clearings</field>
        <field name="res_model">hr.expense.advance.clearing</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
