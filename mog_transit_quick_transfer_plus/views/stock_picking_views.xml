<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_picking_form_inherit_transit_quick_transfer_plus" model="ir.ui.view">
    <field name="name">stock.picking.form.transit.quick.transfer.plus</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
      <!-- Ensure the field used in modifiers is present in the view -->
      <xpath expr="//form" position="inside">
        <field name="is_transit_receipt" invisible="1"/>
      </xpath>
      <xpath expr="//header" position="inside">
        <button name="action_open_transit_transfer_wizard"
                type="object"
                string="Create Transfer"
                class="oe_highlight"
                invisible="not is_transit_receipt"/>
        <button name="action_rebuild_valuation"
                type="object"
                string="Rebuild Valuation"
                invisible="state != 'done' or picking_type_id.code != 'internal'"
                class="btn-secondary"/>
      </xpath>
    </field>
  </record>
</odoo>
