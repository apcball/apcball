<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_dp_excel" model="ir.actions.report">
        <field name="name">DP Excel Report</field>
        <field name="model">sale.order</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">mogen_report_dp_excel.report_dp_xlsx</field>
        <field name="report_file">mogen_report_dp_excel.report_dp_xlsx</field>
        <field name="print_report_name">'DP_Report_%s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_dp_excel_wizard" model="ir.actions.report">
        <field name="name">DP Excel Report</field>
        <field name="model">mogen.report.dp.excel.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">mogen_report_dp_excel.report_dp_xlsx_wizard</field>
        <field name="report_file">mogen_report_dp_excel.report_dp_xlsx_wizard</field>
        <field name="print_report_name">object.report_filename</field>
    </record>
</odoo>
