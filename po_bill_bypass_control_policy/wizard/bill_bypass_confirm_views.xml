<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bill_bypass_confirm_wizard_form" model="ir.ui.view">
        <field name="name">bill.bypass.confirm.wizard.form</field>
        <field name="model">bill.bypass.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Vendor Bill Before Receipt?">
                <div>
                    This PO has no received quantities yet.<br/>
                    Do you want to continue using bypass mode?
                </div>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
