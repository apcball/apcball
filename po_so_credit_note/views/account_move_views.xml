<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Account Move Form View Extension (Credit Note) -->
    <record id="account_move_form_view_inherit" model="ir.ui.view">
        <field name="name">account.move.form.view.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add source fields to credit notes -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="move_type" invisible="1"/>
                <field name="source_po_id" invisible="move_type != 'in_refund'"/>
                <field name="source_so_id" invisible="move_type != 'out_refund'"/>
                <field name="source_line_ids" invisible="move_type not in ('in_refund', 'out_refund')"/>
            </xpath>
        </field>
    </record>

    <!-- Add source fields to tree view -->
    <record id="account_move_tree_view_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.view.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="source_po_id" optional="hide"/>
                <field name="source_so_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
