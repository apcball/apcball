<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PO Credit Note Wizard Form View -->
    <record id="po_credit_note_wizard_form" model="ir.ui.view">
        <field name="name">po.credit.note.wizard.form</field>
        <field name="model">po.credit.note.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="purchase_order_id"/>
                        <field name="journal_id"/>
                        <field name="date"/>
                        <field name="reason"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="selected"/>
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_create_credit_note"
                            type="object"
                            string="Create Credit Note"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for PO Credit Note Wizard -->
    <record id="action_po_credit_note_wizard" model="ir.actions.act_window">
        <field name="name">Create PO Credit Note</field>
        <field name="res_model">po.credit.note.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
