<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- SO Credit Note Wizard Form View -->
    <record id="so_credit_note_wizard_form" model="ir.ui.view">
        <field name="name">so.credit.note.wizard.form</field>
        <field name="model">so.credit.note.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="journal_id"/>
                        <field name="date"/>
                        <field name="reason"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="selected"/>
                                    <field name="product_id"/>
                                    <field name="ordered_qty"/>
                                    <field name="delivered_qty"/>
                                    <field name="invoiced_qty"/>
                                    <field name="qty_to_refund"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_create_credit_note"
                            type="object"
                            string="Create Credit Note"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for SO Credit Note Wizard -->
    <record id="action_so_credit_note_wizard" model="ir.actions.act_window">
        <field name="name">Create SO Credit Note</field>
        <field name="res_model">so.credit.note.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
