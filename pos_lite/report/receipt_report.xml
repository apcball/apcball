<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_pos_lite_58mm" model="report.paperformat">
        <field name="name">POS Lite Thermal 58mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">58</field>
        <field name="page_height">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="paperformat_pos_lite_80mm" model="report.paperformat">
        <field name="name">POS Lite Thermal 80mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="paperformat_pos_lite_a4" model="report.paperformat">
        <field name="name">POS Lite A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Receipt Template                                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <template id="report_receipt_document">
        <t t-call="web.basic_layout">
            <style>
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-Regular.ttf') format('truetype');
                    font-weight: normal;
                }
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-Bold.ttf') format('truetype');
                    font-weight: bold;
                }
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-Italic.ttf') format('truetype');
                    font-style: italic;
                }
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-BoldItalic.ttf') format('truetype');
                    font-weight: bold;
                    font-style: italic;
                }
                .page, table, td, th, div, span, h2, h4, body {
                    font-family: 'Sarabun', sans-serif !important;
                }
            </style>
            <t t-foreach="docs" t-as="o">
                <t t-set="config" t-value="o.env['pos.lite.config'].get_default_config(o.company_id)"/>
                <div class="page" style="font-size: 11px; line-height: 1.35;">
                    <!-- Header -->
                    <div style="text-align: center; margin-bottom: 8px;">
                        <strong t-esc="o.company_id.name"/>
                        <div t-if="config and config.phone">Tel: <span t-esc="config.phone"/></div>
                        <div t-elif="o.company_id.partner_id.phone">Tel: <span t-esc="o.company_id.partner_id.phone"/></div>
                        <div t-if="o.company_id.partner_id.street" t-esc="o.company_id.partner_id.street"/>
                        <t t-set="display_vat" t-value="config.vat_number if config and config.vat_number else o.company_id.vat"/>
                        <div t-if="display_vat">Tax ID: <span t-esc="display_vat"/><span t-if="config and config.branch_number"> สาขา: <span t-esc="config.branch_number"/></span></div>
                        <div t-if="o.is_return" style="margin-top: 4px; font-weight: bold; color: #b00020;">
                            <span t-if="o.is_exchange">EXCHANGE</span>
                            <span t-else="">RETURN / REFUND</span>
                        </div>
                    </div>
                    <!-- Order info -->
                    <div style="border-top: 1px dashed #333; border-bottom: 1px dashed #333; padding: 6px 0; margin-bottom: 8px;">
                        <div>Date: <span t-esc="(o.date_order or o.create_date).strftime('%Y-%m-%d %H:%M')"/></div>
                        <div>Order: <span t-esc="o.name"/></div>
                        <div t-if="o.session_id">Session: <span t-esc="o.session_id.name"/></div>
                        <div t-if="o.customer_name">Customer: <span t-esc="o.customer_name"/></div>
                        <div t-if="o.partner_phone">Phone: <span t-esc="o.partner_phone"/></div>
                        <div t-if="o.partner_invoice_id">Address: <span t-esc="o.partner_invoice_id.contact_address"/></div>
                        <div t-if="o.partner_shipping_id">Delivery: <span t-esc="o.partner_shipping_id.contact_address"/></div>
                        <div t-if="not o.partner_shipping_id and o.partner_invoice_id">Delivery: <span t-esc="o.partner_invoice_id.contact_address"/> (same as customer)</div>
                        <div>Channel: <span t-esc="dict(o._fields['channel'].selection).get(o.channel, o.channel)"/></div>
                        <div>Cashier: <span t-esc="o.create_uid.name"/></div>
                        <div t-if="o.employee_id">Employee: <span t-esc="o.employee_id.name"/></div>
                        <div t-if="o.is_return and o.return_of_order_id">Original: <span t-esc="o.return_of_order_id.name"/></div>
                        <div t-if="o.return_reason">Reason: <span t-esc="o.return_reason"/></div>
                    </div>
                    <!-- Line items -->
                    <table class="table table-sm" style="width: 100%; margin-bottom: 8px;">
                        <thead>
                            <tr>
                                <th style="width: 40%">Item</th>
                                <th class="text-end" style="width: 10%">Qty</th>
                                <th class="text-end" style="width: 16%">Price</th>
                                <th class="text-end" style="width: 10%">Disc.</th>
                                <th class="text-end" style="width: 24%">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.line_ids" t-as="line">
                                <tr>
                                    <td>
                                        <span t-esc="line.description or line.product_id.display_name"/>
                                        <div t-if="line.product_id.default_code" style="font-size: 9px; color: #666;">
                                            <span t-esc="line.product_id.default_code"/>
                                        </div>
                                    </td>
                                    <td class="text-end"><span t-esc="line.qty"/></td>
                                    <td class="text-end"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    <td class="text-end"><span t-if="line.discount" t-esc="'%s%%' % line.discount"/></td>
                                    <td class="text-end"><span t-field="line.price_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <!-- Totals -->
                    <table style="width: 100%; margin-bottom: 4px;">
                        <tr><td>Subtotal</td><td class="text-end"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td></tr>
                        <tr><td>VAT / Tax</td><td class="text-end"><span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td></tr>
                        <tr style="font-weight: bold; font-size: 12px;">
                            <td><span t-esc="'Refund Total' if o.is_return else 'Total'"/></td>
                            <td class="text-end"><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                        </tr>
                    </table>
                    <!-- Payments -->
                    <t t-if="o.payment_ids">
                        <div style="border-top: 1px dashed #333; padding-top: 4px; margin-bottom: 4px;">
                            <strong>Payment:</strong>
                        </div>
                        <t t-foreach="o.payment_ids" t-as="pay">
                            <div style="display: flex; justify-content: space-between;">
                                <span t-esc="dict(pay._fields['payment_method'].selection).get(pay.payment_method, pay.payment_method)"/>
                                <span t-field="pay.amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </div>
                            <div t-if="pay.reference" style="font-size: 9px; color: #666; padding-left: 8px;">
                                Ref: <span t-esc="pay.reference"/>
                            </div>
                        </t>
                    </t>
                    <div style="margin-top: 4px;">
                        <div style="display: flex; justify-content: space-between;">
                            <span t-esc="'Refund Paid' if o.is_return else 'Paid'"/>
                            <span t-field="o.amount_paid" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </div>
                        <div t-if="o.amount_change > 0" style="display: flex; justify-content: space-between; font-weight: bold;">
                            <span>Change</span>
                            <span t-field="o.amount_change" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </div>
                    </div>
                    <div t-if="o.note" style="margin: 8px 0; border-top: 1px dashed #333; padding-top: 4px;">
                        <strong>Note:</strong> <span t-esc="o.note"/>
                    </div>
                    <div style="text-align: center; border-top: 1px dashed #333; padding-top: 8px; margin-top: 8px;">Thank you!</div>
                </div>
            </t>
        </t>
    </template>

    <!-- Receipt report actions -->
    <record id="action_report_pos_lite_receipt_58mm" model="ir.actions.report">
        <field name="name">POS Lite Receipt 58mm</field>
        <field name="model">pos.lite.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_receipt_document</field>
        <field name="report_file">pos_lite.report_receipt_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_58mm"/>
        <field name="print_report_name">'POS Receipt - %s' % (object.name)</field>
    </record>

    <record id="action_report_pos_lite_receipt_80mm" model="ir.actions.report">
        <field name="name">POS Lite Receipt 80mm</field>
        <field name="model">pos.lite.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_receipt_document</field>
        <field name="report_file">pos_lite.report_receipt_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_80mm"/>
        <field name="print_report_name">'POS Receipt - %s' % (object.name)</field>
    </record>

    <record id="action_report_pos_lite_receipt_a4" model="ir.actions.report">
        <field name="name">POS Lite Receipt A4</field>
        <field name="model">pos.lite.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_receipt_document</field>
        <field name="report_file">pos_lite.report_receipt_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_a4"/>
        <field name="print_report_name">'POS Receipt - %s' % (object.name)</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Session Summary Report                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <template id="report_session_document">
        <t t-call="web.basic_layout">
            <style>
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-Regular.ttf') format('truetype');
                    font-weight: normal;
                }
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-Bold.ttf') format('truetype');
                    font-weight: bold;
                }
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-Italic.ttf') format('truetype');
                    font-style: italic;
                }
                @font-face {
                    font-family: 'Sarabun';
                    src: url('/pos_lite/static/fonts/Sarabun-BoldItalic.ttf') format('truetype');
                    font-weight: bold;
                    font-style: italic;
                }
                .page, table, td, th, div, span, h1, h2, h3, h4, body {
                    font-family: 'Sarabun', sans-serif !important;
                }
                .sum-table {
                    width: 100%;
                    border-collapse: collapse;
                }
                .sum-table td {
                    padding: 6px 10px;
                    font-size: 20px;
                    border-bottom: 1px solid #e0e0e0;
                }
                .sum-table tr:last-child td {
                    border-bottom: none;
                }
                .sum-table .label-col {
                    width: 55%;
                    color: #333;
                }
                .sum-table .value-col {
                    width: 45%;
                    text-align: right;
                    font-weight: normal;
                }
                .section-box {
                    border: 1px solid #ccc;
                    border-radius: 6px;
                    margin-bottom: 16px;
                    overflow: hidden;
                }
                .section-header {
                    background: #2c3e50;
                    color: #fff;
                    padding: 8px 14px;
                    font-size: 20px;
                    font-weight: bold;
                }
                .section-body {
                    padding: 0;
                }
                .highlight-row td {
                    background: #eaf6ff;
                    font-weight: bold;
                    font-size: 22px;
                }
                .net-row td {
                    background: #1a73e8;
                    color: #fff;
                    font-weight: bold;
                    font-size: 24px;
                    border-bottom: none;
                }
            </style>
            <t t-foreach="docs" t-as="s">
                <div class="page" style="font-size: 20px; line-height: 1.5; padding: 10px;">

                    <!-- ═══ Title Bar ═══ -->
                    <div style="background: #2c3e50; color: #fff; text-align: center; padding: 14px 10px; border-radius: 8px; margin-bottom: 16px;">
                        <div style="font-size: 28px; font-weight: bold;">สรุปยอดขายประจำวัน</div>
                        <div style="font-size: 20px; margin-top: 2px;">SESSION SUMMARY</div>
                    </div>

                    <!-- ═══ Info Section ═══ -->
                    <div class="section-box">
                        <div class="section-header">📋 ข้อมูล Session</div>
                        <div class="section-body">
                            <table class="sum-table">
                                <tr>
                                    <td class="label-col" style="width: 25%;"><strong>Session:</strong></td>
                                    <td style="width: 25%;"><span t-esc="s.name"/></td>
                                    <td class="label-col" style="width: 25%;"><strong>สาขา:</strong></td>
                                    <td style="width: 25%;"><span t-esc="s.company_id.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>เปิดเมื่อ:</strong></td>
                                    <td><span t-esc="s.date_open.strftime('%d/%m/%Y %H:%M') if s.date_open else ''"/></td>
                                    <td><strong>ปิดเมื่อ:</strong></td>
                                    <td><span t-esc="s.date_close.strftime('%d/%m/%Y %H:%M') if s.date_close else 'ยังไม่ปิด'"/></td>
                                </tr>
                                <tr>
                                    <td><strong>ผู้เปิด:</strong></td>
                                    <td><span t-esc="s.user_id.name"/></td>
                                    <td><strong>ผู้ปิด:</strong></td>
                                    <td><span t-if="s.close_user_id" t-esc="s.close_user_id.name"/><span t-else="">-</span></td>
                                </tr>
                                <tr t-if="s.employee_id">
                                    <td><strong>พนักงาน:</strong></td>
                                    <td colspan="3"><span t-esc="s.employee_id.name"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- ═══ Two Column Layout ═══ -->
                    <div style="display: flex; gap: 14px;">

                        <!-- LEFT: Sales Summary -->
                        <div style="flex: 1;">
                            <div class="section-box">
                                <div class="section-header">💰 สรุปยอดขาย</div>
                                <div class="section-body">
                                    <table class="sum-table">
                                        <tr>
                                            <td class="label-col">จำนวนออเดอร์ขาย</td>
                                            <td class="value-col"><span t-esc="s.order_count_sales"/> รายการ</td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">จำนวนคืนสินค้า</td>
                                            <td class="value-col"><span t-esc="s.order_count_returns"/> รายการ</td>
                                        </tr>
                                        <tr class="highlight-row">
                                            <td class="label-col">รวมทั้งหมด</td>
                                            <td class="value-col"><span t-esc="s.order_count"/> รายการ</td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">ยอดขายรวม (Gross)</td>
                                            <td class="value-col"><span t-field="s.amount_total" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">ยอดก่อนภาษี</td>
                                            <td class="value-col"><span t-field="s.amount_untaxed" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">ภาษี 7%</td>
                                            <td class="value-col"><span t-field="s.amount_tax" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">ยอดคืนสินค้า</td>
                                            <td class="value-col" style="color: #b00020;">- <span t-field="s.amount_refund" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr class="net-row">
                                            <td class="label-col">💰 ยอดขายสุทธิ</td>
                                            <td class="value-col"><span t-field="s.amount_net" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- RIGHT: Payment Breakdown -->
                        <div style="flex: 1;">
                            <div class="section-box">
                                <div class="section-header">💳 รายการรับชำระ</div>
                                <div class="section-body">
                                    <table class="sum-table">
                                        <tr>
                                            <td class="label-col">💵 เงินสด (Cash)</td>
                                            <td class="value-col"><span t-field="s.payment_cash" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">🏦 เงินโอน (Transfer)</td>
                                            <td class="value-col"><span t-field="s.payment_transfer" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">💳 บัตรเครดิต (Card)</td>
                                            <td class="value-col"><span t-field="s.payment_card" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">📱 พร้อมเพย์ (PromptPay)</td>
                                            <td class="value-col"><span t-field="s.payment_promptpay" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-col">📦 อื่นๆ (Other)</td>
                                            <td class="value-col"><span t-field="s.payment_other" t-options='{"widget": "monetary", "display_currency": s.currency_id}'/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Note box -->
                            <div t-if="s.note" class="section-box">
                                <div class="section-header">📝 หมายเหตุ</div>
                                <div class="section-body" style="padding: 10px 14px;">
                                    <span t-esc="s.note"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div style="margin-top: 20px; padding-top: 10px; border-top: 2px solid #2c3e50; display: flex; justify-content: space-between; font-size: 18px; color: #666;">
                        <span>พิมพ์เมื่อ: <span t-esc="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/></span>
                        <span>POS Lite — <span t-esc="s.company_id.name"/></span>
                    </div>

                </div>
            </t>
        </t>
    </template>

    <record id="action_report_pos_lite_session" model="ir.actions.report">
        <field name="name">Session Summary</field>
        <field name="model">pos.lite.session</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_session_document</field>
        <field name="report_file">pos_lite.report_session_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_a4"/>
        <field name="print_report_name">'Session Summary - %s' % (object.name)</field>
    </record>
</odoo>
