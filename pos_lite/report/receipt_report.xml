<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_pos_lite_58mm" model="report.paperformat">
        <field name="name">POS Lite Thermal 58mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">58</field>
        <field name="page_height">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="paperformat_pos_lite_80mm" model="report.paperformat">
        <field name="name">POS Lite Thermal 80mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="paperformat_pos_lite_a4" model="report.paperformat">
        <field name="name">POS Lite A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Receipt Template                                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <template id="report_receipt_document">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <t t-set="config" t-value="o.env['pos.lite.config'].get_default_config(o.company_id)"/>
                <div class="page" style="font-size: 11px; line-height: 1.35;">
                    <!-- Header -->
                    <div style="text-align: center; margin-bottom: 8px;">
                        <strong t-esc="o.company_id.name"/>
                        <div t-if="config and config.phone">Tel: <span t-esc="config.phone"/></div>
                        <div t-elif="o.company_id.partner_id.phone">Tel: <span t-esc="o.company_id.partner_id.phone"/></div>
                        <div t-if="o.company_id.partner_id.street" t-esc="o.company_id.partner_id.street"/>
                        <t t-set="display_vat" t-value="config.vat_number if config and config.vat_number else o.company_id.vat"/>
                        <div t-if="display_vat">Tax ID: <span t-esc="display_vat"/><span t-if="config and config.branch_number"> สาขา: <span t-esc="config.branch_number"/></span></div>
                        <div t-if="o.is_return" style="margin-top: 4px; font-weight: bold; color: #b00020;">
                            <span t-if="o.is_exchange">EXCHANGE</span>
                            <span t-else="">RETURN / REFUND</span>
                        </div>
                    </div>
                    <!-- Order info -->
                    <div style="border-top: 1px dashed #333; border-bottom: 1px dashed #333; padding: 6px 0; margin-bottom: 8px;">
                        <div>Date: <span t-esc="(o.date_order or o.create_date).strftime('%Y-%m-%d %H:%M')"/></div>
                        <div>Order: <span t-esc="o.name"/></div>
                        <div t-if="o.session_id">Session: <span t-esc="o.session_id.name"/></div>
                        <div t-if="o.customer_name">Customer: <span t-esc="o.customer_name"/></div>
                        <div t-if="o.partner_phone">Phone: <span t-esc="o.partner_phone"/></div>
                        <div>Channel: <span t-esc="dict(o._fields['channel'].selection).get(o.channel, o.channel)"/></div>
                        <div>Cashier: <span t-esc="o.create_uid.name"/></div>
                        <div t-if="o.is_return and o.return_of_order_id">Original: <span t-esc="o.return_of_order_id.name"/></div>
                        <div t-if="o.return_reason">Reason: <span t-esc="o.return_reason"/></div>
                    </div>
                    <!-- Line items -->
                    <table class="table table-sm" style="width: 100%; margin-bottom: 8px;">
                        <thead>
                            <tr>
                                <th style="width: 40%">Item</th>
                                <th class="text-end" style="width: 10%">Qty</th>
                                <th class="text-end" style="width: 16%">Price</th>
                                <th class="text-end" style="width: 10%">Disc.</th>
                                <th class="text-end" style="width: 24%">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.line_ids" t-as="line">
                                <tr>
                                    <td>
                                        <span t-esc="line.description or line.product_id.display_name"/>
                                        <div t-if="line.product_id.default_code" style="font-size: 9px; color: #666;">
                                            <span t-esc="line.product_id.default_code"/>
                                        </div>
                                    </td>
                                    <td class="text-end"><span t-esc="line.qty"/></td>
                                    <td class="text-end"><span t-esc="formatLang(line.price_unit, currency_obj=o.currency_id)"/></td>
                                    <td class="text-end"><span t-if="line.discount" t-esc="'%s%%' % line.discount"/></td>
                                    <td class="text-end"><span t-esc="formatLang(line.price_total, currency_obj=o.currency_id)"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <!-- Totals -->
                    <table style="width: 100%; margin-bottom: 4px;">
                        <tr><td>Subtotal</td><td class="text-end"><span t-esc="formatLang(o.amount_untaxed, currency_obj=o.currency_id)"/></td></tr>
                        <tr><td>VAT / Tax</td><td class="text-end"><span t-esc="formatLang(o.amount_tax, currency_obj=o.currency_id)"/></td></tr>
                        <tr style="font-weight: bold; font-size: 12px;">
                            <td><span t-esc="'Refund Total' if o.is_return else 'Total'"/></td>
                            <td class="text-end"><span t-esc="formatLang(o.amount_total, currency_obj=o.currency_id)"/></td>
                        </tr>
                    </table>
                    <!-- Payments -->
                    <t t-if="o.payment_ids">
                        <div style="border-top: 1px dashed #333; padding-top: 4px; margin-bottom: 4px;">
                            <strong>Payment:</strong>
                        </div>
                        <t t-foreach="o.payment_ids" t-as="pay">
                            <div style="display: flex; justify-content: space-between;">
                                <span t-esc="dict(pay._fields['payment_method'].selection).get(pay.payment_method, pay.payment_method)"/>
                                <span t-esc="formatLang(pay.amount, currency_obj=o.currency_id)"/>
                            </div>
                            <div t-if="pay.reference" style="font-size: 9px; color: #666; padding-left: 8px;">
                                Ref: <span t-esc="pay.reference"/>
                            </div>
                        </t>
                    </t>
                    <div style="margin-top: 4px;">
                        <div style="display: flex; justify-content: space-between;">
                            <span t-esc="'Refund Paid' if o.is_return else 'Paid'"/>
                            <span t-esc="formatLang(o.amount_paid, currency_obj=o.currency_id)"/>
                        </div>
                        <div t-if="o.amount_change > 0" style="display: flex; justify-content: space-between; font-weight: bold;">
                            <span>Change</span>
                            <span t-esc="formatLang(o.amount_change, currency_obj=o.currency_id)"/>
                        </div>
                    </div>
                    <div t-if="o.note" style="margin: 8px 0; border-top: 1px dashed #333; padding-top: 4px;">
                        <strong>Note:</strong> <span t-esc="o.note"/>
                    </div>
                    <div style="text-align: center; border-top: 1px dashed #333; padding-top: 8px; margin-top: 8px;">Thank you!</div>
                </div>
            </t>
        </t>
    </template>

    <!-- Receipt report actions -->
    <record id="action_report_pos_lite_receipt_58mm" model="ir.actions.report">
        <field name="name">POS Lite Receipt 58mm</field>
        <field name="model">pos.lite.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_receipt_document</field>
        <field name="report_file">pos_lite.report_receipt_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_58mm"/>
        <field name="print_report_name">'POS Receipt - %s' % (object.name)</field>
    </record>

    <record id="action_report_pos_lite_receipt_80mm" model="ir.actions.report">
        <field name="name">POS Lite Receipt 80mm</field>
        <field name="model">pos.lite.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_receipt_document</field>
        <field name="report_file">pos_lite.report_receipt_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_80mm"/>
        <field name="print_report_name">'POS Receipt - %s' % (object.name)</field>
    </record>

    <record id="action_report_pos_lite_receipt_a4" model="ir.actions.report">
        <field name="name">POS Lite Receipt A4</field>
        <field name="model">pos.lite.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_receipt_document</field>
        <field name="report_file">pos_lite.report_receipt_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_a4"/>
        <field name="print_report_name">'POS Receipt - %s' % (object.name)</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Session Summary Report                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <template id="report_session_document">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="s">
                <t t-set="config" t-value="s.config_id"/>
                <div class="page" style="font-size: 12px; line-height: 1.4;">
                    <div style="text-align: center; margin-bottom: 16px;">
                        <h2 style="margin: 0;">Session Summary</h2>
                        <strong t-esc="s.company_id.name"/>
                        <div>Session: <span t-esc="s.name"/></div>
                    </div>
                    <table style="width: 100%; margin-bottom: 12px;">
                        <tr><td style="width: 50%"><strong>Opened:</strong> <span t-esc="s.date_open.strftime('%Y-%m-%d %H:%M') if s.date_open else ''"/></td>
                            <td><strong>Closed:</strong> <span t-esc="s.date_close.strftime('%Y-%m-%d %H:%M') if s.date_close else 'N/A'"/></td></tr>
                        <tr><td><strong>Cashier:</strong> <span t-esc="s.user_id.name"/></td>
                            <td><strong>Closed By:</strong> <span t-if="s.close_user_id" t-esc="s.close_user_id.name"/><span t-else="">-</span></td></tr>
                    </table>

                    <h4>Sales Summary</h4>
                    <table class="table table-sm table-bordered" style="width: 100%; margin-bottom: 12px;">
                        <tr><td>Sales Orders</td><td class="text-end"><span t-esc="s.order_count_sales"/></td></tr>
                        <tr><td>Returns</td><td class="text-end"><span t-esc="s.order_count_returns"/></td></tr>
                        <tr><td>Total Orders</td><td class="text-end"><span t-esc="s.order_count"/></td></tr>
                        <tr><td>Gross Sales</td><td class="text-end"><span t-esc="formatLang(s.amount_total, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>Untaxed</td><td class="text-end"><span t-esc="formatLang(s.amount_untaxed, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>Tax</td><td class="text-end"><span t-esc="formatLang(s.amount_tax, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>Refunds</td><td class="text-end"><span t-esc="formatLang(s.amount_refund, currency_obj=s.currency_id)"/></td></tr>
                        <tr style="font-weight: bold; font-size: 1.1em;"><td>Net Revenue</td><td class="text-end"><span t-esc="formatLang(s.amount_net, currency_obj=s.currency_id)"/></td></tr>
                    </table>

                    <h4>Payment Breakdown</h4>
                    <table class="table table-sm table-bordered" style="width: 100%;">
                        <tr><td>Cash</td><td class="text-end"><span t-esc="formatLang(s.payment_cash, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>Transfer</td><td class="text-end"><span t-esc="formatLang(s.payment_transfer, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>Card</td><td class="text-end"><span t-esc="formatLang(s.payment_card, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>PromptPay</td><td class="text-end"><span t-esc="formatLang(s.payment_promptpay, currency_obj=s.currency_id)"/></td></tr>
                        <tr><td>Other</td><td class="text-end"><span t-esc="formatLang(s.payment_other, currency_obj=s.currency_id)"/></td></tr>
                    </table>

                    <div t-if="s.note" style="margin-top: 12px;">
                        <strong>Notes:</strong> <span t-esc="s.note"/>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_pos_lite_session" model="ir.actions.report">
        <field name="name">Session Summary</field>
        <field name="model">pos.lite.session</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_lite.report_session_document</field>
        <field name="report_file">pos_lite.report_session_document</field>
        <field name="paperformat_id" ref="pos_lite.paperformat_pos_lite_a4"/>
        <field name="print_report_name">'Session Summary - %s' % (object.name)</field>
    </record>
</odoo>
