<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_lite_config_tree" model="ir.ui.view">
        <field name="name">pos.lite.config.tree</field>
        <field name="model">pos.lite.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
                <field name="warehouse_id"/>
                <field name="pricelist_id"/>
                <field name="journal_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_pos_lite_config_form" model="ir.ui.view">
        <field name="name">pos.lite.config.form</field>
        <field name="model">pos.lite.config</field>
        <field name="arch" type="xml">
            <form string="POS Lite Configuration">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="warehouse_id"/>
                            <field name="pricelist_id"/>
                            <field name="journal_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_lite_config" model="ir.actions.act_window">
        <field name="name">POS Lite Configuration</field>
        <field name="res_model">pos.lite.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
