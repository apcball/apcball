<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_lite_order_tree" model="ir.ui.view">
        <field name="name">pos.lite.order.tree</field>
        <field name="model">pos.lite.order</field>
        <field name="arch" type="xml">
            <tree decoration-success="state in ('paid','done')" decoration-muted="state == 'cancelled'" decoration-warning="state == 'held'" decoration-danger="is_return">
                <field name="name"/>
                <field name="date_order" string="Date"/>
                <field name="state"/>
                <field name="channel"/>
                <field name="partner_id"/>
                <field name="warehouse_id"/>
                <field name="amount_total" sum="Total"/>
                <field name="amount_paid" sum="Paid"/>
                <field name="amount_change" sum="Change"/>
                <field name="is_return" invisible="1"/>
                <field name="is_exchange" invisible="1"/>
                <field name="return_of_order_id"/>
                <field name="return_count" invisible="1"/>
                <field name="invoice_id"/>
                <field name="picking_id"/>
                <field name="session_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_pos_lite_order_search" model="ir.ui.view">
        <field name="name">pos.lite.order.search</field>
        <field name="model">pos.lite.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id" context="{'pos_lite_partner_search': 1}"/>
                <field name="warehouse_id"/>
                <field name="channel"/>
                <field name="session_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Held" name="held" domain="[('state', '=', 'held')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Returns" name="returns" domain="[('is_return', '=', True)]"/>
                <filter string="Sales" name="sales" domain="[('is_return', '=', False)]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('date_order', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Week" name="this_week" domain="[('date_order', '&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Month" name="this_month" domain="[('date_order', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Channel" name="group_channel" context="{'group_by': 'channel'}"/>
                    <filter string="Warehouse" name="group_warehouse" context="{'group_by': 'warehouse_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Session" name="group_session" context="{'group_by': 'session_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date_order:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pos_lite_order_form" model="ir.ui.view">
        <field name="name">pos.lite.order.form</field>
        <field name="model">pos.lite.order</field>
        <field name="arch" type="xml">
            <form string="POS Lite Order">
                <header>
                    <!-- Draft actions -->
                    <button name="action_quick_pay_and_process" type="object" string="⚡ Pay &amp; Process" class="oe_highlight" invisible="state not in ('draft', 'held')" groups="pos_lite.group_pos_lite_user"/>
                    <button name="action_register_payment" type="object" string="💳 Payment" class="btn-secondary" invisible="state not in ('draft', 'held')"/>
                    <button name="action_process_order" type="object" string="✓ Process" invisible="state != 'draft'" groups="pos_lite.group_pos_lite_user"/>
                    <button name="action_hold" type="object" string="⏸ Hold" invisible="state != 'draft'"/>
                    <button name="action_resume" type="object" string="▶ Resume" class="oe_highlight" invisible="state != 'held'"/>
                    <!-- Paid actions -->
                    <button name="action_done" type="object" string="Mark Done" invisible="state != 'paid'"/>
                    <!-- Done actions -->
                    <button name="action_create_return" type="object" string="↩ Return" class="btn-secondary" invisible="state != 'done' or is_return"/>
                    <button name="action_create_exchange" type="object" string="⇄ Exchange" class="btn-secondary" invisible="state != 'done' or is_return"/>
                    <!-- Any processed state -->
                    <button name="action_reorder" type="object" string="🔄 Re-order" class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_cancel" type="object" string="✕ Cancel" invisible="state == 'cancelled' or (state == 'done' and not is_return)"/>
                    <!-- Print -->
                    <button name="action_print_receipt_58mm" type="object" string="🧾 58mm" invisible="state == 'draft'" groups="pos_lite.group_pos_lite_user"/>
                    <button name="action_print_receipt_80mm" type="object" string="🧾 80mm" invisible="state == 'draft'" groups="pos_lite.group_pos_lite_user"/>
                    <button name="action_print_receipt_a4" type="object" string="🧾 A4" invisible="state == 'draft'" groups="pos_lite.group_pos_lite_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="invoice_id"/></span>
                                <span class="o_stat_text">Invoice</span>
                            </div>
                        </button>
                        <button name="action_view_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="picking_id"/></span>
                                <span class="o_stat_text">Picking</span>
                            </div>
                        </button>
                        <button name="action_view_returns" type="object" class="oe_stat_button" icon="fa-undo" invisible="is_return or return_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="return_count"/></span>
                                <span class="o_stat_text">Returns</span>
                            </div>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money" invisible="state == 'draft'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Payments</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="customer_name" placeholder="Customer Name"/>
                            <field name="partner_id" context="{'pos_lite_partner_search': 1}" options="{'no_create_edit': False}"/>
                            <field name="partner_phone"/>
                            <field name="partner_address"/>
                            <field name="partner_tax_id"/>
                        </group>
                        <group string="Order">
                            <field name="channel"/>
                            <field name="date_order"/>
                            <field name="warehouse_id" options="{'no_create': True}"/>
                            <field name="pricelist_id"/>
                            <field name="session_id" options="{'no_create': True}"/>
                            <field name="company_id" invisible="1"/>
                            <field name="is_return" invisible="1"/>
                        </group>
                    </group>
                    <!-- Return/Exchange info -->
                    <group invisible="not is_return">
                        <group string="Return Info">
                            <field name="return_of_order_id" readonly="1"/>
                            <field name="return_reason" readonly="1"/>
                            <field name="is_exchange" invisible="1"/>
                            <field name="exchange_of_order_id" readonly="1" invisible="not is_exchange"/>
                        </group>
                    </group>
                    <!-- Totals bar (always visible) -->
                    <field name="currency_id" invisible="1"/>
                    <group col="6" colspan="2">
                        <group>
                            <field name="amount_untaxed" readonly="1" widget="monetary" string="Untaxed"/>
                        </group>
                        <group>
                            <field name="amount_tax" readonly="1" widget="monetary" string="Tax"/>
                        </group>
                        <group>
                            <field name="amount_total" readonly="1" widget="monetary" string="Total" class="oe_inline"/>
                        </group>
                        <group>
                            <field name="amount_paid" readonly="1" widget="monetary" string="Paid"/>
                        </group>
                        <group>
                            <field name="amount_residual" readonly="1" widget="monetary" string="Due" decoration-danger="amount_residual > 0"/>
                        </group>
                        <group>
                            <field name="amount_change" readonly="1" widget="monetary" string="Change"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="line_ids" mode="tree" nolabel="1">
                                <tree editable="bottom" decoration-danger="is_low_stock">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" context="{'pos_lite_search': 1}" string="Product"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="qty_available" readonly="1" string="Stock"/>
                                    <field name="is_low_stock" invisible="1"/>
                                    <field name="price_unit" string="Price"/>
                                    <field name="discount" string="Disc%"/>
                                    <field name="price_subtotal" readonly="1" sum="Subtotal"/>
                                    <field name="price_tax" readonly="1" sum="Tax"/>
                                    <field name="price_total" readonly="1" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Payments" invisible="state == 'draft' and not payment_ids">
                            <field name="payment_ids" nolabel="1">
                                <tree editable="bottom" readonly="state not in ('draft', 'held')">
                                    <field name="state" invisible="1"/>
                                    <field name="company_id" invisible="1"/>
                                    <field name="payment_method"/>
                                    <field name="amount"/>
                                    <field name="journal_id"/>
                                    <field name="reference"/>
                                    <field name="payment_date"/>
                                    <field name="note"/>
                                    <field name="account_payment_id" readonly="1" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note" placeholder="Add notes, delivery instructions, LINE message details..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_pos_lite_orders" model="ir.actions.act_window">
        <field name="name">POS Lite Orders</field>
        <field name="res_model">pos.lite.order</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_channel': 'phone', 'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create the first lightweight order.</p>
        </field>
    </record>

    <!-- Held Orders Action -->
    <record id="action_pos_lite_held_orders" model="ir.actions.act_window">
        <field name="name">Held Orders</field>
        <field name="res_model">pos.lite.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'held')]</field>
    </record>
</odoo>
