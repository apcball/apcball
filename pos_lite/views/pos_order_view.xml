<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_lite_order_tree" model="ir.ui.view">
        <field name="name">pos.lite.order.tree</field>
        <field name="model">pos.lite.order</field>
        <field name="arch" type="xml">
            <tree decoration-success="state in ('paid','done')" decoration-muted="state == 'cancelled'" decoration-warning="state == 'held'" decoration-danger="return_status == 'Return'">
                <field name="name"/>
                <field name="date_order" string="Date"/>
                <field name="state" widget="badge" decoration-success="state in ('paid','done')" decoration-warning="state == 'held'" decoration-danger="state == 'cancelled'"/>
                <field name="channel" widget="badge"/>
                <field name="partner_id"/>
                <field name="partner_shipping_id" optional="hide" string="Delivery"/>
                <field name="warehouse_id"/>
                <field name="amount_total" sum="Total" widget="monetary"/>
                <field name="amount_paid" sum="Paid" widget="monetary"/>
                <field name="amount_residual" sum="Due" widget="monetary" decoration-danger="amount_residual > 0"/>
                <field name="return_status" widget="badge" decoration-danger="return_status == 'Return'" decoration-success="return_status == 'Sale'" optional="show"/>
                <field name="exchange_status" widget="badge" decoration-warning="exchange_status == 'Exchange'" decoration-muted="exchange_status == 'Direct'" optional="show"/>
                <field name="return_of_order_id" optional="hide"/>
                <field name="return_count" invisible="1"/>
                <field name="invoice_id" optional="hide"/>
                <field name="picking_id" optional="hide"/>
                <field name="session_id" optional="hide"/>
                <field name="employee_id" optional="hide" string="Employee"/>
            </tree>
        </field>
    </record>

    <record id="view_pos_lite_order_search" model="ir.ui.view">
        <field name="name">pos.lite.order.search</field>
        <field name="model">pos.lite.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id" context="{'pos_lite_partner_search': 1}"/>
                <field name="partner_phone"/>
                <field name="warehouse_id"/>
                <field name="channel"/>
                <field name="session_id"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Held" name="held" domain="[('state', '=', 'held')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Returns" name="returns" domain="[('is_return', '=', True)]" invisible="1"/>
                <filter string="Sales" name="sales" domain="[('is_return', '=', False)]" invisible="1"/>
                <separator/>
                <filter string="Today" name="today" domain="[('date_order', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Week" name="this_week" domain="[('date_order', '&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Month" name="this_month" domain="[('date_order', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <separator/>
                <filter string="Has Invoice" name="has_invoice" domain="[('invoice_id', '!=', False)]"/>
                <filter string="No Invoice" name="no_invoice" domain="[('invoice_id', '=', False), ('state', 'in', ('paid','done'))]"/>
                <filter string="Has Picking" name="has_picking" domain="[('picking_id', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Channel" name="group_channel" context="{'group_by': 'channel'}"/>
                    <filter string="Warehouse" name="group_warehouse" context="{'group_by': 'warehouse_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Session" name="group_session" context="{'group_by': 'session_id'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date_order:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pos_lite_order_form" model="ir.ui.view">
        <field name="name">pos.lite.order.form</field>
        <field name="model">pos.lite.order</field>
        <field name="arch" type="xml">
            <form string="POS Lite Order">
                <header>
                    <!-- Draft/Held actions -->
                    <button name="action_quick_pay_and_process" type="object" string="⚡ Pay &amp; Process" class="oe_highlight" invisible="state not in ('draft', 'held')" groups="pos_lite.group_pos_lite_user"/>
                    <button name="action_register_payment" type="object" string="💳 Payment" class="btn-secondary" invisible="state not in ('draft', 'held')"/>
                    <button name="action_process_order" type="object" string="✓ Process" invisible="state != 'draft'" groups="pos_lite.group_pos_lite_user"/>
                    <button name="action_hold" type="object" string="⏸ Hold" invisible="state != 'draft'"/>
                    <button name="action_resume" type="object" string="▶ Resume" class="oe_highlight" invisible="state != 'held'"/>
                    <!-- Paid actions -->
                    <button name="action_done" type="object" string="Mark Done" invisible="state != 'paid'"/>
                    <!-- Return/Exchange — only for completed orders -->
                    <button name="action_create_return" type="object" string="↩ Return" class="btn-secondary" invisible="state != 'done'"/>
                    <button name="action_create_exchange" type="object" string="⇄ Exchange" class="btn-secondary" invisible="state != 'done'"/>
                    <!-- General -->
                    <button name="action_reorder" type="object" string="🔄 Re-order" class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_cancel" type="object" string="✕ Cancel" invisible="state == 'cancelled' or (state == 'done' and not is_return)"/>
                    <!-- Print -->
                    <button name="action_print_invoice" type="object" string="📄 Invoice" class="oe_highlight" invisible="state == 'draft'" groups="pos_lite.group_pos_lite_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid,done,cancelled"/>
                </header>
                <sheet>
                    <!-- Stat buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="invoice_id"/></span>
                                <span class="o_stat_text">Invoice</span>
                            </div>
                        </button>
                        <button name="action_view_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="picking_id"/></span>
                                <span class="o_stat_text">Picking</span>
                            </div>
                        </button>
                        <button name="action_view_returns" type="object" class="oe_stat_button" icon="fa-undo" invisible="is_return or return_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="return_count"/></span>
                                <span class="o_stat_text">Returns</span>
                            </div>
                        </button>
                        <button name="action_view_exchanges" type="object" class="oe_stat_button" icon="fa-exchange" invisible="is_return or exchange_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="exchange_count"/></span>
                                <span class="o_stat_text">Exchanges</span>
                            </div>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money" invisible="state == 'draft'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Payments</span>
                            </div>
                        </button>
                    </div>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ═══ Main Info: 3 columns ═══ -->
                    <group col="3" colspan="2">
                        <!-- Col 1: Customer -->
                        <group string="👤 Customer">
                            <field name="partner_id" context="{'pos_lite_partner_search': 1}" options="{'no_create_edit': False}" placeholder="Search or create customer..."/>
                            <field name="customer_name" placeholder="Customer Name" readonly="1"/>
                        </group>
                        <!-- Col 2: Invoice Address -->
                        <group string="📍 Invoice Address">
                            <field name="partner_invoice_id" options="{'no_create_edit': False}" placeholder="Auto-filled from customer"/>
                        </group>
                        <!-- Col 3: Delivery Address -->
                        <group string="🚚 Delivery Address">
                            <field name="partner_shipping_id" options="{'no_create_edit': False}" placeholder="Auto-filled from customer"/>
                        </group>
                    </group>

                    <!-- ═══ Order Details: 2 columns ═══ -->
                    <group col="2" colspan="2">
                        <group string="📋 Order Info">
                            <field name="channel"/>
                            <field name="date_order" readonly="state != 'draft'"/>
                            <field name="warehouse_id" options="{'no_create': True}"/>
                            <field name="pricelist_id"/>
                        </group>
                        <group string="⚙ Session">
                            <field name="session_id" options="{'no_create': True}"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="is_return" invisible="1"/>
                        </group>
                    </group>

                    <!-- Return/Exchange info -->
                    <group invisible="not is_return">
                        <group string="↩ Return Info">
                            <field name="return_of_order_id" readonly="1"/>
                            <field name="return_reason" readonly="1"/>
                            <field name="is_exchange" invisible="1"/>
                            <field name="exchange_of_order_id" readonly="1" invisible="not is_exchange"/>
                            <field name="exchange_return_order_id" readonly="1" invisible="not is_exchange"/>
                        </group>
                    </group>

                    <!-- Exchange info — original order side -->
                    <group invisible="is_return or exchange_count == 0">
                        <group string="⇄ Exchange Summary" col="2">
                            <field name="exchange_return_total" readonly="1" widget="monetary" string="Return Value"/>
                            <field name="exchange_new_total" readonly="1" widget="monetary" string="New Items Value"/>
                            <field name="exchange_difference" readonly="1" widget="monetary"
                                   string="Difference"
                                   decoration-success="exchange_customer_gets_refund == True"
                                   decoration-danger="exchange_customer_pays == True"/>
                            <field name="exchange_customer_pays" invisible="1"/>
                            <field name="exchange_customer_gets_refund" invisible="1"/>
                            <div class="alert alert-info" colspan="2" role="alert"
                                 invisible="not exchange_customer_pays">
                                <span>💡 Customer pays extra <field name="exchange_difference" widget="monetary"/> for the new items.</span>
                            </div>
                            <div class="alert alert-success" colspan="2" role="alert"
                                 invisible="not exchange_customer_gets_refund">
                                <span>💡 Customer gets refunded <field name="exchange_difference" widget="monetary" decoration-success="True"/> (new items cost less).</span>
                            </div>
                        </group>
                    </group>

                    <!-- ═══ Totals Bar ═══ -->
                    <field name="currency_id" invisible="1"/>
                    <group col="4" colspan="2">
                        <group>
                            <field name="amount_untaxed" readonly="1" widget="monetary" string="Untaxed"/>
                        </group>
                        <group>
                            <field name="amount_tax" readonly="1" widget="monetary" string="Tax"/>
                        </group>
                        <group class="oe_subtotal_footer oe_right" colspan="1">
                            <field name="amount_total" readonly="1" widget="monetary" string="Total" class="oe_inline"/>
                        </group>
                        <group>
                            <field name="amount_paid" readonly="1" widget="monetary" string="Paid"/>
                            <field name="amount_residual" readonly="1" widget="monetary" string="Due" decoration-danger="amount_residual > 0"/>
                            <field name="amount_change" readonly="1" widget="monetary" string="Change"/>
                        </group>
                    </group>

                    <!-- ═══ Notebook ═══ -->
                    <notebook>
                        <page string="🛒 Order Lines">
                            <field name="line_ids" mode="tree" nolabel="1">
                                <tree editable="bottom" decoration-danger="is_low_stock" decoration-warning="qty_available &gt; 0 and qty_available &lt; qty">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_image" widget="image" class="oe_avatar" options="{'size': [40, 40]}" string=" "/>
                                    <field name="product_id" context="{'pos_lite_search': 1}" string="Product"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="qty_available" readonly="1" string="Stock"
                                           decoration-danger="qty_available &lt; qty"
                                           decoration-success="qty_available &gt;= qty"/>
                                    <field name="is_low_stock" invisible="1"/>
                                    <field name="price_unit" string="Price"/>
                                    <field name="discount_type" string="Type" widget="radio"/>
                                    <field name="discount" string="Discount"/>
                                    <field name="price_subtotal" readonly="1" sum="Subtotal"/>
                                    <field name="price_tax" readonly="1" sum="Tax"/>
                                    <field name="price_total" readonly="1" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="💳 Payments" invisible="state == 'draft' and not payment_ids">
                            <field name="payment_ids" nolabel="1">
                                <tree editable="bottom" readonly="state not in ('draft', 'held')">
                                    <field name="state" invisible="1"/>
                                    <field name="company_id" invisible="1"/>
                                    <field name="payment_method"/>
                                    <field name="amount"/>
                                    <field name="journal_id"/>
                                    <field name="reference"/>
                                    <field name="payment_date"/>
                                    <field name="note"/>
                                    <field name="account_payment_id" readonly="1" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="🔄 Exchanges" invisible="exchange_count == 0">
                            <group string="Exchange Orders">
                                <field name="exchange_order_ids" nolabel="1" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="date_order" string="Date"/>
                                        <field name="state" widget="badge"
                                               decoration-success="state in ('paid','done')"
                                               decoration-danger="state == 'cancelled'"/>
                                        <field name="amount_total" widget="monetary"/>
                                        <field name="exchange_return_order_id" string="Return Order" optional="hide"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                        <page string="📝 Notes">
                            <field name="note" placeholder="Add notes, delivery instructions, LINE message details..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_pos_lite_orders" model="ir.actions.act_window">
        <field name="name">POS Lite Orders</field>
        <field name="res_model">pos.lite.order</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_channel': 'phone', 'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_no_content_smiling_face">Create the first lightweight order.</p>
        </field>
    </record>

    <!-- Held Orders Action -->
    <record id="action_pos_lite_held_orders" model="ir.actions.act_window">
        <field name="name">Held Orders</field>
        <field name="res_model">pos.lite.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'held')]</field>
    </record>
</odoo>
