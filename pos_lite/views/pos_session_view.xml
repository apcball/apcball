<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Session Tree -->
    <record id="view_pos_lite_session_tree" model="ir.ui.view">
        <field name="name">pos.lite.session.tree</field>
        <field name="model">pos.lite.session</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'opened'" decoration-danger="state == 'closed'"
                  expand="1">
                <field name="name"/>
                <field name="config_id"/>
                <field name="employee_ids" string="Employees" widget="many2many_tags"/>
                <field name="current_employee_id" string="พนักงานขายปัจจุบัน" optional="show"/>
                <field name="current_channel" string="ช่องทาง" optional="show"/>
                <field name="user_id" string="Cashier"/>
                <field name="date_open" string="วันที่เปิด"/>
                <field name="date_close" string="วันที่ปิด" optional="hide"/>
                <field name="order_count" string="Orders"/>
                <field name="amount_total" widget="monetary" string="ยอดขาย"/>
                <field name="amount_refund" widget="monetary" string="Refund" optional="hide"/>
                <field name="amount_net" widget="monetary" string="Net"
                       decoration-success="amount_net &gt; 0"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'opened'"
                       decoration-warning="state == 'closed'"/>
                <field name="company_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Session Form -->
    <record id="view_pos_lite_session_form" model="ir.ui.view">
        <field name="name">pos.lite.session.form</field>
        <field name="model">pos.lite.session</field>
        <field name="arch" type="xml">
            <form string="POS Lite Session">
                <header>
                    <!-- Primary Actions -->
                    <button name="action_new_order" type="object"
                            string="🛒 สั่งขาย"
                            class="btn-primary"
                            invisible="state != 'opened'"/>
                    <button name="action_open_terminal" type="object"
                            string="🖥 Terminal"
                            class="btn-secondary ms-2"
                            invisible="1"/>
                    <!-- Change Employee / Channel -->
                    <button name="action_start_sale" type="object"
                            string="🔄 เปลี่ยนพนักงาน"
                            class="btn-secondary"
                            invisible="state != 'opened'"/>
                    <!-- Close / Reopen / Print -->
                    <button name="action_close_session" type="object"
                            string="ปิด Session"
                            class="btn-warning ms-2"
                            invisible="state != 'opened'"
                            confirm="ปิด Session นี้? กรุณาประมวลผล draft orders ให้เสร็จก่อน"/>
                    <button name="action_reopen_session" type="object"
                            string="เปิดใหม่"
                            class="btn-secondary"
                            invisible="state != 'closed'"
                            groups="pos_lite.group_pos_lite_manager"
                            confirm="เปิด Session นี้ใหม่?"/>
                    <button name="action_print_session_summary" type="object"
                            string="🖨 พิมพ์สรุป"
                            class="btn-secondary"
                            invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="opened,closed"
                           invisible="state == 'opened'"
                           class="bg-success text-white fw-bold ms-2 px-3 rounded"
                           decoration-success="state == 'opened'"
                           decoration-muted="state == 'closed'"/>
                </header>
                <sheet>
                    <field name="currency_id" invisible="1"/>
                    <!-- Title + Status -->
                    <div class="oe_title mb-3">
                        <h1 class="d-flex align-items-center gap-3">
                            <field name="name" readonly="1"
                                   class="fs-2 fw-bold"/>
                            <span invisible="state != 'opened'"
                                  class="badge bg-success fs-6">เปิดใช้งาน</span>
                            <span invisible="state != 'closed'"
                                  class="badge bg-secondary fs-6">ปิดแล้ว</span>
                        </h1>
                    </div>

                    <!-- ===== Smart Buttons Row ===== -->
                    <div class="oe_button_box mb-4" name="button_box">
                        <button name="action_new_order" type="object"
                                class="oe_stat_button btn-primary"
                                icon="fa-shopping-cart"
                                invisible="state != 'opened'">
                            <div class="o_stat_text fw-bold text-primary">สั่งขาย</div>
                        </button>
                        <button name="action_open_terminal" type="object"
                                class="oe_stat_button"
                                icon="fa-desktop"
                                invisible="1">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Terminal</span>
                            </div>
                        </button>
                        <button name="action_view_orders" type="object"
                                class="oe_stat_button"
                                icon="fa-list-ol">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-primary fw-bold fs-5">
                                    <field name="order_count"/>
                                </span>
                                <span class="o_stat_text">Orders</span>
                            </div>
                        </button>
                        <button name="action_start_sale" type="object"
                                class="oe_stat_button"
                                icon="fa-exchange"
                                invisible="state != 'opened'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">เปลี่ยนพนักงาน</span>
                            </div>
                        </button>
                    </div>

                    <!-- ===== KPI Summary Cards ===== -->
                    <div class="row g-3 mb-4">
                        <!-- Gross Sales -->
                        <div class="col-6 col-lg-3">
                            <div class="card border-start border-4 border-primary shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="text-muted small text-uppercase">ยอดขายรวม</div>
                                    <div class="fs-3 fw-bold text-primary mt-1">
                                        <field name="amount_total" widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <field name="order_count_sales"/> ขาย ·
                                        <field name="order_count_exchanges"/> เปลี่ยน
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Refunds -->
                        <div class="col-6 col-lg-3">
                            <div class="card border-start border-4 border-danger shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="text-muted small text-uppercase">Refund</div>
                                    <div class="fs-3 fw-bold text-danger mt-1">
                                        <field name="amount_refund" widget="monetary"/>
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <field name="order_count_returns"/> รายการคืน
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Tax -->
                        <div class="col-6 col-lg-3">
                            <div class="card border-start border-4 border-info shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="text-muted small text-uppercase">VAT</div>
                                    <div class="fs-4 fw-bold text-info mt-1">
                                        <field name="amount_tax" widget="monetary"/>
                                    </div>
                                    <div class="text-muted small mt-1">
                                        ก่อน VAT: <field name="amount_untaxed" widget="monetary"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Net Revenue -->
                        <div class="col-6 col-lg-3">
                            <div class="card border-start border-4 border-success shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="text-muted small text-uppercase">Net Revenue</div>
                                    <div class="fs-3 fw-bold text-success mt-1">
                                        <field name="amount_net" widget="monetary"/>
                                    </div>
                                    <div class="text-muted small mt-1">
                                        สุทธิหลังหัก refund
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== Main Content ===== -->
                    <div class="row">
                        <!-- Left: Session Info -->
                        <div class="col-lg-8">
                            <div class="card shadow-sm mb-3">
                                <div class="card-header bg-light">
                                    <h5 class="card-title mb-0">
                                        <i class="fa fa-info-circle me-2"/>
                                        ข้อมูล Session
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">Config (ร้าน)</span>
                                            <div>
                                                <field name="config_id"/>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">ผู้เปิด</span>
                                            <div>
                                                <field name="user_id"/>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">วันที่เปิด</span>
                                            <div>
                                                <field name="date_open"/>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">วันที่ปิด</span>
                                            <div>
                                                <field name="date_close"/>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">ผู้ปิด</span>
                                            <div>
                                                <field name="close_user_id"/>
                                            </div>
                                        </div>
                                        <field name="employee_id" invisible="1"/>
                                        <div class="col-12">
                                            <span class="o_form_label text-muted small">พนักงานที่ทำงาน</span>
                                            <div>
                                                <field name="employee_ids" widget="many2many_tags"/>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">พนักงานขายปัจจุบัน</span>
                                            <div>
                                                <field name="current_employee_id"/>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <span class="o_form_label text-muted small">ช่องทางปัจจุบัน</span>
                                            <div>
                                                <field name="current_channel"/>
                                            </div>
                                        </div>
                                        <field name="company_id" invisible="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right: Payment Breakdown -->
                        <div class="col-lg-4">
                            <div class="card shadow-sm mb-3">
                                <div class="card-header bg-light">
                                    <h5 class="card-title mb-0">
                                        <i class="fa fa-credit-card me-2"/>
                                        ช่องทางการชำระ
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">เงินสด</span>
                                        <span class="fw-bold fs-5">
                                            <field name="payment_cash" widget="monetary"/>
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">โอนเงิน</span>
                                        <span class="fw-bold fs-5">
                                            <field name="payment_transfer" widget="monetary"/>
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">บัตรเครดิต</span>
                                        <span class="fw-bold fs-5">
                                            <field name="payment_card" widget="monetary"/>
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">PromptPay</span>
                                        <span class="fw-bold fs-5">
                                            <field name="payment_promptpay" widget="monetary"/>
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">อื่น ๆ</span>
                                        <span class="fw-bold fs-5">
                                            <field name="payment_other" widget="monetary"/>
                                        </span>
                                    </div>
                                    <hr/>
                                    <div class="d-flex justify-content-between align-items-center py-2 bg-light rounded px-3">
                                        <span class="fw-bold">ยอดรวม</span>
                                        <span class="fw-bold fs-4 text-primary">
                                            <field name="amount_net" widget="monetary"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ===== Notes ===== -->
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center cursor-pointer">
                            <h5 class="card-title mb-0">
                                <i class="fa fa-sticky-note me-2"/>
                                บันทึก
                            </h5>
                        </div>
                        <div class="card-body">
                            <field name="note" nolabel="1"
                                   placeholder="เพิ่มบันทึกสำหรับ session นี้..."/>
                        </div>
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Session Search -->
    <record id="view_pos_lite_session_search" model="ir.ui.view">
        <field name="name">pos.lite.session.search</field>
        <field name="model">pos.lite.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="config_id"/>
                <field name="user_id"/>
                <field name="employee_ids"/>
                <filter string="Open" name="open" domain="[('state', '=', 'opened')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <filter string="Today" name="today" domain="[('date_open', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Config" name="group_config" context="{'group_by': 'config_id'}"/>
                    <filter string="Cashier" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_ids'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date_open:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Session Action -->
    <record id="action_pos_lite_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">pos.lite.session</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No sessions yet. Open your first session to start selling.</p>
        </field>
    </record>
</odoo>
