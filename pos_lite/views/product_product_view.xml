<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_lite_product_form_inherit" model="ir.ui.view">
        <field name="name">pos.lite.product.form.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="can_be_pos"/>
                    <label for="can_be_pos"/>
                </span>
            </xpath>
        </field>
    </record>

    <record id="view_pos_lite_product_tree_inherit" model="ir.ui.view">
        <field name="name">pos.lite.product.tree.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="can_be_pos" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_lite_product_template_form_inherit" model="ir.ui.view">
        <field name="name">pos.lite.product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="can_be_pos"/>
                    <label for="can_be_pos"/>
                </span>
            </xpath>
        </field>
    </record>

    <record id="view_pos_lite_product_template_tree_inherit" model="ir.ui.view">
        <field name="name">pos.lite.product.template.tree.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="can_be_pos" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>