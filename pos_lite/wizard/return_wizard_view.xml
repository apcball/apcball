<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_lite_return_wizard_form" model="ir.ui.view">
        <field name="name">pos.lite.return.wizard.form</field>
        <field name="model">pos.lite.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Return">
                <sheet>
                    <group>
                        <group>
                            <field name="order_id" readonly="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="return_reason" placeholder="Optional return reason..."/>
                        </group>
                    </group>
                    <group>
                        <field name="line_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="order_line_id" invisible="1"/>
                                <field name="product_id" readonly="1"/>
                                <field name="description" readonly="1"/>
                                <field name="qty_available" readonly="1"/>
                                <field name="qty"/>
                                <field name="price_unit" readonly="1"/>
                                <field name="discount" readonly="1"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Create Return" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
