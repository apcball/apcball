<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_installation" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.installation</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="payment_term_id" position="after">
                <field name="is_retail_installation" invisible="1"/>
                <field name="is_project_installation" invisible="1"/>
            </field>
            <xpath expr="//field[@name='order_line']/tree//field[@name='price_unit']" position="before">
                <field name="include_installation"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="before">
                <field name="include_installation"/>
            </xpath>
        </field>
    </record>
</odoo>
