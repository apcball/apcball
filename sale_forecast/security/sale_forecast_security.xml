<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_sale_forecast" model="ir.module.category">
        <field name="name">Sales Forecast</field>
        <field name="description">Access rights for sales forecasting and allocations.</field>
        <field name="sequence">45</field>
    </record>

    <record id="group_sale_forecast_planner" model="res.groups">
        <field name="name">Forecast Planner</field>
        <field name="category_id" ref="sale_forecast.module_category_sale_forecast"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sale_forecast_sales" model="res.groups">
        <field name="name">Forecast Sales Allocator</field>
        <field name="category_id" ref="sale_forecast.module_category_sale_forecast"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_sale_forecast_manager" model="res.groups">
        <field name="name">Forecast Manager</field>
        <field name="category_id" ref="sale_forecast.module_category_sale_forecast"/>
        <field name="implied_ids" eval="[(4, ref('sale_forecast.group_sale_forecast_planner')), (4, ref('sale_forecast.group_sale_forecast_sales')), (4, ref('sales_team.group_sale_manager'))]"/>
    </record>
</odoo>
