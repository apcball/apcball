<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_forecast_allocation_tree" model="ir.ui.view">
        <field name="name">forecast.allocation.tree</field>
        <field name="model">forecast.allocation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="plan_id"/>
                <field name="plan_line_id"/>
                <field name="product_id"/>
                <field name="sale_order_id"/>
                <field name="customer_id"/>
                <field name="salesperson_id"/>
                <field name="allocated_qty" sum="Allocated"/>
                <field name="actual_sold_qty" sum="Actual Sold"/>
                <field name="is_non_forecast" optional="hide"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_forecast_allocation_form" model="ir.ui.view">
        <field name="name">forecast.allocation.form</field>
        <field name="model">forecast.allocation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancel"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="plan_id" options="{'no_create': True}"/>
                            <field name="plan_line_id" domain="[('plan_id','=',plan_id)]" options="{'no_create': True}"/>
                            <field name="product_id"/>
                            <field name="allocated_qty" readonly="state == 'cancel'"/>
                            <field name="is_non_forecast" readonly="1"/>
                        </group>
                        <group>
                            <field name="sale_order_id"/>
                            <field name="sale_order_line_id" readonly="1"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="salesperson_id" readonly="1"/>
                            <field name="actual_sold_qty" readonly="1"/>
                            <field name="month" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_forecast_allocation_search" model="ir.ui.view">
        <field name="name">forecast.allocation.search</field>
        <field name="model">forecast.allocation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="plan_id"/>
                <field name="product_id"/>
                <field name="sale_order_id"/>
                <field name="customer_id"/>
                <field name="salesperson_id"/>
                <filter string="Active" name="active" domain="[('state','!=','cancel')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancel')]"/>
                <filter string="Non-Forecast" name="non_forecast" domain="[('is_non_forecast','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Salesperson" name="group_salesperson" context="{'group_by': 'salesperson_id'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_forecast_allocation_pivot" model="ir.ui.view">
        <field name="name">forecast.allocation.pivot</field>
        <field name="model">forecast.allocation</field>
        <field name="arch" type="xml">
            <pivot string="Allocation &amp; Sales Performance">
                <field name="product_id" type="row"/>
                <field name="salesperson_id" type="row"/>
                <field name="month" type="col" interval="month"/>
                <field name="allocated_qty" type="measure"/>
                <field name="actual_sold_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_forecast_allocation_graph" model="ir.ui.view">
        <field name="name">forecast.allocation.graph</field>
        <field name="model">forecast.allocation</field>
        <field name="arch" type="xml">
            <graph type="line" string="Salesperson Allocation Trend">
                <field name="month" interval="month"/>
                <field name="allocated_qty" type="measure"/>
                <field name="actual_sold_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_forecast_allocation_kanban" model="ir.ui.view">
        <field name="name">forecast.allocation.kanban</field>
        <field name="model">forecast.allocation</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="allocated_qty"/>
                <field name="actual_sold_qty"/>
                <field name="salesperson_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div><field name="product_id"/></div>
                            <div>Customer: <field name="customer_id"/></div>
                            <div>Salesperson: <field name="salesperson_id"/></div>
                            <div>Allocated: <field name="allocated_qty"/></div>
                            <div>Actual: <field name="actual_sold_qty"/></div>
                            <div><field name="state"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_forecast_allocation" model="ir.actions.act_window">
        <field name="name">Forecast Allocations</field>
        <field name="res_model">forecast.allocation</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="search_view_id" ref="view_forecast_allocation_search"/>
    </record>
</odoo>
