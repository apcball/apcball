<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_forecast_plan_tree" model="ir.ui.view">
        <field name="name">forecast.plan.tree</field>
        <field name="model">forecast.plan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="user_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="total_forecast_qty" sum="Forecast"/>
                <field name="total_allocated_qty" sum="Allocated"/>
                <field name="total_actual_sold_qty" sum="Actual Sold"/>
                <field name="allocation_rate" widget="percentage"/>
                <field name="accuracy_rate" widget="percentage"/>
            </tree>
        </field>
    </record>

    <record id="view_forecast_plan_form" model="ir.ui.view">
        <field name="name">forecast.plan.form</field>
        <field name="model">forecast.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_draft" type="object" string="Set to Draft" invisible="state == 'draft'"/>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" type="object" string="Mark Done" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" class="oe_stat_button" name="action_view_lines_analysis" icon="fa-line-chart">
                            <field name="total_forecast_qty" string="Forecast Qty" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="blanket_reference" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="KPI Summary" col="4">
                        <field name="total_forecast_qty" readonly="1"/>
                        <field name="total_allocated_qty" readonly="1"/>
                        <field name="total_actual_sold_qty" readonly="1"/>
                        <field name="allocation_rate" widget="percentage" readonly="1"/>
                        <field name="accuracy_rate" widget="percentage" readonly="1"/>
                    </group>

                    <group>
                        <button name="action_distribute_weekly" type="object" string="Distribute All Lines Weekly" class="btn-secondary"/>
                    </group>

                    <notebook>
                        <page string="Forecast Lines">
                            <field name="line_ids" readonly="state in ('done','cancel')">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="forecast_qty"/>
                                    <field name="arrival_month"/>
                                    <field name="expected_week"/>
                                    <field name="week1_qty"/>
                                    <field name="week2_qty"/>
                                    <field name="week3_qty"/>
                                    <field name="week4_qty"/>
                                    <field name="week5_qty"/>
                                    <field name="allocated_qty" readonly="1"/>
                                    <field name="remaining_qty" readonly="1"/>
                                    <field name="actual_sold_qty" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_forecast_plan_search" model="ir.ui.view">
        <field name="name">forecast.plan.search</field>
        <field name="model">forecast.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="start_date"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Salesperson" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'start_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_forecast_plan_kanban" model="ir.ui.view">
        <field name="name">forecast.plan.kanban</field>
        <field name="model">forecast.plan</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="total_forecast_qty"/>
                <field name="total_allocated_qty"/>
                <field name="total_actual_sold_qty"/>
                <field name="allocation_rate"/>
                <field name="accuracy_rate"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div><field name="state"/></div>
                            <div>Forecast: <field name="total_forecast_qty"/></div>
                            <div>Allocated: <field name="total_allocated_qty"/></div>
                            <div>Actual Sold: <field name="total_actual_sold_qty"/></div>
                            <div>Allocation Rate: <field name="allocation_rate" widget="percentage"/></div>
                            <div>Accuracy: <field name="accuracy_rate" widget="percentage"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_forecast_line_pivot" model="ir.ui.view">
        <field name="name">forecast.line.pivot</field>
        <field name="model">forecast.line</field>
        <field name="arch" type="xml">
            <pivot string="Forecast vs Allocation vs Actual">
                <field name="product_id" type="row"/>
                <field name="arrival_month" type="col" interval="month"/>
                <field name="forecast_qty" type="measure"/>
                <field name="allocated_qty" type="measure"/>
                <field name="actual_sold_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_forecast_line_graph" model="ir.ui.view">
        <field name="name">forecast.line.graph</field>
        <field name="model">forecast.line</field>
        <field name="arch" type="xml">
            <graph string="Forecast KPI" type="bar">
                <field name="arrival_month" interval="month"/>
                <field name="forecast_qty" type="measure"/>
                <field name="allocated_qty" type="measure"/>
                <field name="actual_sold_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_forecast_plan" model="ir.actions.act_window">
        <field name="name">Forecast Plans</field>
        <field name="res_model">forecast.plan</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_forecast_plan_search"/>
    </record>

    <record id="action_forecast_line_analysis" model="ir.actions.act_window">
        <field name="name">Forecast KPI Dashboard</field>
        <field name="res_model">forecast.line</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>
</odoo>
