<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_forecast_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.forecast.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    type="object"
                    name="action_view_forecast_allocations"
                    class="oe_stat_button"
                    icon="fa-area-chart"
                >
                    <field name="forecast_allocation_count" string="Forecast Allocations" widget="statinfo"/>
                </button>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Forecast Allocations">
                    <field name="forecast_allocation_ids" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="plan_id"/>
                            <field name="product_id"/>
                            <field name="allocated_qty"/>
                            <field name="actual_sold_qty"/>
                            <field name="is_non_forecast" optional="hide"/>
                            <field name="state"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
