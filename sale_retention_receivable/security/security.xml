<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_retention_user" model="res.groups">
        <field name="name">Retention User</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <!-- Sequence for retention receivable records -->
    <record id="seq_sale_retention_receivable" model="ir.sequence">
        <field name="name">Sale Retention Receivable</field>
        <field name="code">sale.retention.receivable</field>
        <field name="prefix">RET/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Retention Receivable report action -->
    <record id="action_report_retention_aging" model="ir.actions.report">
        <field name="name">Retention Aging Report</field>
        <field name="model">sale.retention.receivable</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">sale_retention_receivable.report_retention_aging</field>
        <field name="report_file">sale_retention_receivable.report_retention_aging</field>
        <field name="print_report_name">'Retention Aging Report - %s' % (time.strftime('%%Y-%%m-%%d'))</field>
    </record>
</odoo>
