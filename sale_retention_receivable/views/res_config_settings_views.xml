<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.retention</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="priority" eval="60"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="Retention Receivable" id="sale_retention_receivable_settings">
                    <setting
                        id="sale_retention_account_setting"
                        string="Default Retention Receivable Account"
                        help="Default account for retention receivable entries."
                    >
                        <field name="sale_retention_account_id"/>
                    </setting>
                    <setting
                        id="sale_retention_default_percent_setting"
                        string="Default Retention Percentage (%)"
                        help="Default retention percentage applied on sale orders."
                    >
                        <field name="sale_retention_default_percent"/>
                    </setting>
                    <setting
                        id="sale_retention_default_days_setting"
                        string="Default Retention Days"
                        help="Default number of days after invoice date for retention due date."
                    >
                        <field name="sale_retention_default_days"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
