<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_retention" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.retention</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']" position="inside">
                <group name="retention" string="Retention">
                    <field name="sale_retention_enabled"/>
                    <field name="sale_retention_percent"
                           invisible="not sale_retention_enabled"
                           required="sale_retention_enabled"/>
                    <field name="sale_retention_days"
                           invisible="not sale_retention_enabled"
                           required="sale_retention_enabled"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>