<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_team_dashboard_kanban" model="ir.ui.view">
        <field name="name">sales.target.dashboard.kanban</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <kanban class="o_sales_team_dashboard">
                <field name="id"/>
                <field name="name"/>
                <field name="user_id"/>
                <field name="team_ids"/>
                <field name="team_member_ids"/>
                <field name="target_amount"/>
                <field name="achieved_amount"/>
                <field name="percent_achieved"/>
                <field name="theoretical_status"/>
                <field name="state"/>
                <field name="currency_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <templates>
                    <t t-name="kanban-box">

                        <t t-set="target_val" t-value="record.target_amount.raw_value or 0"/>
                        <t t-set="achieved_val" t-value="record.achieved_amount.raw_value or 0"/>
                        <t t-set="percent" t-value="target_val > 0 ? Math.min(Math.round((achieved_val / target_val) * 100), 999) : 0"/>
                        <t t-set="bar_color" t-value="percent >= 100 ? '#059669' : percent >= 75 ? '#2563eb' : percent >= 50 ? '#d97706' : '#dc2626'"/>
                        <t t-set="badge_cls" t-value="percent >= 100 ? 'o_badge_success' : percent >= 50 ? 'o_badge_warning' : 'o_badge_danger'"/>

                        <div class="o_team_target_card oe_kanban_global_click">

                                <div class="o_team_card_header">
                                <div class="o_team_card_header_left">
                                    <t t-if="record.team_ids.raw_value and record.team_ids.raw_value.length">
                                        <div class="o_team_avatars">
                                            <t t-foreach="record.team_member_ids.raw_value" t-as="member_id">
                                                <img t-att-src="kanban_image('res.users', 'avatar_128', member_id)"
                                                     alt="Avatar" class="o_avatar_item"
                                                     t-att-title="member_id"/>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-elif="record.user_id.raw_value">
                                        <img t-att-src="kanban_image('res.users', 'avatar_128', record.user_id.raw_value)"
                                             alt="Avatar" style="width:32px;height:32px;object-fit:cover;border-radius:50%;flex-shrink:0;border:2px solid #2563eb;margin-right:10px;"/>
                                    </t>
                                    <div>
                                        <h4 class="o_team_name"><field name="name"/></h4>
                                        <div class="o_team_tags">
                                            <field name="team_ids" widget="many2many_tags"/>
                                        </div>
                                    </div>
                                </div>
                                <div t-attf-class="o_status_badge {{badge_cls}}">
                                    <t t-out="percent"/>%
                                </div>
                            </div>

                            <div class="o_team_card_divider"/>

                            <div class="o_team_card_metrics">
                                <div class="o_metric_col">
                                    <p class="o_metric_label">Achieved</p>
                                    <p class="o_metric_value o_metric_achieved">
                                        <field name="achieved_amount" widget="monetary"/>
                                    </p>
                                </div>
                                <div class="o_metric_divider"/>
                                <div class="o_metric_col">
                                    <p class="o_metric_label">Target</p>
                                    <p class="o_metric_value o_metric_target">
                                        <field name="target_amount" widget="monetary"/>
                                    </p>
                                </div>
                            </div>

                            <div class="o_team_card_progress">
                                <div class="o_progress_header">
                                    <span class="o_progress_label">Progress</span>
                                    <span class="o_progress_value"><t t-out="percent"/>%</span>
                                </div>
                                <div class="o_progress_track">
                                    <div class="o_progress_fill"
                                         t-att-style="'width:' + Math.min(percent, 100) + '%; background-color:' + bar_color + ';'"/>
                                </div>
                            </div>

                            <div class="o_team_card_footer">
                                <span class="o_team_date_range">
                                    <field name="date_start"/> - <field name="date_end"/>
                                </span>
                                <span t-attf-class="badge o_tag #{record.state.raw_value == 'draft' ? 'text-bg-info' : record.state.raw_value == 'confirmed' ? 'text-bg-success' : 'text-bg-secondary'}">
                                    <field name="state"/>
                                </span>
                            </div>

                            <t t-if="percent >= 100">
                                <div class="o_team_card_achieved_banner">
                                    <span class="o_achieved_text">Target Achieved!</span>
                                </div>
                            </t>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sale_team_dashboard_search" model="ir.ui.view">
        <field name="name">sales.target.dashboard.search</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Description"/>
                <field name="user_id"/>
                <field name="team_ids"/>

                <filter name="sale_team" string="Sale Team"
                        domain="[('team_ids', '!=', False)]"/>
                <filter name="my_target" string="My Target"
                        domain="[('user_id', '=', uid)]"/>

                <separator/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="closed" string="Closed"
                        domain="[('state', '=', 'closed')]"/>

                <separator/>
                <filter name="this_month" string="This Month"
                        domain="[('date_start', '&lt;=', context_today().strftime('%Y-%m-%d')),
                                ('date_end', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Group By">
                    <filter name="group_user" string="Salesperson" context="{'group_by': 'user_id'}"/>
                    <filter name="group_team" string="Sales Team" context="{'group_by': 'team_ids'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sales_team_target_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">sales.target</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_sale_team_dashboard_search"/>
        <field name="domain">[('state', '!=', 'closed')]</field>
        <field name="context">{'search_default_sale_team': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sales Target Dashboard!
            </p>
            <p>
                Monitor sales targets and track achievement progress.
            </p>
        </field>
    </record>

    <record id="action_sales_team_target_dashboard_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_sale_team_dashboard_kanban"/>
        <field name="act_window_id" ref="action_sales_team_target_dashboard"/>
    </record>

</odoo>
