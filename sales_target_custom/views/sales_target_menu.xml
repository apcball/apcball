<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_sales_target_root" 
              name="Sales Target" 
              parent="sale.sale_menu_root"
              groups="sales_target_custom.group_sales_target_user,sales_target_custom.group_sales_target_lead,sales_target_custom.group_sales_target_manager"
              sequence="20"/>
    
    <!-- My Target - For individual users, no team field -->
    <menuitem id="menu_my_target" 
              name="My Target" 
              parent="menu_sales_target_root" 
              action="action_my_target"
              groups="sales_target_custom.group_sales_target_user,sales_target_custom.group_sales_target_manager"
              sequence="10"/>

    <!-- Company Target - whole company target, no user/team -->
    <menuitem id="menu_company_target" 
              name="Company Target" 
              parent="menu_sales_target_root" 
              action="action_company_target"
              groups="sales_target_custom.group_sales_target_manager,sales_target_custom.group_sales_target_lead"
              sequence="15"/>

    <!-- Sale Team - Team targets with M2M team selection -->
    <menuitem id="menu_sale_team" 
              name="Sale Team" 
              parent="menu_sales_target_root" 
              action="action_sale_team"
              groups="sales_target_custom.group_sales_target_manager"
              sequence="20"/>

    <!-- Dashboard - consolidated view with My Target / Sale Team filters -->
    <menuitem id="menu_sales_target_dashboard" 
              name="Dashboard" 
              parent="menu_sales_target_root" 
              action="action_sales_team_target_dashboard"
              groups="sales_target_custom.group_sales_target_user,sales_target_custom.group_sales_target_lead,sales_target_custom.group_sales_target_manager"
              sequence="5"/>

    <!-- Manager: All Targets -->
    <menuitem id="menu_sales_target_manager" 
              name="All Targets" 
              parent="menu_sales_target_root" 
              action="action_sales_target_manager"
              groups="sales_target_custom.group_sales_target_manager"
              sequence="30"/>
</odoo>
