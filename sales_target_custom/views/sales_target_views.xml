        <field name="arch" type="xml">
            <kanban class="o_sales_team_dashboard">
                <field name="id"/>
                <field name="display_name"/>
                <field name="user_id"/>
                <field name="team_ids"/>
                <field name="target_amount"/>
                <field name="achieved_amount"/>
                <field name="percent_achieved"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">

                        <t t-set="target_val" t-value="record.target_amount.raw_value or 0"/>
                        <t t-set="achieved_val" t-value="record.achieved_amount.raw_value or 0"/>
                        <t t-set="percent" t-value="target_val > 0 ? Math.min(Math.round((achieved_val / target_val) * 100), 999) : 0"/>
                        <t t-set="bar_color" t-value="percent >= 100 ? '#059669' : percent >= 75 ? '#2563eb' : percent >= 50 ? '#0891b2' : percent >= 25 ? '#d97706' : '#dc2626'"/>
                        <t t-set="badge_cls" t-value="percent >= 100 ? 'o_badge_success' : percent >= 50 ? 'o_badge_warning' : 'o_badge_danger'"/>

                        <div class="o_team_target_card oe_kanban_global_click">
                            <div class="o_team_card_header">
                                <div class="o_team_card_header_left">
                                    <div>
                                        <h4 class="o_team_name"><field name="display_name"/></h4>
                                        <div class="o_team_tags">
                                            <field name="user_id"/> <field name="team_ids" widget="many2many_tags"/>
                                        </div>
                                    </div>
                                </div>
                                <div t-attf-class="o_status_badge {{badge_cls}}">
                                    <t t-out="percent"/>%
                                </div>
                            </div>

                            <div class="o_team_card_divider"/>

                            <div class="o_team_card_metrics">
                                <div class="o_metric_col">
                                    <p class="o_metric_label">Achieved</p>
                                    <p class="o_metric_value o_metric_achieved">
                                        <field name="achieved_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    </p>
                                </div>
                                <div class="o_metric_divider"/>
                                <div class="o_metric_col">
                                    <p class="o_metric_label">Target</p>
                                    <p class="o_metric_value o_metric_target">
                                        <field name="target_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    </p>
                                </div>
                            </div>

                            <div class="o_team_card_progress">
                                <div class="o_progress_header">
                                    <span class="o_progress_label">Progress</span>
                                    <span class="o_progress_value"><t t-out="percent"/>%</span>
                                </div>
                                <div class="o_progress_track">
                                    <div class="o_progress_fill"
                                         t-att-style="'width:' + Math.min(percent, 100) + '%; background-color:' + bar_color + ';'"/>
                                </div>
                            </div>

                            <div class="o_team_card_footer">
                                <span t-att-class="'badge ' + (record.state.raw_value == 'draft' ? 'text-bg-info' : record.state.raw_value == 'confirmed' ? 'text-bg-success' : 'text-bg-secondary')">
                                    <field name="state"/>
                                </span>
                            </div>

                            <t t-if="percent >= 100">
                                <div class="o_team_card_achieved_banner">
                                    <span class="o_achieved_text">Target Achieved!</span>
                                </div>
                            </t>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_sales_target_analysis" model="ir.actions.act_window">
        <field name="name">Sales Target Dashboard</field>
        <field name="res_model">sales.target</field>
        <field name="view_mode">kanban,tree,graph,pivot</field>
        <field name="context">{
            'search_default_confirmed': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sales Target Dashboard
            </p>
            <p>
                Monitor your sales target achievement with interactive charts.
                Track progress in real-time and stay motivated to reach your goals!
            </p>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_sales_target_graph" model="ir.ui.view">
        <field name="name">sales.target.graph</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <graph string="Sales Target Analysis" type="bar">
                <field name="user_id" type="row"/>
                <field name="target_amount" type="measure"/>
                <field name="achieved_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_sales_target_pivot" model="ir.ui.view">
        <field name="name">sales.target.pivot</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <pivot string="Sales Target Analysis">
                <field name="user_id" type="row"/>
                <field name="team_ids" type="col"/>
                <field name="target_amount" type="measure"/>
                <field name="achieved_amount" type="measure"/>
                <field name="percent_achieved" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Company Target Views (no user/team — whole company)                -->
    <!-- ================================================================== -->
    <record id="view_company_target_tree" model="ir.ui.view">
        <field name="name">sales.target.company.tree</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <tree decoration-success="state=='confirmed'" decoration-info="state=='draft'" decoration-muted="state=='closed'">
                <field name="name" string="Target"/>
                <field name="target_point" optional="show"/>
                <field name="target_amount" widget="monetary"/>
                <field name="achieved_amount" widget="monetary"/>
                <field name="percent_achieved" widget="percentage"/>
                <field name="date_start" optional="show"/>
                <field name="date_end" optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_company_target_form" model="ir.ui.view">
        <field name="name">sales.target.company.form</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_close" type="object" string="Close" class="oe_highlight"
                            invisible="state != 'confirmed'"/>
                    <button name="action_recompute_achievement" type="object" string="Recompute" class="btn-secondary"
                            title="Recalculate achievement"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Company Target Description"
                                   readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group string="General Information">
                        <group>
                            <field name="target_type" invisible="1"/>
                            <field name="company_id" readonly="state != 'draft'"/>
                            <field name="target_point" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="target_amount" widget="monetary" readonly="state != 'draft'"/>
                            <field name="date_start" readonly="state != 'draft'"/>
                            <field name="date_end" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Achievement Summary">
                        <group>
                            <field name="achieved_amount" widget="monetary" readonly="1"/>
                            <field name="percent_achieved" widget="percentage" readonly="1"/>
                        </group>
                        <group>
                            <field name="theoretical_amount" widget="monetary" readonly="1"/>
                            <field name="theoretical_percent" widget="percentage" readonly="1"/>
                            <field name="theoretical_status" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Related Invoices">
                            <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                                <strong>Target Point:</strong> <field name="target_point" readonly="1" class="oe_inline"/> |
                                <strong>Period:</strong> <field name="date_start" readonly="1" class="oe_inline"/> - <field name="date_end" readonly="1" class="oe_inline"/>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <button name="action_view_invoices" type="object" string="View Invoices" class="btn-primary" style="flex:1;"/>
                                <button name="action_view_invoice_lines" type="object" string="View Invoice Lines" class="btn-secondary" style="flex:1;"/>
                            </div>
                        </page>
                        <page string="Notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_company_target" model="ir.actions.act_window">
        <field name="name">Company Target</field>
        <field name="res_model">sales.target</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('target_type', '=', 'company')]</field>
        <field name="context">{'default_target_type': 'company'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set your first company-wide sales target!
            </p>
            <p>
                Company targets track overall sales performance across the entire organization.
            </p>
        </field>
    </record>

    <record id="action_company_target_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_company_target_tree"/>
        <field name="act_window_id" ref="action_company_target"/>
    </record>

    <record id="action_company_target_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_company_target_form"/>
        <field name="act_window_id" ref="action_company_target"/>
    </record>

</odoo>
