                <field name="name" string="Target"/>
                <field name="team_ids" widget="many2many_tags" optional="show"/>
                <field name="target_point" optional="show"/>
                <field name="target_amount" widget="monetary"/>
                <field name="achieved_amount" widget="monetary"/>
                <field name="percent_achieved" widget="progressbar"/>
                <field name="date_start" optional="show"/>
                <field name="date_end" optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge" decoration-success="state=='confirmed'" decoration-info="state=='draft'" decoration-muted="state=='closed'"/>
            </tree>
        </field>
