<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- My Target Views (individual targets, no team field)                -->
    <!-- ================================================================== -->
    <record id="view_my_target_tree" model="ir.ui.view">
        <field name="name">sales.target.my.tree</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <tree decoration-success="state=='confirmed'" decoration-info="state=='draft'" decoration-muted="state=='closed'" multi_edit="1">
                <field name="name" string="Target"/>
                <field name="user_id" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="target_point" optional="show"/>
                <field name="target_amount" widget="monetary"/>
                <field name="achieved_amount" widget="monetary"/>
                <field name="percent_achieved" widget="percentage"/>
                <field name="total_ordered_qty" optional="hide"/>
                <field name="total_delivered_qty" optional="hide"/>
                <field name="date_start" optional="show"/>
                <field name="date_end" optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_my_target_form" model="ir.ui.view">
        <field name="name">sales.target.my.form</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_close" type="object" string="Close" class="oe_highlight"
                            invisible="state != 'confirmed'"/>
                    <button name="action_send_mail" type="object" string="Send Mail" class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button name="action_recompute_achievement" type="object" string="Recompute" class="btn-secondary"
                            title="Recalculate all achievement percentages"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Target Description"
                                   readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group string="General Information">
                        <group>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="company_id" readonly="state != 'draft'"/>
                            <field name="responsible_id" readonly="1"/>
                            <field name="target_point" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="target_amount" widget="monetary" readonly="state != 'draft'"/>
                            <field name="date_start" readonly="state != 'draft'"/>
                            <field name="date_end" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Achievement Summary">
                        <group>
                            <field name="achieved_amount" widget="monetary" readonly="1"/>
                            <field name="percent_achieved" widget="percentage" readonly="1"/>
                        </group>
                        <group>
                            <field name="theoretical_amount" widget="monetary" readonly="1"/>
                            <field name="theoretical_percent" widget="percentage" readonly="1"/>
                            <field name="theoretical_status" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Related Orders" invisible="target_point != 'sale_order'">
                            <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                                <strong>Target:</strong> Sale Order Confirm |
                                <strong>Period:</strong> <field name="date_start" readonly="1" class="oe_inline"/> - <field name="date_end" readonly="1" class="oe_inline"/>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <button name="action_view_sale_orders" type="object" string="View Sale Orders" class="btn-primary" style="flex:1;"/>
                                <button name="action_view_sale_order_lines" type="object" string="View Order Lines" class="btn-secondary" style="flex:1;"/>
                            </div>
                        </page>
                        <page string="Related Deliveries" invisible="target_point != 'delivery'">
                            <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                                <strong>Target:</strong> Delivery Confirmed |
                                <strong>Period:</strong> <field name="date_start" readonly="1" class="oe_inline"/> - <field name="date_end" readonly="1" class="oe_inline"/>
                            </div>
                            <group string="Delivery Summary">
                                <group>
                                    <field name="total_ordered_qty" readonly="1"/>
                                    <field name="total_delivered_qty" readonly="1"/>
                                </group>
                                <group>
                                    <field name="delivery_order_count" readonly="1"/>
                                </group>
                            </group>
                            <div style="display:flex;gap:8px;">
                                <button name="action_view_delivery_orders" type="object" string="View Delivery Orders" class="btn-primary" style="flex:1;"/>
                            </div>
                        </page>
                        <page string="Related Invoices" invisible="target_point not in ['invoice_validate', 'invoice_paid']">
                            <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                                <strong>Target:</strong> <field name="target_point" readonly="1" class="oe_inline"/> |
                                <strong>Period:</strong> <field name="date_start" readonly="1" class="oe_inline"/> - <field name="date_end" readonly="1" class="oe_inline"/>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <button name="action_view_invoices" type="object" string="View Invoices" class="btn-primary" style="flex:1;"/>
                                <button name="action_view_invoice_lines" type="object" string="View Invoice Lines" class="btn-secondary" style="flex:1;"/>
                            </div>
                        </page>
                        <page string="Notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_my_target_search" model="ir.ui.view">
        <field name="name">sales.target.my.search</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Description"/>
                <field name="user_id"/>

                <filter name="my_targets" string="My Targets"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="closed" string="Closed"
                        domain="[('state', '=', 'closed')]"/>

                <separator/>
                <filter name="this_month" string="This Month"
                        domain="[('date_start', '&lt;=', context_today().strftime('%Y-%m-%d')),
                                ('date_end', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Group By">
                    <filter name="group_user" string="Salesperson" context="{'group_by': 'user_id'}"/>
                    <filter name="group_target_point" string="Target Point" context="{'group_by': 'target_point'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_my_target" model="ir.actions.act_window">
        <field name="name">My Target</field>
        <field name="res_model">sales.target</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_my_target_search"/>
        <field name="context">{'search_default_my_targets': 1, 'default_user_id': uid}</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first personal target!
            </p>
            <p>
                Set sales targets for yourself and track your achievements over time.
            </p>
        </field>
    </record>

    <record id="action_my_target_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_my_target_tree"/>
        <field name="act_window_id" ref="action_my_target"/>
    </record>

    <record id="action_my_target_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_my_target_form"/>
        <field name="act_window_id" ref="action_my_target"/>
    </record>

