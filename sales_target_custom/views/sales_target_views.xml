        <field name="name">sales.target.search</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Description"/>
                <field name="user_id"/>
                <field name="team_ids"/>
                <field name="responsible_id"/>

                <filter name="my_targets" string="My Targets"
