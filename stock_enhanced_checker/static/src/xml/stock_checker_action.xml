<?xml version="1.0" encoding="utf-8"?>
<!-- File: static/src/xml/stock_checker_action.xml -->
<!-- Purpose: OWL template for the main Stock Enhanced Checker — minimal redesign -->
<templates>

    <t t-name="stock_enhanced_checker.StockCheckerAction">
        <div class="o_stock_checker_app" t-att-class="state.theme === 'light' ? 'sc-theme-light' : ''">

            <!-- ─── Header ─────────────────────────────────── -->
            <div class="sc-header">
                <span class="sc-header-brand">📦 Stock Checker</span>

                <div class="sc-controls">
                    <select class="sc-select"
                            t-on-change="onWarehouseChange"
                            t-att-disabled="state.loading">
                        <option value="">Warehouse</option>
                        <t t-foreach="state.warehouses" t-as="wh" t-key="wh.id">
                            <option t-att-value="wh.id"
                                    t-att-selected="state.selectedWarehouseId === wh.id">
                                <t t-esc="wh.name"/>
                            </option>
                        </t>
                    </select>

                    <select class="sc-select"
                            t-on-change="onLocationChange"
                            t-att-disabled="state.loading or !state.selectedWarehouseId">
                        <option value="">Location</option>
                        <t t-foreach="state.locations" t-as="loc" t-key="loc.id">
                            <option t-att-value="loc.id"
                                    t-att-selected="state.selectedLocationId === loc.id">
                                <t t-esc="loc.complete_name"/>
                            </option>
                        </t>
                    </select>

                    <select class="sc-select"
                            t-on-change="onPricelistChange"
                            t-att-disabled="state.loading">
                        <option value="">Pricelist</option>
                        <t t-foreach="state.pricelists" t-as="pl" t-key="pl.id">
                            <option t-att-value="pl.id"
                                    t-att-selected="state.selectedPricelistId === pl.id">
                                <t t-esc="pl.name"/>
                            </option>
                        </t>
                    </select>

                    <div class="sc-search-wrap">
                        <i class="fa fa-search"/>
                        <input type="text" class="sc-search-input"
                               placeholder="Search product… (Enter)"
                               t-att-value="state.search"
                               t-on-input="onSearchType"
                               t-on-keydown="onSearchKeydown"
                               t-att-disabled="state.loading"/>
                    </div>

                    <button class="sc-icon-btn"
                            t-on-click="loadStockData"
                            t-att-disabled="state.loading or !state.selectedLocationId"
                            title="Refresh">
                        <i class="fa fa-refresh" t-att-class="state.loading ? 'fa-spin' : ''"/>
                    </button>

                    <button class="sc-icon-btn"
                            t-on-click="toggleTheme"
                            t-att-title="state.theme === 'dark' ? 'Light Mode' : 'Dark Mode'">
                        <i t-if="state.theme === 'dark'" class="fa fa-sun-o"/>
                        <i t-else="" class="fa fa-moon-o"/>
                    </button>
                </div>
            </div>

            <!-- ─── Filter Bar ─────────────────────────────── -->
            <div class="sc-filter-bar">
                <t t-foreach="filters" t-as="f" t-key="f.key">
                    <button class="sc-filter-pill"
                            t-att-class="state.filterType === f.key ? 'active' : ''"
                            t-on-click="() => this.onFilterChange(f.key)">
                        <i t-if="f.icon" t-att-class="'fa fa-' + f.icon"/>
                        <t t-esc="f.label"/>
                    </button>
                </t>

                <span class="sc-filter-spacer"/>

                <!-- Stats -->
                <t t-if="!state.loading and state.products.length">
                    <span class="sc-stat">Total <b t-esc="state.total"/></span>
                    <span class="sc-stats-divider"/>
                    <span class="sc-stat sc-stat-ok">✓ <b t-esc="stats.in_stock"/></span>
                    <span class="sc-stat sc-stat-warn">⚠ <b t-esc="stats.low_stock"/></span>
                    <span class="sc-stat sc-stat-bad">✗ <b t-esc="stats.out_of_stock"/></span>
                    <span class="sc-stat sc-stat-in">↑ <b t-esc="stats.with_incoming"/></span>
                </t>
            </div>

            <!-- ─── Content ────────────────────────────────── -->
            <div class="sc-content">
                <t t-if="state.loading and !state.products.length">
                    <div class="sc-loading">
                        <div class="sc-spinner"/>
                        <span class="sc-loading-text">Loading stock data…</span>
                    </div>
                </t>

                <t t-elif="!state.selectedLocationId">
                    <div class="sc-empty">
                        <div class="sc-empty-icon">🏭</div>
                        <h3>Select Warehouse &amp; Location</h3>
                        <p>Choose a warehouse and location above to view stock.</p>
                    </div>
                </t>

                <t t-elif="state.products.length === 0 and !state.loading">
                    <div class="sc-empty">
                        <div class="sc-empty-icon">🔍</div>
                        <h3>No Products Found</h3>
                        <p>Try adjusting your search or filter.</p>
                    </div>
                </t>

                <t t-else="">
                    <!-- Select-all row -->
                    <t t-if="state.canCreateQuotation">
                        <div class="sc-select-all-row">
                            <label>
                                <input type="checkbox" class="sc-ck"
                                       t-att-checked="allSelected"
                                       t-on-change="onToggleAll"/>
                                Select all
                            </label>
                            <span class="sc-stat"><t t-esc="state.products.length"/> of <t t-esc="state.total"/> products</span>
                        </div>
                    </t>

                    <StockCheckerTable
                        products="state.products"
                        selectedIds="state.selectedIds"
                        qtys="state.qtys"
                        prices="state.prices"
                        onToggleRow.bind="onToggleRow"
                        onQtyChange.bind="onQtyChange"
                        onPriceChange.bind="onPriceChange"
                        canCreateQuotation="state.canCreateQuotation"
                    />

                    <!-- Load More -->
                    <t t-if="state.products.length lt state.total">
                        <div class="sc-load-more">
                            <button class="sc-btn sc-btn-outline"
                                    t-on-click="loadMore"
                                    t-att-disabled="state.loading">
                                <i class="fa fa-chevron-down"/>
                                Load More
                                (<t t-esc="state.total - state.products.length"/>)
                            </button>
                        </div>
                    </t>
                </t>
            </div>

            <!-- ─── Action Bar ─────────────────────────────── -->
            <div class="sc-action-bar" t-if="state.canCreateQuotation">
                <!-- Partner inputs -->
                <div class="sc-partner-group">
                    <div class="sc-partner-wrap">
                        <i class="fa fa-id-card-o"/>
                        <input type="text" class="sc-partner-input"
                               placeholder="Partner code…"
                               t-att-value="state.partnerCode"
                               t-on-input="onPartnerCodeInput"
                               t-on-keydown="onPartnerCodeKeydown"
                               autocomplete="off"/>
                        <div class="sc-partner-dd" t-if="state.partnerResults.length">
                            <t t-foreach="state.partnerResults" t-as="p" t-key="p.id">
                                <div class="sc-partner-dd-item"
                                     t-on-click="() => this.onSelectPartner(p)">
                                    <span t-if="p.ref" class="sc-partner-dd-ref" t-esc="p.ref"/>
                                    <span t-esc="p.name"/>
                                </div>
                            </t>
                        </div>
                    </div>

                    <div class="sc-partner-wrap">
                        <i class="fa fa-user-o"/>
                        <input type="text" class="sc-partner-input"
                               t-att-class="!state.selectedPartnerId and state.partnerName ? 'sc-input-new' : ''"
                               placeholder="Customer name…"
                               t-att-value="state.partnerName"
                               t-on-input="onPartnerNameInput"
                               autocomplete="off"/>
                        <span t-if="state.selectedPartnerId" class="sc-p-badge sc-p-badge-existing">Existing</span>
                        <span t-elif="state.partnerName" class="sc-p-badge sc-p-badge-new">New</span>
                    </div>
                </div>

                <!-- Selection + actions -->
                <span class="sc-sel-count" t-esc="state.selectedIds.length"/>
                <span class="sc-sel-label">selected</span>

                <span class="sc-action-spacer"/>

                <button class="sc-btn sc-btn-ghost"
                        t-on-click="clearSelection"
                        t-att-disabled="!state.selectedIds.length">
                    <i class="fa fa-times"/> Clear
                </button>
                <button class="sc-btn sc-btn-primary"
                        t-on-click="createQuotation"
                        t-att-disabled="!state.selectedIds.length or state.creating">
                    <i t-if="state.creating" class="fa fa-spinner fa-spin"/>
                    <i t-else="" class="fa fa-file-text-o"/>
                    <t t-if="state.creating">Creating…</t>
                    <t t-else="">Create Quotation</t>
                </button>
            </div>

            <!-- ─── Toast ──────────────────────────────────── -->
            <t t-if="state.toast">
                <div class="sc-toast"
                     t-att-class="'sc-toast-' + state.toast.type">
                    <span class="sc-toast-icon">
                        <t t-if="state.toast.type === 'success'">✅</t>
                        <t t-elif="state.toast.type === 'error'">❌</t>
                        <t t-else="">ℹ️</t>
                    </span>
                    <div class="sc-toast-body">
                        <div class="sc-toast-title" t-esc="state.toast.title"/>
                        <div class="sc-toast-msg" t-esc="state.toast.msg"/>
                    </div>
                    <button class="sc-toast-close" t-on-click="clearToast">✕</button>
                </div>
            </t>

        </div>
    </t>

</templates>
