<?xml version="1.0" encoding="utf-8"?>
<!-- File: static/src/xml/stock_checker_table.xml -->
<!-- Purpose: Card-style product rows for Stock Enhanced Checker -->
<templates>

    <!-- ═══════════════════════════════════════════════════
         StockCheckerTable — renders a list of product cards
         ═══════════════════════════════════════════════════ -->
    <t t-name="stock_enhanced_checker.StockCheckerTable">
        <t t-foreach="props.products" t-as="product" t-key="product.id">
            <StockCheckerRow
                product="product"
                selected="props.selectedIds.includes(product.id)"
                qty="props.qtys[product.id] || 0"
                price="props.prices[product.id] !== undefined ? props.prices[product.id] : product.list_price"
                canCreateQuotation="props.canCreateQuotation"
                onToggle.bind="() => props.onToggleRow(product.id)"
                onQtyChange.bind="(val) => props.onQtyChange(product.id, val)"
                onPriceChange.bind="(val) => props.onPriceChange(product.id, val)"
            />
        </t>
    </t>

    <!-- ═══════════════════════════════════════════════════
         StockCheckerRow — single product card
         ═══════════════════════════════════════════════════ -->
    <t t-name="stock_enhanced_checker.StockCheckerRow">
        <div class="sc-card" t-att-class="props.selected and props.canCreateQuotation ? 'sc-selected' : ''">

            <!-- Checkbox -->
            <t t-if="props.canCreateQuotation">
                <input type="checkbox" class="sc-ck"
                       t-att-checked="props.selected"
                       t-on-change="() => props.onToggle()"/>
            </t>

            <!-- Product info -->
            <div class="sc-card-body">
                <!-- Line 1: Name + Ref -->
                <div class="sc-card-top">
                    <span class="sc-card-name" t-esc="props.product.name"/>
                    <span t-if="props.product.default_code" class="sc-card-ref" t-esc="props.product.default_code"/>
                </div>

                <!-- Line 2: Meta -->
                <div class="sc-card-meta">
                    <!-- Available badge -->
                    <span class="sc-avail"
                          t-att-class="availableClass(props.product)">
                        <t t-esc="formatQty(props.product.actual_available)"/>
                        avail.
                    </span>

                    <!-- On Hand -->
                    <span class="sc-meta-item">
                        <i class="fa fa-cube"/>
                        <span class="sc-meta-val sc-q-ok" t-esc="formatQty(props.product.qty_on_hand)"/>
                    </span>

                    <!-- Reserved -->
                    <span t-if="props.product.qty_reserved > 0" class="sc-meta-item">
                        <i class="fa fa-lock"/>
                        <span class="sc-meta-val sc-q-warn" t-esc="formatQty(props.product.qty_reserved)"/>
                    </span>

                    <!-- Incoming -->
                    <t t-if="props.product.incoming_qty > 0">
                        <span class="sc-meta-item sc-incoming-tip"
                              t-att-data-tip="props.product.po_refs ? 'POs: ' + props.product.po_refs : 'Incoming'">
                            <i class="fa fa-arrow-up sc-q-in"/>
                            <span class="sc-meta-val sc-q-in" t-esc="formatQty(props.product.incoming_qty)"/>
                        </span>
                    </t>

                    <!-- UoM -->
                    <span class="sc-uom" t-esc="props.product.uom_name"/>

                    <!-- Pricelist price (shown when pricelist is selected and not in quotation mode) -->
                    <t t-if="!props.canCreateQuotation and props.product.list_price">
                        <span class="sc-price-tag"><t t-esc="formatQty(props.product.list_price)"/> <small>inc.VAT</small></span>
                    </t>

                    <!-- Reorder point (only if set and below threshold) -->
                    <t t-if="props.product.reorder_point > 0 and props.product.actual_available &lt;= props.product.reorder_point">
                        <span class="sc-meta-item sc-reorder-alert">
                            <i class="fa fa-exclamation-triangle"/>
                            Reorder <t t-esc="formatQty(props.product.reorder_point)"/>
                        </span>
                    </t>
                </div>
            </div>

            <!-- Right side: Qty & Price inputs -->
            <t t-if="props.canCreateQuotation">
                <div class="sc-card-actions">
                    <input type="number" class="sc-input-sm"
                           min="0" step="1"
                           t-att-value="props.qty"
                           t-on-input="onQtyInput"
                           t-on-focus="onQtyFocus"
                           placeholder="Qty"/>
                    <input type="number" class="sc-input-sm sc-input-price"
                           min="0" step="0.01"
                           t-att-value="props.price"
                           t-on-input="onPriceInput"
                           placeholder="Price*" title="Price inc. VAT"/>
                </div>
            </t>

        </div>
    </t>

</templates>
