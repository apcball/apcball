<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Stock Valuation Layer View with Warehouse Position -->
        <record id="view_stock_valuation_layer_tree_with_location" model="ir.ui.view">
            <field name="name">stock.valuation.layer.tree.warehouse.position</field>
            <field name="model">stock.valuation.layer</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="create_date"/>
                    <field name="product_id"/>
                    <field name="warehouse_id"/>
                    <field name="origin_valuation_layer_id"/>
                    <field name="quantity"/>
                    <field name="remaining_qty"/>
                    <field name="position_qty_available"/>
                    <field name="current_origin_unit_cost"/>
                    <field name="position_valuation"/>
                    <field name="value"/>
                    <field name="company_id"/>
                </tree>
            </field>
        </record>
        
        <record id="view_stock_valuation_layer_form_with_location" model="ir.ui.view">
            <field name="name">stock.valuation.layer.form.warehouse.position</field>
            <field name="model">stock.valuation.layer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="product_id" readonly="1"/>
                                <field name="warehouse_id" readonly="1"/>
                                <field name="origin_valuation_layer_id" readonly="1"/>
                                <field name="company_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="create_date" readonly="1"/>
                                <field name="quantity" readonly="1"/>
                                <field name="unit_cost" readonly="1"/>
                                <field name="position_qty_available" readonly="1"/>
                                <field name="current_origin_unit_cost" readonly="1"/>
                                <field name="position_valuation" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="value" readonly="1"/>
                            <field name="description" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Inherit Search View: Add warehouse filters and group -->
        <record id="view_inventory_valuation_search_inherit_location" model="ir.ui.view">
            <field name="name">stock.valuation.layer.search.warehouse</field>
            <field name="model">stock.valuation.layer</field>
            <field name="inherit_id" ref="stock_account.view_inventory_valuation_search"/>
            <field name="arch" type="xml">
                <!-- Add filters before the Group By section -->
                <xpath expr="//filter[@name='has_remaining_qty']" position="after">
                    <separator/>
                    <filter string="Stock Moves Only (Has Warehouse)"
                            name="has_warehouse"
                            domain="[('warehouse_id', '!=', False)]"
                            help="Hide bill price difference adjustments that have no warehouse"/>
                    <filter string="Bill Adjustments (No Warehouse)"
                            name="no_warehouse"
                            domain="[('warehouse_id', '=', False)]"
                            help="Show only price difference adjustments from vendor bills"/>
                </xpath>
                <!-- Add Group By Warehouse in Group By section -->
                <xpath expr="//filter[@name='group_by_product_id']" position="before">
                    <filter string="Warehouse" name="group_by_warehouse_id"
                            context="{'group_by': 'warehouse_id'}"/>
                </xpath>
            </field>
        </record>

        <!-- Override the main Stock Valuation action to auto-filter by warehouse -->
        <record id="stock_account.stock_valuation_layer_action" model="ir.actions.act_window">
            <field name="name">Stock Valuation</field>
            <field name="res_model">stock.valuation.layer</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="domain">[('product_id.type', '=', 'product')]</field>
            <field name="context">{
                'search_default_group_by_product_id': True,
                'search_default_has_warehouse': True
            }</field>
        </record>

        <!-- Override the Stock Valuation by Location action -->
        <record id="stock_valuation_layer_action_by_warehouse" model="ir.actions.act_window">
            <field name="name">Stock Valuation by Location</field>
            <field name="res_model">stock.valuation.layer</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="domain">[('product_id.type', '=', 'product'), ('warehouse_id', '!=', False)]</field>
            <field name="context">{
                'search_default_group_by_warehouse_id': True,
                'search_default_has_warehouse': True
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face"/>
                <p>
                    Stock Valuation grouped by warehouse. Bill price difference adjustments are excluded.
                </p>
            </field>
        </record>
        
    </data>
</odoo>
