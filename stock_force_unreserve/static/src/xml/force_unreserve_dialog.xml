<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="stock_force_unreserve.ForceUnreserveDialog" owl="1">
        <style>
            /* Hide default Action Dialog footer */
            .o_dialog .modal-footer {
                display: none !important;
            }
        </style>
        <div class="o_force_unreserve_content">
            <t t-if="state.loading">
                <div class="text-center p-5">
                    <i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw text-primary"></i>
                    <h4 class="mt-3">Analyzing Reservations...</h4>
                </div>
            </t>
            <t t-else="">
                <div class="alert alert-warning mb-4" role="alert">
                    <h5 class="alert-heading"><i class="fa fa-warning"></i> Warning</h5>
                    <p class="mb-0">This action will:</p>
                    <ul class="mb-0">
                        <li>Remove stock reservations from other deliveries</li>
                        <li>Reallocate stock to this order</li>
                    </ul>
                    <hr/>
                    <p class="mb-0">This may impact other operations. Do you want to continue?</p>
                </div>
                
                <h5>Reservation Insight Panel</h5>
                <div class="table-responsive mb-4">
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Required Qty</th>
                                <th class="text-end">Reserved Qty</th>
                                <th class="text-end">Shortage</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.insight.lines.length === 0">
                                <tr><td colspan="5" class="text-center text-muted">No shortage detected.</td></tr>
                            </t>
                            <tr t-foreach="state.insight.lines" t-as="line" t-key="line.product"
                                t-att-class="line.status === 'shortage' ? 'table-danger' : (line.status === 'partial' ? 'table-warning' : '')">
                                <td><t t-esc="line.product"/></td>
                                <td class="text-end"><t t-esc="line.demand"/></td>
                                <td class="text-end"><t t-esc="line.reserved"/></td>
                                <td class="text-end text-danger fw-bold"><t t-esc="line.shortage"/></td>
                                <td class="text-center">
                                    <span t-att-class="'badge ' + (line.status === 'shortage' ? 'bg-danger' : (line.status === 'partial' ? 'bg-warning' : 'bg-success'))">
                                        <t t-esc="line.status.toUpperCase()"/>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <t t-if="state.insight.competing_pickings.length > 0">
                    <div class="card bg-light border-info">
                        <div class="card-body py-2">
                            <h6 class="card-title text-info mb-2"><i class="fa fa-exchange"></i> Competing Reservations Detected</h6>
                            <ul class="mb-0 small">
                                <li t-foreach="state.insight.competing_pickings" t-as="picking_info" t-key="picking_info">
                                    <t t-esc="picking_info"/>
                                </li>
                            </ul>
                        </div>
                    </div>
                </t>
            </t>

            <!-- Custom Footer -->
            <div class="mt-4 pt-3 border-top text-end">
                <button type="button" class="btn btn-secondary me-2" t-on-click="cancel" t-att-disabled="state.executing">Cancel</button>
                <button type="button" class="btn btn-danger" t-on-click="confirm" t-att-disabled="state.executing || state.loading || state.insight.lines.length === 0">
                    <t t-if="state.executing">
                        <i class="fa fa-spinner fa-spin me-2"></i>Processing...
                    </t>
                    <t t-else="">
                        <i class="fa fa-bolt me-2"></i>Force Unreserve
                    </t>
                </button>
            </div>
        </div>
    </t>
</templates>
