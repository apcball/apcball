<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_export_excel" model="ir.ui.view">
        <field name="name">stock.picking.form.export.excel</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_export_excel" string="Export Excel" type="object" groups="stock_picking_export_excel.group_stock_picking_export_excel" />
                <button name="%(action_stock_picking_import_wizard)d" string="Import Excel" type="action" groups="stock_picking_export_excel.group_stock_picking_export_excel" />
            </xpath>
        </field>
    </record>

    <record id="action_stock_picking_batch_export" model="ir.actions.server">
        <field name="name">Export Excel</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="groups_id" eval="[(4, ref('stock_picking_export_excel.group_stock_picking_export_excel'))]"/>
        <field name="code">
            action = records.action_export_excel()
        </field>
    </record>
</odoo>
