<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Expire Reservations (Daily at 01:00) -->
        <record id="cron_expire_reservations" model="ir.cron">
            <field name="name">Stock Reservation: Expire Past-Due Reservations</field>
            <field name="model_id" ref="model_stock_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_reservations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="True"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="datetime(2026, 6, 26, 1, 0, 0)"/>
        </record>

        <!-- Cron: Notify Near-Expiry (Daily at 07:00) -->
        <record id="cron_notify_near_expiry" model="ir.cron">
            <field name="name">Stock Reservation: Notify Near-Expiry Reservations</field>
            <field name="model_id" ref="model_stock_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_notify_near_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="True"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="datetime(2026, 6, 26, 7, 0, 0)"/>
        </record>

        <!-- Cron: Auto-Release Expired Reservations (Daily at 02:00) -->
        <record id="cron_auto_release_expired" model="ir.cron">
            <field name="name">Stock Reservation: Auto-Release Expired Reservations</field>
            <field name="model_id" ref="model_stock_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_release_expired()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="True"/>
            <field name="active" eval="False"/>
            <field name="nextcall" eval="datetime(2026, 6, 26, 2, 0, 0)"/>
        </record>
    </data>
</odoo>
