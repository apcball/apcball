<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Reservation Sequence -->
        <record id="seq_stock_reservation" model="ir.sequence">
            <field name="name">Stock Reservation</field>
            <field name="code">stock.reservation</field>
            <field name="prefix">RES/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for release wizard batches -->
        <record id="seq_reservation_release_batch" model="ir.sequence">
            <field name="name">Reservation Release Batch</field>
            <field name="code">reservation.release.batch</field>
            <field name="prefix">RLS/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
