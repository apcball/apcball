<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_transfer_recovery_purchase_order_form" model="ir.ui.view">
        <field name="name">purchase.order.stock.transfer.recovery.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="can_recreate_transfer" invisible="1"/>
                <button name="action_recreate_receipt_wizard"
                        string="Recreate Receipt"
                        type="object"
                        class="btn-secondary"
                        invisible="not can_recreate_transfer"
                        groups="base.group_user"/>
            </xpath>
        </field>
    </record>

    <record id="action_batch_recreate_receipt" model="ir.actions.server">
        <field name="name">Recreate Receipt (Batch)</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_recreate_receipt_wizard_batch()
        </field>
    </record>
</odoo>
