<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_transfer_recovery_view_order_form" model="ir.ui.view">
        <field name="name">sale.order.stock.transfer.recovery.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="can_recreate_transfer" invisible="1"/>
                <button name="action_recreate_delivery_wizard"
                        string="Recreate Delivery"
                        type="object"
                        class="btn-secondary"
                        invisible="not can_recreate_transfer"
                        groups="base.group_user"/>
            </xpath>
        </field>
    </record>

    <record id="action_batch_recreate_delivery" model="ir.actions.server">
        <field name="name">Recreate Delivery (Batch)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_recreate_delivery_wizard_batch()
        </field>
    </record>
</odoo>
